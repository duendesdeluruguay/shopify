{% comment %}
  GUARDIAN STORY — Página de lore cinematográfica
  Duendes del Uruguay — Historia profunda de cada ser elemental
  Lee la historia del metafield custom.guardian_story y la muestra en diseño editorial
{% endcomment %}

{% style %}
@import url('https://fonts.googleapis.com/css2?family=Tangerine:wght@400;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Lato:wght@300;400;700&display=swap');

* { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --white: #FEFDFB;
  --cream: #F8F6F1;
  --gold: #B8973B;
  --gold-soft: #D4BC7C;
  --gold-pale: rgba(184, 151, 59, 0.08);
  --black: #111111;
  --black-soft: #1A1A1A;
  --text: #1A1A1A;
  --text-mid: #555555;
  --text-light: #888888;
  --text-faint: #BBBBBB;
  --line: #E0DDD6;
  --line-dark: #2A2A2A;
}

body {
  font-family: 'Lato', sans-serif;
  background: var(--white);
  color: var(--text);
  -webkit-font-smoothing: antialiased;
}

.guardian-story-section {
  background: var(--white);
  overflow: hidden;
}

/* HERO — Full-bleed cinematic with gradient overlay */
.story-hero {
  position: relative;
  width: 100%;
  height: 60vh;
  min-height: 400px;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.story-hero-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(0.5) saturate(0.85);
  z-index: 1;
}

.story-hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0.3) 0%,
    rgba(0, 0, 0, 0.6) 50%,
    rgba(0, 0, 0, 0.8) 100%
  );
  z-index: 2;
}

.story-hero-content {
  position: relative;
  z-index: 3;
  text-align: center;
  padding: 60px 40px;
  max-width: 800px;
  margin-bottom: 40px;
  animation: heroFadeIn 1s ease-out;
}

@keyframes heroFadeIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: none; }
}

.story-hero-label {
  font-family: 'Lato', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: var(--gold-soft);
  margin-bottom: 16px;
  display: block;
}

.story-hero-name {
  font-family: 'Tangerine', cursive;
  font-size: 72px;
  font-weight: 700;
  color: white;
  line-height: 1;
  margin-bottom: 8px;
  letter-spacing: 2px;
  -webkit-font-smoothing: antialiased;
  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
}

.story-hero-type {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 12px;
}

.story-hero-divider {
  width: 60px;
  height: 1px;
  background: var(--gold);
  margin: 0 auto 12px;
}

.story-hero-date {
  font-size: 10px;
  letter-spacing: 2px;
  color: var(--gold-soft);
  font-style: italic;
}

/* EMPTY STATE */
.story-empty {
  padding: 80px 40px;
  text-align: center;
  background: var(--cream);
}

.story-empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
  opacity: 0.4;
}

.story-empty-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 24px;
  font-weight: 300;
  color: var(--text-light);
  margin-bottom: 8px;
}

.story-empty-text {
  font-size: 14px;
  color: var(--text-light);
  max-width: 400px;
  margin: 0 auto;
}

/* CONTENT BLOCK — Editorial layout */
.story-content {
  max-width: 820px;
  margin: 0 auto;
  padding: 80px 60px 100px;
}

@media (max-width: 768px) {
  .story-content {
    padding: 60px 32px 80px;
  }
}

/* Story text formatting */
.story-body {
  font-family: 'Lato', sans-serif;
  font-size: 16px;
  line-height: 1.85;
  color: var(--text);
  letter-spacing: 0.3px;
}

.story-body p {
  margin-bottom: 24px;
}

.story-body p:last-child {
  margin-bottom: 0;
}

.story-body strong {
  font-weight: 600;
  color: var(--black);
}

.story-body em {
  font-style: italic;
  color: var(--text-mid);
}

/* SECTION HEADERS within story */
.story-body h5 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gold);
  margin: 40px 0 12px 0;
}

/* METADATA BLOCK */
.story-metadata {
  margin-top: 60px;
  padding-top: 40px;
  border-top: 1px solid var(--line);
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.story-meta-item {
  display: flex;
  gap: 16px;
  font-size: 13px;
  color: var(--text-mid);
}

.story-meta-label {
  font-weight: 600;
  color: var(--text);
  min-width: 80px;
}

/* BACK LINK */
.story-back-link {
  display: inline-block;
  margin-top: 20px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gold);
  text-decoration: none;
  padding-bottom: 3px;
  border-bottom: 1px solid var(--gold);
  transition: all 0.3s;
}

.story-back-link:hover {
  color: var(--text);
  border-bottom-color: var(--text);
}

/* SCROLL ANIMATION */
@keyframes scrollReveal {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: none;
  }
}

.story-content {
  animation: scrollReveal 0.8s ease-out;
}

/* JSON-LD Schema (hidden) */
script[type="application/ld+json"] {
  display: none;
}

/* RESPONSIVE */
@media (max-width: 1024px) {
  .story-hero-content {
    padding: 40px 32px;
  }

  .story-hero-name {
    font-size: 56px;
  }
}

@media (max-width: 640px) {
  .story-hero {
    height: 50vh;
    min-height: 320px;
  }

  .story-hero-content {
    padding: 30px 24px;
    margin-bottom: 30px;
  }

  .story-hero-name {
    font-size: 44px;
  }

  .story-content {
    padding: 40px 24px 60px;
  }

  .story-body {
    font-size: 15px;
    line-height: 1.75;
  }
}

/* PRINT STYLES */
@media print {
  .story-hero-overlay {
    background: white;
  }

  .story-hero-image {
    display: none;
  }

  .story-hero-name,
  .story-hero-type,
  .story-hero-label {
    color: var(--text);
  }
}
{% endstyle %}

{%- comment -%} Solo renderizar si hay historia canalizada (metafield poblado).
    Sin fallback: si no hay historia, el bloque entero desaparece — la
    historia visible está arriba en la página de producto. Cambio 2026-05-01. {%- endcomment -%}
{%- if product.metafields.custom.guardian_story -%}
<div class="guardian-story-section">

    {%- comment -%} Extract story data {%- endcomment -%}
    {%- assign story = product.metafields.custom.guardian_story -%}
    {%- assign guardian_name = product.title -%}
    {%- assign guardian_type = product.metafields.custom.guardian_type | default: 'ser elemental' -%}
    {%- assign guardian_image = product.featured_image.src -%}
    {%- assign publish_date = product.metafields.custom.channeling_date | default: product.published_at -%}

    {%- comment -%} HERO SECTION {%- endcomment -%}
    <div class="story-hero">
      {%- if guardian_image -%}
        <img src="{{ guardian_image | image_url: width: 1200 }}" alt="{{ guardian_name }}" class="story-hero-image" loading="lazy">
      {%- endif -%}
      <div class="story-hero-overlay"></div>

      <div class="story-hero-content">
        <span class="story-hero-label">Historia Canalizada</span>
        <h1 class="story-hero-name">{{ guardian_name }}</h1>
        <p class="story-hero-type">{{ guardian_type | capitalize }}</p>
        <div class="story-hero-divider"></div>
        {%- if publish_date -%}
          <p class="story-hero-date">Canalizado · {{ publish_date | date: "%B %d, %Y" }}</p>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} CONTENT SECTION {%- endcomment -%}
    <article class="story-content">
      <div class="story-body">
        {{ story }}
      </div>

      {%- comment -%} Metadata footer {%- endcomment -%}
      <footer class="story-metadata">
        {%- if guardian_type -%}
          <div class="story-meta-item">
            <span class="story-meta-label">Tipo:</span>
            <span>{{ guardian_type | capitalize }}</span>
          </div>
        {%- endif -%}

        {%- if product.metafields.custom.guardian_excerpt -%}
          <div class="story-meta-item">
            <span class="story-meta-label">Esencia:</span>
            <span>{{ product.metafields.custom.guardian_excerpt }}</span>
          </div>
        {%- endif -%}

        <div class="story-meta-item">
          <span class="story-meta-label">Comunidad:</span>
          <span>Duendes del Uruguay</span>
        </div>
      </footer>

      {%- comment -%} Back to product link {%- endcomment -%}
      <a href="{{ product.url }}" class="story-back-link">← Ver producto</a>
    </article>

</div>
{%- endif -%}

{%- comment -%} JSON-LD SCHEMA FOR SEO {%- endcomment -%}
{%- if product.metafields.custom.guardian_story -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ guardian_name | escape }}",
    "description": "{{ product.metafields.custom.guardian_excerpt | default: 'Historia canalizada de ' | append: guardian_name | escape }}",
    "image": "{{ guardian_image | image_url: width: 1200 | escape }}",
    "datePublished": "{{ publish_date | date: '%Y-%m-%dT%H:%M:%SZ' }}",
    "author": {
      "@type": "Organization",
      "name": "Duendes del Uruguay",
      "url": "https://duendesdeluruguay.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Duendes del Uruguay",
      "logo": {
        "@type": "ImageObject",
        "url": "https://cdn.shopify.com/s/files/1/0627/7785/2001/files/logo.png",
        "width": 250,
        "height": 60
      }
    },
    "mainEntity": {
      "@type": "Thing",
      "name": "{{ guardian_name | escape }}",
      "description": "{{ guardian_type | capitalize | escape }} canalizado"
    }
  }
  </script>
{%- endif -%}
