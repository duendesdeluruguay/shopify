{{ 'duendes-base.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign dh2_rito_tag = section.settings.tag | strip
  if dh2_rito_tag == blank
    assign dh2_rito_tag = 'duendes.home_v2.rito.eyebrow' | t
    if dh2_rito_tag contains 'translation missing'
      assign dh2_rito_tag = 'duendes.home_v2.rito.tag' | t
    endif
  endif
  assign dh2_rito_title = section.settings.title | strip
  if dh2_rito_title == blank
    assign dh2_rito_title = 'duendes.home_v2.rito.title' | t
  endif
  assign dh2_rito_fb1 = blank
  assign dh2_rito_fb2 = blank
  assign dh2_rito_fb3 = blank
  assign dh2_rito_ng = collections['nuevos-guardianes']
  if dh2_rito_ng != blank
    assign dh2_rito_nimg = 0
    for dh2_rito_p in dh2_rito_ng.products limit: 24
      assign dh2_rito_im = blank
      if dh2_rito_p.featured_image != blank
        assign dh2_rito_im = dh2_rito_p.featured_image
      elsif dh2_rito_p.featured_media != blank
        assign dh2_rito_im = dh2_rito_p.featured_media
      elsif dh2_rito_p.images.size > 0
        assign dh2_rito_im = dh2_rito_p.images[0]
      endif
      if dh2_rito_im != blank
        assign dh2_rito_nimg = dh2_rito_nimg | plus: 1
        case dh2_rito_nimg
          when 1
            assign dh2_rito_fb1 = dh2_rito_im
          when 2
            assign dh2_rito_fb2 = dh2_rito_im
          when 3
            assign dh2_rito_fb3 = dh2_rito_im
        endcase
        if dh2_rito_nimg >= 3
          break
        endif
      endif
    endfor
    if dh2_rito_fb1 == blank and dh2_rito_ng.featured_image != blank
      assign dh2_rito_fb1 = dh2_rito_ng.featured_image
    endif
  endif
  assign dh2_rito_tlg = collections['todos-los-guardianes']
  if dh2_rito_tlg != blank
    for dh2_rito_p in dh2_rito_tlg.products limit: 30
      assign dh2_rito_im = blank
      if dh2_rito_p.featured_image != blank
        assign dh2_rito_im = dh2_rito_p.featured_image
      elsif dh2_rito_p.featured_media != blank
        assign dh2_rito_im = dh2_rito_p.featured_media
      elsif dh2_rito_p.images.size > 0
        assign dh2_rito_im = dh2_rito_p.images[0]
      endif
      if dh2_rito_im != blank
        if dh2_rito_fb1 == blank
          assign dh2_rito_fb1 = dh2_rito_im
        elsif dh2_rito_fb2 == blank
          assign dh2_rito_fb2 = dh2_rito_im
        elsif dh2_rito_fb3 == blank
          assign dh2_rito_fb3 = dh2_rito_im
          break
        endif
      endif
    endfor
    if dh2_rito_fb1 == blank and dh2_rito_tlg.featured_image != blank
      assign dh2_rito_fb1 = dh2_rito_tlg.featured_image
    endif
  endif
-%}
<style>
  .dh2-rito {
    background: #faf9f6;
    padding: 24px 0 28px;
    color: #15110d;
    border-top: 1px solid rgba(21, 17, 13, 0.06);
  }
  .dh2-rito__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .dh2-rito__tag {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(21, 17, 13, 0.45);
    text-align: center;
    margin-bottom: 12px;
  }
  .dh2-rito__title {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-weight: 400;
    font-size: clamp(24px, 3vw, 34px);
    text-align: center;
    margin: 0 0 36px;
  }
  .dh2-rito__row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .dh2-rito__card {
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(21, 17, 13, 0.08);
    box-shadow: 0 4px 22px rgba(0, 0, 0, 0.05);
    max-width: 100%;
    box-sizing: border-box;
  }
  .dh2-rito__photo {
    position: relative;
    aspect-ratio: 4 / 3;
    background: #e8e4dc;
  }
  .dh2-rito__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .dh2-rito__photo--empty {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
  }
  .dh2-rito__photo-fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 1;
  }
  .dh2-rito__glyph-ph {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    line-height: 1;
    color: rgba(201, 169, 97, 0.55);
    letter-spacing: 0.2em;
    pointer-events: none;
    z-index: 0;
  }
  .dh2-rito__body {
    padding: 18px 16px 20px;
    text-align: center;
  }
  .dh2-rito__step {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #a88b42;
    margin-bottom: 8px;
  }
  .dh2-rito__h {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 17px;
    margin: 0 0 8px;
  }
  .dh2-rito__p {
    font-family: var(--font-body--family, 'Cormorant Garamond', Georgia, serif);
    font-size: 15px;
    line-height: 1.5;
    color: rgba(21, 17, 13, 0.72);
    margin: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  @media (max-width: 749px) {
    .dh2-rito__row {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 768px) {
    .dh2-rito.section {
      overflow-x: hidden;
    }
    .dh2-rito__inner {
      padding-left: max(20px, env(safe-area-inset-left, 0px));
      padding-right: max(20px, env(safe-area-inset-right, 0px));
    }
    h2.dh2-rito__title,
    .dh2-rito__title {
      font-size: 26px !important;
      line-height: 1.15 !important;
      max-width: 100% !important;
    }
    .dh2-rito__tag {
      font-size: 9px !important;
    }
    h3.dh2-rito__h,
    .dh2-rito__h {
      font-size: 18px !important;
    }
    .dh2-rito__p {
      font-size: 16px !important;
      line-height: 1.45 !important;
    }
    .dh2-rito__step {
      font-size: 9px !important;
    }
  }
  @media (max-width: 768px) {
    .dh2-cb, .dh2-hero, .dh2-be, .dh2-sp, .dh2-ed, .dh2-rito, .dh2-lt, .dh2-tribu {
      padding: 6px 0 6px !important;
    }
  }
</style>

<section class="dh2-rito section">
  <div class="dh2-rito__inner">
    <p class="dh2-rito__tag">{{ dh2_rito_tag }}</p>
    <h2 class="dh2-rito__title">{{ dh2_rito_title }}</h2>
    <div class="dh2-rito__row">
      {%- assign dh2_rito_step_i = 0 -%}
      {% for block in section.blocks %}
        {% if block.type == 'paso' %}
          {%- assign dh2_rito_step_i = dh2_rito_step_i | plus: 1 -%}
          {% liquid
            assign dh2_rs = block.settings.step_label | strip
            assign dh2_rh = block.settings.heading | strip
            assign dh2_rt = block.settings.text | strip
            if dh2_rs == blank or dh2_rh == blank or dh2_rt == blank
              case forloop.index
                when 1
                  if dh2_rs == blank
                    assign dh2_rs = 'duendes.home_v2.rito.step1_label' | t
                  endif
                  if dh2_rh == blank
                    assign dh2_rh = 'duendes.home_v2.rito.step1_heading' | t
                  endif
                  if dh2_rt == blank
                    assign dh2_rt = 'duendes.home_v2.rito.step1_text' | t
                  endif
                when 2
                  if dh2_rs == blank
                    assign dh2_rs = 'duendes.home_v2.rito.step2_label' | t
                  endif
                  if dh2_rh == blank
                    assign dh2_rh = 'duendes.home_v2.rito.step2_heading' | t
                  endif
                  if dh2_rt == blank
                    assign dh2_rt = 'duendes.home_v2.rito.step2_text' | t
                  endif
                else
                  if dh2_rs == blank
                    assign dh2_rs = 'duendes.home_v2.rito.step3_label' | t
                  endif
                  if dh2_rh == blank
                    assign dh2_rh = 'duendes.home_v2.rito.step3_heading' | t
                  endif
                  if dh2_rt == blank
                    assign dh2_rt = 'duendes.home_v2.rito.step3_text' | t
                  endif
              endcase
            endif
          %}
          {% liquid
            assign dh2_rp_img = block.settings.image
            if dh2_rp_img == blank
              case dh2_rito_step_i
                when 1
                  if dh2_rito_fb1 != blank
                    assign dh2_rp_img = dh2_rito_fb1
                  endif
                when 2
                  if dh2_rito_fb2 != blank
                    assign dh2_rp_img = dh2_rito_fb2
                  elsif dh2_rito_fb1 != blank
                    assign dh2_rp_img = dh2_rito_fb1
                  endif
                else
                  if dh2_rito_fb3 != blank
                    assign dh2_rp_img = dh2_rito_fb3
                  elsif dh2_rito_fb2 != blank
                    assign dh2_rp_img = dh2_rito_fb2
                  elsif dh2_rito_fb1 != blank
                    assign dh2_rp_img = dh2_rito_fb1
                  endif
              endcase
            endif
            assign dh2_rp_glyph = block.settings.glyph | strip
            if dh2_rp_glyph == blank
              assign dh2_rp_glyph = '✦'
            endif
          %}
          <article class="dh2-rito__card" {{ block.shopify_attributes }}>
            <div class="dh2-rito__photo{% if dh2_rp_img == blank %} dh2-rito__photo--empty{% endif %}">
              {% if dh2_rp_img != blank %}
                {{ dh2_rp_img | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(min-width:750px) 33vw, 100vw', widths: '400,600,900' }}
              {% else %}
                <span class="dh2-rito__glyph-ph" aria-hidden="true">{{ dh2_rp_glyph }}</span>
                <img
                  class="dh2-rito__photo-fallback"
                  src="{{ 'duendes-rito-paso-fallback.svg' | asset_url }}"
                  width="800"
                  height="600"
                  alt=""
                  loading="lazy"
                >
              {% endif %}
            </div>
            <div class="dh2-rito__body">
              <p class="dh2-rito__step">{{ dh2_rs }}</p>
              {% if dh2_rh != blank %}
                <h3 class="dh2-rito__h">{{ dh2_rh }}</h3>
              {% endif %}
              <p class="dh2-rito__p">{{ dh2_rt }}</p>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DDU v2 · Rito 3 pasos",
  "tag": "section",
  "class": "duendes-home-v2-rito-pasos-section",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "tag", "label": "Etiqueta", "default": "DESPUÉS DE ELEGIR" },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Esto es lo que pasa después."
    }
  ],
  "blocks": [
    {
      "type": "paso",
      "name": "Paso",
      "settings": [
        { "type": "text", "id": "step_label", "label": "Etiqueta paso", "default": "PASO 1" },
        { "type": "text", "id": "heading", "label": "Título", "default": "Te conectás" },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto",
          "default": "Elegís en la tienda o te leemos en el test. El vínculo empieza cuando uno te llama."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Foto real",
          "info": "Si está vacío: se toman hasta 3 fotos distintas de productos en «nuevos-guardianes» (una por paso). Si no hay, glifo."
        },
        {
          "type": "text",
          "id": "glyph",
          "label": "Glifo si no hay foto",
          "default": "✦",
          "info": "Solo cuando no hay imagen en el bloque ni fallback desde la colección."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DDU v2 · Rito 3 pasos",
      "blocks": [
        {
          "type": "paso",
          "settings": {
            "step_label": "LO PREPARAMOS",
            "heading": "",
            "text": "Tarda 7-10 días en el taller en Piriápolis."
          }
        },
        {
          "type": "paso",
          "settings": {
            "step_label": "LO ENVIAMOS",
            "heading": "",
            "text": "Llega a tu casa en 5-10 días con seguimiento."
          }
        },
        {
          "type": "paso",
          "settings": {
            "step_label": "ENTRÁS AL PORTAL",
            "heading": "",
            "text": "Ahí están las guías para cuidarlo, conectar y cuidar la magia."
          }
        }
      ]
    }
  ]
}
{% endschema %}
