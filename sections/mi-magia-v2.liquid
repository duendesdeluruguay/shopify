}

@keyframes mmBadgePulse {
  0%, 100% { transform: scale(1); box-shadow: 0 0 15px rgba(184,90,90,0.5); }
  50% { transform: scale(1.08); box-shadow: 0 0 28px rgba(184,90,90,0.8); }
}

