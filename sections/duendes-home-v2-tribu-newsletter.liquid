{{ 'duendes-base.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign dh2_tr_eyebrow = 'duendes.home_v2.tribu.eyebrow' | t
  if dh2_tr_eyebrow contains 'translation missing'
    assign dh2_tr_eyebrow = ''
  endif
  assign dh2_tr_title = section.settings.title | strip
  if dh2_tr_title == blank
    assign dh2_tr_title = 'duendes.home_v2.tribu.title' | t
    if dh2_tr_title contains 'translation missing'
      assign dh2_tr_title = 'duendes.home_v2.tribu_newsletter.title' | t
    endif
  endif
  assign dh2_tr_sub = section.settings.subtitle | strip
  if dh2_tr_sub == blank
    assign dh2_tr_sub = 'duendes.home_v2.tribu.sub' | t
    if dh2_tr_sub contains 'translation missing'
      assign dh2_tr_sub = 'duendes.home_v2.tribu_newsletter.subtitle' | t
    endif
  endif
  assign dh2_tr_ph = section.settings.placeholder | strip
  if dh2_tr_ph == blank
    assign dh2_tr_ph = 'duendes.home_v2.tribu.placeholder' | t
    if dh2_tr_ph contains 'translation missing'
      assign dh2_tr_ph = 'duendes.home_v2.tribu_newsletter.placeholder' | t
    endif
  endif
  assign dh2_tr_submit = section.settings.submit_label | strip
  if dh2_tr_submit == blank
    assign dh2_tr_submit = 'duendes.home_v2.tribu.cta' | t
    if dh2_tr_submit contains 'translation missing'
      assign dh2_tr_submit = 'duendes.home_v2.tribu_newsletter.submit_label' | t
    endif
  endif
  assign dh2_tr_micro = section.settings.micro | strip
  if dh2_tr_micro == blank
    assign dh2_tr_micro = 'duendes.home_v2.tribu_newsletter.micro' | t
  endif
  assign dh2_tr_success = section.settings.success | strip
  if dh2_tr_success == blank
    assign dh2_tr_success = 'duendes.home_v2.tribu_newsletter.success' | t
  endif
  assign dh2_tr_err = section.settings.error_copy | strip
  if dh2_tr_err == blank
    assign dh2_tr_err = 'duendes.home_v2.tribu_newsletter.error_copy' | t
  endif
-%}
<style>
  .dh2-tribu {
    background: #faf9f6;
    padding: 24px 20px 28px;
    color: #15110d;
    border-top: 1px solid rgba(21, 17, 13, 0.06);
  }
  .dh2-tribu__panel {
    max-width: 480px;
    margin: 0 auto;
    text-align: center;
    background: #fff;
    border-radius: 16px;
    padding: 32px 24px 28px;
    border: 1px solid rgba(21, 17, 13, 0.08);
    box-shadow: 0 8px 36px rgba(0, 0, 0, 0.06);
  }
  .dh2-tribu__eyebrow {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(21, 17, 13, 0.45);
    margin: 0 0 12px;
  }
  .dh2-tribu__title {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: clamp(22px, 2.6vw, 28px);
    margin: 0 0 10px;
  }
  .dh2-tribu__sub {
    font-family: var(--font-body--family, 'Cormorant Garamond', Georgia, serif);
    font-size: 16px;
    line-height: 1.55;
    color: rgba(21, 17, 13, 0.72);
    margin: 0 0 22px;
  }
  .dh2-tribu__form {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-bottom: 12px;
  }
  .dh2-tribu__input {
    flex: 1 1 200px;
    min-width: 0;
    border: 1px solid rgba(21, 17, 13, 0.15);
    border-radius: 6px;
    padding: 12px 14px;
    font-size: 15px;
    font-family: var(--font-body--family, 'Cormorant Garamond', Georgia, serif);
  }
  .dh2-tribu__btn {
    border: none;
    border-radius: 6px;
    background: #15110d;
    color: #faf9f6;
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 12px 20px;
    cursor: pointer;
  }
  .dh2-tribu__btn:hover {
    background: #2a241c;
  }
  .dh2-tribu__micro {
    font-size: 12px;
    color: rgba(21, 17, 13, 0.5);
    font-style: italic;
    margin: 0;
  }
  .dh2-tribu__errors {
    color: #8b2e2e;
    font-size: 13px;
    margin-bottom: 8px;
  }
  @media (max-width: 768px) {
    .dh2-tribu.section {
      overflow-x: hidden;
    }
    .dh2-tribu__panel {
      margin-left: max(0px, env(safe-area-inset-left, 0px));
      margin-right: max(0px, env(safe-area-inset-right, 0px));
      padding-left: max(24px, 5vw);
      padding-right: max(24px, 5vw);
    }
    h2.dh2-tribu__title,
    .dh2-tribu__title {
      font-size: 26px !important;
      line-height: 1.15 !important;
    }
    .dh2-tribu__sub {
      font-size: 16px !important;
      line-height: 1.5 !important;
    }
    .dh2-tribu__input {
      font-size: 16px !important;
    }
    .dh2-tribu__micro {
      font-size: 14px !important;
    }
    .dh2-tribu {
      padding: 6px max(18px, env(safe-area-inset-left, 0px)) 6px max(18px, env(safe-area-inset-right, 0px)) !important;
    }
    .dh2-cb, .dh2-hero, .dh2-new, .dh2-lin, .dh2-be, .dh2-sp, .dh2-ed, .dh2-rito, .dh2-lt {
      padding: 6px 0 6px !important;
    }
  }
</style>

<section class="dh2-tribu section">
  <div class="dh2-tribu__panel">
    {% if dh2_tr_eyebrow != blank %}
      <p class="dh2-tribu__eyebrow">{{ dh2_tr_eyebrow }}</p>
    {% endif %}
    <h2 class="dh2-tribu__title">{{ dh2_tr_title }}</h2>
    <p class="dh2-tribu__sub">{{ dh2_tr_sub }}</p>
    {% form 'customer', class: 'dh2-tribu__formwrap', return_to: request.path %}
      {% if form.errors %}
        <p class="dh2-tribu__errors">{{ dh2_tr_err }}</p>
      {% endif %}
      <div class="dh2-tribu__form">
        <input type="hidden" name="contact[tags]" value="{{ section.settings.customer_tag }}">
        <input type="hidden" name="contact[accepts_marketing]" value="true">
        <input
          type="email"
          name="contact[email]"
          class="dh2-tribu__input"
          value="{{ form.email }}"
          placeholder="{{ dh2_tr_ph | escape }}"
          required
          autocomplete="email"
          aria-label="{{ dh2_tr_ph | escape }}"
        >
        <button type="submit" class="dh2-tribu__btn">{{ dh2_tr_submit }}</button>
      </div>
      {% if form.posted_successfully? %}
        <p class="dh2-tribu__micro" role="status">{{ dh2_tr_success }}</p>
      {% else %}
        <p class="dh2-tribu__micro">{{ dh2_tr_micro }}</p>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "DDU v2 · Newsletter",
  "tag": "section",
  "class": "duendes-home-v2-tribu-newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Tribu Elemental"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Linajes, rituales, sueños, lo que el bosque cuenta esta semana."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder email",
      "default": "tu@email.com"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Botón",
      "default": "Sumarme"
    },
    {
      "type": "text",
      "id": "micro",
      "label": "Microtexto bajo el form",
      "default": "Sin spam. Te escribimos solo cuando hay magia nueva."
    },
    {
      "type": "text",
      "id": "success",
      "label": "Mensaje tras envío",
      "default": "Listo. Revisá tu correo para confirmar."
    },
    {
      "type": "text",
      "id": "customer_tag",
      "label": "Tag en cliente (comma-separated)",
      "default": "newsletter, duendes-home-v2-tribu"
    },
    {
      "type": "text",
      "id": "error_copy",
      "label": "Mensaje si falla el email",
      "default": "Revisá el correo e intentá de nuevo."
    }
  ],
  "presets": [{ "name": "DDU v2 · Newsletter" }]
}
{% endschema %}
