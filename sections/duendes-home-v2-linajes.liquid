{{ 'duendes-base.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign dh2_lin_tag = section.settings.tag | strip
  if dh2_lin_tag == blank
    assign dh2_lin_tag = 'duendes.home_v2.linajes.eyebrow' | t
    if dh2_lin_tag contains 'translation missing'
      assign dh2_lin_tag = 'duendes.home_v2.linajes.tag' | t
    endif
  endif
  assign dh2_lin_title = section.settings.title | strip
  if dh2_lin_title == blank
    assign dh2_lin_title = 'duendes.home_v2.linajes.title' | t
  endif
  assign dh2_lin_sub = 'duendes.home_v2.linajes.sub' | t
  if dh2_lin_sub contains 'translation missing'
    assign dh2_lin_sub = ''
  endif
-%}
<style>
  .dh2-lin {
    background: #faf9f6;
    padding: 24px 0 28px;
    color: #15110d;
  }
  .dh2-lin__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .dh2-lin__tag {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(21, 17, 13, 0.45);
    text-align: center;
    margin-bottom: 12px;
  }
  .dh2-lin__title {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-weight: 400;
    font-size: clamp(24px, 3vw, 36px);
    text-align: center;
    margin: 0 0 10px;
  }
  .dh2-lin__sub {
    font-family: var(--font-body--family, 'Cormorant Garamond', Georgia, serif);
    font-size: clamp(15px, 1.9vw, 18px);
    text-align: center;
    margin: 0 auto 20px;
    max-width: 520px;
    line-height: 1.45;
    color: rgba(21, 17, 13, 0.58);
    font-style: italic;
  }
  .dh2-lin__rail {
    display: flex;
    gap: clamp(10px, 1.8vw, 14px);
    overflow-x: auto;
    overflow-y: hidden;
    padding: 4px 4px 12px;
    margin: 0 -8px;
    scroll-snap-type: x proximity;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }
  .dh2-lin__rail::-webkit-scrollbar {
    height: 6px;
  }
  .dh2-lin__rail::-webkit-scrollbar-thumb {
    background: rgba(21, 17, 13, 0.18);
    border-radius: 99px;
  }
  .dh2-lin__card {
    position: relative;
    flex: 0 0 clamp(130px, 11vw, 160px);
    width: clamp(130px, 11vw, 160px);
    aspect-ratio: 2 / 3;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: #f4f1ec;
    scroll-snap-align: start;
    border: 1px solid rgba(201, 169, 97, 0.45);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.12);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .dh2-lin__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.18);
  }
  .dh2-lin__bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #3a2e1a, #15110d);
  }
  .dh2-lin__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.92;
  }
  .dh2-lin__shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 20%, rgba(5, 4, 2, 0.88));
    z-index: 1;
  }
  .dh2-lin__body {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: 12px 10px 14px;
    text-align: center;
  }
  .dh2-lin__name {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 6px;
    line-height: 1.25;
    color: #fff;
  }
  .dh2-lin__count {
    font-family: var(--font-body--family, 'Cormorant Garamond', Georgia, serif);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: rgba(244, 241, 236, 0.82);
  }
  @media (max-width: 768px) {
    .dh2-lin {
      padding: 24px 0 28px;
    }
    .dh2-lin.section {
      overflow-x: hidden;
    }
    .dh2-lin__inner {
      padding-left: max(20px, env(safe-area-inset-left, 0px));
      padding-right: max(24px, env(safe-area-inset-right, 0px));
    }
    .dh2-lin__sub {
      margin-bottom: 14px !important;
    }
    .dh2-lin__rail {
      gap: 12px;
      padding-top: 2px;
    }
    .dh2-lin__card {
      flex: 0 0 clamp(148px, 44vw, 190px);
      width: clamp(148px, 44vw, 190px);
    }
    .dh2-lin__body {
      padding: 14px 10px 16px;
    }
    .dh2-lin__name {
      font-size: 15px !important;
      letter-spacing: 0.08em !important;
    }
    .dh2-lin__count {
      font-size: 12px !important;
      letter-spacing: 0.06em !important;
    }
    h2.dh2-lin__title,
    .dh2-lin__title {
      font-size: 26px !important;
      line-height: 1.15 !important;
      max-width: 100% !important;
      margin-bottom: 8px !important;
    }
    .dh2-lin__tag {
      font-size: 9px !important;
      margin-bottom: 8px !important;
    }
  }
  @media (max-width: 768px) {
    .dh2-cb, .dh2-hero, .dh2-new, .dh2-lin, .dh2-be, .dh2-sp, .dh2-ed, .dh2-rito, .dh2-lt, .dh2-tribu {
      padding-block: 18px !important;
    }
  }
</style>

<section class="dh2-lin section">
  <div class="dh2-lin__inner">
    <p class="dh2-lin__tag">{{ dh2_lin_tag }}</p>
    <h2 class="dh2-lin__title">{{ dh2_lin_title }}</h2>
    {% if dh2_lin_sub != blank %}
      <p class="dh2-lin__sub">{{ dh2_lin_sub }}</p>
    {% endif %}
    <div class="dh2-lin__rail" role="list">
      {% for block in section.blocks %}
        {% if block.type == 'linaje' %}
          <a class="dh2-lin__card" href="{{ block.settings.url }}" role="listitem" {{ block.shopify_attributes }}>
            <div class="dh2-lin__bg" aria-hidden="true">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: '', widths: '200,400,600' }}
              {% else %}
                <span style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:32px;color:rgba(201,169,97,0.55);">{{ block.settings.glyph | default: '✦' }}</span>
              {% endif %}
            </div>
            <div class="dh2-lin__shade" aria-hidden="true"></div>
            <div class="dh2-lin__body">
              <h3 class="dh2-lin__name">{{ block.settings.title }}</h3>
              <span class="dh2-lin__count">{{ block.settings.count_label }}</span>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DDU v2 · Linajes",
  "tag": "section",
  "class": "duendes-home-v2-linajes-section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Etiqueta",
      "default": "POR LINAJE"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Cada Guardián viene de un linaje."
    }
  ],
  "blocks": [
    {
      "type": "linaje",
      "name": "Linaje",
      "settings": [
        { "type": "text", "id": "title", "label": "Nombre", "default": "Hadas" },
        { "type": "image_picker", "id": "image", "label": "Foto del linaje" },
        { "type": "text", "id": "count_label", "label": "Guardianes / contador (texto)", "default": "Ver colección" },
        { "type": "url", "id": "url", "label": "Enlace a colección" },
        { "type": "text", "id": "glyph", "label": "Marcador si no hay foto", "default": "✦", "info": "Solo se muestra si no cargás imagen." }
      ]
    }
  ],
  "presets": [
    {
      "name": "DDU v2 · Linajes",
      "blocks": [
        { "type": "linaje", "settings": { "title": "Hadas", "url": "shopify://collections/hadas" } },
        { "type": "linaje", "settings": { "title": "Pixies", "url": "shopify://collections/pixies" } },
        { "type": "linaje", "settings": { "title": "Elfos", "url": "shopify://collections/elfos" } },
        { "type": "linaje", "settings": { "title": "Medianos", "url": "shopify://collections/medianos" } },
        { "type": "linaje", "settings": { "title": "Maestros", "url": "shopify://collections/maestros" } },
        { "type": "linaje", "settings": { "title": "Deluxe", "url": "shopify://collections/deluxe" } },
        { "type": "linaje", "settings": { "title": "Brujas", "url": "shopify://collections/brujas" } },
        { "type": "linaje", "settings": { "title": "Grandes", "url": "shopify://collections/grandes" } },
        { "type": "linaje", "settings": { "title": "Gigantes", "url": "shopify://collections/gigantes" } },
        { "type": "linaje", "settings": { "title": "Históricos", "url": "shopify://collections/historicos" } }
      ]
    }
  ]
}
{% endschema %}
