{% comment %}
  Alma de Bruja · Duendes del Uruguay · v1.0
  · 42 páginas · flipbook PageFlip.js
  · Paleta tonal: negro carbón + plata vieja + violeta
  · Talismanes, varitas, sigilos, piedras de poder · línea por venir
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Great+Vibes&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Saira+Condensed:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  .libro-wrap {
    --carbon-deep: #14101a;
    --carbon-medium: #2a2230;
    --silver-old: #8a8a96;
    --silver-light: #c8c8d0;
    --silver-pastel: #e0e0e6;
    --silver-blush: #ededf2;
    --violet-deep: #3a1f5a;
    --violet-medium: #6b3a8a;
    --violet-light: #b08acb;
    --gold: #C9A961;
    --gold-bright: #D8B872;
    --gold-dark: #8b7137;

    --black-deep: #06040a;
    --cream: #ECE6E0;
    --cream-light: #F2EEE8;
    --brown-deep: #1a1420;
    --brown-soft: #36303e;
    --line-gold: rgba(201,169,97,0.32);
    --line-violet: rgba(107,58,138,0.32);
    --line-silver: rgba(138,138,150,0.40);

    --wood-base: #1a1320;
    --wood-mid: #221830;
    --wood-light: #2c1f40;
    --wood-dark: #0c0814;
    --font-info: 'Agency FB', 'Saira Condensed', 'Trebuchet MS', sans-serif;

    color: var(--cream); font-family: 'Cormorant Garamond', Georgia, serif;
    min-height: 100vh; padding: 28px 16px 60px; text-align: center;
    background-color: var(--wood-dark);
    background-image:
      radial-gradient(ellipse at 50% 35%, rgba(107,58,138,0.20) 0%, rgba(0,0,0,0.95) 78%),
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='800' height='600' viewBox='0 0 800 600'><defs><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.045' numOctaves='3'/><feColorMatrix values='0 0 0 0 0.10 0 0 0 0 0.06 0 0 0 0 0.18 0 0 0 0.65 0'/></filter></defs><rect width='100%' height='100%' filter='url(%23n)'/></svg>"),
      repeating-linear-gradient(91deg, var(--wood-dark) 0px, var(--wood-base) 2px, var(--wood-mid) 5px, var(--wood-base) 9px, var(--wood-light) 14px, var(--wood-mid) 22px, var(--wood-base) 30px, var(--wood-dark) 40px);
    background-attachment: fixed; position: relative; min-height: 100vh;
  }
  .libro-wrap::before {
    content:''; position: fixed; inset: 0; pointer-events: none; z-index: 0; opacity: 0.10;
    background-image:
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180' viewBox='0 0 180 180'><g fill='none' stroke='%23C8C8D0' stroke-width='1.4' opacity='0.7'><line x1='90' y1='10' x2='90' y2='170' stroke-width='2.2'/><circle cx='90' cy='30' r='6' fill='%23C8C8D0'/><line x1='65' y1='80' x2='115' y2='80'/><line x1='75' y1='110' x2='105' y2='110'/></g></svg>"),
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='220' height='220' viewBox='0 0 220 220'><g fill='none' stroke='%236B3A8A' stroke-width='1.4' opacity='0.7'><polygon points='110,20 195,80 165,180 55,180 25,80'/><circle cx='110' cy='110' r='10' fill='%236B3A8A'/></g></svg>"),
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160' viewBox='0 0 160 160'><g fill='none' stroke='%23C9A961' stroke-width='1.2' opacity='0.85'><circle cx='80' cy='80' r='50'/><polygon points='80,40 100,75 80,110 60,75'/><circle cx='80' cy='75' r='4' fill='%23C9A961'/></g></svg>");
    background-position: 8% 12%, 78% 22%, 50% 70%;
    background-repeat: no-repeat;
    background-size: 180px, 220px, 160px;
  }
  .libro-wrap::after {
    content:''; position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background:
      radial-gradient(ellipse at 22% 28%, rgba(176,138,203,0.10), transparent 38%),
      radial-gradient(ellipse at 78% 70%, rgba(200,200,208,0.08), transparent 50%);
  }

  .particula { position: fixed; pointer-events: none; z-index: 0; border-radius: 50%; opacity: 0; }
  .particula.silver { background: radial-gradient(circle, rgba(220,220,228,0.85) 0%, rgba(200,200,208,0) 70%); width: 4px; height: 4px; box-shadow: 0 0 10px rgba(220,220,228,0.6); }
  .particula.violet { background: radial-gradient(circle, rgba(176,138,203,0.7) 0%, rgba(107,58,138,0) 70%); width: 4px; height: 4px; box-shadow: 0 0 10px rgba(176,138,203,0.55); }
  .particula.gold { background: radial-gradient(circle, rgba(216,184,114,0.7) 0%, rgba(201,169,97,0) 70%); width: 3px; height: 3px; box-shadow: 0 0 8px rgba(216,184,114,0.5); }

  .libro-wrap > * { position: relative; z-index: 1; }
  .libro-wrap * { box-sizing: border-box; }

  .libro-header { max-width: 760px; margin: 0 auto 24px; text-align: center; }
  .libro-header .eyebrow { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.5em; color: var(--silver-light); text-transform: uppercase; margin-bottom: 12px; text-shadow: 0 2px 8px rgba(0,0,0,0.7); }
  .libro-header h1 { font-family: 'Great Vibes', cursive; font-size: clamp(46px, 6.8vw, 78px); margin: 0 0 8px; line-height: 1; font-weight: 400; color: var(--cream); text-shadow: 0 4px 18px rgba(0,0,0,0.85), 0 0 30px rgba(176,138,203,0.30); }
  .libro-header .sub { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.5em; color: var(--gold-bright); text-transform: uppercase; text-shadow: 0 2px 8px rgba(0,0,0,0.7); }

  .lang-overlay { position: fixed; inset: 0; background: rgba(6,4,10,0.97); z-index: 9999; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(8px); }
  .lang-overlay.hide { display: none; }
  .lang-box { max-width: 480px; text-align: center; padding: 40px 32px; border: 1px solid var(--silver-old); background: linear-gradient(160deg, #1a1320 0%, #06040a 100%); position: relative; }
  .lang-box::before { content:''; position: absolute; inset: 8px; border: 1px solid rgba(176,138,203,0.32); pointer-events:none; }
  .lang-box .ornament { color: var(--silver-light); font-family: 'Cinzel', serif; font-size: 14px; letter-spacing: 0.7em; margin-bottom: 18px; }
  .lang-box h2 { font-family: 'Great Vibes', cursive; font-weight: 400; font-size: 56px; color: var(--cream); margin: 0 0 8px; line-height: 1; }
  .lang-box .pretitle { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.4em; color: var(--silver-light); text-transform: uppercase; margin-bottom: 18px; }
  .lang-box p { font-family: var(--font-info); font-size: 16px; color: rgba(236,230,224,0.85); margin: 14px 0 28px; }
  .lang-buttons { display: flex; gap: 14px; justify-content: center; }
  .lang-buttons button { background: transparent; color: var(--cream); border: 1px solid var(--silver-old); padding: 14px 32px; font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.4em; text-transform: uppercase; cursor: pointer; transition: all 0.3s; }
  .lang-buttons button:hover { background: var(--silver-old); color: var(--black-deep); }
  .lang-buttons .recommended { background: var(--silver-light); color: var(--black-deep); }

  .flipbook-container { display: flex; justify-content: center; align-items: center; margin: 0 auto; max-width: 1120px; min-height: 600px; padding: 16px; }
  #book {
    box-shadow: 0 32px 100px rgba(0,0,0,0.92), 0 0 0 8px rgba(20,16,26,0.7), 0 0 0 9px var(--silver-old), 0 0 100px rgba(176,138,203,0.18);
    border-radius: 4px;
    touch-action: pan-y;
  }
  .page { background: var(--cream); color: var(--brown-deep); overflow: hidden; }
  .page-inner { padding: 36px 32px 26px; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; position: relative; text-align: center; }
  .page.dark { background: var(--black-deep); color: var(--cream); }
  .page.dark .page-inner::before { content: ''; position: absolute; inset: 14px; border: 1px solid rgba(200,200,208,0.25); pointer-events: none; }
  .page.silver { background: linear-gradient(160deg, var(--silver-pastel) 0%, var(--silver-blush) 70%, var(--cream-light) 100%); color: var(--brown-deep); }
  .page.silver .page-inner::before { content: ''; position: absolute; inset: 14px; border: 1px solid var(--line-silver); pointer-events: none; }
  .page.deep-violet { background: linear-gradient(160deg, #1a1226 0%, #06040a 100%); color: var(--cream); }
  .page.deep-violet .page-inner::before { content: ''; position: absolute; inset: 14px; border: 1px solid rgba(176,138,203,0.35); pointer-events: none; }

  .page .eyebrow { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; letter-spacing: 0.5em; color: var(--silver-old); text-transform: uppercase; margin-bottom: 14px; text-align: center; width: 100%; }
  .page.dark .eyebrow, .page.deep-violet .eyebrow { color: var(--silver-light); }
  .page.silver .eyebrow { color: var(--violet-deep); }
  .page h2 { font-family: 'Great Vibes', cursive; font-size: 48px; margin: 0 auto 14px; line-height: 1; font-weight: 400; color: var(--brown-deep); text-align: center; width: 100%; }
  .page.dark h2, .page.deep-violet h2 { color: var(--cream); }
  .page.silver h2 { color: var(--violet-deep); }
  .page h3 { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10.5px; letter-spacing: 0.3em; color: var(--silver-old); text-transform: uppercase; margin: 12px 0 8px; text-align: center; width: 100%; }

  .page p { font-family: var(--font-info); font-weight: 400; font-size: 14px; line-height: 1.55; margin: 0 auto 10px; color: var(--brown-deep); text-align: center; max-width: 380px; }
  .page.dark p, .page.deep-violet p { color: var(--cream); }
  .page p.lead { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; color: var(--brown-soft); font-size: 14.5px; }
  .page.dark p.lead, .page.deep-violet p.lead { color: rgba(236,230,224,0.85); }
  .page.silver p.lead { color: var(--violet-deep); }
  .page strong { color: var(--brown-deep); font-weight: 600; }
  .page.dark strong, .page.deep-violet strong { color: var(--cream); }
  .page em { font-style: italic; }

  .page .center-content { flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; width: 100%; text-align: center; }
  .page .page-number { position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%); font-family: 'Cinzel', serif; font-weight: 400; font-size: 9px; letter-spacing: 0.35em; color: var(--silver-old); }
  .page.dark .page-number, .page.deep-violet .page-number { color: var(--silver-light); opacity: 0.6; }

  .page.cover {
    background:
      radial-gradient(ellipse at 30% 30%, rgba(70,40,100,0.50), transparent 60%),
      radial-gradient(ellipse at 70% 70%, rgba(20,12,30,0.6), transparent 60%),
      linear-gradient(135deg, #1a1226 0%, #050308 50%, #221530 100%);
    color: var(--cream); position: relative; box-shadow: inset 0 0 80px rgba(0,0,0,0.95);
  }
  .page.cover::before { content:''; position: absolute; inset: 22px; border: 1px solid rgba(200,200,208,0.50); }
  .page.cover::after { content:''; position: absolute; inset: 32px; border: 1px solid rgba(176,138,203,0.30); }
  .page.cover .page-inner { z-index: 2; align-items: center; justify-content: space-between; padding: 60px 30px; gap: 12px; text-align: center; }
  .page.cover .ornament-celtic-top { width: 90px; height: 90px; flex-shrink: 0; color: var(--silver-light); opacity: 1; filter: drop-shadow(0 0 14px rgba(176,138,203,0.50)); }
  .page.cover .titulo-grande { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.5em; color: var(--silver-light); text-transform: uppercase; line-height: 1.4; text-align: center; }
  .page.cover h1 { font-family: 'Great Vibes', cursive; font-weight: 400; font-size: 60px; margin: 6px 0 8px; line-height: 1; color: var(--cream); text-shadow: 0 0 36px rgba(176,138,203,0.55); text-align: center; }
  .page.cover .marca-fina { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.6em; color: var(--gold-bright); text-transform: uppercase; text-align: center; }
  .page.cover .pie { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; font-size: 11px; color: rgba(236,230,224,0.70); margin: 0; text-align: center; }

  svg.ornament { display: block; margin: 14px auto; color: var(--silver-old); }
  svg.ornament.dark { color: var(--silver-light); }
  svg.ornament.violet-acc { color: var(--violet-deep); }
  svg.ornament.tiny { width: 32px; height: 32px; }
  svg.ornament.small { width: 60px; height: 60px; }
  svg.ornament.med { width: 90px; height: 90px; }

  .indice { font-family: var(--font-info); font-size: 12px; color: var(--brown-deep); text-align: left; max-width: 380px; margin: 0 auto; }
  .indice-item { display: flex; justify-content: space-between; align-items: baseline; margin: 6px 0; }
  .indice-item .num { color: var(--silver-old); margin-right: 8px; font-size: 11px; font-family: 'Cinzel', serif; letter-spacing: 0.15em; }
  .indice-item .name { flex: 1; }
  .indice-item .dots { flex: 1; border-bottom: 1px dotted var(--silver-old); margin: 0 8px; align-self: end; height: 1px; }
  .indice-item .pg { color: var(--silver-old); font-family: 'Cinzel', serif; }
  .indice-section { font-family: 'Cinzel', serif; font-weight: 500; font-size: 10px; letter-spacing: 0.35em; color: var(--violet-deep); text-transform: uppercase; margin: 12px 0 4px; padding-bottom: 4px; border-bottom: 1px solid var(--silver-old); text-align: center; }

  .page .cita { font-family: 'Great Vibes', cursive; font-size: 40px; line-height: 1.2; color: var(--violet-deep); text-align: center; padding: 16px 14px; font-weight: 400; }
  .page.dark .cita, .page.deep-violet .cita { color: var(--silver-light); font-size: 50px; text-shadow: 0 0 32px rgba(176,138,203,0.35); }

  .objeto-card {
    background: linear-gradient(160deg, var(--silver-blush) 0%, var(--silver-pastel) 100%);
    border: 1.5px solid var(--silver-old); border-radius: 10px;
    padding: 16px 18px; margin: 10px auto; max-width: 380px;
    box-shadow: 0 6px 18px rgba(20,16,26,0.20);
  }
  .objeto-card .obj-icon { width: 60px; height: 60px; margin: 0 auto 8px; color: var(--violet-deep); }
  .objeto-card .obj-nombre { font-family: 'Great Vibes', cursive; font-size: 36px; color: var(--violet-deep); margin: 0 0 4px; line-height: 1; }
  .objeto-card .obj-uso { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.4em; color: var(--silver-old); text-transform: uppercase; margin-bottom: 8px; }
  .objeto-card .obj-detalle { font-family: var(--font-info); font-size: 12.5px; color: var(--brown-soft); line-height: 1.55; margin: 0 auto 8px; text-align: center; }
  .objeto-card .obj-meta { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; margin-top: 8px; }
  .objeto-card .obj-meta span { font-family: 'Cinzel', serif; font-size: 8.5px; letter-spacing: 0.2em; color: var(--silver-old); text-transform: uppercase; padding: 3px 8px; border: 1px solid var(--silver-old); border-radius: 100px; background: rgba(255,255,255,0.4); }

  .consejo-card { background: var(--cream-light); border: 1px solid var(--silver-old); border-radius: 6px; padding: 12px 14px; margin: 8px auto; text-align: center; max-width: 360px; }
  .consejo-card .titulo { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.3em; color: var(--silver-old); text-transform: uppercase; margin-bottom: 5px; }
  .consejo-card p { font-family: var(--font-info); font-size: 13.5px; margin: 0 auto; line-height: 1.5; max-width: none; }
  .consejo-card.violet { border-color: var(--violet-medium); background: linear-gradient(180deg, #f0e8f5 0%, var(--cream-light) 100%); }
  .consejo-card.violet .titulo { color: var(--violet-deep); }

  .elementos-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid var(--silver-old); margin: 10px auto; max-width: 380px; background: var(--cream-light); }
  .elemento-cell { padding: 12px 10px; border-right: 1px solid var(--silver-old); border-bottom: 1px solid var(--silver-old); text-align: center; }
  .elemento-cell:nth-child(2n) { border-right: none; }
  .elemento-cell:nth-last-child(-n+2) { border-bottom: none; }
  .elemento-cell .titulo { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.3em; color: var(--violet-deep); margin-bottom: 5px; }
  .elemento-cell .quien { font-family: var(--font-info); font-size: 12px; color: var(--brown-deep); margin-bottom: 4px; font-weight: 500; }
  .elemento-cell .funcion { font-family: var(--font-info); font-size: 11.5px; color: var(--brown-soft); line-height: 1.45; }

  .dia-item { padding: 6px 8px; border-bottom: 1px solid var(--line-silver); text-align: center; max-width: 360px; margin: 0 auto; }
  .dia-item:last-child { border-bottom: none; }
  .dia-item .num { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; letter-spacing: 0.3em; color: var(--silver-old); }
  .dia-item .titulo { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; letter-spacing: 0.2em; color: var(--brown-deep); }
  .dia-item .desc { font-family: var(--font-info); font-size: 12.5px; color: var(--brown-soft); line-height: 1.5; margin-top: 2px; }

  .compendio-tabla { font-size: 11px; max-width: 380px; margin: 0 auto; }
  .compendio-row { display: flex; padding: 7px 0; border-bottom: 1px solid var(--line-silver); align-items: baseline; text-align: left; }
  .compendio-row:last-child { border-bottom: none; }
  .compendio-row .nombre { flex: 0 0 110px; color: var(--violet-deep); letter-spacing: 0.18em; text-transform: uppercase; font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; }
  .compendio-row .uso { flex: 1; color: var(--brown-soft); font-family: var(--font-info); font-size: 12.5px; }

  .faq { margin: 8px auto; padding-bottom: 8px; border-bottom: 1px dotted var(--line-violet); text-align: center; max-width: 380px; }
  .faq:last-child { border-bottom: none; }
  .faq .pregunta { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.2em; color: var(--violet-deep); text-transform: uppercase; margin-bottom: 5px; }
  .faq .respuesta { font-family: var(--font-info); font-size: 12.5px; color: var(--brown-soft); line-height: 1.55; margin: 0 auto; }

  .neuro-tag { display: inline-block; margin-top: 6px; padding: 4px 10px; background: var(--violet-deep); color: var(--cream); font-family: 'Cinzel', serif; font-size: 8.5px; letter-spacing: 0.3em; text-transform: uppercase; border-radius: 4px; }
  .page.dark .neuro-tag, .page.deep-violet .neuro-tag { background: var(--silver-light); color: var(--black-deep); }

  .otra-especie-card { display: flex; flex-direction: column; align-items: center; background: linear-gradient(160deg, var(--cream-light) 0%, #f0e8f5 100%); border: 1px solid var(--silver-old); border-radius: 10px; padding: 14px 16px; max-width: 380px; margin: 0 auto; box-shadow: 0 4px 18px rgba(20,16,26,0.15); }
  .otra-especie-card .otra-foto { width: 120px; height: 120px; border-radius: 50%; overflow: hidden; border: 2px solid var(--silver-old); margin-bottom: 8px; box-shadow: 0 4px 14px rgba(0,0,0,0.20); }
  .otra-especie-card .otra-foto img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .otra-especie-card .otra-foto.placeholder { background: linear-gradient(135deg, #1a1226, #06040a); display: flex; align-items: center; justify-content: center; color: var(--silver-light); }
  .otra-especie-card .otra-nombre { font-family: 'Great Vibes', cursive; font-size: 32px; color: var(--violet-deep); line-height: 1; margin: 4px 0 2px; }
  .otra-especie-card .otra-eyebrow { font-family: 'Cinzel', serif; font-size: 8.5px; letter-spacing: 0.4em; color: var(--silver-old); text-transform: uppercase; margin-bottom: 6px; }
  .otra-especie-card .otra-deseo { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; font-size: 13px; color: var(--brown-deep); line-height: 1.5; margin: 4px auto 8px; max-width: 320px; }
  .otra-especie-card .otra-cta { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.35em; color: var(--violet-deep); text-transform: uppercase; padding: 7px 14px; border: 1px solid var(--violet-deep); border-radius: 100px; text-decoration: none; transition: all 0.3s; background: rgba(255,255,255,0.5); }
  .otra-especie-card .otra-cta:hover { background: var(--violet-deep); color: var(--cream); }

