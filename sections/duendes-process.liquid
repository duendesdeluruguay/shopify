{{ 'duendes-base.css' | asset_url | stylesheet_tag }}

<style>
  .dp3 {
    position: relative;
    overflow: hidden;
    padding: clamp(48px, 6vw, 80px) 0;
    background: #FAFAF7;
  }
  .dp3__container { max-width: 1200px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 2; }
  .dp3__heading { text-align: center; margin-bottom: clamp(32px, 4vw, 48px); }
  .dp3__eyebrow {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: 11px; font-weight: 500; letter-spacing: 5px;
    text-transform: uppercase; color: #1a1a14; margin-bottom: 14px;
    opacity: .5;
  }
  .dp3__heading h2 {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: clamp(26px, 3.2vw, 42px); font-weight: 300;
    color: #1a1a14; line-height: 1.2; letter-spacing: .5px;
  }
  .dp3__heading h2 em { font-style: italic; }
  .dp3__line {
    width: 40px; height: 1px; margin: 16px auto 0;
    background: linear-gradient(90deg, transparent, #1a1a14, transparent);
    opacity: .2;
  }

  /* Grid de pasos */
  .dp3__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    position: relative;
  }
  .dp3__step {
    position: relative;
    padding: 28px 20px 24px;
    text-align: center;
    border-right: 1px solid rgba(26,26,20,.08);
    transition: background .4s ease;
  }
  .dp3__step:last-child { border-right: none; }
  .dp3__step:hover { background: rgba(26,26,20,.03); }

  .dp3__step-num {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: 11px; letter-spacing: 3px; color: rgba(26,26,20,.25);
    margin-bottom: 16px; font-weight: 500;
  }
  .dp3__step-icon {
    width: 48px; height: 48px; margin: 0 auto 16px;
    border: 1px solid rgba(26,26,20,.15); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    transition: all .5s ease;
  }
  .dp3__step:hover .dp3__step-icon {
    border-color: #1a1a14;
    box-shadow: 0 0 20px rgba(26,26,20,.08);
  }
  .dp3__step-icon svg { width: 22px; height: 22px; }

  .dp3__step-title {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: 16px; font-weight: 600; color: #1a1a14;
    margin-bottom: 8px; letter-spacing: .3px; line-height: 1.3;
  }
  .dp3__step-desc {
    font-family: var(--serif, 'Cormorant Garamond', serif);
    font-size: 14px; color: rgba(26,26,20,.55);
    line-height: 1.6; font-style: italic;
  }

  /* Conector entre pasos */
  .dp3__step::after {
    content: '›';
    position: absolute;
    right: -7px; top: 50%;
    transform: translateY(-50%);
    font-size: 18px; color: rgba(26,26,20,.2);
    z-index: 3;
  }
  .dp3__step:last-child::after { display: none; }

  /* Tablet */
  @media (max-width: 1024px) {
    .dp3__grid { grid-template-columns: repeat(3, 1fr); }
    .dp3__step:nth-child(3) { border-right: none; }
    .dp3__step:nth-child(3)::after { display: none; }
    .dp3__step:nth-child(4),
    .dp3__step:nth-child(5) { border-top: 1px solid rgba(26,26,20,.08); }
  }

  /* Mobile */
  @media (max-width: 600px) {
    .dp3 { padding: 40px 0; }
    .dp3__grid {
      grid-template-columns: 1fr;
      gap: 0;
      max-width: 400px;
      margin: 0 auto;
    }
    .dp3__step {
      display: flex;
      align-items: center;
      text-align: left;
      padding: 16px 20px;
      border-right: none;
      border-bottom: 1px solid rgba(26,26,20,.07);
    }
    .dp3__step:last-child { border-bottom: none; }
    .dp3__step::after { display: none; }
    .dp3__step-num {
      position: absolute;
      top: 8px; right: 12px;
      margin-bottom: 0;
      font-size: 10px;
    }
    .dp3__step-icon {
      width: 42px; height: 42px; margin: 0 16px 0 0;
      flex-shrink: 0;
    }
    .dp3__step-icon svg { width: 20px; height: 20px; }
    .dp3__step-text { flex: 1; }
    .dp3__step-title { font-size: 15px; margin-bottom: 4px; }
    .dp3__step-desc { font-size: 13px; }
  }
</style>

<section class="dp3" id="duendes-proceso">
  <div class="dp3__container">
    <div class="dp3__heading duendes-reveal">
      {% if section.settings.eyebrow != blank %}
        <p class="dp3__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2>{{ section.settings.heading }}</h2>
      <div class="dp3__line"></div>
    </div>

    <div class="dp3__grid">
      {% for block in section.blocks %}
        {%- assign num = forloop.index | prepend: '0' | slice: -2, 2 -%}
        <div class="dp3__step duendes-reveal" {{ block.shopify_attributes }}>
          <span class="dp3__step-num">{{ num }}</span>
          <div class="dp3__step-icon">
            {% case block.settings.icon %}
              {% when 'search' %}
                <svg viewBox="0 0 26 26" fill="none"><circle cx="11" cy="11" r="5.5" stroke="#1a1a14" stroke-width="1.3"/><path d="M15 15l4.5 4.5" stroke="#1a1a14" stroke-width="1.3" stroke-linecap="round"/></svg>
              {% when 'form' %}
                <svg viewBox="0 0 26 26" fill="none"><rect x="6" y="4" width="14" height="18" rx="2" stroke="#1a1a14" stroke-width="1.3"/><path d="M10 10h6M10 14h4" stroke="#1a1a14" stroke-width="1.3" stroke-linecap="round"/></svg>
              {% when 'channel' %}
                <svg viewBox="0 0 26 26" fill="none"><path d="M13 5l2 4 4.5.6-3.3 3.2.8 4.5L13 15l-4 2.3.8-4.5L6.5 9.6 11 9l2-4z" stroke="#1a1a14" stroke-width="1.3" stroke-linejoin="round"/></svg>
              {% when 'letter' %}
                <svg viewBox="0 0 26 26" fill="none"><rect x="4" y="7" width="18" height="12" rx="2" stroke="#1a1a14" stroke-width="1.3"/><path d="M4 9l9 5 9-5" stroke="#1a1a14" stroke-width="1.3"/></svg>
              {% when 'ship' %}
                <svg viewBox="0 0 26 26" fill="none"><path d="M3 17h20l-2 4H5l-2-4z" stroke="#1a1a14" stroke-width="1.3"/><path d="M6 17v-7a2 2 0 012-2h10a2 2 0 012 2v7" stroke="#1a1a14" stroke-width="1.3"/><path d="M13 8v9" stroke="#1a1a14" stroke-width="1" stroke-dasharray="2 2"/></svg>
              {% else %}
                <svg viewBox="0 0 26 26" fill="none"><circle cx="13" cy="13" r="5" stroke="#1a1a14" stroke-width="1.3"/></svg>
            {% endcase %}
          </div>
          <div class="dp3__step-text">
            <h3 class="dp3__step-title">{{ block.settings.title }}</h3>
            <p class="dp3__step-desc">{{ block.settings.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<div class="duendes-divider">&#10022;</div>

{% schema %}
{
  "name": "Duendes Proceso",
  "tag": "section",
  "class": "duendes-proceso-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta superior",
      "default": "DEL TALLER A TU HOGAR"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Como Llega Tu Guardian"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Imagen de fondo",
      "info": "Imagen sutil detras del timeline de proceso. Se muestra con baja opacidad."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Paso",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icono",
          "options": [
            { "value": "search", "label": "Busqueda" },
            { "value": "form", "label": "Formulario" },
            { "value": "channel", "label": "Canalizacion" },
            { "value": "letter", "label": "Carta" },
            { "value": "ship", "label": "Envio" }
          ],
          "default": "search"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titulo del paso",
          "default": "Elegi tu Guardian"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripcion",
          "default": "Browse the shop or take the Guardian Test. When one calls you, that's the one."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Duendes Proceso",
      "blocks": [
        { "type": "step", "settings": { "icon": "search", "title": "Choose Your Guardian", "description": "Explore the shop or take the Test. When one stops you, don't ignore it." } },
        { "type": "step", "settings": { "icon": "form", "title": "Contanos Tu Momento", "description": "Después de la compra recibís un formulario breve. Tu respuesta es la base para la canalización." } },
        { "type": "step", "settings": { "icon": "channel", "title": "Thibisay Canaliza", "description": "Conecta con la energía del guardián y con la tuya. El resultado es un mensaje único." } },
        { "type": "step", "settings": { "icon": "letter", "title": "Recibís Tu Carta", "description": "Una carta escrita a mano, sellada, que solo tiene sentido para vos." } },
        { "type": "step", "settings": { "icon": "ship", "title": "Llega a Tu Puerta", "description": "DHL Express o DAC en Uruguay. Protegido como merece." } }
      ]
    }
  ]
}
{% endschema %}
