{%- comment -%}
  Sección "Te eligen a vos" — Pacto homepage 2026-05-04
  CTA al Test del Guardián. Hero foto + texto cinematográfico, sin carrusel.
  Copy y especificación: handoff Cowork msg_1777858049130.
{%- endcomment -%}

{%- liquid
  assign sec = section.settings
-%}

<section id="ddu-eligen-{{ section.id }}" class="ddu-eligen">
  <div class="ddu-eligen__hero">
    {%- if sec.hero_image -%}
      <img class="ddu-eligen__hero-img" src="{{ sec.hero_image | image_url: width: 1800 }}" alt="" loading="lazy">
    {%- endif -%}
    <div class="ddu-eligen__inner">
      {%- if sec.badge != blank -%}
        <span class="ddu-eligen__badge">{{ sec.badge }}</span>
      {%- endif -%}
      <h2 class="ddu-eligen__title">{{ sec.title }}</h2>
      <p class="ddu-eligen__subtitle">{{ sec.subtitle }}</p>
      {%- if sec.cta_text != blank and sec.cta_url != blank -%}
        <a class="ddu-eligen__cta" href="{{ sec.cta_url }}">{{ sec.cta_text }} →</a>
      {%- endif -%}
    </div>
  </div>
</section>

{%- style -%}
  #ddu-eligen-{{ section.id }} { background: #0a0706; color: #f4ecd8; padding: 0; overflow: hidden; }
  .ddu-eligen__hero { position: relative; width: 100%; min-height: 88vh; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .ddu-eligen__hero-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .ddu-eligen__hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at center, rgba(10,7,6,.35) 0%, rgba(10,7,6,.85) 75%); pointer-events: none; }
  .ddu-eligen__inner { position: relative; z-index: 2; text-align: center; padding: 64px 24px; max-width: 720px; }
  .ddu-eligen__badge { display: inline-block; font-size: 11px; letter-spacing: .25em; text-transform: uppercase; color: #d6b366; padding: 6px 14px; border: 1px solid rgba(214,179,102,.4); border-radius: 999px; margin-bottom: 22px; backdrop-filter: blur(6px); background: rgba(10,7,6,.4); }
  .ddu-eligen__title { font-family: 'Cinzel', 'Playfair Display', serif; font-size: clamp(30px, 7vw, 64px); font-weight: 500; line-height: 1.1; margin: 0 0 22px; color: #f4ecd8; }
  .ddu-eligen__subtitle { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(16px, 2.4vw, 21px); font-style: italic; line-height: 1.55; margin: 0 0 34px; color: rgba(244,236,216,.92); }
  .ddu-eligen__cta { display: inline-block; font-family: 'Cinzel', serif; font-size: 14px; letter-spacing: .22em; text-transform: uppercase; color: #0a0706; background: #d6b366; padding: 16px 36px; border-radius: 4px; text-decoration: none; transition: transform .3s, background .3s, box-shadow .3s; box-shadow: 0 8px 32px rgba(214,179,102,.25); }
  .ddu-eligen__cta:hover { background: #e6c378; transform: translateY(-2px); box-shadow: 0 12px 40px rgba(214,179,102,.4); }

  @media (min-width: 768px) {
    .ddu-eligen__hero { min-height: 80vh; }
    .ddu-eligen__inner { padding: 80px 48px; max-width: 800px; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Te eligen a vos",
  "tag": "section",
  "class": "section-ddu-eligen",
  "settings": [
    { "type": "header", "content": "Texto" },
    { "type": "text",      "id": "badge",    "label": "Badge",                            "default": "Te toma 2 minutos" },
    { "type": "text",      "id": "title",    "label": "Título (H2)",                      "default": "Vos no elegís. Te eligen." },
    { "type": "textarea",  "id": "subtitle", "label": "Subtítulo",                        "default": "El que llega a tu casa no es el que más te gustó en la pantalla. Es el que reconoció tu energía. Hacé el Test del Guardián y mirá cuáles ya saben tu nombre." },
    { "type": "text",      "id": "cta_text", "label": "Texto del botón",                  "default": "Hacer el Test" },
    { "type": "url",       "id": "cta_url",  "label": "URL del botón" },
    { "type": "header", "content": "Imagen de fondo" },
    { "type": "image_picker", "id": "hero_image", "label": "Imagen (Thibisay reemplazará por una IA después)" }
  ],
  "presets": [
    { "name": "Te eligen a vos" }
  ]
}
{% endschema %}
