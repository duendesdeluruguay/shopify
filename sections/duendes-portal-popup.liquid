{% comment %}
============================================================
  DUENDES DEL URUGUAY · POPUP BIENVENIDA 10%
  Captura email → Klaviyo Lista "Comunidad Maestra" (XvtVMG)
  Dispara flow Bienvenida (QNJbCL) automáticamente
  El primer email del flow incluye código BIENVENIDA10 (10% off)

  GUARD COWORK 2026-04-27: deshabilitado en /pages/mi-magia, /pages/rito-reconocimiento, /account
============================================================
{% endcomment %}

{%- assign _h = page.handle | default: '' -%}
{%- comment -%}
  GUARD 2026-05-01: deshabilitado en páginas con flow propio o de discovery
  donde el popup interrumpe el ritmo emocional. Cowork + Code + Thibisay.
{%- endcomment -%}
{%- if _h == 'mi-magia'
   or _h == 'rito-reconocimiento'
   or _h == 'test-del-guardian'
   or _h == 'como-funciona'
   or _h == 'senales'
   or template contains 'customers' -%}
  {%- comment -%} Popup deshabilitado en esta página {%- endcomment -%}
{%- else -%}

<style>
  /* DDU popup — rebranding 2026-05-01: paleta marca, más compacto, cinematográfico */
  .ddu-popup-backdrop{position:fixed;inset:0;background:rgba(8,10,6,.78);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);z-index:99999;display:none;align-items:center;justify-content:center;padding:16px;opacity:0;transition:opacity .35s ease}
  .ddu-popup-backdrop.active{display:flex;opacity:1}
  .ddu-popup-card{position:relative;width:100%;max-width:360px;background:linear-gradient(180deg,#0d0f09 0%,#0a0c06 100%);border:1px solid rgba(201,168,76,.28);border-radius:10px;padding:28px 24px 22px;box-shadow:0 30px 80px rgba(0,0,0,.55),0 0 60px rgba(201,168,76,.06);transform:translateY(16px) scale(.97);transition:transform .45s cubic-bezier(0.19,1,0.22,1) .1s,opacity .35s ease;opacity:0}
  .ddu-popup-backdrop.active .ddu-popup-card{transform:translateY(0) scale(1);opacity:1}
  .ddu-popup-close{position:absolute;top:10px;right:10px;background:transparent;border:0;width:28px;height:28px;cursor:pointer;color:rgba(245,245,220,.4);font-size:20px;line-height:1;transition:color .2s ease}
  .ddu-popup-close:hover{color:#dfc472}
  .ddu-popup-glyph{font-family:'Cinzel',serif;text-align:center;color:#dfc472;font-size:18px;letter-spacing:.4em;margin:0 0 14px;opacity:.85}
  .ddu-popup-eyebrow{font-family:'Cinzel',serif;font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:rgba(223,196,114,.7);text-align:center;margin:0 0 10px;font-weight:500}
  .ddu-popup-title{font-family:'Cormorant Garamond',serif;font-weight:300;font-size:22px;line-height:1.2;color:#F5F5DC;text-align:center;margin:0 0 8px;letter-spacing:.01em}
  .ddu-popup-title strong{font-weight:500;color:#dfc472;font-style:italic}
  .ddu-popup-text{font-family:'Cormorant Garamond',serif;font-size:13px;line-height:1.55;color:rgba(245,245,220,.65);font-style:italic;text-align:center;margin:0 0 18px}
  .ddu-popup-form{display:flex;flex-direction:column;gap:10px}
  .ddu-popup-input{width:100%;padding:12px 14px;background:rgba(245,245,220,.04);border:1px solid rgba(201,168,76,.25);border-radius:6px;font-family:'Cormorant Garamond',serif;font-size:14px;color:#F5F5DC;outline:none;transition:border-color .2s ease}
  .ddu-popup-input::placeholder{color:rgba(245,245,220,.35);font-style:italic}
  .ddu-popup-input:focus{border-color:#c9a84c;background:rgba(201,168,76,.06)}
  .ddu-popup-button{width:100%;padding:13px 24px;background:#c9a84c;color:#0a0c06;border:0;border-radius:6px;font-family:'Cinzel',serif;font-size:11px;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;transition:all .25s ease;font-weight:600;box-shadow:0 4px 18px rgba(201,168,76,.32)}
  .ddu-popup-button:hover{background:#dfc472;transform:translateY(-1px);box-shadow:0 6px 24px rgba(201,168,76,.45)}
  .ddu-popup-button:disabled{opacity:.5;cursor:not-allowed;transform:none}
  .ddu-popup-disclaimer{font-family:'Cormorant Garamond',serif;font-size:10px;color:rgba(245,245,220,.35);font-style:italic;text-align:center;margin:12px 0 0;line-height:1.4}
  .ddu-popup-success{display:none;text-align:center;padding:14px 0}
  .ddu-popup-success.active{display:block}
  .ddu-popup-success h4{font-family:'Cormorant Garamond',serif;font-size:20px;color:#dfc472;margin:0 0 10px;font-style:italic;font-weight:400}
  .ddu-popup-success p{font-family:'Cormorant Garamond',serif;font-size:13px;color:rgba(245,245,220,.7);line-height:1.5;margin:0}
  @media (max-width:480px){.ddu-popup-card{padding:24px 20px 18px;max-width:340px}.ddu-popup-title{font-size:20px}}
</style>

<div class="ddu-popup-backdrop" id="dduPopupBackdrop" role="dialog" aria-modal="true" aria-labelledby="dduPopupTitle">
  <div class="ddu-popup-card">
    <button type="button" class="ddu-popup-close" id="dduPopupClose" aria-label="Cerrar">&times;</button>
    <div class="ddu-popup-glyph" aria-hidden="true">✦</div>
    <p class="ddu-popup-eyebrow">Bienvenida elemental</p>
    <h3 id="dduPopupTitle" class="ddu-popup-title">10% en tu<br><strong>first adoption</strong></h3>
    <p class="ddu-popup-text">Leave us your email and we'll send you the code. First Guardian only.</p>
    <form class="ddu-popup-form" id="dduPopupForm" novalidate>
      <input type="email" class="ddu-popup-input" id="dduPopupEmail" placeholder="tu@email.com" required autocomplete="email">
      <button type="submit" class="ddu-popup-button" id="dduPopupSubmit">I want my code</button>
    </form>
    <p class="ddu-popup-disclaimer">Sin spam. Te escribimos solo cuando hay magia nueva.</p>
    <div class="ddu-popup-success" id="dduPopupSuccess">
      <h4>✦ Listo</h4>
      <p>Check your email in the next few minutes. Your welcome code is on its way.</p>
    </div>
  </div>
</div>

<script>
(function() {
  // Trigger: 30s o exit-intent, una vez por sesión
  if (sessionStorage.getItem('dduPopupShown')) return;
  
  var backdrop = document.getElementById('dduPopupBackdrop');
  var closeBtn = document.getElementById('dduPopupClose');
  var form = document.getElementById('dduPopupForm');
  var emailInput = document.getElementById('dduPopupEmail');
  var btn = document.getElementById('dduPopupSubmit');
  var successDiv = document.getElementById('dduPopupSuccess');
  
  if (!backdrop) return;
  
  function show() {
    if (sessionStorage.getItem('dduPopupShown')) return;
    backdrop.classList.add('active');
    sessionStorage.setItem('dduPopupShown', '1');
  }
  function hide() { backdrop.classList.remove('active'); }
  
  setTimeout(show, 30000);
  document.addEventListener('mouseleave', function(e) {
    if (e.clientY < 0) show();
  });
  
  closeBtn.addEventListener('click', hide);
  backdrop.addEventListener('click', function(e) { if (e.target === backdrop) hide(); });
  
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var email = emailInput.value.trim();
    if (!email) return;
    btn.disabled = true;
    btn.textContent = 'Enviando...';
    
    fetch('https://a.klaviyo.com/client/subscriptions/?company_id=XvtVMG', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'revision': '2024-10-15' },
      body: JSON.stringify({
        data: {
          type: 'subscription',
          attributes: {
            profile: { data: { type: 'profile', attributes: { email: email } } }
          },
          relationships: { list: { data: { type: 'list', id: 'XvtVMG' } } }
        }
      })
    }).then(function(r) {
      form.style.display = 'none';
      successDiv.classList.add('active');
      setTimeout(hide, 4000);
    }).catch(function() {
      btn.disabled = false;
      btn.textContent = 'I want my code';
    });
  });
})();
</script>

{%- endif -%}
