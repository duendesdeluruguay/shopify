      result_greeting: "your guardian was channeled.",
      result_reveal: "Meet them",
      result_personal_label: "Personal message",
      result_why_label: "Why this guardian",
      result_compat_title: "Others who vibrate close to you",
      result_compat_sub: "Not your central guardian, but they understand you.",
      result_cta: "Adopt them",
      receive_title: "Get your full channeling",
      receive_sub: "Your guardian, the message, and the compatible ones.",
      receive_email: "By email", receive_share_wa: "Share with someone", receive_copy: "Copy link",
      receive_email_sent: "Done. Check your inbox (may take 1-2 minutes).",
      receive_email_sending: "Sending...",
