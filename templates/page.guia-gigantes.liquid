<style>
  .libro-wrap {
    --bordeaux-deep: #5a1d1d;
    --bordeaux-medium: #8a3030;
    --bordeaux-light: #c46a6a;
    --bordeaux-pastel: #e8c8c8;
    --bordeaux-blush: #f4e4e4;
    --gold: #C9A961;
    --gold-bright: #D8B872;
    --gold-dark: #8b7137;

    --black-deep: #0a0606;
    --cream: #F4ECDE;
    --cream-light: #FAF3E6;
    --brown-deep: #2a1414;
    --brown-soft: #523030;
    --line-gold: rgba(201,169,97,0.32);
    --line-bordeaux: rgba(138,48,48,0.32);

    --wood-base: #2a0e0e;
    --wood-mid: #38161a;
    --wood-light: #481c20;
    --wood-dark: #160606;
    --font-info: 'Agency FB', 'Saira Condensed', 'Trebuchet MS', sans-serif;

    color: var(--cream); font-family: 'Cormorant Garamond', Georgia, serif;
    min-height: 100vh; padding: 28px 16px 60px; text-align: center;
    background-color: var(--wood-dark);
    background-image:
      radial-gradient(ellipse at 50% 35%, rgba(138,48,48,0.22) 0%, rgba(0,0,0,0.95) 78%),
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='800' height='600' viewBox='0 0 800 600'><defs><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.035' numOctaves='3'/><feColorMatrix values='0 0 0 0 0.20 0 0 0 0 0.06 0 0 0 0 0.06 0 0 0 0.65 0'/></filter></defs><rect width='100%' height='100%' filter='url(%23n)'/></svg>"),
      repeating-linear-gradient(91deg, var(--wood-dark) 0px, var(--wood-base) 2px, var(--wood-mid) 5px, var(--wood-base) 9px, var(--wood-light) 14px, var(--wood-mid) 22px, var(--wood-base) 30px, var(--wood-dark) 40px);
    background-attachment: fixed; position: relative; min-height: 100vh;
  }
  .libro-wrap::before {
    content:''; position: fixed; inset: 0; pointer-events: none; z-index: 0; opacity: 0.10;
    background-image:
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200' viewBox='0 0 200 200'><g fill='none' stroke='%23C9A961' stroke-width='1.6' opacity='0.85'><circle cx='100' cy='100' r='62'/><path d='M100 38 L100 162 M38 100 L162 100' stroke-width='2.5'/><circle cx='100' cy='100' r='10' fill='%23C9A961'/></g></svg>"),
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='220' height='220' viewBox='0 0 220 220'><g fill='none' stroke='%238A3030' stroke-width='1.4' opacity='0.7'><polygon points='110,30 180,80 155,170 65,170 40,80'/><circle cx='110' cy='110' r='6' fill='%238A3030'/></g></svg>");
    background-position: 8% 12%, 78% 22%;
    background-repeat: no-repeat;
    background-size: 200px, 220px;
  }
  .libro-wrap::after {
    content:''; position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background:
      radial-gradient(ellipse at 22% 28%, rgba(196,106,106,0.10), transparent 38%),
      radial-gradient(ellipse at 78% 70%, rgba(201,169,97,0.10), transparent 50%);
  }

  .particula { position: fixed; pointer-events: none; z-index: 0; border-radius: 50%; opacity: 0; }
  .particula.gold { background: radial-gradient(circle, rgba(216,184,114,0.85) 0%, rgba(201,169,97,0) 70%); width: 6px; height: 6px; box-shadow: 0 0 10px rgba(216,184,114,0.7); }
  .particula.bordeaux { background: radial-gradient(circle, rgba(196,106,106,0.7) 0%, rgba(138,48,48,0) 70%); width: 5px; height: 5px; box-shadow: 0 0 10px rgba(196,106,106,0.55); }

  .libro-wrap > * { position: relative; z-index: 1; }
  .libro-wrap * { box-sizing: border-box; }

  .libro-header { max-width: 760px; margin: 0 auto 24px; text-align: center; }
  .libro-header .eyebrow { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.5em; color: var(--gold); text-transform: uppercase; margin-bottom: 12px; text-shadow: 0 2px 8px rgba(0,0,0,0.7); }
  .libro-header h1 { font-family: 'Great Vibes', cursive; font-size: clamp(46px, 6.8vw, 78px); margin: 0 0 8px; line-height: 1; font-weight: 400; color: var(--cream); text-shadow: 0 4px 18px rgba(0,0,0,0.85), 0 0 30px rgba(196,106,106,0.20); }
  .libro-header .sub { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.5em; color: var(--gold-bright); text-transform: uppercase; text-shadow: 0 2px 8px rgba(0,0,0,0.7); }

  .lang-overlay { position: fixed; inset: 0; background: rgba(10,6,6,0.97); z-index: 9999; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(8px); }
  .lang-overlay.hide { display: none; }
  .lang-box { max-width: 480px; text-align: center; padding: 40px 32px; border: 1px solid var(--gold); background: linear-gradient(160deg, #2a0e0e 0%, #0a0404 100%); position: relative; }
  .lang-box::before { content:''; position: absolute; inset: 8px; border: 1px solid rgba(196,106,106,0.32); pointer-events:none; }
  .lang-box .ornament { color: var(--gold); font-family: 'Cinzel', serif; font-size: 14px; letter-spacing: 0.7em; margin-bottom: 18px; }
  .lang-box h2 { font-family: 'Great Vibes', cursive; font-weight: 400; font-size: 56px; color: var(--cream); margin: 0 0 8px; line-height: 1; }
  .lang-box .pretitle { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.4em; color: var(--gold); text-transform: uppercase; margin-bottom: 18px; }
  .lang-box p { font-family: var(--font-info); font-size: 16px; color: rgba(244,236,222,0.85); margin: 14px 0 28px; }
  .lang-buttons { display: flex; gap: 14px; justify-content: center; }
  .lang-buttons button { background: transparent; color: var(--cream); border: 1px solid var(--gold); padding: 14px 32px; font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.4em; text-transform: uppercase; cursor: pointer; transition: all 0.3s; }
  .lang-buttons button:hover { background: var(--gold); color: var(--black-deep); }
  .lang-buttons .recommended { background: var(--gold); color: var(--black-deep); }

  .flipbook-container { display: flex; justify-content: center; align-items: center; margin: 0 auto; max-width: 1120px; min-height: 600px; padding: 16px; }
  #book {
    box-shadow: 0 32px 100px rgba(0,0,0,0.9), 0 0 0 8px rgba(40,14,14,0.7), 0 0 0 9px var(--gold-dark), 0 0 100px rgba(196,106,106,0.15);
    border-radius: 4px;
    touch-action: pan-y;
  }
  .page { background: var(--cream); color: var(--brown-deep); overflow: hidden; }
  .page-inner { padding: 36px 32px 26px; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; position: relative; text-align: center; }
  .page.dark { background: var(--black-deep); color: var(--cream); }
  .page.dark .page-inner::before { content: ''; position: absolute; inset: 14px; border: 1px solid rgba(196,106,106,0.25); pointer-events: none; }
  .page.bordeaux { background: linear-gradient(160deg, var(--bordeaux-pastel) 0%, var(--bordeaux-blush) 70%, var(--cream-light) 100%); color: var(--brown-deep); }
  .page.bordeaux .page-inner::before { content: ''; position: absolute; inset: 14px; border: 1px solid var(--line-bordeaux); pointer-events: none; }
  .page.deep-bordeaux { background: linear-gradient(160deg, #2a0e0e 0%, #100404 100%); color: var(--cream); }
  .page.deep-bordeaux .page-inner::before { content: ''; position: absolute; inset: 14px; border: 1px solid rgba(196,106,106,0.32); pointer-events: none; }

  .page .eyebrow { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; letter-spacing: 0.5em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 14px; text-align: center; width: 100%; }
  .page.dark .eyebrow, .page.deep-bordeaux .eyebrow { color: var(--gold); }
  .page.bordeaux .eyebrow { color: var(--bordeaux-deep); }
  .page h2 { font-family: 'Great Vibes', cursive; font-size: 48px; margin: 0 auto 14px; line-height: 1; font-weight: 400; color: var(--brown-deep); text-align: center; width: 100%; }
  .page.dark h2, .page.deep-bordeaux h2 { color: var(--cream); }
  .page.bordeaux h2 { color: var(--bordeaux-deep); }
  .page h3 { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10.5px; letter-spacing: 0.3em; color: var(--gold-dark); text-transform: uppercase; margin: 12px 0 8px; text-align: center; width: 100%; }

  .page p { font-family: var(--font-info); font-weight: 400; font-size: 14px; line-height: 1.55; margin: 0 auto 10px; color: var(--brown-deep); text-align: center; max-width: 380px; }
  .page.dark p, .page.deep-bordeaux p { color: var(--cream); }
  .page p.lead { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; color: var(--brown-soft); font-size: 14.5px; }
  .page.dark p.lead, .page.deep-bordeaux p.lead { color: rgba(244,236,222,0.85); }
  .page.bordeaux p.lead { color: var(--bordeaux-deep); }
  .page strong { color: var(--brown-deep); font-weight: 600; }
  .page.dark strong, .page.deep-bordeaux strong { color: var(--cream); }
  .page em { font-style: italic; }

  .page .center-content { flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; width: 100%; text-align: center; }
  .page .page-number { position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%); font-family: 'Cinzel', serif; font-weight: 400; font-size: 9px; letter-spacing: 0.35em; color: var(--gold-dark); }
  .page.dark .page-number, .page.deep-bordeaux .page-number { color: var(--gold); opacity: 0.6; }

  .page.cover {
    background:
      radial-gradient(ellipse at 30% 30%, rgba(80,20,20,0.55), transparent 60%),
      radial-gradient(ellipse at 70% 70%, rgba(40,10,10,0.6), transparent 60%),
      linear-gradient(135deg, #2a0e0e 0%, #0a0404 50%, #1f0808 100%);
    color: var(--cream); position: relative; box-shadow: inset 0 0 80px rgba(0,0,0,0.9);
  }
  .page.cover::before { content:''; position: absolute; inset: 22px; border: 1px solid rgba(201,169,97,0.5); }
  .page.cover::after { content:''; position: absolute; inset: 32px; border: 1px solid rgba(196,106,106,0.25); }
  .page.cover .page-inner { z-index: 2; align-items: center; justify-content: space-between; padding: 60px 30px; gap: 12px; text-align: center; }
  .page.cover .ornament-celtic-top { width: 90px; height: 90px; flex-shrink: 0; color: var(--gold); opacity: 1; filter: drop-shadow(0 0 14px rgba(201,169,97,0.45)); }
  .page.cover .titulo-grande { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.5em; color: var(--gold); text-transform: uppercase; line-height: 1.4; text-align: center; }
  .page.cover h1 { font-family: 'Great Vibes', cursive; font-weight: 400; font-size: 60px; margin: 6px 0 8px; line-height: 1; color: var(--cream); text-shadow: 0 0 36px rgba(196,106,106,0.45); text-align: center; }
  .page.cover .marca-fina { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.6em; color: var(--gold-bright); text-transform: uppercase; text-align: center; }
  .page.cover .pie { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; font-size: 11px; color: rgba(244,236,222,0.6); margin: 0; text-align: center; }

  svg.ornament { display: block; margin: 14px auto; color: var(--gold-dark); }
  svg.ornament.dark { color: var(--gold); }
  svg.ornament.bordeaux-acc { color: var(--bordeaux-deep); }
  svg.ornament.tiny { width: 32px; height: 32px; }
  svg.ornament.small { width: 60px; height: 60px; }
  svg.ornament.med { width: 90px; height: 90px; }

  .indice { font-family: var(--font-info); font-size: 12px; color: var(--brown-deep); text-align: left; max-width: 380px; margin: 0 auto; }
  .indice-item { display: flex; justify-content: space-between; align-items: baseline; margin: 6px 0; }
  .indice-item .num { color: var(--gold-dark); margin-right: 8px; font-size: 11px; font-family: 'Cinzel', serif; letter-spacing: 0.15em; }
  .indice-item .name { flex: 1; }
  .indice-item .dots { flex: 1; border-bottom: 1px dotted var(--gold-dark); margin: 0 8px; align-self: end; height: 1px; }
  .indice-item .pg { color: var(--gold-dark); font-family: 'Cinzel', serif; }
  .indice-section { font-family: 'Cinzel', serif; font-weight: 500; font-size: 10px; letter-spacing: 0.35em; color: var(--bordeaux-deep); text-transform: uppercase; margin: 12px 0 4px; padding-bottom: 4px; border-bottom: 1px solid var(--gold-dark); text-align: center; }

  .page .cita { font-family: 'Great Vibes', cursive; font-size: 40px; line-height: 1.2; color: var(--bordeaux-deep); text-align: center; padding: 16px 14px; font-weight: 400; }
  .page.dark .cita, .page.deep-bordeaux .cita { color: var(--cream); font-size: 50px; text-shadow: 0 0 32px rgba(196,106,106,0.30); }

  .foto-circle { width: 150px; height: 150px; border-radius: 50%; margin: 14px auto; overflow: hidden; border: 3px solid var(--gold); box-shadow: 0 8px 30px rgba(0,0,0,0.5), 0 0 30px rgba(196,106,106,0.20); display: block; }
  .foto-circle img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .foto-rounded { width: 220px; height: 150px; border-radius: 16px; margin: 14px auto; overflow: hidden; border: 1px solid var(--gold); box-shadow: 0 6px 26px rgba(0,0,0,0.4); display: block; }
  .foto-rounded img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .foto-arch { width: 150px; height: 200px; border-radius: 75px 75px 6px 6px; margin: 14px auto; overflow: hidden; border: 2px solid var(--gold); box-shadow: 0 10px 32px rgba(0,0,0,0.5), 0 0 30px rgba(196,106,106,0.20); display: block; }
  .foto-arch img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .foto-caption { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9px; letter-spacing: 0.35em; color: var(--gold-dark); text-transform: uppercase; margin-top: 8px; text-align: center; }

  .consejo-card { background: var(--cream-light); border: 1px solid var(--gold); border-radius: 6px; padding: 12px 14px; margin: 8px auto; text-align: center; max-width: 360px; }
  .consejo-card .titulo { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.3em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 5px; }
  .consejo-card p { font-family: var(--font-info); font-size: 13.5px; margin: 0 auto; line-height: 1.5; max-width: none; }
  .consejo-card.warning { border-color: #c47844; background: #fef0e0; }
  .consejo-card.warning .titulo { color: #a85e2c; }
  .consejo-card.bordeaux { border-color: var(--bordeaux-medium); background: linear-gradient(180deg, var(--bordeaux-blush) 0%, var(--cream-light) 100%); }
  .consejo-card.bordeaux .titulo { color: var(--bordeaux-deep); }

  .dia-item { padding: 6px 8px; border-bottom: 1px solid var(--line-gold); text-align: center; max-width: 360px; margin: 0 auto; }
  .dia-item:last-child { border-bottom: none; }
  .dia-item .num { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; letter-spacing: 0.3em; color: var(--gold-dark); }
  .dia-item .titulo { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; letter-spacing: 0.2em; color: var(--brown-deep); }
  .dia-item .desc { font-family: var(--font-info); font-size: 12.5px; color: var(--brown-soft); line-height: 1.5; margin-top: 2px; }

  .compendio-tabla { font-size: 11px; max-width: 380px; margin: 0 auto; }
  .compendio-row { display: flex; padding: 7px 0; border-bottom: 1px solid var(--line-gold); align-items: baseline; text-align: left; }
  .compendio-row:last-child { border-bottom: none; }
  .compendio-row .nombre { flex: 0 0 110px; color: var(--bordeaux-deep); letter-spacing: 0.18em; text-transform: uppercase; font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; }
  .compendio-row .uso { flex: 1; color: var(--brown-soft); font-family: var(--font-info); font-size: 12.5px; }

  .faq { margin: 8px auto; padding-bottom: 8px; border-bottom: 1px dotted var(--line-bordeaux); text-align: center; max-width: 380px; }
  .faq:last-child { border-bottom: none; }
  .faq .pregunta { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.2em; color: var(--bordeaux-deep); text-transform: uppercase; margin-bottom: 5px; }
  .faq .respuesta { font-family: var(--font-info); font-size: 12.5px; color: var(--brown-soft); line-height: 1.55; margin: 0 auto; }

  .ser-card { background: linear-gradient(160deg, var(--bordeaux-blush) 0%, var(--bordeaux-pastel) 100%); border: 2px solid var(--gold); border-radius: 10px; padding: 16px 18px; margin: 10px auto; max-width: 380px; box-shadow: 0 6px 18px rgba(90,29,29,0.20); }
  .ser-card .ser-nombre { font-family: 'Great Vibes', cursive; font-size: 40px; color: var(--bordeaux-deep); margin: 0 0 4px; line-height: 1; }
  .ser-card .ser-energia { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.4em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 8px; }
  .ser-card .ser-detalle { font-family: var(--font-info); font-size: 12.5px; color: var(--brown-soft); line-height: 1.55; margin: 0 auto 8px; text-align: center; }
  .ser-card .ser-meta { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; margin-top: 8px; }
  .ser-card .ser-meta span { font-family: 'Cinzel', serif; font-size: 8.5px; letter-spacing: 0.2em; color: var(--gold-dark); text-transform: uppercase; padding: 3px 8px; border: 1px solid var(--gold-dark); border-radius: 100px; background: rgba(255,255,255,0.4); }

  .neuro-tag { display: inline-block; margin-top: 6px; padding: 4px 10px; background: var(--bordeaux-deep); color: var(--cream); font-family: 'Cinzel', serif; font-size: 8.5px; letter-spacing: 0.3em; text-transform: uppercase; border-radius: 4px; }
  .page.dark .neuro-tag, .page.deep-bordeaux .neuro-tag { background: var(--gold); color: var(--black-deep); }

  .otra-especie-card { display: flex; flex-direction: column; align-items: center; background: linear-gradient(160deg, var(--cream-light) 0%, var(--bordeaux-blush) 100%); border: 1px solid var(--gold); border-radius: 10px; padding: 14px 16px; max-width: 380px; margin: 0 auto; box-shadow: 0 4px 18px rgba(90,29,29,0.15); }
  .otra-especie-card .otra-foto { width: 120px; height: 120px; border-radius: 50%; overflow: hidden; border: 2px solid var(--gold); margin-bottom: 8px; box-shadow: 0 4px 14px rgba(0,0,0,0.20); }
  .otra-especie-card .otra-foto img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .otra-especie-card .otra-foto.placeholder { background: linear-gradient(135deg, #2a0e0e, #100404); display: flex; align-items: center; justify-content: center; color: var(--gold); }
  .otra-especie-card .otra-nombre { font-family: 'Great Vibes', cursive; font-size: 32px; color: var(--bordeaux-deep); line-height: 1; margin: 4px 0 2px; }
  .otra-especie-card .otra-eyebrow { font-family: 'Cinzel', serif; font-size: 8.5px; letter-spacing: 0.4em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 6px; }
  .otra-especie-card .otra-deseo { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; font-size: 13px; color: var(--brown-deep); line-height: 1.5; margin: 4px auto 8px; max-width: 320px; }
  .otra-especie-card .otra-cta { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.35em; color: var(--bordeaux-deep); text-transform: uppercase; padding: 7px 14px; border: 1px solid var(--bordeaux-deep); border-radius: 100px; text-decoration: none; transition: all 0.3s; background: rgba(255,255,255,0.5); }
  .otra-especie-card .otra-cta:hover { background: var(--bordeaux-deep); color: var(--cream); }

  .cta-final { display: flex; flex-direction: column; gap: 10px; margin: 12px auto; max-width: 380px; }
  .cta-final-btn { display: block; padding: 14px 16px; background: var(--cream-light); border: 1px solid var(--gold); border-radius: 4px; text-decoration: none; color: var(--brown-deep); transition: all 0.3s; text-align: center; }
  .cta-final-btn:hover { background: var(--gold); color: var(--black-deep); }
  .cta-final-btn .cta-titulo { font-family: 'Cinzel', serif; font-weight: 500; font-size: 10px; letter-spacing: 0.3em; color: var(--bordeaux-deep); text-transform: uppercase; margin-bottom: 4px; }
