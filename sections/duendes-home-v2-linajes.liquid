{{ 'duendes-base.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign dh2_lin_tag = section.settings.tag | strip
  if dh2_lin_tag == blank
    assign dh2_lin_tag = 'duendes.home_v2.linajes.tag' | t
    if dh2_lin_tag contains 'translation missing'
      assign dh2_lin_tag = 'POR LINAJE'
    endif
  endif

  assign dh2_lin_title = section.settings.title | strip
  if dh2_lin_title == blank
    assign dh2_lin_title = 'duendes.home_v2.linajes.title' | t
    if dh2_lin_title contains 'translation missing'
      assign dh2_lin_title = 'Encontrá tu familia.'
    endif
  endif

  assign dh2_lin_sub = section.settings.subtitle | strip
  if dh2_lin_sub == blank
    assign dh2_lin_sub = 'duendes.home_v2.linajes.subtitle' | t
    if dh2_lin_sub contains 'translation missing'
      assign dh2_lin_sub = ''
    endif
  endif
-%}

<style>
  .dh2-lin {
    position: relative;
    background: #faf9f7;
    color: #15110d;
    padding: 22px 14px 6px;
  }
  .dh2-lin__head { text-align: center; margin: 0 0 14px; }
  .dh2-lin__tag {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 10px;
    letter-spacing: 0.26em;
    color: #8a7657;
    text-transform: uppercase;
    margin: 0 0 4px;
  }
  .dh2-lin__title {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-weight: 400;
    font-size: clamp(18px, 2.4vw, 26px);
    line-height: 1.18;
    color: #15110d;
    margin: 0 0 4px;
  }
  .dh2-lin__sub {
    font-family: var(--font-body--family, 'Cormorant Garamond', Georgia, serif);
    font-style: italic;
    font-size: 13px;
    color: #6b5d4f;
    margin: 0;
  }

  /* Cada bloque de linaje */
  .dh2-lin__group { margin-bottom: 14px; }

  /* Banner horizontal del linaje */
  .dh2-lin__banner {
    position: relative;
    height: 86px;
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    display: block;
    background: #2a1810;
  }
  .dh2-lin__banner-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
  }
  .dh2-lin__banner-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(10, 8, 6, 0.78) 0%, rgba(10, 8, 6, 0.32) 100%);
  }
  .dh2-lin__banner-body {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 18px;
    height: 100%;
    color: #faf9f6;
  }
  .dh2-lin__banner-name {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-weight: 400;
    font-size: 16px;
    letter-spacing: 0.15em;
    margin: 0;
    color: #faf9f6;
  }
  .dh2-lin__banner-count {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: #c9a961;
    margin: 4px 0 0;
  }
  .dh2-lin__banner-chev {
    color: #c9a961;
    font-size: 22px;
    line-height: 1;
  }

  /* Modo Oportunidades — terracota */
  .dh2-lin__group--oferta .dh2-lin__banner {
    background: linear-gradient(90deg, #a85b1a 0%, #3a1c08 100%);
  }
  .dh2-lin__group--oferta .dh2-lin__banner-img { opacity: 0.32; mix-blend-mode: multiply; }
  .dh2-lin__group--oferta .dh2-lin__banner-veil { background: linear-gradient(90deg, rgba(168, 91, 26, 0.55) 0%, rgba(58, 28, 8, 0.4) 100%); }
  .dh2-lin__group--oferta .dh2-lin__banner-count { color: #ffe6b0; }
  .dh2-lin__group--oferta .dh2-lin__banner-chev {
    background: #fff;
    color: #a85b1a;
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 11px;
    letter-spacing: 0.12em;
    padding: 4px 10px;
    border-radius: 2px;
  }

  /* Modo Vacío — apagado */
  .dh2-lin__group--empty .dh2-lin__banner { filter: grayscale(0.55) brightness(0.85); }
  .dh2-lin__group--empty .dh2-lin__banner-count { color: rgba(201, 169, 97, 0.7); }

  /* Carrusel de productos por familia */
  .dh2-lin__rail {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    overflow-y: visible;
    padding: 8px 0 4px;
    margin: 0;
    width: 100%;
    box-sizing: border-box;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-x pan-y;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }
  .dh2-lin__rail::-webkit-scrollbar { display: none; }

  .dh2-lin__pcard {
    flex: 0 0 38%;
    max-width: 168px;
    background: #fff;
    border: 0.5px solid rgba(0, 0, 0, 0.08);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: #15110d;
    scroll-snap-align: start;
    position: relative;
  }
  .dh2-lin__pcard-img {
    width: 100%;
    aspect-ratio: 3 / 4;
    background: linear-gradient(180deg, #3a2820, #1a0f08);
    object-fit: cover;
    display: block;
  }
  .dh2-lin__pcard-info {
    padding: 7px 9px;
    font-family: var(--font-heading--family, 'Cinzel', serif);
  }
  .dh2-lin__pcard-name {
    font-size: 12px;
    color: #15110d;
    margin: 0 0 2px;
    font-weight: 400;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .dh2-lin__pcard-price {
    font-size: 10px;
    color: #6b5d4f;
    margin: 0;
  }
  .dh2-lin__pcard-price s { color: #b5ab9c; margin-right: 4px; }
  .dh2-lin__pcard-price .now-oferta { color: #a85b1a; font-weight: 500; }
  .dh2-lin__pcard-discount {
    position: absolute;
    top: 6px;
    right: 6px;
    background: #a85b1a;
    color: #fff;
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 9px;
    letter-spacing: 0.08em;
    padding: 2px 6px;
    border-radius: 2px;
    z-index: 2;
  }

  /* Última card: VER TODAS */
  .dh2-lin__see-all {
    flex: 0 0 38%;
    max-width: 168px;
    background: #15110d;
    border-radius: 6px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 22px 8px;
    color: #c9a961;
    border: 0.5px solid rgba(201, 169, 97, 0.4);
    aspect-ratio: 3 / 4;
    scroll-snap-align: start;
    font-family: var(--font-heading--family, 'Cinzel', serif);
    text-align: center;
  }
  .dh2-lin__see-all-star {
    font-size: 24px;
    line-height: 1;
    margin-bottom: 10px;
  }
  .dh2-lin__see-all-lbl {
    font-size: 10px;
    letter-spacing: 0.22em;
    margin: 0;
  }
  .dh2-lin__see-all-qty {
    font-family: var(--font-body--family, 'Cormorant Garamond', Georgia, serif);
    font-style: italic;
    font-size: 10px;
    color: rgba(244, 241, 236, 0.6);
    margin: 4px 0 0;
  }
  .dh2-lin__group--oferta .dh2-lin__see-all {
    background: #a85b1a;
    border-color: rgba(255, 255, 255, 0.3);
    color: #fff;
  }
  .dh2-lin__group--oferta .dh2-lin__see-all-qty { color: rgba(255, 255, 255, 0.7); }

  /* Estado vacío */
  .dh2-lin__empty {
    background: rgba(21, 17, 13, 0.04);
    border: 0.5px dashed rgba(21, 17, 13, 0.18);
    border-radius: 6px;
    padding: 18px 16px;
    text-align: center;
    margin: 8px 0 0;
  }
  .dh2-lin__empty-msg {
    font-family: var(--font-body--family, 'Cormorant Garamond', Georgia, serif);
    font-style: italic;
    font-size: 13px;
    color: #6b5d4f;
    margin: 0 0 4px;
    line-height: 1.4;
  }
  .dh2-lin__empty-tag {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 11px;
    color: #a88b42;
    letter-spacing: 0.18em;
    margin: 0;
  }

  /* Desktop */
  @media (min-width: 769px) {
    .dh2-lin { padding: 36px 24px; }
    .dh2-lin__inner { max-width: 1080px; margin: 0 auto; }
    .dh2-lin__banner { height: 96px; }
    .dh2-lin__banner-name { font-size: 18px; }
    .dh2-lin__pcard, .dh2-lin__see-all { flex: 0 0 22%; max-width: 220px; }
  }
</style>

<section class="dh2-lin section">
  <div class="dh2-lin__inner">
    <header class="dh2-lin__head">
      <p class="dh2-lin__tag">{{ dh2_lin_tag }}</p>
      <h2 class="dh2-lin__title">{{ dh2_lin_title }}</h2>
      {% if dh2_lin_sub != blank %}<p class="dh2-lin__sub">{{ dh2_lin_sub }}</p>{% endif %}
    </header>

    {% for block in section.blocks %}
      {%- liquid
        assign _url = block.settings.url | default: '' | strip
        assign _handle = ''
        if _url contains 'shopify://collections/'
          assign _handle = _url | remove: 'shopify://collections/' | split: '/' | first | split: '?' | first
        elsif _url contains '/collections/'
          assign _tail = _url | split: '/collections/' | last
          assign _handle = _tail | split: '/' | first | split: '?' | first
        endif
        assign _col = collections[_handle]
        assign _count = 0
        if _col != blank
          assign _count = _col.products_count | default: _col.all_products_count
        endif
        assign _photo = block.settings.image
        if _photo == blank and _col != blank and _col.featured_image != blank
          assign _photo = _col.featured_image
        endif
        if _photo == blank and _col != blank
          for _p in _col.products limit: 5
            if _p.featured_image != blank
              assign _photo = _p.featured_image
              break
            endif
          endfor
        endif
        assign _mode = block.settings.mode | default: 'normal'
        assign _empty_msg = block.settings.empty_msg | default: 'Todos fueron adoptados por ahora.'
        assign _empty_tag = block.settings.empty_tag | default: 'VUELVEN PRONTO ✦'
        assign _is_empty = false
        if _count == 0
          assign _is_empty = true
        endif

        assign _public_url = '/collections/'
        if _handle != blank
          assign _public_url = '/collections/' | append: _handle
        endif

        assign _group_cls = 'dh2-lin__group'
        if _mode == 'oferta'
          assign _group_cls = _group_cls | append: ' dh2-lin__group--oferta'
        endif
        if _is_empty
          assign _group_cls = _group_cls | append: ' dh2-lin__group--empty'
        endif
      -%}

      <div class="{{ _group_cls }}" {{ block.shopify_attributes }}>
        <a class="dh2-lin__banner" href="{{ _public_url }}" aria-label="{{ block.settings.title }}">
          {% if _photo != blank %}
            <img class="dh2-lin__banner-img" src="{{ _photo | image_url: width: 800 }}" alt="" loading="lazy">
          {% endif %}
          <div class="dh2-lin__banner-veil"></div>
          <div class="dh2-lin__banner-body">
            <div>
              <p class="dh2-lin__banner-name">{{ block.settings.title }}</p>
              <p class="dh2-lin__banner-count">
                {%- if _is_empty -%}
                  EN ESPERA
                {%- elsif _mode == 'oferta' -%}
                  {{ _count }} CON DESCUENTO
                {%- else -%}
                  {{ _count }} EN EL BOSQUE
                {%- endif -%}
              </p>
            </div>
            <span class="dh2-lin__banner-chev" aria-hidden="true">
              {%- if _mode == 'oferta' and block.settings.discount_label != blank -%}
                {{ block.settings.discount_label }}
              {%- elsif _is_empty -%}
                ✦
              {%- else -%}
                ›
              {%- endif -%}
            </span>
          </div>
        </a>

        {% if _is_empty %}
          <div class="dh2-lin__empty">
            <p class="dh2-lin__empty-msg">{{ _empty_msg }}</p>
            <p class="dh2-lin__empty-tag">{{ _empty_tag }}</p>
          </div>
        {% else %}
          <div class="dh2-lin__rail" role="list">
            {% for product in _col.products limit: 4 %}
              <a class="dh2-lin__pcard" href="{{ product.url }}" role="listitem">
                {% if _mode == 'oferta' and product.compare_at_price > product.price %}
                  {%- assign _disc = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round -%}
                  <span class="dh2-lin__pcard-discount">−{{ _disc }}%</span>
                {% endif %}
                {% if product.featured_image != blank %}
                  <img class="dh2-lin__pcard-img" src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" loading="lazy">
                {% else %}
                  <div class="dh2-lin__pcard-img"></div>
                {% endif %}
                <div class="dh2-lin__pcard-info">
                  <p class="dh2-lin__pcard-name">{{ product.title | escape }}</p>
                  <p class="dh2-lin__pcard-price">
                    {% if _mode == 'oferta' and product.compare_at_price > product.price %}
                      <s>{{ product.compare_at_price | money }}</s><span class="now-oferta">{{ product.price | money }}</span>
                    {% else %}
                      {{ product.price | money }}
                    {% endif %}
                  </p>
                </div>
              </a>
            {% endfor %}
            <a class="dh2-lin__see-all" href="{{ _public_url }}">
              <span class="dh2-lin__see-all-star">✦</span>
              <p class="dh2-lin__see-all-lbl">VER TODAS</p>
              <p class="dh2-lin__see-all-qty">{{ _count }} {{ block.settings.title | downcase }}</p>
            </a>
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "DDU v2 · Linajes",
  "tag": "section",
  "class": "duendes-home-v2-linajes-section",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "tag", "label": "Etiqueta superior", "default": "POR LINAJE" },
    { "type": "text", "id": "title", "label": "Título", "default": "Encontrá tu familia." },
    { "type": "textarea", "id": "subtitle", "label": "Subtítulo (opcional)", "default": "" }
  ],
  "blocks": [
    {
      "type": "linaje",
      "name": "Familia",
      "settings": [
        { "type": "text", "id": "title", "label": "Nombre de la familia", "default": "HADAS" },
        { "type": "url", "id": "url", "label": "Colección" },
        { "type": "image_picker", "id": "image", "label": "Foto del banner (opcional · sino usa imagen destacada de la colección)" },
        {
          "type": "select",
          "id": "mode",
          "label": "Modo",
          "default": "normal",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "oferta", "label": "Oportunidades (con descuento)" }
          ]
        },
        { "type": "text", "id": "discount_label", "label": "Etiqueta de descuento (solo modo oferta)", "default": "−25%" },
        { "type": "text", "id": "empty_msg", "label": "Mensaje si está vacía", "default": "Todos fueron adoptados por ahora." },
        { "type": "text", "id": "empty_tag", "label": "Cierre cuando está vacía", "default": "VUELVEN PRONTO ✦" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DDU v2 · Linajes",
      "blocks": [
        { "type": "linaje", "settings": { "title": "HADAS", "url": "shopify://collections/hadas", "mode": "normal" } },
        { "type": "linaje", "settings": { "title": "DUENDES", "url": "shopify://collections/duendes-todos", "mode": "normal" } },
        { "type": "linaje", "settings": { "title": "PIXIES", "url": "shopify://collections/pixies", "mode": "normal" } },
        { "type": "linaje", "settings": { "title": "BRUJAS", "url": "shopify://collections/brujas", "mode": "normal" } },
        { "type": "linaje", "settings": { "title": "GUARDIANES MAYORES", "url": "shopify://collections/guardianes-mayores", "mode": "normal" } },
        { "type": "linaje", "settings": { "title": "OPORTUNIDADES MÁGICAS", "url": "shopify://collections/oportunidades-magicas", "mode": "oferta", "discount_label": "−25%" } },
        { "type": "linaje", "settings": { "title": "ACCESORIOS", "url": "shopify://collections/accesorios", "mode": "normal" } }
      ]
    }
  ]
}
{% endschema %}
