{{ 'duendes-base.css' | asset_url | stylesheet_tag }}
<style>
.dsp-toast{position:fixed;bottom:24px;left:24px;z-index:999;pointer-events:none}
.dsp-card{display:flex;align-items:center;gap:12px;padding:12px 18px 12px 14px;background:rgba(8,10,6,.92);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(198,165,90,.15);border-radius:14px;box-shadow:0 8px 32px rgba(0,0,0,.4),0 0 0 1px rgba(198,165,90,.05);transform:translateX(-120%);opacity:0;transition:transform .6s cubic-bezier(.16,1,.3,1),opacity .4s;max-width:340px;pointer-events:auto}
.dsp-card.show{transform:translateX(0);opacity:1}
.dsp-card.hide{transform:translateX(-120%);opacity:0}
.dsp-avatar{width:40px;height:40px;border-radius:50%;overflow:hidden;flex-shrink:0;border:1.5px solid var(--gold, #C6A55A);position:relative;background:linear-gradient(135deg,rgba(198,165,90,.2),rgba(74,93,58,.15))}
.dsp-avatar img{width:100%;height:100%;object-fit:cover}
.dsp-avatar-fallback{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:16px}
.dsp-info{flex:1;min-width:0}
.dsp-name{font-family:var(--serif, Georgia);font-size:13px;color:#fff;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.dsp-name span{color:var(--gold-lt, #D6BD7B);font-weight:400;font-style:italic}
.dsp-meta{font-family:var(--serif, Georgia);font-size:11px;color:rgba(255,255,255,.75);margin-top:2px;display:flex;align-items:center;gap:6px}
.dsp-dot{width:5px;height:5px;border-radius:50%;background:var(--gold, #C6A55A);animation:dspPulse 2s infinite}
@keyframes dspPulse{0%,100%{opacity:.4;transform:scale(1)}50%{opacity:1;transform:scale(1.3)}}
.dsp-verified{display:inline-flex;align-items:center;gap:3px;font-size:10px;color:var(--gold, #C6A55A);letter-spacing:.5px}
.dsp-close{position:absolute;top:6px;right:8px;width:16px;height:16px;border:none;background:transparent;color:rgba(255,255,255,.25);cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center;border-radius:50%;transition:all .2s}
.dsp-close:hover{color:rgba(255,255,255,.6);background:rgba(255,255,255,.05)}
@media(max-width:768px){.dsp-toast{bottom:80px;left:12px;right:12px}.dsp-card{max-width:100%}}
</style>

<div class="dsp-toast" id="dspToast">
  <div class="dsp-card" id="dspCard" style="position:relative">
    <div class="dsp-avatar"><div class="dsp-avatar-fallback" id="dspEmoji"></div></div>
    <div class="dsp-info">
      <div class="dsp-name" id="dspName"></div>
      <div class="dsp-meta">
        <span class="dsp-dot"></span>
        <span id="dspTime"></span>
        <span class="dsp-verified"> Verificado</span>
      </div>
    </div>
    <button class="dsp-close" id="dspClose"></button>
  </div>
</div>

<script>
(function(){
  var adoptions = [
    {name:'Valentina',loc:'Buenos Aires',guardian:'Cedric',type:'Guardián de la Intuición',time:'hace 2 horas',emoji:''},
    {name:'Camila',loc:'Santiago',guardian:'Mini Rowan',type:'Guardián de la Sabiduría',time:'hace 4 horas',emoji:''},
    {name:'Mariana',loc:'Bogotá',guardian:'Willow',type:'Guardiana del Amor',time:'hace 6 horas',emoji:''},
    {name:'Roberto',loc:'Ciudad de México',guardian:'Phoenix',type:'Guardián del Renacimiento',time:'hace 8 horas',emoji:''},
    {name:'Lucía',loc:'Madrid',guardian:'Mini Sage',type:'Guardián del Consuelo',time:'hace 11 horas',emoji:''},
    {name:'Diego',loc:'Lima',guardian:'Thorne',type:'Guardián de los Límites',time:'hace 14 horas',emoji:''},
    {name:'Andrea',loc:'Montevideo',guardian:'Hazel',type:'Guardiana de la Claridad',time:'hace 1 día',emoji:''},
    {name:'Fernando',loc:'São Paulo',guardian:'Sterling',type:'Guardián de la Verdad',time:'hace 1 día',emoji:''},
    {name:'Sofía',loc:'Barcelona',guardian:'Mini Ember',type:'Guardián del Coraje',time:'hace 2 días',emoji:''},
    {name:'Tomás',loc:'Córdoba',guardian:'Grove',type:'Guardián del Hogar',time:'hace 2 días',emoji:''},
    {name:'Ana',loc:'Quito',guardian:'Linden',type:'Guardiana de Nuevos Comienzos',time:'hace 3 días',emoji:''},
    {name:'Matías',loc:'Punta del Este',guardian:'Mini Birch',type:'Guardiana del Equilibrio',time:'hace 3 días',emoji:''}
  ];
  var toast=document.getElementById('dspToast');
  var card=document.getElementById('dspCard');
  var nameEl=document.getElementById('dspName');
  var timeEl=document.getElementById('dspTime');
  var emojiEl=document.getElementById('dspEmoji');
  var closeBtn=document.getElementById('dspClose');
  var idx=Math.floor(Math.random()*adoptions.length);
  var paused=false;
  var timer;

  function show(){
    if(paused)return;
    var a=adoptions[idx%adoptions.length];
    nameEl.innerHTML=a.name+' de '+a.loc+' adoptó a <span>'+a.guardian+'</span>';
    timeEl.textContent=a.time;
    emojiEl.textContent=a.emoji;
    card.classList.remove('hide');
    card.classList.add('show');
    idx++;
    timer=setTimeout(function(){
      card.classList.remove('show');
      card.classList.add('hide');
      timer=setTimeout(show,12000+Math.random()*8000);
    },5500);
  }

  closeBtn.addEventListener('click',function(e){
    e.stopPropagation();
    card.classList.remove('show');
    card.classList.add('hide');
    paused=true;
    clearTimeout(timer);
    setTimeout(function(){paused=false;timer=setTimeout(show,25000)},30000);
  });

  /* Start after 6s delay */
  setTimeout(show,6000);
})();
</script>

