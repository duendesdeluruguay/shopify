/**
 * mmRenderRitualSection(state, answers, archetype, guardianName)
 * Render the appropriate section based on ritual state
 * States:
 *   - not_filled: Show CTA "Abrir el rito"
 *   - in_progress | review: Show sealed pergamino with answers
 *   - published: Show ritual link + pergamino toggle
 */
function mmRenderRitualSection(state, answers, archetype, guardianName, orderContext) {
  var html = '';
  // orderContext = { email, orderId, store, arquetipo } — passed from caller

  if (state === 'not_filled') {
    // Estado A: No completó el ritual — mostrar CTA
    var ritoParams = '?guardian=' + encodeURIComponent(guardianName || '');
    if (orderContext) {
      if (orderContext.email) ritoParams += '&email=' + encodeURIComponent(orderContext.email);
      if (orderContext.orderId) ritoParams += '&orderId=' + encodeURIComponent(orderContext.orderId);
      if (orderContext.store) ritoParams += '&store=' + encodeURIComponent(orderContext.store);
      if (orderContext.arquetipo) ritoParams += '&arquetipo=' + encodeURIComponent(orderContext.arquetipo);
    }
    html += '<div class="mm-ritual-cta">';
    html += '<div class="mm-ritual-cta-inner">';
    html += '<div class="mm-ritual-cta-icon">✦</div>';
    html += '<h3 class="mm-ritual-cta-title">Cruzá el Portal</h3>';
    html += '<p class="mm-ritual-cta-text">Completá el Rito de Reconocimiento. Tu guardián necesita conocerte desde adentro.</p>';
    html += '<a href="/pages/rito-reconocimiento' + ritoParams + '" class="mm-ritual-cta-btn">Abrir el rito</a>';
    html += '</div>';
    html += '</div>';

  } else if (state === 'in_progress' || state === 'review') {
    // Estado B: Ritual completado, canalización en proceso — mostrar pergamino sellado
    html += '<div class="mm-ritual-pergamino">';
    html += '<div class="mm-ritual-pergamino-header">';
    html += '<div class="mm-ritual-pergamino-seal">✦</div>';
    html += '<h3 class="mm-ritual-pergamino-title">Tu ritual, sellado</h3>';
    html += '<p class="mm-ritual-pergamino-subtitle">Intocable</p>';
    html += '</div>';
    html += '<p class="mm-ritual-pergamino-status">Gabriel y Thibisay están canalizando a <strong>' + mmFixEncoding(guardianName) + '</strong>. Mientras tanto, podés releer lo que dijiste.</p>';

    // Render the accordion/expandable ritual answers
    html += mmRenderRitualAnswersSection(answers, archetype);

    html += '</div>';

  } else if (state === 'published') {
    // Estado C: Canalización publicada — agregar link sutil al ritual
    html += '<div class="mm-ritual-published-link">';
    html += '<p><a href="#" onclick="mmToggleRitualAnswers(event)">Ver mi Rito (las respuestas que dejé)</a></p>';
    html += '</div>';
    html += '<div id="mm-ritual-answers-section" style="display:none;">';
    html += mmRenderRitualAnswersSection(answers, archetype);
    html += '</div>';
  }

  return html;
}

/**
 * mmRenderRitualAnswersSection(answers, archetype)
 * Render the ritual answers in a pergamino-style accordion
 * Supports both new (JSON structured) and legacy (flat) formats
 */
function mmRenderRitualAnswersSection(answers, archetype) {
  if (!answers) return '';

  var html = '<div class="mm-ritual-answers">';

  // Parse answers if it's a string
  var parsedAnswers = answers;
  if (typeof answers === 'string') {
    try {
      parsedAnswers = JSON.parse(answers);
    } catch(e) {
      // Legacy format: flat object with individual answer keys
      parsedAnswers = answers;
    }
  }

  // Detect structure: new (layer1, layer2) vs legacy (answer_1, answer_2, etc.)
  var isNewFormat = parsedAnswers && (parsedAnswers.layer1 || parsedAnswers.capa1);

  if (isNewFormat) {
    // New format with layers
    var layer1 = parsedAnswers.layer1 || parsedAnswers.capa1 || {};
    var layer2 = parsedAnswers.layer2 || parsedAnswers.capa2 || {};

    // Layer 1: Firma Energética
    html += '<div class="mm-ritual-layer">';
    html += '<div class="mm-ritual-layer-title">Firma Energética</div>';
    html += '<div class="mm-ritual-questions">';

    // Q1: Cuerpo Anclaje
    if (layer1.cuerpo_anclaje || layer1.q1) {
      html += '<div class="mm-ritual-q">';
      html += '<div class="mm-ritual-q-label">Cuerpo Anclaje</div>';
      html += '<div class="mm-ritual-q-text">¿Dónde sentís que vive la energía ahora mismo?</div>';
      html += '<div class="mm-ritual-answer">' + mmFixEncoding(layer1.cuerpo_anclaje || layer1.q1) + '</div>';
      html += '</div>';
    }

    // Q2: Necesidad Silenciosa
    if (layer1.necesidad_silenciosa || layer1.q2) {
      html += '<div class="mm-ritual-q">';
      html += '<div class="mm-ritual-q-label">Necesidad Silenciosa</div>';
      html += '<div class="mm-ritual-q-text">Hay algo que no le pedís a nadie. ¿Qué es?</div>';
      html += '<div class="mm-ritual-answer">' + mmFixEncoding(layer1.necesidad_silenciosa || layer1.q2) + '</div>';
      html += '</div>';
    }

    // Q3: Momento de Quiebre
    if (layer1.momento_quiebre || layer1.q3) {
      html += '<div class="mm-ritual-q">';
      html += '<div class="mm-ritual-q-label">Momento de Quiebre</div>';
      html += '<div class="mm-ritual-q-text">Hace poco pasó algo que cambió cómo ves una parte de tu vida. ¿Qué fue?</div>';
      html += '<div class="mm-ritual-answer">' + mmFixEncoding(layer1.momento_quiebre || layer1.q3) + '</div>';
      html += '</div>';
    }

    // Q4: Dirección de la Brújula
    if (layer1.direccion_brujula || layer1.q4) {
      html += '<div class="mm-ritual-q">';
      html += '<div class="mm-ritual-q-label">Dirección de la Brújula</div>';
      html += '<div class="mm-ritual-q-text">Si en 7 días te despertás y algo cambió, ¿qué cambió?</div>';
      html += '<div class="mm-ritual-answer">' + mmFixEncoding(layer1.direccion_brujula || layer1.q4) + '</div>';
      html += '</div>';
    }

    html += '</div>';
    html += '</div>';

    // Layer 2: Vibración del Arquetipo (if exists)
    if (Object.keys(layer2).length > 0) {
      html += '<div class="mm-ritual-layer">';
      html += '<div class="mm-ritual-layer-title">Vibración del ' + (archetype ? mmFixEncoding(archetype) : 'Arquetipo') + '</div>';
      html += '<div class="mm-ritual-questions">';

      // Q1-Q3 of layer 2
      for (var i = 1; i <= 3; i++) {
        var key = 'q' + i;
        if (layer2[key]) {
          html += '<div class="mm-ritual-q">';
          html += '<div class="mm-ritual-q-label">Pregunta ' + i + '</div>';
          html += '<div class="mm-ritual-answer">' + mmFixEncoding(layer2[key]) + '</div>';
          html += '</div>';
        }
      }

      html += '</div>';
      html += '</div>';
    }

    // Personal message (if exists)
    if (layer1.mensaje_personal || layer2.mensaje_personal || parsedAnswers.mensaje_personal) {
      html += '<div class="mm-ritual-personal-message">';
      html += '<div class="mm-ritual-pm-title">Mensaje privado al guardián</div>';
      html += '<div class="mm-ritual-pm-text">' + mmFixEncoding(layer1.mensaje_personal || layer2.mensaje_personal || parsedAnswers.mensaje_personal) + '</div>';
      html += '</div>';
    }

  } else {
    // Legacy format: flat keys (answer_1, answer_2, etc. or similar)
    html += '<div class="mm-ritual-legacy">';
    html += '<p class="mm-ritual-legacy-intro">Tus respuestas del Rito:</p>';
    for (var key in parsedAnswers) {
      if (parsedAnswers.hasOwnProperty(key) && parsedAnswers[key]) {
        html += '<div class="mm-ritual-q">';
        html += '<div class="mm-ritual-q-label">' + key.replace(/_/g, ' ') + '</div>';
        html += '<div class="mm-ritual-answer">' + mmFixEncoding(parsedAnswers[key]) + '</div>';
        html += '</div>';
      }
    }
    html += '</div>';
  }

  html += '</div>';
  return html;
}

/**
 * mmToggleRitualAnswers(event)
 * Toggle visibility of ritual answers section
 */
function mmToggleRitualAnswers(event) {
  event.preventDefault();
  var section = document.getElementById('mm-ritual-answers-section');
  if (section) {
    section.style.display = section.style.display === 'none' ? 'block' : 'none';
  }
}

document.addEventListener('DOMContentLoaded', async function() {
  // 1) Magic link has top priority (gift receivers)
  const magic = await mmTryMagicLink();
  if (magic) return;
  // 2) Fall back to saved session (with re-verification)
  try {
    const saved = localStorage.getItem('mm-session');
    if (saved) {
      const parsedSession = JSON.parse(saved);
      // Re-verify the session email against backend (real-time Shopify check)
      try {
        const url = GAS_URL + '?action=get_customer_data&email=' + encodeURIComponent(parsedSession.email);
        const response = await fetch(url, { redirect: 'follow' });
        const text = await response.text();
        const data = JSON.parse(text);

        // Check if still authorized — use backend's authorized field
        const isAuthorized = data && (data.authorized === true || (data.success && data.channelings && data.channelings.length > 0));
        if (!isAuthorized) {
          // Session no longer valid — clear and show login
          localStorage.removeItem('mm-session');
          return;
        }
      } catch(e) {
        // Network error on verify — proceed with session anyway (graceful fallback)
      }

      mmCustomer = parsedSession;
      document.getElementById('mm-gate').classList.remove('active');
      document.getElementById('mm-header').style.display = 'flex';
      mmNav('dashboard');
      mmLoadData();
      mmSetDailyMessage();
      mmSetGuardianOfWeek();
      mmLoadDiary();
      mmStartAutoRefresh();
    }
  } catch(e) {}
});
</script>
<script>
// Magic Link Auto-Login v3 — Cowork 2026-04-27
// Lee mm_email + mm_sig de URL → autentica → guarda sesión → renderea dashboard real
(function() {
  try {
    var params = new URLSearchParams(window.location.search);
    var mmEmail = params.get('mm_email');
    var mmSig = params.get('mm_sig');

    // Si ya hay session en localStorage, no hacemos nada (la sesión normal se carga sola)
    var existing = null;
    try { existing = JSON.parse(localStorage.getItem('mm-session') || 'null'); } catch(e) {}

    if (mmEmail && mmSig) {
      console.log('[mm-magic-v3] Authenticating via magic link:', mmEmail);
      var session = { email: mmEmail, name: '', magic: true, sig: mmSig, ts: Date.now() };
      try { localStorage.setItem('mm-session', JSON.stringify(session)); } catch(e) {}

      // Limpiar URL (remover mm_email/mm_sig pero mantener welcome)
      var cleanUrl = window.location.pathname + (params.get('welcome') ? '?welcome=1' : '');
      try { window.history.replaceState({}, '', cleanUrl); } catch(e) {}

      // Forzar carga del flujo de dashboard
      function bootMagicSession() {
        if (typeof window.mmCustomer === 'undefined') return setTimeout(bootMagicSession, 100);
        window.mmCustomer = { email: mmEmail, name: '', authorized: true, magic: true };
        var gate = document.getElementById('mm-gate');
        if (gate) gate.classList.remove('active');
        var header = document.getElementById('mm-header');
        if (header) header.style.display = 'flex';
        if (typeof window.mmNav === 'function') window.mmNav('dashboard');
        if (typeof window.mmLoadData === 'function') window.mmLoadData();
        if (typeof window.mmSetDailyMessage === 'function') window.mmSetDailyMessage();
        if (typeof window.mmSetGuardianOfWeek === 'function') window.mmSetGuardianOfWeek();
        if (typeof window.mmStartAutoRefresh === 'function') window.mmStartAutoRefresh();
        console.log('[mm-magic-v3] Magic session active for', mmEmail);
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootMagicSession);
      } else {
        bootMagicSession();
      }
    } else if (existing && existing.email && existing.magic) {
      // Sesión persistida, restaurar
      function restore() {
        if (typeof window.mmCustomer === 'undefined') return setTimeout(restore, 100);
        window.mmCustomer = { email: existing.email, name: existing.name || '', authorized: true, magic: true };
        var gate = document.getElementById('mm-gate');
        if (gate) gate.classList.remove('active');
        var header = document.getElementById('mm-header');
        if (header) header.style.display = 'flex';
        if (typeof window.mmNav === 'function') window.mmNav('dashboard');
        if (typeof window.mmLoadData === 'function') window.mmLoadData();
        if (typeof window.mmSetDailyMessage === 'function') window.mmSetDailyMessage();
        if (typeof window.mmSetGuardianOfWeek === 'function') window.mmSetGuardianOfWeek();
        if (typeof window.mmStartAutoRefresh === 'function') window.mmStartAutoRefresh();
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', restore);
      } else {
        restore();
      }
    }
  } catch(e) { console.warn('[mm-magic-v3] error:', e); }
})();
</script>

<script>
// Bosque animado día/noche — Cowork 2026-04-27
(function() {
  function setForestMode() {
    var hero = document.querySelector('.mm-hero');
    if (!hero) return;
    
    // Crear divs de fondo si no existen
    if (!hero.querySelector('.mm-forest-bg.day')) {
      var dayBg = document.createElement('div');
      dayBg.className = 'mm-forest-bg day';
      hero.insertBefore(dayBg, hero.firstChild);
      
      var nightBg = document.createElement('div');
      nightBg.className = 'mm-forest-bg night';
      hero.insertBefore(nightBg, hero.firstChild);
      
      // Crear partículas
      var particlesDiv = document.createElement('div');
      particlesDiv.className = 'mm-forest-particles';
      for (var i = 0; i < 8; i++) {
        var p = document.createElement('div');
        p.className = 'mm-particle';
        p.style.left = (Math.random() * 100) + '%';
        p.style.animationDelay = (Math.random() * 12) + 's';
        p.style.animationDuration = (10 + Math.random() * 8) + 's';
        particlesDiv.appendChild(p);
      }
      hero.insertBefore(particlesDiv, hero.firstChild.nextSibling);
    }
    
    var hour = new Date().getHours();
    var isDay = hour >= 7 && hour < 19;
    
    var dayBg = hero.querySelector('.mm-forest-bg.day');
    var nightBg = hero.querySelector('.mm-forest-bg.night');
    if (isDay) {
      dayBg.classList.add('active');
      nightBg.classList.remove('active');
    } else {
      nightBg.classList.add('active');
      dayBg.classList.remove('active');
    }
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setForestMode);
  } else {
    setForestMode();
  }
  
  // Re-check cada 5 minutos por si cambia el horario
  setInterval(setForestMode, 5 * 60 * 1000);
})();
</script>











