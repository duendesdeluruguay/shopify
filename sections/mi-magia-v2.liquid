{% comment %}
  MI MAGIA v3 — Portal Post-Adopcion Cinematografico
  Duendes del Uruguay — Immersive Fantasy Portal
  Dashboard circular con fotos/iconos, Tu Identidad Elemental, El Oraculo Q&A
  Experiencia Tolkien meets luxury editorial — cada detalle transporta
{% endcomment %}

{% style %}
@import url('https://fonts.googleapis.com/css2?family=Tangerine:wght@400;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Lato:wght@300;400;700&display=swap');

* { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --white: #FFFFFF;
  --cream: #FEFDFB;
  --gold: #B8973B;
  --gold-soft: #D4BC7C;
  --gold-pale: rgba(184, 151, 59, 0.08);
  --black: #111111;
  --black-soft: #1A1A1A;
  --text: #1A1A1A;
  --text-mid: #555555;
  --text-light: #888888;
  --text-faint: #CCCCCC;
  --line: #E8E5DE;
  --line-dark: #2A2A2A;
  --red: #B85A5A;
  --deep: #FEFDFB;
  --surface: #F5F3EE;
  --surface-elevated: #FFFFFF;
}

body {
  font-family: 'Lato', sans-serif;
  background: var(--cream);
  color: var(--text);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ═══════ GOLD SHIMMER ANIMATION ═══════ */
@keyframes goldShimmer {
  0% { background-position: -200% center; }
  100% { background-position: 200% center; }
}
@keyframes subtleGlow {
  0%, 100% { filter: drop-shadow(0 0 4px rgba(184,151,59,0.3)); }
  50% { filter: drop-shadow(0 0 12px rgba(184,151,59,0.5)); }
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.mm-gold-shimmer {
  background: linear-gradient(105deg, var(--gold) 0%, #E8D48C 25%, var(--gold) 50%, #F0E2A0 75%, var(--gold) 100%);
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: goldShimmer 4s ease-in-out infinite;
}
.mm-gold-border-shimmer {
  position: relative;
}
.mm-gold-border-shimmer::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  border: 2px solid transparent;
  background: linear-gradient(105deg, var(--gold), #E8D48C, var(--gold), #F0E2A0, var(--gold)) border-box;
  background-size: 200% auto;
  -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  animation: goldShimmer 4s ease-in-out infinite;
  pointer-events: none;
}

/* Hide Shopify chrome */
.shopify-section-header, .shopify-section-footer,
.section-header, .section-footer,
header.header, footer.footer,
.shopify-section-group-header-group,
.shopify-section-group-footer-group,
.announcement-bar, .shopify-section-announcement-bar,
#shopify-section-announcement-bar { display: none !important; }
.shopify-section-group-body-content > .shopify-section:not(.shopify-section--template) { display: none !important; }

/* Kill Horizon spacing */
.shopify-section-group-body-content,
.shopify-section-group-footer-group,
.shopify-section-group-header-group,
#MainContent, main, .main-content,
.template-page .shopify-section,
.shopify-section--template,
.page-width, .content-for-layout {
  padding: 0 !important; margin: 0 !important;
  max-width: 100% !important;
}

#mi-magia-v2 {
  min-height: 100vh;
  position: relative;
  background: var(--cream);
}

/* ═══════════════════════════════════════
   NAVIGATION — Clean hamburger bar
   ═══════════════════════════════════════ */
.mm-nav-bar {
  position: fixed; top: 0; left: 0; right: 0;
  height: 56px;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--line);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 32px;
  z-index: 1000;
  transition: transform 0.3s ease;
}

.mm-nav-logo {
  font-family: 'Tangerine', cursive;
  font-size: 32px;
  font-weight: 700;
  color: var(--gold);
  cursor: pointer;
  flex-shrink: 0;
}

.mm-nav-right {
  display: flex; align-items: center; gap: 20px;
}

/* Notification bell */
.mm-nav-bell {
  position: relative;
  cursor: pointer;
  padding: 6px;
  transition: opacity 0.3s;
}
.mm-nav-bell:hover { opacity: 0.7; }
.mm-nav-bell svg { width: 20px; height: 20px; color: var(--text-mid); }
.mm-nav-bell-dot {
  display: none;
  position: absolute;
  top: 4px; right: 4px;
  width: 8px; height: 8px;
  background: var(--gold);
  border-radius: 50%;
  border: 2px solid #fff;
  animation: subtleGlow 2s ease-in-out infinite;
}
.mm-nav-bell-dot.active { display: block; }

/* Hamburger — always visible */
.mm-hamburger {
  cursor: pointer; padding: 8px;
  display: flex; flex-direction: column; gap: 4px;
  z-index: 1002;
}
.mm-hamburger span {
  display: block; width: 22px; height: 1.5px;
  background: var(--text); transition: all 0.3s;
}
.mm-hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(4px, 4px); }
.mm-hamburger.open span:nth-child(2) { opacity: 0; }
.mm-hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(4px, -4px); }

/* Slide-out menu panel */
.mm-menu-overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.3);
  z-index: 999;
  opacity: 0;
  transition: opacity 0.3s ease;
}
.mm-menu-overlay.open { display: block; opacity: 1; }

.mm-menu-panel {
  position: fixed; top: 0; right: -360px;
  width: 340px; max-width: 85vw;
  height: 100vh;
  background: var(--white);
  z-index: 1001;
  transition: right 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  overflow-y: auto;
  box-shadow: -8px 0 40px rgba(0,0,0,0.08);
}
.mm-menu-panel.open { right: 0; }

.mm-menu-header {
  padding: 24px 28px 20px;
  border-bottom: 1px solid var(--line);
}
.mm-menu-header-title {
  font-family: 'Tangerine', cursive;
  font-size: 36px;
  font-weight: 700;
  color: var(--gold);
}
.mm-menu-header-sub {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--text-light);
  margin-top: 2px;
}

.mm-menu-section {
  padding: 20px 28px 12px;
}
.mm-menu-section-title {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--text-light);
  margin-bottom: 16px;
}

.mm-menu-link {
  display: flex; align-items: center; gap: 14px;
  padding: 12px 0;
  font-family: 'Lato', sans-serif;
  font-size: 14px; font-weight: 400;
  color: var(--text);
  text-decoration: none;
  cursor: pointer;
  transition: color 0.2s;
  border-bottom: 1px solid rgba(0,0,0,0.04);
}
.mm-menu-link:hover { color: var(--gold); }
.mm-menu-link svg { width: 18px; height: 18px; color: var(--gold); flex-shrink: 0; opacity: 0.7; }

.mm-menu-link.mm-menu-tienda {
  margin-top: 8px;
  padding: 12px 20px;
  background: var(--black);
  color: var(--white);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  justify-content: center;
  border: none;
}
.mm-menu-link.mm-menu-tienda:hover { background: #333; color: var(--white); }
.mm-menu-link.mm-menu-tienda svg { color: var(--white); }

.mm-menu-footer {
  padding: 20px 28px;
  border-top: 1px solid var(--line);
  margin-top: 12px;
}
.mm-menu-logout {
  font-size: 12px;
  color: var(--text-faint);
  cursor: pointer;
  text-decoration: none;
  transition: color 0.3s;
}
.mm-menu-logout:hover { color: var(--red); }

/* ─── Notification Toast (side) ─── */
.mm-notif-toast {
  position: fixed;
  bottom: 32px; right: -420px;
  width: 360px; max-width: calc(100vw - 40px);
  background: var(--white);
  border: 1px solid var(--line);
  box-shadow: 0 12px 48px rgba(0,0,0,0.12), 0 0 0 1px rgba(184,151,59,0.08);
  z-index: 998;
  transition: right 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  overflow: hidden;
}
.mm-notif-toast.visible { right: 32px; }

.mm-notif-toast-accent {
  height: 3px;
  background: linear-gradient(90deg, var(--gold) 0%, #E8D48C 50%, var(--gold) 100%);
  background-size: 200% auto;
  animation: goldShimmer 3s ease-in-out infinite;
}
.mm-notif-toast-body {
  padding: 20px 24px;
}
.mm-notif-toast-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 10px;
}
.mm-notif-toast-label {
  font-size: 9px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--gold);
}
.mm-notif-toast-close {
  cursor: pointer;
  width: 24px; height: 24px;
  display: flex; align-items: center; justify-content: center;
  color: var(--text-faint);
  transition: color 0.2s;
  background: none; border: none; font-size: 16px;
}
.mm-notif-toast-close:hover { color: var(--text); }

.mm-notif-toast-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 17px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 6px;
}
.mm-notif-toast-text {
  font-size: 13px;
  color: var(--text-mid);
  line-height: 1.6;
  margin-bottom: 14px;
}
.mm-notif-toast-action {
  display: inline-block;
  font-size: 11px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--white);
  background: var(--black);
  padding: 10px 20px;
  text-decoration: none;
  transition: background 0.3s;
}
.mm-notif-toast-action:hover { background: #333; }

/* ─── Notification Panel (from bell) ─── */
.mm-notif-panel {
  position: fixed;
  top: 56px; right: -400px;
  width: 380px; max-width: 90vw;
  max-height: calc(100vh - 56px);
  background: var(--white);
  border-left: 1px solid var(--line);
  box-shadow: -8px 0 40px rgba(0,0,0,0.08);
  z-index: 997;
  overflow-y: auto;
  transition: right 0.35s cubic-bezier(0.22, 1, 0.36, 1);
}
.mm-notif-panel.open { right: 0; }

.mm-notif-panel-header {
  padding: 24px 24px 16px;
  border-bottom: 1px solid var(--line);
  font-size: 9px; font-weight: 700;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--text-light);
}

.mm-notif-item {
  padding: 20px 24px;
  border-bottom: 1px solid rgba(0,0,0,0.04);
  cursor: pointer;
  transition: background 0.2s;
}
.mm-notif-item:hover { background: var(--surface); }
.mm-notif-item-dot {
  display: inline-block;
  width: 6px; height: 6px;
  background: var(--gold);
  border-radius: 50%;
  margin-right: 8px;
  vertical-align: middle;
}
.mm-notif-item-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px; font-weight: 600;
  color: var(--text);
  margin-bottom: 4px;
}
.mm-notif-item-text {
  font-size: 12px; color: var(--text-mid);
  line-height: 1.5;
}
.mm-notif-item-time {
  font-size: 10px; color: var(--text-light);
  margin-top: 6px;
}

.mm-notif-empty {
  padding: 40px 24px;
  text-align: center;
  font-family: 'Cormorant Garamond', serif;
  font-size: 15px;
  font-style: italic;
  color: var(--text-light);
}
.mm-notif-footer {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 20px;
  border-top: 1px solid var(--line);
  font-size: 11px; color: var(--text-light);
}
.mm-refresh-btn {
  display: inline-flex; align-items: center; gap: 5px;
  background: none; border: 1px solid var(--line);
  padding: 5px 12px; border-radius: 16px;
  font-size: 11px; color: var(--text-mid);
  cursor: pointer; transition: all 0.2s;
  font-family: 'Cormorant Garamond', serif;
}
.mm-refresh-btn:hover { border-color: var(--gold); color: var(--gold); }
.mm-refresh-btn.refreshing { opacity: 0.6; pointer-events: none; }
.mm-refresh-icon { display: inline-block; width: 12px; height: 12px; }

/* ═══════════════════════════════════════
   GATE — Cinematic login
   ═══════════════════════════════════════ */
.mm-gate {
  display: none;
  min-height: 100vh;
  align-items: center; justify-content: center;
  background: var(--cream);
}
.mm-gate.active { display: flex; }

.mm-gate-inner {
  text-align: center;
  max-width: 380px; width: 100%;
  padding: 40px 24px;
}

.mm-gate-ornament {
  width: 32px; height: 32px;
  margin: 0 auto 40px;
  opacity: 0.6;
}

.mm-gate-title {
  font-family: 'Tangerine', cursive;
  font-size: 68px;
  font-weight: 700;
  color: var(--gold);
  line-height: 1;
  margin-bottom: 8px;
}

.mm-gate-sub {
  font-family: 'Cormorant Garamond', serif;
  font-size: 11px; font-weight: 600;
  letter-spacing: 5px; text-transform: uppercase;
  color: var(--text-light);
  margin-bottom: 48px;
}

.mm-gate-label {
  display: block; text-align: left;
  font-size: 9px; font-weight: 700;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--text-light);
  margin-bottom: 8px;
}

.mm-input {
  width: 100%;
  padding: 14px 0;
  border: none; border-bottom: 1px solid rgba(198,165,90,0.25);
  font-family: 'Lato', sans-serif;
  font-size: 15px; color: var(--text);
  background: transparent;
  outline: none;
  transition: border-color 0.3s;
}
.mm-input:focus { border-bottom-color: var(--gold); }
.mm-input::placeholder { color: var(--text-faint); }

.mm-btn-primary {
  width: 100%;
  padding: 16px;
  background: var(--black);
  color: #FFFFFF;
  border: none;
  font-family: 'Lato', sans-serif;
  font-size: 10px; font-weight: 700;
  letter-spacing: 4px; text-transform: uppercase;
  cursor: pointer;
  transition: all 0.4s;
  margin-top: 32px;
}
.mm-btn-primary:hover { background: #333; color: #FFFFFF; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(0,0,0,0.15); }

.mm-gate-hint {
  font-size: 12px; color: var(--text-faint);
  margin-top: 20px;
  font-style: italic;
}

/* ═══════════════════════════════════════
   LOGIN STATES — Loading, error, etc.
   ═══════════════════════════════════════ */
.mm-gate.mm-gate-loading .mm-gate-ornament {
  animation: mmSpinnerPulse 1.5s ease-in-out infinite;
}

@keyframes mmSpinnerPulse {
  0% { opacity: 0.4; }
  50% { opacity: 1; }
  100% { opacity: 0.4; }
}

.mm-gate-spinner {
  display: inline-block;
  width: 14px; height: 14px;
  margin-right: 8px;
  border: 2px solid transparent;
  border-radius: 50%;
  border-top-color: currentColor;
  animation: mmSpinnerRotate 0.8s linear infinite;
  vertical-align: middle;
}

@keyframes mmSpinnerRotate {
  to { transform: rotate(360deg); }
}

.mm-btn-primary:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.mm-gate-error-container {
  display: none;
  text-align: center;
  animation: mmFadeIn 0.4s ease;
}

.mm-gate-error-container.show {
  display: block;
}

@keyframes mmFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.mm-gate-error-ornament {
  width: 32px; height: 32px;
  margin: 0 auto 24px;
  padding: 16px;
  border-radius: 50%;
  background: rgba(198, 165, 90, 0.1);
}

.mm-gate-error-ornament svg {
  width: 100%;
  height: 100%;
}

.mm-gate-error-heading {
  font-family: 'Cormorant Garamond', serif;
  font-size: 24px;
  font-weight: 600;
  color: var(--gold);
  margin-bottom: 12px;
}

.mm-gate-error-text {
  font-family: 'Lato', sans-serif;
  font-size: 14px;
  color: var(--text-mid);
  line-height: 1.6;
  margin-bottom: 8px;
}

.mm-gate-error-subtext {
  font-size: 12px;
  color: var(--text-light);
  font-style: italic;
  margin-bottom: 24px;
}

.mm-gate-error-button {
  display: inline-block;
  padding: 12px 28px;
  background: var(--gold);
  color: var(--black);
  border: none;
  font-family: 'Lato', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.3s;
  margin-top: 8px;
}

.mm-gate-error-button:hover {
  background: var(--gold-soft);
  transform: translate(0, -2px);
}

/* ═══════════════════════════════════════
   SECTIONS — Editorial pages
   ═══════════════════════════════════════ */
.mm-page {
  display: none;
  padding-top: 56px;
