/**
 * Calculate how many days since the channeling started
 * Uses publishedDate (when the channeling was made available)
 * Returns 0-7+ (0 = same day, 7 = all revealed)
 */
function mmGetRevealDay(ch) {
  // Use channeling start date if available, otherwise published date
  var startDate = ch.revealStartDate || ch.publishedDate || ch.date;
  if (!startDate) return 99; // No date = show everything (safety fallback)
  var start = new Date(startDate);
  start.setHours(0, 0, 0, 0);
  var now = new Date();
  now.setHours(0, 0, 0, 0);
  var diff = Math.floor((now - start) / (1000 * 60 * 60 * 24));
  return Math.max(0, diff);
}

/**
 * Check if this channeling uses progressive reveal
 * Only new orders with sections JSON get progressive reveal
 * Old orders without sections show everything at once (backward compatible)
 */
function mmHasProgressiveReveal(ch) {
  if (!ch.sections) return false;
  try {
    var s = typeof ch.sections === 'string' ? JSON.parse(ch.sections) : ch.sections;
    return s && typeof s === 'object' && Object.keys(s).length > 0;
  } catch(e) { return false; }
}

// RENDER CHANNELINGS (with progressive reveal support)
function mmRenderChannelings(channelings) {
  const list = document.getElementById('mm-channelings-list');
  const empty = document.getElementById('mm-no-channelings');
  if (!channelings || channelings.length === 0) { list.innerHTML = ''; empty.style.display = 'block'; return; }
  empty.style.display = 'none';
  let html = '';
  channelings.forEach((ch, i) => {
    const name = mmFixEncoding(ch.guardianName || 'Guardian');
    const type = mmFixEncoding(ch.guardianType || 'Ser Elemental');
    const dateStr = ch.date ? new Date(ch.date).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
    const text = ch.channelingText || '';
    // Status can be: 'published', 'completado', a date string (ISO), or 'review'/'pending'
    const isPublished = ch.status === 'published' || ch.status === 'completado' || (ch.status && ch.status.match && ch.status.match(/^\d{4}-\d{2}/));
    const hasReveal = mmHasProgressiveReveal(ch);

    html += '<div class="mm-ch-card">';
    html += '<div class="mm-ch-header"><div>';
    html += '<p class="mm-ch-type">' + type + '</p>';
    html += '<h2 class="mm-ch-name">' + name + '</h2>';

    // ── PROGRESSIVE REVEAL MODE ──
    if (isPublished && hasReveal) {
      var sections;
      try { sections = typeof ch.sections === 'string' ? JSON.parse(ch.sections) : ch.sections; } catch(e) { sections = {}; }
      var revealDay = mmGetRevealDay(ch);

      html += '</div>';
      if (dateStr) html += '<p class="mm-ch-date">' + dateStr + '</p>';
      html += '</div>';

      // Progress indicator (7 dots)
      html += '<div class="mm-reveal-progress">';
      for (var d = 1; d <= 7; d++) {
        var dotClass = 'mm-reveal-dot';
        if (d < revealDay) dotClass += ' unlocked';
        else if (d === revealDay) dotClass += ' current';
        html += '<div class="' + dotClass + '"></div>';
        if (d < 7) {
          var lineClass = 'mm-reveal-line';
          if (d < revealDay) lineClass += ' unlocked';
          html += '<div class="' + lineClass + '"></div>';
        }
      }
      html += '</div>';

      // Render each section (unlocked or locked)
      html += '<div class="mm-reveal-container">';
      REVEAL_SECTIONS.forEach(function(sec) {
        var isUnlocked = revealDay >= sec.day;
        var isJustUnlocked = revealDay === sec.day;
        var content = sections[sec.key] || '';

        if (isUnlocked && content) {
          // ── UNLOCKED SECTION ──
          var extraClass = isJustUnlocked ? ' just-unlocked' : '';
          html += '<div class="mm-reveal-section visible' + extraClass + '">';
          html += '<div class="mm-reveal-section-inner">';
          html += '<div class="mm-reveal-tag">' + sec.tag + '</div>';
          html += '<div class="mm-reveal-title">' + sec.title + '</div>';
          html += '<div class="mm-reveal-body">' + content.replace(/\n/g, '<br>') + '</div>';
          html += '</div></div>';
        } else if (!isUnlocked) {
          // ── LOCKED SECTION (teaser) ──
          html += '<div class="mm-reveal-locked">';
          html += '<div class="mm-reveal-locked-tag">' + sec.tag + '</div>';
          html += '<div class="mm-reveal-locked-hint">';
          html += '<svg class="mm-reveal-locked-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>';
          html += (REVEAL_HINTS[sec.key] || 'Pronto se revela\u2026');
          html += '</div></div>';
        }
      });

      // Completion message (all 7 days done)
      if (revealDay >= 7) {
        html += '<div class="mm-reveal-complete">';
        html += '<div class="mm-reveal-complete-line"></div>';
        html += '<div class="mm-reveal-complete-text">La canalizaci\u00f3n est\u00e1 completa. Tu guardi\u00e1n y vos ya est\u00e1n conectados.</div>';
        html += '</div>';
      }
      html += '</div>'; // close mm-reveal-container

    // ── LEGACY MODE (old orders without sections — show everything at once) ──
    } else if (isPublished && text) {
      var soulName = ch.soulName || '';
      var soulMeaning = ch.soulNameMeaning || '';
      var soulGuardian = ch.soulNameGuardian || '';
      var soulGuardianMeaning = ch.soulNameGuardianMeaning || '';

      // FIX: Detect if soulNameGuardian contains JSON (care_guide data stored in wrong column)
      var extraCareFromGuardian = null;
      if (soulGuardian && soulGuardian.trim().charAt(0) === '{') {
        try {
          extraCareFromGuardian = JSON.parse(soulGuardian);
          soulGuardian = ''; // Clear — it's not a name, it's care data
        } catch(e) { /* not valid JSON, keep as name */ }
      }
      // Same check for soulGuardianMeaning
      if (soulGuardianMeaning && soulGuardianMeaning.trim().charAt(0) === '{') {
        try { JSON.parse(soulGuardianMeaning); soulGuardianMeaning = ''; } catch(e) {}
      }
      // Same check for soulName
      if (soulName && soulName.trim().charAt(0) === '{') {
        try { JSON.parse(soulName); soulName = ''; } catch(e) {}
      }

      if (soulName || soulGuardian) {
        html += '<div class="mm-ch-souls">';
        if (soulGuardian) {
          html += '<div class="mm-ch-soul-block"><span class="mm-ch-soul-label">Nombre \u00e1lmico del guardi\u00e1n</span>';
          html += '<p class="mm-ch-soul-name">' + soulGuardian + '</p>';
          if (soulGuardianMeaning) html += '<p class="mm-ch-soul-meaning">' + soulGuardianMeaning + '</p>';
          html += '</div>';
        }
        if (soulName) {
          html += '<div class="mm-ch-soul-block"><span class="mm-ch-soul-label">Tu nombre \u00e1lmico</span>';
          html += '<p class="mm-ch-soul-name">' + soulName + '</p>';
          if (soulMeaning) html += '<p class="mm-ch-soul-meaning">' + soulMeaning + '</p>';
          html += '</div>';
        }
        html += '</div>';
      }
      html += '</div>';
      if (dateStr) html += '<p class="mm-ch-date">' + dateStr + '</p>';
      html += '</div>';
      html += '<div class="mm-ch-text">' + text.replace(/\n/g, '<br>') + '</div>';

      // Merge care data: use ch.careInfo if it looks like JSON, otherwise use extraCareFromGuardian
      var careData = null;
      if (ch.careInfo && typeof ch.careInfo === 'string' && ch.careInfo.trim().charAt(0) === '{') {
        careData = ch.careInfo;
      } else if (ch.careInfo && typeof ch.careInfo === 'object') {
        careData = ch.careInfo;
      }
      if (!careData && extraCareFromGuardian) careData = extraCareFromGuardian;
      if (careData) {
        html += '<div class="mm-ch-care">';
        html += '<h4>Gu\u00eda de Convivencia</h4>';
        try {
          const care = typeof careData === 'string' ? JSON.parse(careData) : careData;
          if (care.how_to_care) html += '<p><strong>C\u00f3mo cuidarlo:</strong> ' + care.how_to_care + '</p>';
          if (care.activity_signs) html += '<p><strong>Se\u00f1ales de actividad:</strong> ' + care.activity_signs + '</p>';
          if (care.special_bond) html += '<p><strong>V\u00ednculo especial:</strong> ' + care.special_bond + '</p>';
        } catch(e) { html += '<p>' + String(careData) + '</p>'; }
        html += '</div>';
      }

    // ── PENDING (channeling not ready yet) ──
    } else {
      html += '</div>';
      if (dateStr) html += '<p class="mm-ch-date">' + dateStr + '</p>';
      html += '</div>';
      html += '<div class="mm-ch-pending">';
      html += '<div style="width:40px;height:1px;background:var(--gold);margin:0 auto 16px;"></div>';
      html += '<p>Tu canalizacion se esta preparando...</p>';
      html += '<p style="font-size:13px;color:var(--text-faint);margin-top:8px;">Vamos a avisarte cuando este lista</p>';
      html += '</div>';
    }
    html += '</div>'; // close mm-ch-card
  });
  list.innerHTML = html;
}

