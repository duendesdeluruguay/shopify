/* Pergamino Sellado — Sealed ritual answers */

.mm-ritual-pergamino {
  margin: 28px 0;
  padding: 32px;
  background: linear-gradient(135deg, rgba(198,165,90,0.08), rgba(198,165,90,0.03));
  border: 1px solid rgba(198,165,90,0.3);
  border-radius: 8px;
  position: relative;
}

.mm-ritual-pergamino::before {
  content: '';
  position: absolute;
  top: 16px; right: 16px;
  width: 48px; height: 48px;
  border: 2px solid var(--gold);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.3;
}

.mm-ritual-pergamino-header {
  text-align: center;
  margin-bottom: 20px;
}

.mm-ritual-pergamino-seal {
  font-size: 36px;
  color: var(--gold);
  margin-bottom: 12px;
  opacity: 0.7;
}

.mm-ritual-pergamino-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 24px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 4px;
}

.mm-ritual-pergamino-subtitle {
  font-size: 13px;
  color: var(--text-light);
  font-style: italic;
  letter-spacing: 1px;
}

.mm-ritual-pergamino-status {
  font-size: 14px;
  color: var(--text-mid);
  line-height: 1.6;
  margin-bottom: 24px;
  padding: 16px;
  background: rgba(255,255,255,0.3);
  border-left: 2px solid var(--gold);
  border-radius: 4px;
}

.mm-ritual-pergamino-status strong {
  color: var(--gold);
  font-weight: 600;
}

/* Ritual answers container */

.mm-ritual-answers {
  background: rgba(255,255,255,0.5);
  border-radius: 6px;
  padding: 20px;
  margin-top: 16px;
}

.mm-ritual-layer {
  margin-bottom: 24px;
  padding-bottom: 24px;
  border-bottom: 1px solid rgba(198,165,90,0.15);
}

.mm-ritual-layer:last-child {
  margin-bottom: 0;
  border-bottom: none;
}

.mm-ritual-layer-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px;
  font-weight: 600;
  color: var(--gold);
  margin-bottom: 16px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.mm-ritual-questions {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.mm-ritual-q {
  padding: 12px;
  background: rgba(255,255,255,0.4);
  border-radius: 4px;
  border-left: 2px solid var(--gold);
}

.mm-ritual-q-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 6px;
}

.mm-ritual-q-text {
  font-size: 12px;
  color: var(--text-light);
  margin-bottom: 8px;
  font-style: italic;
}

.mm-ritual-answer {
  font-size: 14px;
  color: var(--text);
  line-height: 1.5;
  font-weight: 500;
}

.mm-ritual-legacy {
  padding: 12px;
}

.mm-ritual-legacy-intro {
  font-size: 12px;
  color: var(--text-light);
  margin-bottom: 12px;
  font-style: italic;
}

.mm-ritual-personal-message {
  margin-top: 20px;
  padding: 16px;
  background: rgba(198,165,90,0.08);
  border-radius: 4px;
  border: 1px solid rgba(198,165,90,0.2);
}

.mm-ritual-pm-title {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 8px;
}

.mm-ritual-pm-text {
  font-size: 13px;
  color: var(--text);
  line-height: 1.6;
  font-style: italic;
}

/* Published state — link to ritual */

.mm-ritual-published-link {
  margin: 16px 0;
  padding: 12px;
  text-align: center;
}

.mm-ritual-published-link a {
  font-size: 12px;
  color: var(--gold);
  text-decoration: none;
  border-bottom: 1px solid var(--gold);
  transition: all 0.3s ease;
  cursor: pointer;
}

.mm-ritual-published-link a:hover {
  color: var(--gold-soft);
  border-bottom-color: var(--gold-soft);
}

@media (max-width: 768px) {
  .mm-ritual-cta { padding: 24px; }
  .mm-ritual-pergamino { padding: 24px; }
  .mm-ritual-pergamino-title { font-size: 20px; }
  .mm-ritual-answers { padding: 16px; }
}

/* ═══════════════════════════════════════════════════════════
   MI MAGIA v3 CINEMATIC DASHBOARD — 2026-04-21
   Hero + rectángulos cinematográficos + floating Rito badge
   ═══════════════════════════════════════════════════════════ */

.mm-hero-cinematic {
  position: relative;
  width: 100%;
  height: 300px;
  overflow: hidden;
  background: linear-gradient(135deg, #1a3a2d 0%, #0d1a2a 55%, #2d1a0d 100%);
  margin: 0;
}

.mm-hero-cinematic::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: url('https://images.unsplash.com/photo-1441906363162-903afd0d3d52?w=1600&auto=format&fit=crop&q=80');
  background-size: cover;
  background-position: center;
  opacity: 0.52;
  animation: mmHeroZoom 22s ease-in-out infinite alternate;
  z-index: 1;
}

.mm-hero-cinematic::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(13,26,42,0.25) 0%, rgba(13,26,42,0.65) 70%, rgba(13,26,42,0.85) 100%);
  z-index: 2;
  pointer-events: none;
}

@keyframes mmHeroZoom {
  0% { transform: scale(1); }
  100% { transform: scale(1.08); }
}

.mm-hero-cinematic-content {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 40px 24px;
  height: 100%;
  max-width: 900px;
  margin: 0 auto;
}

.mm-hero-orb {
  position: absolute;
  top: 24px;
  right: 34px;
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #fff2b8 0%, #d4bc7c 45%, #8b6d1f 100%);
  box-shadow:
    0 0 50px rgba(255, 215, 120, 0.55),
    0 0 100px rgba(212, 175, 55, 0.3),
    inset 0 0 25px rgba(255, 255, 255, 0.3);
  filter: blur(0.4px);
  animation: mmOrbFloat 7s ease-in-out infinite, mmOrbPulse 3.5s ease-in-out infinite;
  z-index: 3;
  pointer-events: none;
}

@keyframes mmOrbFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-22px); }
}

@keyframes mmOrbPulse {
  0%, 100% { opacity: 0.85; }
  50% { opacity: 1; }
}

.mm-hero-label {
  font-family: 'Lato', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: rgba(212, 188, 124, 0.9);
  margin-bottom: 14px;
  opacity: 0;
  animation: mmFadeIn 0.8s ease-out 0.15s forwards;
}

.mm-hero-greeting {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 400;
  font-size: 36px;
  color: #f5e6c8;
  letter-spacing: 0.04em;
  text-shadow: 0 2px 12px rgba(0,0,0,0.85), 0 0 20px rgba(212,175,55,0.4);
  margin-bottom: 6px;
  text-shadow: 0 2px 18px rgba(212, 175, 55, 0.35), 0 0 40px rgba(0,0,0,0.5);
  opacity: 0;
  transform: translateY(30px);
  animation: mmFadeInUp 0.8s ease-out 0.35s forwards;
}

.mm-hero-soul {
  font-family: 'Tangerine', cursive;
  font-weight: 700;
  font-size: 64px;
  color: #d4af37; text-shadow: 0 2px 12px rgba(0,0,0,0.85);
  line-height: 1;
  margin-bottom: 18px;
  text-shadow: 0 0 25px rgba(255, 215, 120, 0.55), 0 2px 12px rgba(0,0,0,0.5);
  opacity: 0;
  transform: translateY(30px);
  animation: mmFadeInUp 0.9s ease-out 0.55s forwards;
}

.mm-hero-subtitle {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-weight: 400;
  font-size: 18px;
  color: rgba(212, 188, 124, 0.95);
  letter-spacing: 0.02em;
  max-width: 560px;
  line-height: 1.5;
  opacity: 0;
  animation: mmFadeIn 1.2s ease-out 0.9s forwards;
}

@keyframes mmFadeInUp {
  to { opacity: 1; transform: translateY(0); }
}

@keyframes mmFadeIn {
  to { opacity: 1; }
}

/* Floating orbs in hero background */
.mm-hero-floating-orbs {
  position: absolute;
  inset: 0;
  z-index: 2;
  pointer-events: none;
  overflow: hidden;
}
.mm-hero-floating-orbs span {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(255,232,160,0.7) 0%, rgba(212,175,55,0.4) 50%, transparent 100%);
  filter: blur(1px);
}
.mm-hero-floating-orbs span:nth-child(1) { width: 18px; height: 18px; top: 20%; left: 15%; animation: mmOrbFloat 8s ease-in-out infinite; opacity: 0.6; }
.mm-hero-floating-orbs span:nth-child(2) { width: 10px; height: 10px; top: 65%; left: 25%; animation: mmOrbFloat 10s ease-in-out infinite; opacity: 0.5; }
.mm-hero-floating-orbs span:nth-child(3) { width: 14px; height: 14px; top: 40%; left: 78%; animation: mmOrbFloat 9s ease-in-out infinite; opacity: 0.55; }
.mm-hero-floating-orbs span:nth-child(4) { width: 8px; height: 8px; top: 75%; left: 85%; animation: mmOrbFloat 11s ease-in-out infinite; opacity: 0.4; }
.mm-hero-floating-orbs span:nth-child(5) { width: 12px; height: 12px; top: 30%; left: 50%; animation: mmOrbFloat 7s ease-in-out infinite; opacity: 0.5; }

/* ═══════ CINEMATIC CARDS GRID ═══════ */
.mm-cards-section {
  max-width: 1200px;
  margin: 0 auto;
  padding: 60px 24px 80px;
}

.mm-cards-section-header {
  text-align: center;
  margin-bottom: 48px;
}

.mm-cards-section-label {
  font-family: 'Lato', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: var(--text-light);
  margin-bottom: 12px;
}

.mm-cards-section-title {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 400;
  font-size: 38px;
  color: var(--text);
  letter-spacing: 0.02em;
  line-height: 1.1;
}

.mm-cards-section-divider {
  width: 60px;
  height: 1px;
  background: var(--gold);
  margin: 16px auto 0;
}

.mm-cards-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
}

@media (min-width: 900px) {
  .mm-cards-grid {
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
}

.mm-cine-card {
  position: relative;
  height: 220px;
  border-radius: 16px;
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
              box-shadow 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  box-shadow:
    0 6px 22px rgba(0,0,0,0.18),
    0 12px 44px rgba(0,0,0,0.12),
    inset 0 1px 0 rgba(255,255,255,0.08);
  text-decoration: none;
  color: #f5f1eb;
  will-change: transform;
  display: block;
}

.mm-cine-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: var(--card-bg);
  background-size: cover;
  background-position: center;
  transition: transform 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  z-index: 1;
}

.mm-cine-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(13,26,42,0.15) 0%, rgba(13,26,42,0.55) 55%, rgba(13,26,42,0.88) 100%),
    var(--card-tint, rgba(26,58,45,0.35));
  z-index: 2;
  pointer-events: none;
}

.mm-cine-card:hover {
  transform: translateY(-8px) scale(1.005);
  box-shadow:
    0 12px 48px rgba(184,151,59,0.3),
    0 24px 80px rgba(0,0,0,0.25),
    inset 0 1px 0 rgba(255,255,255,0.15);
}

.mm-cine-card:hover::before {
  transform: scale(1.08);
}

.mm-cine-card-orb {
  position: absolute;
  top: 18px;
  right: 22px;
  width: 54px;
  height: 54px;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, var(--card-orb, #ffe99a) 0%, var(--gold) 55%, #8b6d1f 100%);
  box-shadow:
    0 0 22px rgba(255, 215, 120, 0.55),
    0 0 44px rgba(212, 175, 55, 0.3);
  z-index: 4;
  animation: mmOrbFloat 5.5s ease-in-out infinite, mmOrbPulse 3s ease-in-out infinite;
  pointer-events: none;
}

.mm-cine-card-content {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  padding: 28px 26px 24px;
  z-index: 3;
}

.mm-cine-card-label {
  font-family: 'Lato', sans-serif;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: rgba(212, 188, 124, 0.95);
  margin-bottom: 8px;
  text-shadow: 0 1px 4px rgba(0,0,0,0.4);
}

.mm-cine-card-title {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 400;
  font-size: 30px;
  color: #f5f1eb;
  letter-spacing: 0.02em;
  line-height: 1.1;
  margin-bottom: 6px;
  text-shadow: 0 2px 14px rgba(0,0,0,0.5);
}

.mm-cine-card-sub {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 14.5px;
  color: rgba(245,241,235,0.88);
  line-height: 1.4;
  margin-bottom: 14px;
  max-width: 92%;
  text-shadow: 0 1px 6px rgba(0,0,0,0.4);
}

.mm-cine-card-cta {
  font-family: 'Lato', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #f0d88c;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: gap 0.3s ease;
}

.mm-cine-card:hover .mm-cine-card-cta {
  gap: 14px;
}

.mm-cine-card-badge {
  position: absolute;
  top: 16px;
  left: 18px;
  z-index: 5;
  background: linear-gradient(90deg, #B85A5A 0%, #d47878 100%);
  color: #fff;
  font-family: 'Lato', sans-serif;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 6px 11px;
  border-radius: 20px;
  box-shadow: 0 0 15px rgba(184,90,90,0.5);
