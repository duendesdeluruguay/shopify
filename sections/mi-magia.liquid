  checkAuthentication();
  initializeLanguageToggle();
  renderRitualDays();

  // Listen for hash changes
  window.addEventListener('hashchange', handleHashChange);
});

function initializeFireflies() {
  const container = document.getElementById('fireflies-container');
  const firefliesCount = window.innerWidth > 768 ? 20 : 10;

  for (let i = 0; i < firefliesCount; i++) {
    const firefly = document.createElement('div');
    firefly.className = 'firefly';

    const colors = ['gold', 'green', 'white'];
    const randomColor = colors[Math.floor(Math.random() * colors.length)];
    if (randomColor !== 'gold') firefly.classList.add(randomColor);

    const x = Math.random() * 100;
    const y = Math.random() * 100;
    const duration = 8 + Math.random() * 12;
    const tx = (Math.random() - 0.5) * 200;
    const ty = (Math.random() - 0.5) * 200;

    firefly.style.left = x + '%';
    firefly.style.top = y + '%';
    firefly.style.setProperty('--duration', duration + 's');
    firefly.style.setProperty('--tx', tx + 'px');
    firefly.style.setProperty('--ty', ty + 'px');

    container.appendChild(firefly);
  }
}

function initializeLanguageToggle() {
  document.querySelectorAll('[data-es]').forEach(el => {
    el.setAttribute('data-es', el.getAttribute('data-es') || el.textContent);
    if (!el.getAttribute('data-en')) {
      el.setAttribute('data-en', el.textContent);
    }
  });
}

function checkAuthentication() {
  // Check if customer is logged in via Shopify session
  if (Shopify && Shopify.customer && Shopify.customer.id) {
    currentCustomer = {
      id: Shopify.customer.id,
      email: Shopify.customer.email,
      firstName: Shopify.customer.first_name
    };
    loadCustomerData();
  } else {
    // Show gate
    switchSection('#gate');
  }
}

// ============================================================================
// AUTHENTICATION
// ============================================================================

function loginWithShopify() {
  const email = document.getElementById('login-email').value.trim();

  if (!email) {
    alert('Por favor ingresa tu email');
    return;
  }

  // In production, this would verify the email against Shopify customers
  // For now, we simulate successful login
  currentCustomer = {
    email: email,
    firstName: email.split('@')[0]
  };

  // Save to localStorage for demo
  localStorage.setItem('mi-magia-customer', JSON.stringify(currentCustomer));

  loadCustomerData();
  switchSection('#dashboard');
}

function loadCustomerData() {
  const firstName = currentCustomer.firstName || 'Adoptante';
  document.getElementById('dashboard-name').textContent = 'Bienvenida, ' + firstName;

  // Fetch orders and guardians
  if (window.Shopify && window.Shopify.customer && window.Shopify.customer.orders) {
    renderGuardians(window.Shopify.customer.orders);
  } else {
    // Demo data
    renderGuardians([]);
  }
}

function logout() {
  currentCustomer = null;
  localStorage.removeItem('mi-magia-customer');
  switchSection('#gate');
  document.getElementById('login-email').value = '';
}

// ============================================================================
// SECTION NAVIGATION
// ============================================================================

function switchSection(sectionId) {
  // Hide all sections
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));

  // Show selected section
  const section = document.querySelector(sectionId);
  if (section) {
    section.classList.add('active');
  }

  // Update nav links
  document.querySelectorAll('.nav-link').forEach(link => link.classList.remove('active'));

  // Close dropdown
  const dropdown = document.getElementById('dropdown-menu');
  if (dropdown) dropdown.classList.remove('active');
}

function handleHashChange() {
  const hash = window.location.hash || '#dashboard';
  switchSection(hash);
}

function toggleDropdown() {
  const dropdown = document.getElementById('dropdown-menu');
  dropdown.classList.toggle('active');
}

function openLink(url) {
  window.open(url, '_blank');
}

// ============================================================================
// GUARDIANS RENDERING
// ============================================================================

function renderGuardians(orders) {
  const container = document.getElementById('guardians-container');
  const emptyState = document.getElementById('empty-guardians');

  if (!orders || orders.length === 0) {
    emptyState.style.display = 'block';
    container.innerHTML = '';
    return;
  }

  emptyState.style.display = 'none';

  let html = '<div class="guardian-grid">';

  orders.forEach(order => {
    const guardianName = 'Duende Elemental'; // Would come from metafields
    const guardianType = 'Ser de Luz';
    const orderDate = new Date(order.created_at).toLocaleDateString('es-ES');

    html += `
      <div class="guardian-card">
        <div class="guardian-name">${guardianName}</div>
        <div class="guardian-type">${guardianType}</div>
        <div class="guardian-meta">
          <p><strong>Orden:</strong> #${order.order_number}</p>
          <p><strong>Fecha:</strong> ${orderDate}</p>
          <p><strong>Estado:</strong> ${order.fulfillment_status || 'Procesando'}</p>
        </div>
      </div>
    `;
  });

  html += '</div>';
  container.innerHTML = html;
}

// ============================================================================
// FORMULARIO
// ============================================================================

function selectMode(mode) {
  // Hide all modes
  document.querySelectorAll('.form-mode-content').forEach(el => el.style.display = 'none');
  document.querySelectorAll('.mode-button').forEach(btn => btn.classList.remove('active'));

  // Show selected mode
  const modeEl = document.getElementById('modo-' + mode);
  if (modeEl) modeEl.style.display = 'block';

  // Mark button as active
  event.target.classList.add('active');
}

function selectGender(gender) {
  document.querySelectorAll('.gender-button').forEach(btn => btn.classList.remove('active'));
  event.target.classList.add('active');
  document.getElementById('selected-gender').value = gender;
}

function toggleFrequency() {
  const toggle = document.getElementById('frequency-toggle');
  const hidden = document.getElementById('frequency-963');

  toggle.classList.toggle('active');
  hidden.value = toggle.classList.contains('active') ? 'true' : 'false';
}

async function submitFormulario(e) {
  e.preventDefault();

  const form = e.target;
  const formData = new FormData(form);

  // Collect all form data
  const data = {
    email: currentCustomer.email,
    firstName: currentCustomer.firstName,
    mode: document.querySelector('.form-mode-content:not([style*="display: none"])') ? 'para-mi' : 'unknown',
    frequency963: document.getElementById('frequency-963').value === 'true',
    responses: Object.fromEntries(formData)
  };

  // Submit al Worker (API)
  try {
    const response = await fetch(DUENDES_API_URL + '?action=submit_form', {
      method: 'POST',
      body: JSON.stringify(data)
    });

    if (response.ok) {
      alert('Formulario enviado. Tu canalización comenzará ahora.');
      switchSection('#canalizacion');
    }
  } catch (error) {
    console.error('Error submitting form:', error);
    alert('Error al enviar el formulario. Por favor, intenta de nuevo.');
  }
}

// ============================================================================
// CANALIZACION
// ============================================================================

function loadChannelingData() {
  // Fetch desde el Worker
  // For now, show locked state
  document.getElementById('channeling-locked').style.display = 'block';
  document.getElementById('channeling-published').style.display = 'none';
}

// ============================================================================
// RITUAL
// ============================================================================

function renderRitualDays() {
  const container = document.getElementById('ritual-days-container');
  let html = '';

  ritualDays.forEach((day, index) => {
    html += `
      <div class="ritual-day" onclick="toggleRitualDay(${index})">
        <div class="day-number">${index + 1}</div>
        <div class="day-name">${currentLanguage === 'es' ? day.name : 'Day ' + (index + 1)}</div>
        <div class="day-description">${day.description}</div>
        <div class="day-checkbox">
          <div class="checkbox" id="ritual-checkbox-${index}"></div>
          <span class="checkbox-label" data-es="Completado" data-en="Completed">Completado</span>
        </div>
      </div>
    `;
  });

  container.innerHTML = html;
}

function toggleRitualDay(index) {
  const checkbox = document.getElementById('ritual-checkbox-' + index);
  checkbox.classList.toggle('checked');

  // Update progress
  const completed = document.querySelectorAll('.ritual-day .checkbox.checked').length;
  document.getElementById('ritual-progress').textContent = completed;
  document.getElementById('ritual-progress-fill').style.width = (completed / 7 * 100) + '%';

  // Update parent card
  const card = checkbox.closest('.ritual-day');
  card.classList.toggle('completed');

  // Submit al Worker (API)
  updateRitualProgress(index, checkbox.classList.contains('checked'));
}

async function updateRitualProgress(dayIndex, completed) {
  try {
    await fetch(DUENDES_API_URL + '?action=update_ritual', {
      method: 'POST',
      body: JSON.stringify({
        email: currentCustomer.email,
        dayIndex: dayIndex,
        completed: completed
      })
    });
  } catch (error) {
    console.error('Error updating ritual:', error);
  }
}

// ============================================================================
// BIENVENIDA
// ============================================================================

async function submitBienvenida(e) {
  e.preventDefault();

  const name = document.getElementById('bienvenida-name').value;
  const dob = document.getElementById('bienvenida-dob').value;

  try {
    const response = await fetch(DUENDES_API_URL + '?action=submit_bienvenida', {
      method: 'POST',
      body: JSON.stringify({
        email: currentCustomer.email,
        name: name,
        dateOfBirth: dob
      })
    });

    if (response.ok) {
      // Generate soul name
      generateSoulName(name);
      switchSection('#dashboard');
    }
  } catch (error) {
    console.error('Error:', error);
    alert('Error al guardar información');
  }
}

function generateSoulName(name) {
  // En producción: Claude u otro modelo vía Worker (Cloudflare)
  const soulNames = ['Thyraleth Verdania', 'Aelindor Luminar', 'Celestria Dorada', 'Silvanus Encantado', 'Miriel Etérea'];
  const randomSoulName = soulNames[Math.floor(Math.random() * soulNames.length)];

  document.getElementById('soul-name-display').textContent = randomSoulName;
}

// ============================================================================
// LANGUAGE
// ============================================================================

function setLanguage(lang) {
  currentLanguage = lang;

  // Update language toggle
  document.getElementById('lang-es').classList.toggle('active');
  document.getElementById('lang-en').classList.toggle('active');

  // Update all content
  document.querySelectorAll('[data-es]').forEach(el => {
    const content = lang === 'es' ? el.getAttribute('data-es') : el.getAttribute('data-en');
    el.textContent = content;
  });

  // Re-render ritual days if visible
  if (document.getElementById('ritual').classList.contains('active')) {
    renderRitualDays();
  }
}

// ============================================================================
// LOAD ON READY
// ============================================================================

// Check if customer data is available on page load
window.addEventListener('load', () => {
  const savedCustomer = localStorage.getItem('mi-magia-customer');
  if (savedCustomer) {
    currentCustomer = JSON.parse(savedCustomer);
    loadCustomerData();
    switchSection('#dashboard');
  }
});
</script>
