{%- liquid
  assign threshold = section.settings.premium_threshold_cents | default: 200000 | plus: 0
  assign override_tag = section.settings.premium_override_tag | strip
  assign show_premium = false
  if customer
    if customer.total_spent >= threshold
      assign show_premium = true
    endif
    if override_tag != blank and customer.tags contains override_tag
      assign show_premium = true
    endif
  endif
-%}

<div class="du-el-portal color-{{ section.settings.color_scheme }}">
  <div class="du-el-portal__bg"></div>
  <div class="page-width du-el-portal__inner section section--page-width spacing-style" style="{% render 'spacing-style', settings: section.settings %}">
    {% if customer == blank %}
      <header class="du-el-portal__hero">
        <p class="du-el-portal__glyph">✦</p>
        <h1 class="du-el-portal__title">{{ section.settings.gate_title | escape }}</h1>
        <p class="du-el-portal__lead">{{ section.settings.gate_lead | escape }}</p>
        <div class="du-el-portal__actions">
          <a class="button" href="{{ routes.account_login_url }}?return_url=%2Fpages%2Fel-portal">{{ section.settings.gate_cta_login | escape }}</a>
          <a class="button button--secondary" href="{{ routes.account_register_url }}?return_url=%2Fpages%2Fel-portal">{{ section.settings.gate_cta_register | escape }}</a>
        </div>
      </header>
    {% else %}
      <header class="du-el-portal__hero du-el-portal__hero--authed">
        <p class="du-el-portal__glyph">✦</p>
        <p class="du-el-portal__eyebrow">{{ section.settings.welcome_eyebrow | escape }}</p>
        {% assign _portal_nm = customer.first_name | default: 'Elegida' %}
        {% assign _portal_wt = section.settings.welcome_title | replace: '[name]', _portal_nm %}
        <h1 class="du-el-portal__title">{{ _portal_wt | escape }}</h1>
        <p class="du-el-portal__lead">{{ section.settings.welcome_lead | escape }}</p>
      </header>

      {%- comment -%}
        Duendes 2026-05-17 — Biblioteca con GATING por linaje comprado.
        Lee customer.orders y arma string con los linajes adoptados.
        Cada libro se muestra abierto (si lo tiene) o sellado (si no).
      {%- endcomment -%}
      {%- assign owned_lineages = ',' -%}
      {%- if customer -%}
        {%- for o in customer.orders limit: 100 -%}
          {%- for li in o.line_items -%}
            {%- assign lin = li.product.metafields.custom.linaje.value | default: li.product.metafields.custom.linaje -%}
            {%- if lin != blank -%}
              {%- assign lin_key = ',' | append: lin | append: ',' -%}
              {%- unless owned_lineages contains lin_key -%}
                {%- assign owned_lineages = owned_lineages | append: lin | append: ',' -%}
              {%- endunless -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      {%- endif -%}

      {%- assign has_duende = false -%}
      {%- assign has_hada = false -%}
      {%- assign has_pixie = false -%}
      {%- assign has_elfo = false -%}
      {%- assign has_mayor = false -%}
      {%- assign has_deluxe = false -%}
      {%- assign has_bruja = false -%}
      {%- if owned_lineages contains ',Duende,' -%}{%- assign has_duende = true -%}{%- endif -%}
      {%- if owned_lineages contains ',Hada,' -%}{%- assign has_hada = true -%}{%- endif -%}
      {%- if owned_lineages contains ',Pixie,' -%}{%- assign has_pixie = true -%}{%- endif -%}
      {%- if owned_lineages contains ',Elfo,' -%}{%- assign has_elfo = true -%}{%- endif -%}
      {%- if owned_lineages contains ',Mayor,' -%}{%- assign has_mayor = true -%}{%- endif -%}
      {%- if owned_lineages contains ',Deluxe,' -%}{%- assign has_deluxe = true -%}{%- endif -%}
      {%- if owned_lineages contains ',Bruja,' -%}{%- assign has_bruja = true -%}{%- endif -%}

      <section class="du-portal-biblio" aria-label="Biblioteca de los Elegidos">
        <p class="du-portal-biblio__eyebrow">— Biblioteca de los Elegidos —</p>
        <h2 class="du-portal-biblio__title">Los 7 Libros canalizados</h2>
        <p class="du-portal-biblio__lead">Cada libro se abre solo en las manos de su Elegido. Adoptás un guardián, se desbloquea su linaje.</p>

        <div class="du-portal-biblio__grid">

          {%- comment -%} La Biblia: la abre quien tenga CUALQUIER duende o maestro {%- endcomment -%}
          {%- if has_duende or has_mayor -%}
            <a class="du-portal-biblio__card du-portal-biblio__card--bible" href="/pages/libro-elemental">
              <span class="du-portal-biblio__spine"></span>
              <span class="du-portal-biblio__eyebrow-card">La Biblia</span>
              <span class="du-portal-biblio__name">La Guía de los Duendes del Uruguay</span>
              <span class="du-portal-biblio__meta">50 páginas · negro &amp; oro</span>
              <span class="du-portal-biblio__cta">Abrir el libro →</span>
            </a>
          {%- else -%}
            <div class="du-portal-biblio__card du-portal-biblio__card--bible du-portal-biblio__card--locked" aria-disabled="true">
              <span class="du-portal-biblio__spine"></span>
              <span class="du-portal-biblio__eyebrow-card">La Biblia</span>
              <span class="du-portal-biblio__name">La Guía de los Duendes del Uruguay</span>
              <span class="du-portal-biblio__meta">Sellado · solo Elegidos del linaje</span>
              <span class="du-portal-biblio__lock">🔒 Adoptá un Duende para abrirlo</span>
            </div>
          {%- endif -%}

          {%- if has_hada -%}
            <a class="du-portal-biblio__card du-portal-biblio__card--hadas" href="/pages/guia-hadas">
              <span class="du-portal-biblio__spine"></span>
              <span class="du-portal-biblio__eyebrow-card">Linaje del agua</span>
              <span class="du-portal-biblio__name">La Guía de las Hadas</span>
              <span class="du-portal-biblio__meta">50 páginas · rosa &amp; perla</span>
              <span class="du-portal-biblio__cta">Abrir el libro →</span>
            </a>
          {%- else -%}
            <div class="du-portal-biblio__card du-portal-biblio__card--hadas du-portal-biblio__card--locked" aria-disabled="true">
              <span class="du-portal-biblio__spine"></span>
              <span class="du-portal-biblio__eyebrow-card">Linaje del agua</span>
              <span class="du-portal-biblio__name">La Guía de las Hadas</span>
              <span class="du-portal-biblio__meta">Sellado · solo Elegidos del linaje</span>
              <span class="du-portal-biblio__lock">🔒 Adoptá una Hada para abrirlo</span>
            </div>
          {%- endif -%}

          {%- if has_pixie -%}
            <a class="du-portal-biblio__card du-portal-biblio__card--pixies" href="/pages/guia-pixies">
              <span class="du-portal-biblio__spine"></span>
              <span class="du-portal-biblio__eyebrow-card">Linaje del aire</span>
              <span class="du-portal-biblio__name">La Guía de las Pixies</span>
              <span class="du-portal-biblio__meta">46 páginas · menta &amp; oro</span>
              <span class="du-portal-biblio__cta">Abrir el libro →</span>
            </a>
          {%- else -%}
            <div class="du-portal-biblio__card du-portal-biblio__card--pixies du-portal-biblio__card--locked" aria-disabled="true">
              <span class="du-portal-biblio__spine"></span>
              <span class="du-portal-biblio__eyebrow-card">Linaje del aire</span>
              <span class="du-portal-biblio__name">La Guía de las Pixies</span>
              <span class="du-portal-biblio__meta">Sellado · solo Elegidos del linaje</span>
              <span class="du-portal-biblio__lock">🔒 Adoptá una Pixie para abrirlo</span>
            </div>
          {%- endif -%}

          {%- if has_elfo -%}
            <a class="du-portal-biblio__card du-portal-biblio__card--elfos" href="/pages/guia-elfos">
              <span class="du-portal-biblio__spine"></span>
              <span class="du-portal-biblio__eyebrow-card">Linaje vegetal</span>
              <span class="du-portal-biblio__name">La Guía de los Elfos</span>
              <span class="du-portal-biblio__meta">46 páginas · azul &amp; plata</span>
              <span class="du-portal-biblio__cta">Abrir el libro →</span>
            </a>
          {%- else -%}
            <div class="du-portal-biblio__card du-portal-biblio__card--elfos du-portal-biblio__card--locked" aria-disabled="true">
              <span class="du-portal-biblio__spine"></span>
              <span class="du-portal-biblio__eyebrow-card">Linaje vegetal</span>
              <span class="du-portal-biblio__name">La Guía de los Elfos</span>
              <span class="du-portal-biblio__meta">Sellado · solo Elegidos del linaje</span>
              <span class="du-portal-biblio__lock">🔒 Adoptá un Elfo para abrirlo</span>
            </div>
          {%- endif -%}

          {%- if has_mayor -%}
            <a class="du-portal-biblio__card du-portal-biblio__card--gigantes" href="/pages/guia-gigantes">
              <span class="du-portal-biblio__spine"></span>
              <span class="du-portal-biblio__eyebrow-card">Únicos · Irrepetibles</span>
              <span class="du-portal-biblio__name">La Guía de los Maestros Gigantes</span>
              <span class="du-portal-biblio__meta">46 páginas · bordó &amp; oro</span>
              <span class="du-portal-biblio__cta">Abrir el libro →</span>
            </a>
          {%- else -%}
            <div class="du-portal-biblio__card du-portal-biblio__card--gigantes du-portal-biblio__card--locked" aria-disabled="true">
              <span class="du-portal-biblio__spine"></span>
              <span class="du-portal-biblio__eyebrow-card">Únicos · Irrepetibles</span>
              <span class="du-portal-biblio__name">La Guía de los Maestros Gigantes</span>
              <span class="du-portal-biblio__meta">Sellado · solo Elegidos del linaje</span>
              <span class="du-portal-biblio__lock">🔒 Adoptá un Maestro Gigante para abrirlo</span>
            </div>
          {%- endif -%}

          {%- if has_deluxe -%}
            <a class="du-portal-biblio__card du-portal-biblio__card--deluxe" href="/pages/guia-seres-deluxe">
              <span class="du-portal-biblio__spine"></span>
              <span class="du-portal-biblio__eyebrow-card">Ultra mágica</span>
              <span class="du-portal-biblio__name">La Guía de los Seres Deluxe</span>
              <span class="du-portal-biblio__meta">46 páginas · púrpura &amp; cobre</span>
              <span class="du-portal-biblio__cta">Abrir el libro →</span>
            </a>
          {%- else -%}
            <div class="du-portal-biblio__card du-portal-biblio__card--deluxe du-portal-biblio__card--locked" aria-disabled="true">
              <span class="du-portal-biblio__spine"></span>
              <span class="du-portal-biblio__eyebrow-card">Ultra mágica</span>
              <span class="du-portal-biblio__name">La Guía de los Seres Deluxe</span>
              <span class="du-portal-biblio__meta">Sellado · solo Elegidos del linaje</span>
              <span class="du-portal-biblio__lock">🔒 Adoptá un Ser Deluxe para abrirlo</span>
            </div>
          {%- endif -%}

          {%- if has_bruja -%}
            <a class="du-portal-biblio__card du-portal-biblio__card--bruja" href="/pages/guia-alma-de-bruja">
              <span class="du-portal-biblio__spine"></span>
              <span class="du-portal-biblio__eyebrow-card">Línea por venir</span>
              <span class="du-portal-biblio__name">Alma de Bruja</span>
              <span class="du-portal-biblio__meta">42 páginas · negro &amp; violeta</span>
              <span class="du-portal-biblio__cta">Abrir el libro →</span>
            </a>
          {%- else -%}
            <div class="du-portal-biblio__card du-portal-biblio__card--bruja du-portal-biblio__card--locked" aria-disabled="true">
              <span class="du-portal-biblio__spine"></span>
              <span class="du-portal-biblio__eyebrow-card">Línea por venir</span>
              <span class="du-portal-biblio__name">Alma de Bruja</span>
              <span class="du-portal-biblio__meta">Sellado · solo Elegidos del linaje</span>
              <span class="du-portal-biblio__lock">🔒 Adoptá una Bruja para abrirlo</span>
            </div>
          {%- endif -%}

        </div>
      </section>

      {%- comment -%}
        Duendes 2026-05-17 — Cartas de tus Guardianes.
        Muestra todos los guardianes adoptados por este cliente con su mensaje
        personal revelable (tap-to-reveal vía <details>). Dedup por product.id.
      {%- endcomment -%}
      {%- if customer -%}
        {%- assign seen_ids = ',' -%}
        {%- assign adopted_count = 0 -%}
        {%- capture cartas_html -%}
          {%- for o in customer.orders limit: 50 -%}
            {%- for li in o.line_items -%}
              {%- assign p = li.product -%}
              {%- if p != blank -%}
                {%- assign mensaje = p.metafields.custom.mensaje_personal.value -%}
                {%- if mensaje == nil -%}{%- assign mensaje = p.metafields.custom.mensaje_personal -%}{%- endif -%}
                {%- if mensaje != blank -%}
                  {%- assign id_key = ',' | append: p.id | append: ',' -%}
                  {%- unless seen_ids contains id_key -%}
                    {%- assign seen_ids = seen_ids | append: p.id | append: ',' -%}
                    {%- assign adopted_count = adopted_count | plus: 1 -%}
                    {%- assign clean_name = p.title | split: ' - ' | first | strip -%}
                    {%- assign esencia = p.metafields.custom.esencia.value | default: p.metafields.custom.esencia -%}
                    <details class="du-portal-carta">
                      <summary class="du-portal-carta__face">
                        <div class="du-portal-carta__media">
                          {%- if p.featured_image -%}
                            <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ clean_name | escape }}" loading="lazy" width="600" height="800">
                          {%- endif -%}
                          <span class="du-portal-carta__seal" aria-hidden="true">✦</span>
                        </div>
                        <div class="du-portal-carta__body">
                          <span class="du-portal-carta__eyebrow">Tu Guardián</span>
                          <h3 class="du-portal-carta__name">{{ clean_name }}</h3>
                          {%- if esencia != blank -%}
                            <span class="du-portal-carta__chip">{{ esencia }}</span>
                          {%- endif -%}
                          <span class="du-portal-carta__cta">Tocá para abrir su carta →</span>
                        </div>
                      </summary>
                      <div class="du-portal-carta__inner">
                        <p class="du-portal-carta__hello">— Mensaje personal de {{ clean_name }} · para vos —</p>
                        <div class="du-portal-carta__letter">{{ mensaje | newline_to_br }}</div>
                        <p class="du-portal-carta__hint">— Guardalo. Es entre vos y {{ clean_name }}. —</p>
                      </div>
                    </details>
                  {%- endunless -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endfor -%}
        {%- endcapture -%}

        {%- if adopted_count > 0 -%}
          <section class="du-portal-cartas" aria-label="Cartas de tus Guardianes">
            <header class="du-portal-cartas__head">
              <p class="du-portal-cartas__eyebrow">✦ {{ adopted_count }} {% if adopted_count == 1 %}Guardián te adoptó{% else %}Guardianes te adoptaron{% endif %} ✦</p>
              <h2 class="du-portal-cartas__title">Cartas de tus Guardianes</h2>
              <p class="du-portal-cartas__sub">Cada uno tejió su mensaje en silencio antes de llegar. Tocá una carta para abrir la suya.</p>
            </header>
            <div class="du-portal-cartas__grid">
              {{ cartas_html }}
            </div>
          </section>
        {%- endif -%}
      {%- endif -%}

      <div class="du-el-portal__grid">
        <section class="du-el-portal__card">
          <h2>{{ section.settings.block_guides_title | escape }}</h2>
          <div class="rte">{{ section.settings.block_guides_body }}</div>
        </section>
        <section class="du-el-portal__card">
          <h2>{{ section.settings.block_meditaciones_title | escape }}</h2>
          <div class="rte">{{ section.settings.block_meditaciones_body }}</div>
        </section>
      </div>

      {%- comment -%}
        Duendes 2026-05-17 — Bloques de contenido adicional Mi Magia
        (para que el portal no se vea vacío)
      {%- endcomment -%}

      <section class="du-portal-luna">
        <p class="du-portal-luna__eyebrow">— Calendario lunar —</p>
        <h2 class="du-portal-luna__title">La luna y tu Guardián</h2>
        <p class="du-portal-luna__lead">Tu Guardián se carga con la luna. Cada fase activa una intención distinta. Sincronizá tus rituales con el cielo.</p>
        <div class="du-portal-luna__grid">
          <div class="du-portal-luna__fase">
            <span class="du-portal-luna__icon">🌑</span>
            <h3>Luna Nueva</h3>
            <p>Momento de sembrar. Pediles a tus Guardianes una intención clara — la que quieras que crezca en los próximos 28 días.</p>
          </div>
          <div class="du-portal-luna__fase">
            <span class="du-portal-luna__icon">🌓</span>
            <h3>Cuarto Creciente</h3>
            <p>Energía de acción. Ponéles cristales arriba para que potencien lo que ya empezó a moverse en tu vida.</p>
          </div>
          <div class="du-portal-luna__fase">
            <span class="du-portal-luna__icon">🌕</span>
            <h3>Luna Llena</h3>
            <p>Carga máxima. Dejá a tus Guardianes en la ventana toda la noche bajo la luna. Despiertan con toda la energía del ciclo.</p>
          </div>
          <div class="du-portal-luna__fase">
            <span class="du-portal-luna__icon">🌗</span>
            <h3>Cuarto Menguante</h3>
            <p>Tiempo de soltar. Decíles qué querés dejar atrás. Ellos se llevan lo que ya cumplió su función.</p>
          </div>
        </div>
      </section>

      <section class="du-portal-cuidados">
        <p class="du-portal-cuidados__eyebrow">— Cuidados esenciales —</p>
        <h2 class="du-portal-cuidados__title">Cómo convivir con tu Guardián</h2>
        <div class="du-portal-cuidados__grid">
          <article>
            <span class="du-portal-cuidados__num">01</span>
            <h3>El primer día</h3>
            <p>Abrí la caja en un momento de calma, no apurada. Sostené a tu Guardián con ambas manos. Cerrá los ojos. Respirá profundo tres veces. Decí su nombre en voz alta. Ese primer contacto es el más importante de todos.</p>
          </article>
          <article>
            <span class="du-portal-cuidados__num">02</span>
            <h3>Dónde ponerlo</h3>
            <p>Lugar fijo, no de paso. Mesa de luz, escritorio, repisa con luz natural. Lejos de baños y cocinas. Cerca de un cristal si tenés. No lo escondas — necesita ver y ser visto.</p>
          </article>
          <article>
            <span class="du-portal-cuidados__num">03</span>
            <h3>Limpieza energética</h3>
            <p>Cada luna llena, pasale una pluma o humo de palo santo. No lo mojes nunca. Si lo sentís cargado después de visitas pesadas, dejalo afuera 10 minutos.</p>
          </article>
          <article>
            <span class="du-portal-cuidados__num">04</span>
            <h3>Cuándo hablarle</h3>
            <p>Antes de dormir, antes de decisiones importantes, en momentos densos. No necesita ritual largo — solo tu intención clara y tu voz. Lo demás lo hace él.</p>
          </article>
        </div>
      </section>

      <section class="du-portal-aniversario">
        <p class="du-portal-aniversario__eyebrow">— Aniversario y ciclos —</p>
        <h2>El día que llegó es sagrado</h2>
        <p class="du-portal-aniversario__lead">Anotá la fecha en que adoptaste a tu Guardián. Cada año en ese día, hacé un ritual mínimo: una vela, una respiración, decirle gracias. El vínculo se renueva.</p>
        <p class="du-portal-aniversario__hint">El día que llegó está en tu correo de confirmación de Shopify.</p>
      </section>

      <section class="du-portal-comunidad">
        <p class="du-portal-comunidad__eyebrow">— Comunidad Elemental —</p>
        <h2>No estás sola en esto</h2>
        <p class="du-portal-comunidad__lead">Más de 15.000 Elegidos en 45 países ya recibieron a sus Guardianes. Compartimos experiencias, sueños y señales en nuestro blog y redes.</p>
        <div class="du-portal-comunidad__links">
          <a href="/blogs/comunidad-elemental">Leer historias →</a>
          <a href="https://instagram.com/duendesdeluruguay" target="_blank" rel="noopener">Instagram</a>
          <a href="/pages/test-del-guardian">Test del Guardián</a>
        </div>
      </section>

      {% if show_premium %}
        <section class="du-el-portal__premium">
          <p class="du-el-portal__premium-label">{{ section.settings.premium_eyebrow | escape }}</p>
          <h2>{{ section.settings.premium_title | escape }}</h2>
          <div class="rte">{{ section.settings.premium_body }}</div>
        </section>
      {% else %}
        <p class="du-el-portal__premium-hint">{{ section.settings.premium_locked_note | escape }}</p>
      {% endif %}
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .du-el-portal {
    position: relative;
    overflow: hidden;
    background: rgb(var(--color-background-rgb));
  }
  .du-el-portal__bg {
    pointer-events: none;
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(201, 169, 97, 0.12), transparent 55%);
    opacity: 1;
  }
  .du-el-portal__inner {
    position: relative;
    z-index: 1;
    padding-block: 48px 72px;
  }
  .du-el-portal__hero {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 40px;
  }
  .du-el-portal__glyph {
    font-family: var(--font-heading--family);
    letter-spacing: 0.45em;
    color: rgba(var(--color-foreground-rgb), 0.45);
    font-size: 1rem;
    margin: 0 0 12px;
  }
  .du-el-portal__eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    opacity: 0.75;
    margin: 0 0 10px;
  }
  .du-el-portal__title {
    font-family: var(--font-heading--family);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1.15;
    margin: 0 0 16px;
  }
  .du-el-portal__lead {
    font-style: italic;
    line-height: 1.65;
    opacity: 0.88;
    margin: 0 0 28px;
  }
  .du-el-portal__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }
  .du-el-portal__grid {
    display: grid;
    gap: 24px;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    margin-top: 8px;
  }
  .du-el-portal__card {
    border: 1px solid rgba(var(--color-foreground-rgb), 0.12);
    border-radius: 8px;
    padding: 28px 24px;
    background: rgba(var(--color-foreground-rgb), 0.03);
  }
  .du-el-portal__card h2 {
    font-size: 1.05rem;
    letter-spacing: 0.06em;
    margin: 0 0 14px;
  }
  .du-el-portal__premium {
    margin-top: 36px;
    padding: 32px 28px;
    border-radius: 8px;
    border: 1px solid rgba(201, 169, 97, 0.35);
    background: rgba(201, 169, 97, 0.06);
    text-align: center;
  }
  .du-el-portal__premium-label {
    font-size: 0.68rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    opacity: 0.8;
    margin: 0 0 10px;
  }
  .du-el-portal__premium h2 {
    margin: 0 0 12px;
    font-size: 1.35rem;
  }
  .du-el-portal__premium-hint {
    text-align: center;
    font-style: italic;
    opacity: 0.72;
    margin: 32px auto 0;
    max-width: 520px;
    font-size: 0.95rem;
  }

  /* ========= Biblioteca de los Elegidos · 7 flipbooks ========= */
  .du-portal-biblio { margin: 36px 0 28px; text-align: center; }
  .du-portal-biblio__eyebrow { font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 0.45em; text-transform: uppercase; color: #876a36; margin: 0 0 8px; }
  .du-portal-biblio__title { font-family: 'Great Vibes', cursive, var(--font-heading--family, serif); font-weight: 400; font-size: clamp(2rem, 4.2vw, 2.8rem); line-height: 1.1; margin: 0 0 10px; }
  .du-portal-biblio__lead { font-style: italic; opacity: 0.78; max-width: 560px; margin: 0 auto 28px; line-height: 1.6; }
  .du-portal-biblio__grid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  .du-portal-biblio__card {
    position: relative;
    display: flex; flex-direction: column; gap: 8px;
    padding: 28px 22px 26px 32px;
    text-decoration: none;
    border-radius: 4px 8px 8px 4px;
    color: #f5f0e1;
    overflow: hidden;
    min-height: 200px;
    transition: transform 0.35s ease, box-shadow 0.35s ease;
    box-shadow: 0 6px 22px rgba(0,0,0,0.25), inset -2px 0 0 rgba(0,0,0,0.18);
  }
  .du-portal-biblio__card:hover { transform: translateY(-3px) rotate(-0.3deg); box-shadow: 0 14px 34px rgba(0,0,0,0.4), inset -2px 0 0 rgba(0,0,0,0.2); }
  .du-portal-biblio__spine { position: absolute; left: 0; top: 0; bottom: 0; width: 10px; background: linear-gradient(180deg, rgba(255,255,255,0.18), rgba(0,0,0,0.25)); border-right: 1px solid rgba(0,0,0,0.25); }
  .du-portal-biblio__eyebrow-card { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.45em; text-transform: uppercase; opacity: 0.78; }
  .du-portal-biblio__name { font-family: 'Great Vibes', cursive, var(--font-heading--family, serif); font-weight: 400; font-size: 1.6rem; line-height: 1.1; margin-top: 4px; }
  .du-portal-biblio__meta { font-family: 'Cinzel', serif; font-size: 9.5px; letter-spacing: 0.3em; text-transform: uppercase; opacity: 0.72; margin-top: auto; }
  .du-portal-biblio__cta { font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 0.32em; text-transform: uppercase; opacity: 0.92; padding-top: 6px; border-top: 0.5px solid rgba(245,240,225,0.22); }

  .du-portal-biblio__card--bible    { background: radial-gradient(ellipse at top, #1a120a 0%, #050505 70%); }
  .du-portal-biblio__card--bible    .du-portal-biblio__eyebrow-card,
  .du-portal-biblio__card--bible    .du-portal-biblio__cta { color: #d6b370; }

  .du-portal-biblio__card--hadas    { background: linear-gradient(160deg, #4a1d28 0%, #6b3a44 60%, #2a0e14 100%); }
  .du-portal-biblio__card--hadas    .du-portal-biblio__eyebrow-card,
  .du-portal-biblio__card--hadas    .du-portal-biblio__cta { color: #e8c7c8; }

  .du-portal-biblio__card--pixies   { background: linear-gradient(160deg, #1f3a2c 0%, #3a5c47 60%, #0e1d16 100%); }
  .du-portal-biblio__card--pixies   .du-portal-biblio__eyebrow-card,
  .du-portal-biblio__card--pixies   .du-portal-biblio__cta { color: #d6b370; }

  .du-portal-biblio__card--elfos    { background: linear-gradient(160deg, #14264a 0%, #2b4670 55%, #08121f 100%); }
  .du-portal-biblio__card--elfos    .du-portal-biblio__eyebrow-card,
  .du-portal-biblio__card--elfos    .du-portal-biblio__cta { color: #c8d4e0; }

  .du-portal-biblio__card--gigantes { background: linear-gradient(160deg, #4a1822 0%, #6b1f2c 55%, #1a0810 100%); }
  .du-portal-biblio__card--gigantes .du-portal-biblio__eyebrow-card,
  .du-portal-biblio__card--gigantes .du-portal-biblio__cta { color: #d6b370; }

  .du-portal-biblio__card--deluxe   { background: linear-gradient(160deg, #2c1a4a 0%, #4a2c5c 55%, #120a1f 100%); }
  .du-portal-biblio__card--deluxe   .du-portal-biblio__eyebrow-card,
  .du-portal-biblio__card--deluxe   .du-portal-biblio__cta { color: #d4a86b; }

  .du-portal-biblio__card--bruja    { background: linear-gradient(160deg, #1a0e22 0%, #2a1838 55%, #080414 100%); }
  .du-portal-biblio__card--bruja    .du-portal-biblio__eyebrow-card,
  .du-portal-biblio__card--bruja    .du-portal-biblio__cta { color: #b08bd6; }

  @media (max-width: 600px) {
    .du-portal-biblio__grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .du-portal-biblio__card { padding: 20px 14px 18px 24px; min-height: 170px; }
    .du-portal-biblio__name { font-size: 1.3rem; }
    .du-portal-biblio__meta, .du-portal-biblio__cta { font-size: 8.5px; }
  }

  /* ════════════════════════════════════════════════════════════════
     Duendes 2026-05-17 — Cartas de tus Guardianes (post-adopción)
     ════════════════════════════════════════════════════════════════ */
  .du-portal-cartas {
    margin: 56px 0 48px;
    position: relative;
  }
  .du-portal-cartas__head {
    text-align: center;
    margin: 0 0 32px;
  }
  .du-portal-cartas__eyebrow {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.32em;
    color: #c9a96e;
    text-transform: uppercase;
    margin: 0 0 12px;
  }
  .du-portal-cartas__title {
    font-family: 'Cinzel', serif;
    font-weight: 500;
    font-size: clamp(28px, 4vw, 42px);
    color: #15110d;
    margin: 0 0 12px;
    letter-spacing: 0.02em;
  }
  .du-portal-cartas__sub {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: clamp(15px, 1.4vw, 18px);
    color: #6b5d4f;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.5;
  }
  .du-portal-cartas__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 22px;
  }

  /* CARTA */
  .du-portal-carta {
    background: linear-gradient(180deg, #1a1612 0%, #15110d 100%);
    border: 1px solid rgba(201,169,110,0.32);
    border-radius: 14px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.2, 0.7, 0.2, 1);
    box-shadow: 0 6px 22px -8px rgba(0,0,0,0.4);
  }
  .du-portal-carta[open] {
    border-color: rgba(201,169,110,0.65);
    box-shadow: 0 10px 32px -10px rgba(201,169,110,0.4), 0 0 0 1px rgba(201,169,110,0.25) inset;
  }
  .du-portal-carta__face {
    list-style: none;
    cursor: pointer;
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .du-portal-carta__face::-webkit-details-marker { display: none; }
  .du-portal-carta__face::marker { display: none; }

  .du-portal-carta__media {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(201,169,110,0.38);
    background: #0e0a07;
  }
  .du-portal-carta__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease, filter 0.6s ease;
    filter: brightness(0.85) saturate(0.95);
  }
  .du-portal-carta:hover .du-portal-carta__media img,
  .du-portal-carta[open] .du-portal-carta__media img {
    filter: brightness(1) saturate(1);
    transform: scale(1.03);
  }
  .du-portal-carta__seal {
    position: absolute;
    bottom: 10px;
    right: 10px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, #c9a96e, #8b6f3f);
    color: #15110d;
    font-family: 'Cinzel', serif;
    font-size: 14px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 3px 10px rgba(201,169,110,0.4);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .du-portal-carta[open] .du-portal-carta__seal {
    opacity: 0;
    transform: scale(0.6) rotate(180deg);
  }

  .du-portal-carta__body {
    text-align: center;
  }
  .du-portal-carta__eyebrow {
    display: block;
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 0.28em;
    color: #c9a96e;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .du-portal-carta__name {
    font-family: 'Cinzel', serif;
    font-weight: 500;
    font-size: 22px;
    color: #f5f0e1;
    margin: 0 0 8px;
    letter-spacing: 0.02em;
  }
  .du-portal-carta__chip {
    display: inline-block;
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c9a96e;
    padding: 3px 10px;
    border: 1px solid rgba(201,169,110,0.4);
    border-radius: 999px;
    margin: 0 0 10px;
  }
  .du-portal-carta__cta {
    display: block;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 13px;
    color: rgba(245,240,225,0.7);
    margin-top: 4px;
  }
  .du-portal-carta[open] .du-portal-carta__cta { display: none; }

  /* CONTENIDO REVELADO */
  .du-portal-carta__inner {
    padding: 0 22px 26px;
    animation: cartaIn 0.7s ease;
  }
  @keyframes cartaIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .du-portal-carta__hello {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: #c9a96e;
    text-transform: uppercase;
    text-align: center;
    margin: 0 0 18px;
    padding-top: 10px;
    border-top: 1px solid rgba(201,169,110,0.2);
  }
  .du-portal-carta__letter {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 16px;
    line-height: 1.65;
    color: #f5f0e1;
    white-space: pre-line;
  }
  .du-portal-carta__letter p,
  .du-portal-carta__letter br + br {
    margin-bottom: 10px;
  }
  .du-portal-carta__hint {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 12px;
    color: rgba(245,240,225,0.55);
    text-align: center;
    margin: 18px 0 0;
  }

  @media (max-width: 600px) {
    .du-portal-cartas { margin: 40px 0 36px; }
    .du-portal-cartas__grid { grid-template-columns: 1fr; gap: 16px; }
    .du-portal-carta__name { font-size: 19px; }
    .du-portal-carta__letter { font-size: 15px; }
  }

  /* ═══════════════════════════════════════════════════════════
     Duendes 2026-05-17 — Card LOCKED (libro no adoptado aún)
     ═══════════════════════════════════════════════════════════ */
  .du-portal-biblio__card--locked {
    position: relative;
    cursor: not-allowed;
    filter: grayscale(0.6) brightness(0.55);
    transition: filter 0.4s ease;
  }
  .du-portal-biblio__card--locked:hover {
    filter: grayscale(0.4) brightness(0.7);
  }
  .du-portal-biblio__card--locked::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.35);
    border-radius: inherit;
    pointer-events: none;
  }
  .du-portal-biblio__lock {
    position: relative;
    z-index: 2;
    display: block;
    margin-top: 14px;
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c9a96e;
    font-weight: 500;
  }

  /* ═══════════════════════════════════════════════════════════
     Duendes 2026-05-17 — Nuevos bloques de contenido
     Calendario lunar · Cuidados · Aniversario · Comunidad
     ═══════════════════════════════════════════════════════════ */
  .du-portal-luna,
  .du-portal-cuidados,
  .du-portal-aniversario,
  .du-portal-comunidad {
    margin: 48px 0;
    padding: 32px 24px;
    background: linear-gradient(180deg, #faf7ed 0%, #f5f0e1 100%);
    border-radius: 18px;
    border: 1px solid rgba(201,169,110,0.2);
  }
  .du-portal-luna__eyebrow,
  .du-portal-cuidados__eyebrow,
  .du-portal-aniversario__eyebrow,
  .du-portal-comunidad__eyebrow {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.3em;
    color: #c9a96e;
    text-transform: uppercase;
    text-align: center;
    margin: 0 0 10px;
  }
  .du-portal-luna__title,
  .du-portal-cuidados__title,
  .du-portal-aniversario h2,
  .du-portal-comunidad h2 {
    font-family: 'Cinzel', serif;
    font-weight: 500;
    font-size: clamp(24px, 3vw, 32px);
    color: #15110d;
    text-align: center;
    margin: 0 0 12px;
  }
  .du-portal-luna__lead,
  .du-portal-cuidados__lead,
  .du-portal-aniversario__lead,
  .du-portal-comunidad__lead {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 16px;
    color: #6b5d4f;
    text-align: center;
    max-width: 580px;
    margin: 0 auto 28px;
    line-height: 1.55;
  }

  /* Calendario lunar */
  .du-portal-luna__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 18px;
    margin-top: 22px;
  }
  .du-portal-luna__fase {
    background: white;
    border: 1px solid rgba(201,169,110,0.18);
    border-radius: 12px;
    padding: 22px 18px;
    text-align: center;
    transition: all 0.3s ease;
  }
  .du-portal-luna__fase:hover {
    border-color: rgba(201,169,110,0.5);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px -8px rgba(201,169,110,0.3);
  }
  .du-portal-luna__icon {
    font-size: 32px;
    display: block;
    margin-bottom: 8px;
  }
  .du-portal-luna__fase h3 {
    font-family: 'Cinzel', serif;
    font-weight: 500;
    font-size: 14px;
    color: #15110d;
    margin: 0 0 8px;
    letter-spacing: 0.04em;
  }
  .du-portal-luna__fase p {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 14px;
    color: #6b5d4f;
    line-height: 1.5;
    margin: 0;
  }

  /* Cuidados */
  .du-portal-cuidados__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 22px;
    margin-top: 24px;
  }
  .du-portal-cuidados__grid article {
    background: white;
    border: 1px solid rgba(201,169,110,0.18);
    border-radius: 12px;
    padding: 24px 22px;
    position: relative;
  }
  .du-portal-cuidados__num {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    color: #c9a96e;
    font-weight: 600;
  }
  .du-portal-cuidados__grid article h3 {
    font-family: 'Cinzel', serif;
    font-weight: 500;
    font-size: 17px;
    color: #15110d;
    margin: 6px 0 10px;
    letter-spacing: 0.02em;
  }
  .du-portal-cuidados__grid article p {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 15px;
    line-height: 1.6;
    color: #4a4035;
    margin: 0;
  }

  /* Aniversario */
  .du-portal-aniversario {
    text-align: center;
  }
  .du-portal-aniversario__hint {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 13px;
    color: #8a7657;
    margin: 12px 0 0;
  }

  /* Comunidad */
  .du-portal-comunidad {
    text-align: center;
  }
  .du-portal-comunidad__links {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 22px;
    margin-top: 18px;
  }
  .du-portal-comunidad__links a {
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #15110d;
    border-bottom: 1px solid rgba(201,169,110,0.4);
    padding: 4px 2px;
    transition: all 0.25s ease;
    text-decoration: none;
  }
  .du-portal-comunidad__links a:hover {
    color: #c9a96e;
    border-bottom-color: #c9a96e;
  }

  @media (max-width: 600px) {
    .du-portal-luna, .du-portal-cuidados, .du-portal-aniversario, .du-portal-comunidad {
      margin: 32px 0;
      padding: 24px 18px;
    }
    .du-portal-luna__grid { grid-template-columns: 1fr 1fr; gap: 12px; }
    .du-portal-luna__fase { padding: 18px 12px; }
    .du-portal-luna__fase h3 { font-size: 13px; }
    .du-portal-luna__fase p { font-size: 13px; }
    .du-portal-cuidados__grid { grid-template-columns: 1fr; }
    .du-portal-comunidad__links { gap: 14px; font-size: 11px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "El Portal (exclusivo)",
  "tag": "section",
  "class": "du-el-portal-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de color",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Visitante (sin sesión)"
    },
    {
      "type": "text",
      "id": "gate_title",
      "label": "Título",
      "default": "Mi Magia ✦"
    },
    {
      "type": "textarea",
      "id": "gate_lead",
      "label": "Texto",
      "default": "Mi Magia es el portal privado para Elegidos. Si tu Guardián ya te eligió, entrá con la cuenta que usaste para adoptarlo. Si todavía no, recorré el bosque — alguno te está esperando."
    },
    {
      "type": "text",
      "id": "gate_cta_login",
      "label": "Botón iniciar sesión",
      "default": "Iniciar sesión"
    },
    {
      "type": "text",
      "id": "gate_cta_register",
      "label": "Botón crear cuenta",
      "default": "Crear cuenta"
    },
    {
      "type": "header",
      "content": "Cliente autenticado"
    },
    {
      "type": "text",
      "id": "welcome_eyebrow",
      "label": "Antetítulo",
      "default": "Portal exclusivo"
    },
    {
      "type": "text",
      "id": "welcome_title",
      "label": "Título (usá [name] para el nombre)",
      "default": "Bienvenida, [name]"
    },
    {
      "type": "textarea",
      "id": "welcome_lead",
      "label": "Bajada",
      "default": "Acá reunimos guías para convivir con tu Guardián, cuidados sencillos y acceso a meditaciones y cartas canalizadas del estudio."
    },
    {
      "type": "text",
      "id": "block_guides_title",
      "label": "Bloque guías — título",
      "default": "Guías para tu Guardián"
    },
    {
      "type": "richtext",
      "id": "block_guides_body",
      "label": "Bloque guías — texto",
      "default": "<p>Cuando llega: dejalo respirar en su empaque unas horas, elegí un lugar con luz natural y poca circulación ruidosa. Primeros días: una vela corta o una flor fresca bastan como ofrenda simbólica. Ritual simple: tres respiraciones conscientes frente a él, nombralo en voz baja y decile por qué lo elegiste.</p>"
