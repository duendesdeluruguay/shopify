{% schema %}
{
  "name": "Duendes Señales",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Etiqueta", "default": "SINCRONICIDADES"},
    {"type": "text", "id": "title", "label": "Título", "default": "Las Señales de tu Guardián"},
    {"type": "textarea", "id": "intro", "label": "Intro", "default": "No estás loca. No es tu imaginación. Lo que sentís es real."},
    {"type": "image_picker", "id": "hero_image", "label": "Imagen hero"},
    {"type": "textarea", "id": "cta_text", "label": "Texto CTA", "default": "Si llegaste hasta acá, probablemente no fue casualidad."}
  ],
  "blocks": [
    {
      "type": "category_header",
      "name": "Categoría",
      "settings": [
        {"type": "text", "id": "eyebrow", "label": "Etiqueta", "default": "SEÑALES"},
        {"type": "text", "id": "title", "label": "Título", "default": "Señales Físicas"},
        {"type": "textarea", "id": "subtitle", "label": "Subtítulo"}
      ]
    },
    {
      "type": "signal_card",
      "name": "Señal",
      "settings": [
        {"type": "text", "id": "icon", "label": "Emoji", "default": "*"},
        {"type": "text", "id": "title", "label": "Título", "default": "Números repetidos"},
        {"type": "textarea", "id": "description", "label": "Descripción", "default": "Ves 11:11, 22:22 en el reloj. No es coincidencia."},
        {"type": "image_picker", "id": "image", "label": "Imagen (opcional)"}
      ]
    }
  ],
  "presets": [{"name": "Duendes Señales"}]
}
{% endschema %}

