      result_greeting: "tu guardián fue canalizado.",
      result_reveal: "Reconocelo",
      result_personal_label: "Mensaje personal",
      result_why_label: "Por qué te tocó",
      result_compat_title: "Otros que vibran cerca tuyo",
      result_compat_sub: "No son tu guardián central, pero te entienden.",
      result_cta: "Adoptarlo",
      receive_title: "Recibí tu canalización completa",
      receive_sub: "Te llega con el guardián, el mensaje y los compatibles.",
      receive_email: "Por email", receive_share_wa: "Compartir con alguien", receive_copy: "Copiar enlace",
