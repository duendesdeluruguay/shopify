  cursor: pointer;
}
.mm-back-link:hover { color: var(--gold); }

/* Empty state — elegant */
.mm-empty {
  text-align: center;
  padding: 100px 40px;
}

.mm-empty-text {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px; font-weight: 300;
  color: var(--text-light);
  margin-bottom: 32px;
}

.mm-btn-outline {
  display: inline-block;
  padding: 14px 40px;
  border: 1px solid var(--black);
  background: transparent;
  color: var(--black);
  font-family: 'Lato', sans-serif;
  font-size: 10px; font-weight: 700;
  letter-spacing: 3px; text-transform: uppercase;
  text-decoration: none;
  transition: all 0.3s;
  cursor: pointer;
}
.mm-btn-outline:hover { background: var(--black); color: var(--white); }

/* Recommendations */
.mm-reco-section {
  background: var(--surface);
  padding: 60px 40px;
}

.mm-reco-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  max-width: 1000px;
  margin: 0 auto;
}

.mm-reco-card {
  cursor: pointer;
  transition: opacity 0.3s;
}
.mm-reco-card:hover { opacity: 0.85; }

.mm-reco-card img {
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  margin-bottom: 12px;
}

.mm-reco-card h4 {
  font-family: 'Tangerine', cursive;
  font-size: 32px;
  font-weight: 700;
  color: var(--gold);
  margin-bottom: 4px;
}

.mm-reco-card .type {
  font-size: 9px; letter-spacing: 2px;
  text-transform: uppercase; color: var(--text-light);
}

.mm-reco-card .price {
  font-size: 14px; font-weight: 700;
  color: var(--text); margin-top: 6px;
}

/* Channeling cards */
.mm-ch-card {
  padding: 60px 0;
  border-bottom: 1px solid var(--line);
}

.mm-ch-card:last-child { border-bottom: none; }

.mm-ch-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32px;
}

.mm-ch-name {
  font-family: 'Tangerine', cursive;
  font-size: 56px;
  font-weight: 700;
  color: var(--gold);
  line-height: 1;
}

.mm-ch-type {
  font-size: 10px; font-weight: 700;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--text-light);
  margin-top: 6px;
}

.mm-ch-soul {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px; font-style: italic;
  color: var(--gold);
  margin-top: 4px;
}

.mm-ch-souls {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18px;
  margin-top: 18px;
  padding: 22px;
  background: linear-gradient(135deg, rgba(198,165,90,0.08), rgba(198,165,90,0.02));
  border: 1px solid rgba(198,165,90,0.25);
  border-radius: 10px;
  position: relative;
}
.mm-ch-souls::before {
  content: '\2726';
  position: absolute;
  top: -12px; left: 50%;
  transform: translateX(-50%);
  background: var(--bg, #080a06);
  color: var(--gold);
  padding: 0 10px;
  font-size: 16px;
}
@media (min-width: 720px) {
  .mm-ch-souls { grid-template-columns: 1fr 1fr; }
}
.mm-ch-soul-block { text-align: center; }
.mm-ch-soul-label {
  display: block;
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--text-light, #8a8a7a);
  margin-bottom: 6px;
}
.mm-ch-soul-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 28px;
  font-weight: 500;
  font-style: italic;
  color: var(--gold);
  margin: 0 0 6px 0;
  letter-spacing: 0.5px;
}
.mm-ch-soul-meaning {
  font-family: 'Cormorant Garamond', serif;
  font-size: 14px;
  line-height: 1.55;
  color: var(--text-mid);
  opacity: 0.85;
  margin: 0;
}

.mm-ch-date {
  font-size: 12px;
  color: var(--text-light);
}

.mm-ch-text {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px; font-weight: 300;
  line-height: 2;
  color: var(--text-mid);
  padding-left: 24px;
  border-left: 2px solid var(--gold);
}

.mm-ch-pending {
  padding: 40px;
  text-align: center;
  border: 1px dashed var(--line);
}

.mm-ch-pending p {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px; font-weight: 300;
  color: var(--text-light);
}

.mm-ch-care {
  margin-top: 32px;
  padding-top: 24px;
  border-top: 1px solid var(--line);
}

.mm-ch-care h4 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px; font-weight: 600;
  color: var(--gold);
  margin-bottom: 12px;
}

.mm-ch-care p {
  font-size: 14px; line-height: 1.8;
  color: var(--text-mid);
  margin-bottom: 8px;
}

/* ═══════════════════════════════════════
   DIARY
   ═══════════════════════════════════════ */
.mm-diary-form {
  background: var(--surface);
  padding: 48px;
  margin-bottom: 48px;
}

.mm-diary-form label {
  display: block;
  font-size: 9px; font-weight: 700;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--text-light);
  margin-bottom: 8px;
  margin-top: 20px;
}

.mm-diary-form label:first-child { margin-top: 0; }

.mm-select {
  width: 100%; max-width: 300px;
  padding: 12px 0;
  border: none; border-bottom: 1px solid var(--line-dark);
  font-family: 'Lato', sans-serif;
  font-size: 14px; color: var(--text);
  background: transparent;
  outline: none;
  -webkit-appearance: none;
}

.mm-textarea {
  width: 100%;
  min-height: 120px;
  padding: 16px 0;
  border: none; border-bottom: 1px solid var(--line-dark);
  font-family: 'Lato', sans-serif;
  font-size: 15px; color: var(--text);
  background: transparent;
  resize: vertical;
  outline: none;
}
.mm-textarea:focus { border-bottom-color: var(--gold); }

.mm-diary-entry {
  padding: 32px 0;
  border-bottom: 1px solid var(--line);
}

.mm-diary-entry .date {
  font-size: 10px; font-weight: 700;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 12px;
}

.mm-diary-entry .content {
  font-family: 'Cormorant Garamond', serif;
  font-size: 17px; font-weight: 300;
  line-height: 1.8;
  color: var(--text-mid);
}

/* ═══════════════════════════════════════
   ENCICLOPEDIA — Elegant accordion
   ═══════════════════════════════════════ */
.mm-accordion {
  border-bottom: 1px solid var(--line);
}

.mm-accordion-header {
  padding: 24px 0;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px; font-weight: 500;
  color: var(--text);
  transition: color 0.3s;
}

.mm-accordion-header:hover { color: var(--gold); }

.mm-accordion-arrow {
  font-size: 18px;
  color: var(--text-light);
  transition: transform 0.3s;
}

.mm-accordion-body {
  display: none;
  padding: 0 0 32px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px; font-weight: 300;
  line-height: 1.9;
  color: var(--text-mid);
}

.mm-accordion-body.open { display: block; }

/* ═══════════════════════════════════════
   CUIDADOS — Tabs + Content
   ═══════════════════════════════════════ */
.mm-tabs {
  display: flex; gap: 0;
  border-bottom: 1px solid var(--line);
  margin-bottom: 40px;
}

.mm-tab {
  padding: 16px 24px;
  font-size: 10px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--text-light);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: all 0.3s;
}

.mm-tab.active { color: var(--gold); border-bottom-color: var(--gold); }
.mm-tab:hover { color: var(--text); }

.mm-tab-panel { display: none; }
.mm-tab-panel.active { display: block; }

.mm-care-block {
  margin-bottom: 32px;
}

.mm-care-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px; font-weight: 600;
  color: var(--gold);
  margin-bottom: 10px;
}

.mm-care-text {
  font-size: 15px; line-height: 1.9;
  color: var(--text-mid);
}

/* Warning blocks */
.mm-warning {
  padding: 24px 0 24px 24px;
  border-left: 2px solid var(--red);
  margin-bottom: 24px;
}

.mm-warning-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 17px; font-weight: 600;
  color: var(--red);
  margin-bottom: 8px;
}

.mm-warning-text {
  font-size: 14px; line-height: 1.8;
  color: var(--text-mid);
}

/* Intention grid */
.mm-intention-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--line);
}

.mm-intention-card {
  padding: 32px;
  background: var(--white);
}

.mm-intention-card h4 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px; font-weight: 500;
  color: var(--gold);
  margin-bottom: 12px;
}

.mm-intention-card p {
  font-size: 14px; line-height: 1.8;
  color: var(--text-mid);
}

/* ═══════════════════════════════════════
   FRECUENCIAS & MEDITACIONES
   ═══════════════════════════════════════ */
.mm-freq-hero {
  background: linear-gradient(135deg, #0a0a08 0%, #1a1612 30%, #0f0d0a 60%, #0a0a08 100%);
  padding: 80px 40px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.mm-freq-hero::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at 50% 30%, rgba(184,151,59,0.08) 0%, transparent 70%);
  pointer-events: none;
}
.mm-freq-hero-label {
  font-size: 9px; font-weight: 700;
  letter-spacing: 5px; text-transform: uppercase;
  color: var(--gold-soft); margin-bottom: 16px;
  position: relative;
}
.mm-freq-hero-title {
  font-family: 'Tangerine', cursive;
  font-size: 64px; font-weight: 700;
  color: var(--gold);
  line-height: 1; margin-bottom: 12px;
  position: relative;
}
.mm-freq-hero-sub {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px; font-weight: 300;
  color: #999; letter-spacing: 1px;
  position: relative;
}
.mm-freq-tabs {
  display: flex; justify-content: center;
  border-bottom: 1px solid var(--line);
  background: var(--white);
  position: sticky; top: 56px; z-index: 90;
}
.mm-freq-tab {
  padding: 16px 28px;
  font-size: 10px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--text-light); cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all 0.3s;
}
.mm-freq-tab:hover { color: var(--text); }
.mm-freq-tab.active {
  color: var(--gold);
  border-bottom-color: var(--gold);
}
.mm-freq-panel { display: none; padding: 60px 40px; max-width: 900px; margin: 0 auto; }
.mm-freq-panel.active { display: block; }

/* Frequency cards */
.mm-freq-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 24px;
}
.mm-freq-card {
  background: var(--surface);
  border: 1px solid var(--line);
  padding: 32px 24px;
  text-align: center;
  transition: all 0.4s;
  cursor: default;
}
.mm-freq-card:hover {
  border-color: var(--gold-soft);
  box-shadow: 0 8px 32px rgba(184,151,59,0.1);
  transform: translateY(-2px);
}
.mm-freq-hz {
  font-family: 'Cormorant Garamond', serif;
  font-size: 36px; font-weight: 300;
  color: var(--gold);
  line-height: 1; margin-bottom: 4px;
}
.mm-freq-hz-unit {
  font-size: 14px; color: var(--gold-soft);
  letter-spacing: 2px;
}
.mm-freq-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px; font-weight: 600;
  color: var(--text);
  margin: 12px 0 8px;
  letter-spacing: 1px;
}
.mm-freq-desc {
  font-size: 13px; line-height: 1.7;
  color: var(--text-mid);
}
.mm-freq-play {
  display: inline-flex; align-items: center; gap: 8px;
  margin-top: 16px; padding: 8px 20px;
  background: var(--black);
  color: var(--white);
  font-size: 10px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  text-decoration: none;
  transition: all 0.3s;
}
.mm-freq-play:hover {
  background: var(--gold);
  color: var(--black);
}
.mm-freq-play svg { width: 12px; height: 12px; }

/* Meditation cards */
.mm-med-list { display: flex; flex-direction: column; gap: 24px; }
.mm-med-card {
  display: flex; gap: 24px;
  border: 1px solid var(--line);
  background: var(--white);
  transition: all 0.4s;
  overflow: hidden;
}
.mm-med-card:hover {
  border-color: var(--gold-soft);
  box-shadow: 0 8px 32px rgba(184,151,59,0.1);
}
.mm-med-thumb {
  width: 200px; min-height: 140px;
  background-size: cover; background-position: center;
  flex-shrink: 0;
  position: relative;
}
.mm-med-thumb::after {
  content: '▶'; position: absolute;
  top: 50%; left: 50%; transform: translate(-50%,-50%);
  width: 40px; height: 40px;
  background: rgba(0,0,0,0.7); color: var(--gold);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; padding-left: 3px;
  opacity: 0; transition: opacity 0.3s;
}
.mm-med-card:hover .mm-med-thumb::after { opacity: 1; }
.mm-med-info {
  padding: 24px; display: flex;
  flex-direction: column; justify-content: center;
}
.mm-med-duration {
  font-size: 9px; font-weight: 700;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--gold); margin-bottom: 8px;
}
.mm-med-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px; font-weight: 600;
  color: var(--text); margin-bottom: 8px;
}
.mm-med-desc {
  font-size: 13px; line-height: 1.7;
  color: var(--text-mid);
}
.mm-med-link {
  display: inline-block; margin-top: 12px;
  font-size: 10px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--gold); text-decoration: none;
  transition: color 0.3s;
}
.mm-med-link:hover { color: var(--black); }

/* Section intro */
.mm-freq-intro {
  text-align: center;
  max-width: 600px; margin: 0 auto 48px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px; font-weight: 300;
  line-height: 1.8; color: var(--text-mid);
}
.mm-freq-lang-toggle {
  display: flex; justify-content: center; gap: 12px;
  margin-bottom: 40px;
}
.mm-freq-lang {
  padding: 6px 16px;
  font-size: 10px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  cursor: pointer; transition: all 0.3s;
  border: 1px solid var(--line);
  color: var(--text-light);
  background: transparent;
}
.mm-freq-lang.active {
  background: var(--black); color: var(--white);
  border-color: var(--black);
}

/* ═══════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════ */
@media (max-width: 768px) {
  .mm-nav-bar { padding: 0 16px; }
  .mm-menu-panel { width: 100%; max-width: 100vw; }
  .mm-notif-panel { width: 100%; max-width: 100vw; }
  .mm-notif-toast { width: calc(100vw - 32px); right: -110vw; bottom: 16px; }
  .mm-notif-toast.visible { right: 16px; }

  .mm-welcome-block { padding: 60px 24px 40px; }
  .mm-welcome-name { font-size: 48px; }

  .mm-gotw { padding: 40px 20px 36px; }
  .mm-gotw-image { width: 150px; height: 150px; }
  .mm-gotw-name { font-size: 48px; }
  .mm-gotw-text { padding: 0 12px; }

  .mm-motd { padding: 60px 24px; }
  .mm-motd-quote { font-size: 22px; }

  .mm-elegidos { padding: 60px 24px; }
  .mm-elegidos-title { font-size: 28px; }

  .mm-portal-grid { grid-template-columns: repeat(3, 1fr); gap: 32px 20px; padding: 20px 16px 50px; }
  .mm-portal-circle { width: 110px; height: 110px; }
  .mm-portal-label { font-size: 12px; }
  .mm-identity-pair { gap: 30px; }
  .mm-identity-soul-name { font-size: 42px; }
  .mm-identity-block-name { font-size: 32px; }
  .mm-identity-section { padding: 30px 20px; margin-bottom: 40px; }

  .mm-content, .mm-content-wide { padding: 40px 24px; }
  .mm-hero { height: 35vh; min-height: 250px; }
  .mm-hero-content { padding: 30px 24px; }
  .mm-hero-title { font-size: 28px; }

  .mm-guardians-grid { gap: 24px; }
  .mm-g-card img, .mm-g-card-initial { width: 120px; height: 120px; font-size: 48px; }
  .mm-g-card-info { opacity: 1; transform: translateY(0); }

  .mm-reco-grid { grid-template-columns: 1fr 1fr; gap: 16px; }
  .mm-ch-name { font-size: 44px; }
  .mm-ch-header { flex-direction: column; gap: 8px; }

  .mm-diary-form { padding: 32px 24px; }

  .mm-intention-grid { grid-template-columns: 1fr; }

  .mm-tabs { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .mm-tab { white-space: nowrap; padding: 14px 16px; }

  .mm-freq-hero { padding: 60px 24px; }
  .mm-freq-hero-title { font-size: 48px; }
  .mm-freq-panel { padding: 40px 24px; }
  .mm-freq-grid { grid-template-columns: 1fr 1fr; }
  .mm-freq-tabs { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .mm-freq-tab { white-space: nowrap; padding: 14px 16px; }
  .mm-med-card { flex-direction: column; }
  .mm-med-thumb { width: 100%; min-height: 180px; }
}

@media (max-width: 480px) {
  .mm-guardians-grid { gap: 20px; }
  .mm-g-card img, .mm-g-card-initial { width: 100px; height: 100px; font-size: 42px; }
  .mm-reco-grid { grid-template-columns: 1fr; }
  .mm-gate-title { font-size: 52px; }
  .mm-freq-grid { grid-template-columns: 1fr; }
  .mm-freq-hero-title { font-size: 40px; }
}

/* ═══════ AMBIENT PARTICLES — subtle dashboard magic ═══════ */
.mm-ambient {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}
.mm-ambient-particle {
  position: absolute;
  width: 3px; height: 3px;
  background: var(--gold);
  border-radius: 50%;
  opacity: 0;
  animation: mmFloat 12s infinite ease-in-out;
}
.mm-ambient-particle:nth-child(2) { width: 2px; height: 2px; left: 15%; animation-delay: 2s; animation-duration: 15s; }
.mm-ambient-particle:nth-child(3) { width: 4px; height: 4px; left: 30%; animation-delay: 4s; animation-duration: 10s; }
.mm-ambient-particle:nth-child(4) { width: 2px; height: 2px; left: 50%; animation-delay: 1s; animation-duration: 14s; }
.mm-ambient-particle:nth-child(5) { width: 3px; height: 3px; left: 70%; animation-delay: 3s; animation-duration: 11s; }
.mm-ambient-particle:nth-child(6) { width: 2px; height: 2px; left: 85%; animation-delay: 5s; animation-duration: 13s; }
.mm-ambient-particle:nth-child(7) { width: 3px; height: 3px; left: 40%; animation-delay: 6s; animation-duration: 16s; }
.mm-ambient-particle:nth-child(8) { width: 2px; height: 2px; left: 60%; animation-delay: 0.5s; animation-duration: 12s; }

@keyframes mmFloat {
  0% { transform: translateY(100vh); opacity: 0; }
  10% { opacity: 0.4; }
  50% { opacity: 0.15; }
  90% { opacity: 0.3; }
  100% { transform: translateY(-20vh); opacity: 0; }
}

/* ═══════════════════════════════════════
   REVELACIÓN PROGRESIVA — Day-by-day unlock
   ═══════════════════════════════════════ */

.mm-reveal-container {
  margin-top: 40px;
}

.mm-reveal-progress {
  display: flex;
  align-items: center;
  gap: 0;
  margin-bottom: 48px;
  padding: 0 20px;
}

.mm-reveal-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--line);
  border: 1.5px solid var(--line);
  transition: all 0.6s ease;
  flex-shrink: 0;
  position: relative;
}

.mm-reveal-dot.unlocked {
  background: var(--gold);
  border-color: var(--gold);
  box-shadow: 0 0 12px rgba(184, 151, 59, 0.4);
}

.mm-reveal-dot.current {
  width: 14px; height: 14px;
  background: var(--gold);
  border-color: var(--gold);
  box-shadow: 0 0 20px rgba(184, 151, 59, 0.6);
  animation: mmPulseGold 2s infinite;
}

@keyframes mmPulseGold {
  0%, 100% { box-shadow: 0 0 12px rgba(184, 151, 59, 0.4); }
  50% { box-shadow: 0 0 24px rgba(184, 151, 59, 0.7); }
}

.mm-reveal-line {
  flex: 1;
  height: 1px;
  background: var(--line);
  transition: background 0.6s ease;
}

.mm-reveal-line.unlocked {
  background: var(--gold-soft);
}

.mm-reveal-day-label {
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--text-faint);
  text-align: center;
  margin-top: 6px;
}

.mm-reveal-section {
  opacity: 0;
  max-height: 0;
  overflow: hidden;
  transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  margin-bottom: 0;
}

.mm-reveal-section.visible {
  opacity: 1;
  max-height: 2000px;
  margin-bottom: 32px;
}

.mm-reveal-section-inner {
  border-left: 2px solid var(--gold-soft);
  padding: 24px 32px;
  position: relative;
}

.mm-reveal-section-inner::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, var(--gold-pale) 0%, transparent 60%);
  pointer-events: none;
}

.mm-reveal-tag {
  display: inline-block;
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 12px;
  position: relative;
  z-index: 1;
}

.mm-reveal-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px;
  font-weight: 400;
  color: var(--text);
  margin-bottom: 16px;
  position: relative;
  z-index: 1;
}

.mm-reveal-body {
  font-family: 'Cormorant Garamond', serif;
  font-size: 17px;
  font-weight: 300;
  line-height: 1.9;
  color: var(--text-mid);
  position: relative;
  z-index: 1;
}

/* Locked section teaser */
.mm-reveal-locked {
  padding: 24px 32px;
  border-left: 2px solid var(--line);
  position: relative;
  margin-bottom: 20px;
}

.mm-reveal-locked-tag {
  display: inline-block;
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--text-faint);
  margin-bottom: 8px;
}

.mm-reveal-locked-hint {
  font-family: 'Cormorant Garamond', serif;
  font-size: 15px;
  font-style: italic;
  color: var(--text-faint);
}

.mm-reveal-locked-icon {
  display: inline-block;
  width: 16px;
  height: 16px;
  margin-right: 6px;
  vertical-align: middle;
  opacity: 0.4;
}

/* New section glow animation */
.mm-reveal-section.just-unlocked .mm-reveal-section-inner {
  animation: mmNewReveal 2s ease-out;
}

@keyframes mmNewReveal {
  0% { background: rgba(184, 151, 59, 0.15); }
  100% { background: transparent; }
}

/* Completion celebration */
.mm-reveal-complete {
  text-align: center;
  padding: 40px 20px;
  margin-top: 20px;
}

.mm-reveal-complete-line {
  width: 60px;
  height: 1px;
  background: var(--gold);
  margin: 0 auto 20px;
}

.mm-reveal-complete-text {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px;
  font-style: italic;
  color: var(--gold-soft);
}

@media (max-width: 768px) {
  .mm-reveal-section-inner, .mm-reveal-locked { padding: 20px 20px; }
  .mm-reveal-progress { padding: 0 10px; }
  .mm-reveal-title { font-size: 19px; }
}

/* ═══════════════════════════════════════
   RITUAL STATE SECTION — Pergamino Sellado
   ═══════════════════════════════════════ */

.mm-ritual-cta {
  margin: 28px 0;
  padding: 32px;
  background: linear-gradient(135deg, rgba(198,165,90,0.05), rgba(198,165,90,0.02));
  border: 1px solid rgba(198,165,90,0.25);
  border-radius: 8px;
  text-align: center;
}

.mm-ritual-cta-inner {
  max-width: 420px;
  margin: 0 auto;
}

.mm-ritual-cta-icon {
  font-size: 48px;
  color: var(--gold);
  margin-bottom: 16px;
  opacity: 0.8;
}

.mm-ritual-cta-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 28px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8px;
}

.mm-ritual-cta-text {
  font-size: 14px;
  color: var(--text-mid);
  line-height: 1.6;
