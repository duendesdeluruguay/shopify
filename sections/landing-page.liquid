<script>
(function(){var URLS={latam:'https://uy.duendesdeluruguay.com',intl:'/'};var LABELS={latam:'Ir a Uruguay & Latinoam\u00e9rica',intl:'Ir a Tienda Internacional'};var last=getCookie('duendes_region');if(last&&URLS[last]){var banner=document.getElementById('returnBanner');var link=document.getElementById('returnLink');link.textContent=LABELS[last];link.href=URLS[last];link.onclick=function(e){e.preventDefault();window.location.href=URLS[last]};banner.style.display='flex'}window.goTo=function(region){setCookie('duendes_region',region,365);var u=URLS[region];if(u.indexOf('http')===0)u+='?r='+region;window.location.href=u};window.dismissReturn=function(){document.getElementById('returnBanner').style.display='none';deleteCookie('duendes_region')};function setCookie(n,v,d){var e=new Date();e.setTime(e.getTime()+(d*864e5));document.cookie=n+'='+v+';expires='+e.toUTCString()+';path=/;SameSite=Lax'}function getCookie(n){var c=document.cookie.split(';');for(var i=0;i<c.length;i++){var t=c[i].trim();if(t.indexOf(n+'=')=== 0)return t.substring(n.length+1)}return null}function deleteCookie(n){document.cookie=n+'=;expires=Thu, 01 Jan 1970 00:00:00 UTC;path=/;'}var CDN='https://cdn.shopify.com/s/files/1/0627/7785/2001/files/';var latamImages=[{src:CDN+'00046DF7-25B9-46F9-A7E4-132B3CDC8CFD.png?v=1774486368',pos:'center 20%'},{src:CDN+'E603E629-4FBF-47DA-BFBE-5FFA26DEC358.png?v=1774486369',pos:'center 20%'},{src:CDN+'D16BD6DE-31C3-42F6-A7DF-AFBEAB41A006.png?v=1774486368',pos:'center 20%'}];var intlImages=[{src:CDN+'A489F107-5795-432C-9040-78F0FC5FCBAC.png?v=1774486370',pos:'center 20%'},{src:CDN+'F6478C32-EE0B-411C-8023-3B6A71508150.png?v=1774486369',pos:'center 20%'}];function startSlideshow(prefix,images){var elA=document.getElementById(prefix+'-a');var elB=document.getElementById(prefix+'-b');if(!elA||!elB)return;var idx=0;var showingA=true;elA.style.backgroundImage='url('+images[0].src+')';elA.style.backgroundPosition=images[0].pos;images.forEach(function(img){new Image().src=img.src});setInterval(function(){idx=(idx+1)%images.length;if(showingA){elB.style.backgroundImage='url('+images[idx].src+')';elB.style.backgroundPosition=images[idx].pos;elA.classList.add('faded');elB.classList.add('visible')}else{elA.style.backgroundImage='url('+images[idx].src+')';elA.style.backgroundPosition=images[idx].pos;elA.classList.remove('faded');elB.classList.remove('visible')}showingA=!showingA},4500)}startSlideshow('latam',latamImages);startSlideshow('intl',intlImages);for(var i=0;i<30;i++){var p=document.createElement('div');p.className='particle';p.style.left=(Math.random()*100)+'%';p.style.top=(40+Math.random()*60)+'%';p.style.animationDuration=(6+Math.random()*10)+'s';p.style.animationDelay=(Math.random()*-15)+'s';p.style.width=p.style.height=(1+Math.random()*2)+'px';document.body.appendChild(p)}})();
