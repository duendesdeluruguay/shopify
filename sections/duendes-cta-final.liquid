{{ 'duendes-base.css' | asset_url | stylesheet_tag }}

<style>
  .dcf2 { position: relative; overflow: hidden; padding: clamp(100px, 14vw, 160px) 0; background: var(--black-deep, #080a06); text-align: center; color: var(--white, #FAFAF7); }
  .dcf2__bg { position: absolute; inset: 0; z-index: 0; }
  .dcf2__bg img { width: 100%; height: 100%; object-fit: cover; opacity: .25; filter: saturate(.5); }
  .dcf2__bg-overlay { position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 40%, rgba(8,10,6,.5) 0%, rgba(8,10,6,.82) 50%, rgba(8,10,6,.95) 100%); z-index: 1; }
  .dcf2::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 50%, rgba(198,165,90,.08), transparent 55%); z-index: 2; pointer-events: none; }
  .dcf2::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(198,165,90,.3), transparent); z-index: 3; }
  .dcf2__inner { position: relative; z-index: 3; max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .dcf2__eyebrow { font-family: var(--font-body-family, 'Cormorant Garamond', serif); font-size: 13px; font-weight: 500; letter-spacing: 5px; text-transform: uppercase; color: var(--gold, #C6A55A); margin-bottom: 28px; font-style: italic; }
  .dcf2__inner h2 { font-family: var(--font-heading-family, 'Cinzel', serif); font-size: clamp(36px, 5.5vw, 72px); font-weight: 400; color: #fff; line-height: 1.15; margin-bottom: 24px; letter-spacing: 2px; }
  .dcf2__inner h2 em { font-style: italic; color: var(--gold-lt, #D6BD7B); text-shadow: 0 0 60px rgba(198,165,90,.25); }
  .dcf2__diamond { display: flex; align-items: center; justify-content: center; gap: 20px; margin-bottom: 28px; }
  .dcf2__diamond::before, .dcf2__diamond::after { content: ''; width: 80px; height: 1px; background: linear-gradient(90deg, transparent, var(--gold, #C6A55A), transparent); opacity: .4; }
  .dcf2__diamond-icon { width: 10px; height: 10px; background: var(--gold, #C6A55A); transform: rotate(45deg); flex-shrink: 0; }
  .dcf2__sub { font-family: var(--font-body-family, 'Cormorant Garamond', serif); color: #FAFAF7; font-size: clamp(17px, 2vw, 21px); max-width: 620px; margin: 0 auto 16px; line-height: 1.7; font-style: italic; }
  .dcf2__shipping { color: rgba(255,255,255,.7); font-size: 12px; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 44px; }
  .dcf2__buttons { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; margin-bottom: 52px; }
  .dcf2 .duendes-btn-gold { padding: 19px 52px; font-size: 15px; letter-spacing: 3px; box-shadow: 0 8px 32px rgba(198,165,90,.25); }
  .dcf2 .duendes-btn-outline { border-color: rgba(255,255,255,.25); color: #ffffff; padding: 17px 44px; font-size: 14px; letter-spacing: 2.5px; }
  .dcf2 .duendes-btn-outline:hover { background: var(--gold, #C6A55A); border-color: var(--gold, #C6A55A); color: #fff; }
  .dcf2__trust { display: flex; gap: 40px; justify-content: center; flex-wrap: wrap; }
  .dcf2__badge { display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,.75); font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; transition: color .3s; }
  .dcf2__badge:hover { color: #ffffff; }
  .dcf2__badge svg { width: 20px; height: 20px; opacity: .4; transition: opacity .3s; }
  .dcf2__badge:hover svg { opacity: .7; }
  #dcf2Particles { position: absolute; inset: 0; pointer-events: none; z-index: 2; }
  @media (max-width: 768px) { .dcf2 { padding: 80px 0; } .dcf2__buttons { flex-direction: column; align-items: center; } .dcf2__trust { gap: 24px; } }
  @media (max-width: 480px) { .dcf2 { padding: 64px 0; } .dcf2__inner h2 { letter-spacing: 0; } }
</style>

<section class="dcf2" id="duendes-cta-final">
  {% if section.settings.background_image != blank %}
    <div class="dcf2__bg">
      <img src="{{ section.settings.background_image | image_url: width: 1920 }}" alt="" loading="lazy" fetchpriority="low">
      <div class="dcf2__bg-overlay"></div>
    </div>
  {% endif %}
  <canvas id="dcf2Particles"></canvas>

  <div class="dcf2__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="dcf2__eyebrow duendes-reveal">{{ section.settings.eyebrow }}</p>
    {% endif %}

    <h2 class="duendes-reveal">
      {{ section.settings.title_line1 }}<br>
      <em>{{ section.settings.title_line2 }}</em>
    </h2>

    <div class="dcf2__diamond duendes-reveal">
      <span class="dcf2__diamond-icon"></span>
    </div>

    <p class="dcf2__sub duendes-reveal delay-1">{{ section.settings.subtitle }}</p>
    <p class="dcf2__shipping duendes-reveal delay-1">{{ section.settings.shipping_text }}</p>

    <div class="dcf2__buttons duendes-reveal delay-2">
      {% if section.settings.primary_text != blank %}
        <a href="{{ section.settings.primary_url }}" class="duendes-btn-gold">{{ section.settings.primary_text }}</a>
      {% endif %}
      {% if section.settings.secondary_text != blank %}
        <a href="{{ section.settings.secondary_url }}" class="duendes-btn-outline">{{ section.settings.secondary_text }}</a>
      {% endif %}
    </div>

    <div class="dcf2__trust duendes-reveal delay-3">
      {% for block in section.blocks %}
        <div class="dcf2__badge" {{ block.shopify_attributes }}>
          {% case block.settings.icon %}
            {% when 'shield' %}
              <svg viewBox="0 0 18 18" fill="none"><path d="M9 2l5 3v4c0 3.5-2 6-5 7.5C6 15.5 4 12.5 4 9V5l5-3z" stroke="currentColor" stroke-width="1.2"/></svg>
            {% when 'card' %}
              <svg viewBox="0 0 18 18" fill="none"><rect x="3" y="6" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.2"/><path d="M3 9h12" stroke="currentColor" stroke-width="1.2"/></svg>
            {% when 'check' %}
              <svg viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.2"/><path d="M6 9l2 2 4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {% endcase %}
          <span>{{ block.settings.text }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
(function() {
  var canvas = document.getElementById('dcf2Particles');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var particles = [];

  function resize() {
    var section = canvas.parentElement;
    canvas.width = section.offsetWidth;
    canvas.height = section.offsetHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  for (var i = 0; i < 50; i++) {
    particles.push({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      r: Math.random() * 2.5 + 0.3,
      dx: (Math.random() - 0.5) * 0.25,
      dy: (Math.random() - 0.5) * 0.25,
      o: Math.random() * 0.4 + 0.05
    });
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    particles.forEach(function(p) {
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(198, 165, 90, ' + p.o + ')';
      ctx.fill();
      p.x += p.dx;
      p.y += p.dy;
      if (p.x < 0 || p.x > canvas.width) p.dx *= -1;
      if (p.y < 0 || p.y > canvas.height) p.dy *= -1;
    });
    requestAnimationFrame(draw);
  }

  var obs = new IntersectionObserver(function(entries) {
    if (entries[0].isIntersecting) { draw(); obs.disconnect(); }
  }, { threshold: 0.1 });
  obs.observe(canvas.parentElement);
})();
</script>

{% schema %}
{
  "name": "Duendes CTA Final",
  "tag": "section",
  "class": "duendes-cta-final-section",
  "settings": [
    {"type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1"},
    {"type": "text", "id": "eyebrow", "label": "Etiqueta superior", "default": "NO HAY REPOSICION"},
    {"type": "text", "id": "title_line1", "label": "Titulo linea 1", "default": "Tu guardian"},
    {"type": "text", "id": "title_line2", "label": "Titulo linea 2 (italica)", "default": "te esta buscando."},
    {"type": "text", "id": "subtitle", "label": "Subtitulo", "default": "No hay reposicion. Cuando se adopta, desaparece para siempre."},
    {"type": "text", "id": "shipping_text", "label": "Texto de envio", "default": "Env\u00edo mundial con tracking \u00b7 DAC en Uruguay"},
    {"type": "text", "id": "primary_text", "label": "Boton principal", "default": "Encontrar Mi Guardian"},
    {"type": "url", "id": "primary_url", "label": "Link principal"},
    {"type": "text", "id": "secondary_text", "label": "Boton secundario", "default": "Hacer el Test"},
    {"type": "url", "id": "secondary_url", "label": "Link secundario"},
    {"type": "image_picker", "id": "background_image", "label": "Imagen de fondo", "info": "Imagen hero de fondo para el CTA final. Se muestra con overlay oscuro para mantener legibilidad."}
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge de confianza",
      "settings": [
        {"type": "select", "id": "icon", "label": "Icono", "options": [{"value": "shield", "label": "Escudo"}, {"value": "card", "label": "Tarjeta"}, {"value": "check", "label": "Check"}], "default": "shield"},
        {"type": "text", "id": "text", "label": "Texto", "default": "PAGO SEGURO SSL"}
      ]
    }
  ],
  "presets": [
    {
      "name": "Duendes CTA Final",
      "blocks": [
        { "type": "badge", "settings": { "icon": "shield", "text": "PAGO SEGURO SSL" } },
        { "type": "badge", "settings": { "icon": "card", "text": "MERCADOPAGO \u00b7 PAYPAL \u00b7 DLOCAL" } },
        { "type": "badge", "settings": { "icon": "check", "text": "+15.000 GUARDIANES ENVIADOS" } }
      ]
    }
  ]
}
{% endschema %}
