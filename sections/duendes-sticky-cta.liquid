{{ 'duendes-base.css' | asset_url | stylesheet_tag }}
<style>
.dsticky{position:fixed;bottom:0;left:0;right:0;z-index:900;transform:translateY(100%);transition:transform .4s cubic-bezier(.16,1,.3,1);pointer-events:none}
.dsticky.show{transform:translateY(0);pointer-events:auto}
.dsticky-inner{display:none;padding:12px 16px;background:rgba(8,10,6,.95);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-top:1px solid rgba(198,165,90,.15);gap:10px;align-items:center;justify-content:space-between}
.dsticky-text{font-family:var(--serif,Georgia);font-size:13px;font-style:italic;color:#FAFAF7}
.dsticky-text strong{color:var(--gold,#C6A55A);font-weight:600;font-style:normal}
.dsticky-btn{padding:11px 24px;background:var(--gold,#C6A55A);color:#fff;font-family:var(--serif,Georgia);font-size:12px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;border-radius:6px;text-decoration:none;white-space:nowrap;position:relative;overflow:hidden;flex-shrink:0}
.dsticky-btn::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.12),transparent);transform:translateX(-100%);animation:dstickyShine 3s ease-in-out infinite}
@keyframes dstickyShine{0%{transform:translateX(-100%)}50%,100%{transform:translateX(100%)}}
@media(max-width:768px){.dsticky-inner{display:flex}}
</style>

<div class="dsticky" id="dstickyBar">
  <div class="dsticky-inner">
    <div class="dsticky-text"><strong>{{ section.settings.highlight }}</strong> {{ section.settings.text }}</div>
    <a href="{{ section.settings.cta_url }}" class="dsticky-btn">{{ section.settings.cta_text }}</a>
  </div>
</div>

<script>
(function(){
  var bar=document.getElementById('dstickyBar');
  if(!bar)return;
  var shown=false;
  window.addEventListener('scroll',function(){
    if(window.scrollY>800&&!shown){bar.classList.add('show');shown=true}
    if(window.scrollY<400&&shown){bar.classList.remove('show');shown=false}
  },{passive:true});
})();
</script>

{% schema %}
{
  "name": "Duendes Sticky CTA",
  "settings": [
    {"type": "text", "id": "highlight", "label": "Texto destacado", "default": "12 guardianes"},
    {"type": "text", "id": "text", "label": "Texto", "default": "disponibles ahora"},
    {"type": "text", "id": "cta_text", "label": "Texto botón", "default": "VER GUARDIANES"},
    {"type": "url", "id": "cta_url", "label": "Link botón"}
  ],
  "presets": [{"name": "Duendes Sticky CTA"}]
}
{% endschema %}


