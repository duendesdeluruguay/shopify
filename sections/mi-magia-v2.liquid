function mmRenderChecklist(containerId, tasks, type, guardianName) {
  var container = document.getElementById(containerId);
  container.innerHTML = '';
  
  tasks.forEach(function(task, idx) {
    var dayNum = idx + 1;
    var item = document.createElement('div');
    item.className = 'mm-checklist-item';
    
    var storageKey = 'mm_' + type + '_' + guardianName + '_' + dayNum;
    var isChecked = localStorage.getItem(storageKey) === 'true';
    
    if (isChecked) item.classList.add('checked');
    
    var checkbox = document.createElement('input');
    checkbox.type = 'checkbox';
    checkbox.className = 'mm-checkbox';
    checkbox.checked = isChecked;
    checkbox.onchange = function(e) {
      localStorage.setItem(storageKey, e.target.checked);
      item.classList.toggle('checked');
      mmUpdateProgress(containerId, type, guardianName, tasks.length);
    };
    
    item.appendChild(checkbox);
    var dayDiv = document.createElement('div');
    dayDiv.style.flex = '1';
    dayDiv.innerHTML = '<p class="mm-checklist-day">Día ' + dayNum + '</p><p class="mm-checklist-text">' + task + '</p>';
    item.appendChild(dayDiv);
    container.appendChild(item);
  });
  
  mmUpdateProgress(containerId, type, guardianName, tasks.length);
}

function mmUpdateProgress(containerId, type, guardianName, totalTasks) {
  var completed = 0;
  for (var i = 1; i <= totalTasks; i++) {
    if (localStorage.getItem('mm_' + type + '_' + guardianName + '_' + i) === 'true') completed++;
  }
  
  var progressId = type === 'ritual' ? 'mm-ritual-progress' : 'mm-postrecep-progress';
  var labelId = type === 'ritual' ? 'mm-ritual-label' : 'mm-postrecep-label';
  
  var fill = document.getElementById(progressId);
  if (fill) fill.style.width = (completed / totalTasks) * 100 + '%';
  
  var label = document.getElementById(labelId);
  if (label) label.textContent = completed + ' de ' + totalTasks + ' completados';
}

// Fix encoding issues from Google Sheets (e.g. "Guardiv°n" → "Guardián")
function mmFixEncoding(str) {
  if (!str) return str;
  return str.replace(/v\u00b0/g, 'á').replace(/√°/g, 'á').replace(/√≠/g, 'í')
    .replace(/√©/g, 'é').replace(/√∫/g, 'ú').replace(/√±/g, 'ñ').replace(/√≥/g, 'ó');
}

