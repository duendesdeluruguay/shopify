{{ 'duendes-base.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign dh2_lin_tag = section.settings.tag | strip
  if dh2_lin_tag == blank
    assign dh2_lin_tag = 'duendes.home_v2.linajes.tag' | t
  endif
  assign dh2_lin_title = section.settings.title | strip
  if dh2_lin_title == blank
    assign dh2_lin_title = 'duendes.home_v2.linajes.title' | t
  endif
-%}
<style>
  .dh2-lin {
    background: #faf9f6;
    padding: 64px 0 72px;
    color: #15110d;
  }
  .dh2-lin__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .dh2-lin__tag {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(21, 17, 13, 0.45);
    text-align: center;
    margin-bottom: 12px;
  }
  .dh2-lin__title {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-weight: 400;
    font-size: clamp(24px, 3vw, 36px);
    text-align: center;
    margin: 0 0 36px;
  }
  .dh2-lin__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }
  .dh2-lin__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
    background: #fff;
    border-radius: 12px;
    padding: 18px 12px 16px;
    border: 1px solid rgba(21, 17, 13, 0.08);
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.04);
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .dh2-lin__card:hover {
    border-color: rgba(201, 169, 97, 0.45);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.08);
    transform: translateY(-3px);
  }
  .dh2-lin__icon {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(145deg, rgba(201, 169, 97, 0.2), rgba(201, 169, 97, 0.05));
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
    overflow: hidden;
  }
  .dh2-lin__icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .dh2-lin__glyph {
    font-size: 22px;
    line-height: 1;
  }
  .dh2-lin__name {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 6px;
  }
  .dh2-lin__count {
    font-family: var(--font-body--family, 'Cormorant Garamond', Georgia, serif);
    font-size: 13px;
    color: rgba(21, 17, 13, 0.55);
  }
  @media (max-width: 989px) {
    .dh2-lin__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<section class="dh2-lin section">
  <div class="dh2-lin__inner">
    <p class="dh2-lin__tag">{{ dh2_lin_tag }}</p>
    <h2 class="dh2-lin__title">{{ dh2_lin_title }}</h2>
    <div class="dh2-lin__grid">
      {% for block in section.blocks %}
        {% if block.type == 'linaje' %}
          <a class="dh2-lin__card" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
            <div class="dh2-lin__icon">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: block.settings.title }}
              {% else %}
                <span class="dh2-lin__glyph" aria-hidden="true">{{ block.settings.glyph | default: '✦' }}</span>
              {% endif %}
            </div>
            <h3 class="dh2-lin__name">{{ block.settings.title }}</h3>
            <span class="dh2-lin__count">{{ block.settings.count_label }}</span>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DDU v2 · Linajes",
  "tag": "section",
  "class": "duendes-home-v2-linajes-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Etiqueta",
      "default": "POR LINAJE"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Encontrá tu Guardián por su linaje"
    }
  ],
  "blocks": [
    {
      "type": "linaje",
      "name": "Linaje",
      "settings": [
        { "type": "text", "id": "title", "label": "Nombre", "default": "Hadas" },
        { "type": "url", "id": "url", "label": "Enlace a colección" },
        { "type": "text", "id": "count_label", "label": "Disponibles (texto)", "default": "Ver colección" },
        { "type": "image_picker", "id": "image", "label": "Imagen (opcional)" },
        { "type": "text", "id": "glyph", "label": "Ícono texto si no hay imagen", "default": "✦" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DDU v2 · Linajes",
      "blocks": [
        { "type": "linaje", "settings": { "title": "Hadas", "url": "shopify://collections/hadas" } },
        { "type": "linaje", "settings": { "title": "Pixies", "url": "shopify://collections/pixies" } },
        { "type": "linaje", "settings": { "title": "Elfos", "url": "shopify://collections/elfos" } },
        { "type": "linaje", "settings": { "title": "Medianos", "url": "shopify://collections/medianos" } },
        { "type": "linaje", "settings": { "title": "Maestros", "url": "shopify://collections/maestros" } },
        { "type": "linaje", "settings": { "title": "Deluxe", "url": "shopify://collections/deluxe" } },
        { "type": "linaje", "settings": { "title": "Brujas", "url": "shopify://collections/brujas" } },
        { "type": "linaje", "settings": { "title": "Grandes", "url": "shopify://collections/grandes" } },
        { "type": "linaje", "settings": { "title": "Gigantes", "url": "shopify://collections/gigantes" } },
        { "type": "linaje", "settings": { "title": "Históricos", "url": "shopify://collections/historicos" } }
      ]
    }
  ]
}
{% endschema %}
