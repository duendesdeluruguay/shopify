 * Fetch ritual state for each channeling from GAS
 * States: not_filled, in_progress, review, published
 */
async function mmLoadRitualStates() {
  if (!mmChannelings || mmChannelings.length === 0) return;
  if (!mmCustomer || !mmCustomer.email) return;

  // For each channeling, fetch its ritual state
  mmChannelings.forEach(function(ch, idx) {
    // If no guardianName, skip (legacy issue)
    if (!ch.guardianName) return;

    // Call GAS to get ritual state for this specific guardian
    var url = GAS_URL + '?action=get_ritual_state&email=' + encodeURIComponent(mmCustomer.email)
      + '&guardianName=' + encodeURIComponent(ch.guardianName);

    fetch(url, { redirect: 'follow' })
      .then(function(r) { return r.text(); })
      .then(function(text) {
        try {
          var data = JSON.parse(text);
          if (data && data.state) {
            ch.ritualState = data.state;
            ch.ritualAnswers = data.answers || null;
            ch.ritualArchetype = data.archetype || null;
            // Once loaded, re-render the guardian detail or the page
            mmUpdateGuardianRitualDisplay(idx);
          }
        } catch(e) { /* Silent — fallback to no ritual state */ }
      })
      .catch(function(e) { /* Silent — network error */ });
  });
}

