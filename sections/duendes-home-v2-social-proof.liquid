{{ 'duendes-base.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign dh2_sp_tag = section.settings.tag | strip
  if dh2_sp_tag == blank
    assign dh2_sp_tag = 'duendes.home_v2.social_proof.tag' | t
  endif
  assign dh2_sp_num = section.settings.number | strip
  if dh2_sp_num == blank
    assign dh2_sp_num = 'duendes.home_v2.social_proof.number' | t
  endif
  assign dh2_sp_subtitle = section.settings.subtitle | strip
  if dh2_sp_subtitle == blank
    assign dh2_sp_subtitle = 'duendes.home_v2.social_proof.subtitle' | t
  endif
  assign dh2_sp_title = section.settings.title | strip
  if dh2_sp_title == blank
    assign dh2_sp_title = 'duendes.home_v2.social_proof.title' | t
  endif
-%}
<style>
  .dh2-sp {
    background: #faf9f6;
    padding: 64px 0 72px;
    color: #15110d;
  }
  .dh2-sp__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .dh2-sp__tag {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(21, 17, 13, 0.45);
    text-align: center;
    margin-bottom: 14px;
  }
  .dh2-sp__headline {
    text-align: center;
    margin: 0 0 40px;
  }
  .dh2-sp__number {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-weight: 400;
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.1;
    margin: 0 0 10px;
    color: #15110d;
  }
  .dh2-sp__subtitle {
    font-family: var(--font-body--family, 'Cormorant Garamond', Georgia, serif);
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.45;
    margin: 0 auto;
    max-width: 560px;
    color: rgba(21, 17, 13, 0.68);
    font-style: italic;
  }
  .dh2-sp__title-fallback {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-weight: 400;
    font-size: clamp(24px, 3vw, 38px);
    text-align: center;
    margin: 0 0 40px;
    line-height: 1.2;
  }
  .dh2-sp__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .dh2-sp__card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    display: flex;
    flex-direction: column;
  }
  .dh2-sp__photo {
    aspect-ratio: 1;
    background: linear-gradient(145deg, #e8e4dc, #d4cfc4);
    overflow: hidden;
  }
  .dh2-sp__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .dh2-sp__quote {
    padding: 16px 16px 20px;
    font-family: var(--font-body--family, 'Cormorant Garamond', Georgia, serif);
    font-size: 15px;
    line-height: 1.45;
    font-style: italic;
    color: rgba(21, 17, 13, 0.82);
    flex: 1;
  }
  @media (max-width: 989px) {
    .dh2-sp__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 549px) {
    .dh2-sp__grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .dh2-sp.section {
      overflow-x: hidden;
    }
    .dh2-sp__inner {
      padding-left: max(20px, env(safe-area-inset-left, 0px));
      padding-right: max(24px, env(safe-area-inset-right, 0px));
    }
    h2.dh2-sp__title-fallback,
    .dh2-sp__title-fallback {
      font-size: 26px !important;
      line-height: 1.15 !important;
      max-width: 100% !important;
    }
    .dh2-sp__number {
      font-size: 32px !important;
    }
    .dh2-sp__subtitle {
      font-size: 16px !important;
    }
    .dh2-sp__quote {
      font-size: 16px !important;
      line-height: 1.45 !important;
    }
    .dh2-sp__tag {
      font-size: 9px !important;
    }
  }
</style>

<section class="dh2-sp section">
  <div class="dh2-sp__inner">
    <p class="dh2-sp__tag">{{ dh2_sp_tag }}</p>
    {% if dh2_sp_num != blank or dh2_sp_subtitle != blank %}
      <div class="dh2-sp__headline">
        {% if dh2_sp_num != blank %}
          <p class="dh2-sp__number">{{ dh2_sp_num }}</p>
        {% endif %}
        {% if dh2_sp_subtitle != blank %}
          <p class="dh2-sp__subtitle">{{ dh2_sp_subtitle }}</p>
        {% endif %}
      </div>
    {% elsif dh2_sp_title != blank %}
      <h2 class="dh2-sp__title-fallback">{{ dh2_sp_title }}</h2>
    {% endif %}
    <div class="dh2-sp__grid">
    {% for block in section.blocks %}
        {% if block.type == 'testimonial' %}
          {% unless block.settings.photo == blank %}
          {% liquid
            assign dh2_sp_quote = block.settings.quote | strip
            if dh2_sp_quote == blank
              case forloop.index
                when 1
                  assign dh2_sp_quote = 'duendes.home_v2.social_proof.quote_1' | t
                when 2
                  assign dh2_sp_quote = 'duendes.home_v2.social_proof.quote_2' | t
                when 3
                  assign dh2_sp_quote = 'duendes.home_v2.social_proof.quote_3' | t
                else
                  assign dh2_sp_quote = 'duendes.home_v2.social_proof.quote_4' | t
              endcase
            endif
          %}
          <article class="dh2-sp__card" {{ block.shopify_attributes }}>
            <div class="dh2-sp__photo">
              {{ block.settings.photo | image_url: width: 600 | image_tag: loading: 'lazy', sizes: '(min-width:990px) 25vw, (min-width:550px) 50vw, 100vw', widths: '200,400,600' }}
            </div>
            <p class="dh2-sp__quote">{{ dh2_sp_quote }}</p>
          </article>
          {% endunless %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DDU v2 · Prueba soc",
  "tag": "section",
  "class": "duendes-home-v2-social-proof-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Etiqueta superior",
      "default": "LO QUE CUENTAN LOS QUE LLEGARON ANTES"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título (fallback si no hay número/subtítulo)",
      "default": "Adoptado por +15.000 personas en todo el mundo"
    },
    {
      "type": "text",
      "id": "number",
      "label": "Cifra destacada",
      "default": "+15.000"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo bajo la cifra",
      "default": "Guardianes adoptados en 45 países desde 2015."
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonio",
      "settings": [
        { "type": "image_picker", "id": "photo", "label": "Foto", "info": "Cargá foto real del cliente con su Guardián. Si está vacío, el testimonio no aparece." },
        { "type": "textarea", "id": "quote", "label": "Frase", "default": "Cuando lo abrí, sentí que alguien me había elegido de verdad." }
      ]
    }
  ],
  "presets": [
    {
      "name": "DDU v2 · Prueba soc",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
