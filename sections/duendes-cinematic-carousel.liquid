{{ 'duendes-base.css' | asset_url | stylesheet_tag }}
<style>
.dcc{position:relative;overflow:hidden;padding:0;background:var(--black-deep, #080a06)}
.dcc-track{display:flex;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;scroll-behavior:smooth}
.dcc-track::-webkit-scrollbar{display:none}

.dcc-slide{flex:0 0 100%;scroll-snap-align:start;position:relative;min-height:70vh;display:flex;align-items:center;justify-content:center;overflow:hidden}

/* Cinematic backgrounds */
.dcc-slide__bg{position:absolute;inset:0;z-index:0}
.dcc-slide__bg img{width:100%;height:100%;object-fit:cover;transition:transform 8s linear}
.dcc-slide.active .dcc-slide__bg img{transform:scale(1.08)}
.dcc-slide__bg::after{content:'';position:absolute;inset:0;z-index:1}
.dcc-slide--dark .dcc-slide__bg::after{background:linear-gradient(135deg,rgba(8,10,6,.85),rgba(8,10,6,.6))}
.dcc-slide--gold .dcc-slide__bg::after{background:linear-gradient(135deg,rgba(8,10,6,.75),rgba(30,25,10,.7))}
.dcc-slide--forest .dcc-slide__bg::after{background:linear-gradient(135deg,rgba(20,35,15,.8),rgba(8,10,6,.7))}

/* Particles layer */
.dcc-particles{position:absolute;inset:0;z-index:1;pointer-events:none;overflow:hidden}
.dcc-particle{position:absolute;width:2px;height:2px;background:var(--gold, #C6A55A);border-radius:50%;opacity:0;animation:dccFloat 6s ease-in-out infinite}
@keyframes dccFloat{0%{opacity:0;transform:translateY(0) scale(0)}20%{opacity:.6}50%{opacity:.8;transform:translateY(-80px) scale(1.2)}80%{opacity:.3}100%{opacity:0;transform:translateY(-160px) scale(0)}}

/* Content */
.dcc-slide__content{position:relative;z-index:2;text-align:center;max-width:720px;padding:40px 24px}
.dcc-eyebrow{font-family:var(--serif, Georgia);font-size:11px;letter-spacing:5px;text-transform:uppercase;color:var(--gold, #C6A55A);margin-bottom:16px;opacity:0;transform:translateY(15px);transition:all .8s .2s}
.dcc-title{font-family:var(--serif, Georgia);font-size:clamp(28px,4.5vw,52px);font-weight:300;color:#fff;line-height:1.15;margin:0 0 16px;opacity:0;transform:translateY(20px);transition:all .8s .35s}
.dcc-title em{font-style:italic;color:var(--gold-lt, #D6BD7B);text-shadow:0 0 40px rgba(198,165,90,.2)}
.dcc-body{font-family:var(--serif, Georgia);font-size:clamp(15px,1.8vw,18px);font-style:italic;color:#FAFAF7;line-height:1.7;margin:0 0 28px;max-width:560px;margin-left:auto;margin-right:auto;opacity:0;transform:translateY(20px);transition:all .8s .5s}
.dcc-stat{display:inline-flex;align-items:baseline;gap:8px;padding:10px 24px;border:1px solid rgba(198,165,90,.15);border-radius:24px;background:rgba(198,165,90,.04);margin-bottom:24px;opacity:0;transform:translateY(15px);transition:all .8s .45s}
.dcc-stat strong{font-family:var(--serif, Georgia);font-size:clamp(20px,3vw,32px);color:var(--gold, #C6A55A);font-weight:400}
.dcc-stat span{font-family:var(--serif, Georgia);font-size:13px;color:#FAFAF7;font-style:italic}
.dcc-cta{display:inline-flex;align-items:center;gap:8px;padding:14px 36px;background:var(--gold, #C6A55A);color:#fff;font-family:var(--serif, Georgia);font-size:12px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;border-radius:6px;text-decoration:none;transition:all .4s;opacity:0;transform:translateY(15px);transition:all .8s .6s;position:relative;overflow:hidden}
.dcc-cta::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.12),transparent);transform:translateX(-100%);animation:dccShine 3s ease-in-out infinite 1.5s}
@keyframes dccShine{0%{transform:translateX(-100%)}40%,100%{transform:translateX(100%)}}
.dcc-cta:hover{transform:translateY(-2px)!important;box-shadow:0 8px 32px rgba(198,165,90,.4)}

/* Active state - animate in */
.dcc-slide.active .dcc-eyebrow,
.dcc-slide.active .dcc-title,
.dcc-slide.active .dcc-body,
.dcc-slide.active .dcc-stat,
.dcc-slide.active .dcc-cta{opacity:1;transform:translateY(0)}

/* Navigation dots */
.dcc-nav{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);z-index:10;display:flex;gap:10px}
.dcc-dot{width:8px;height:8px;border-radius:50%;border:1px solid rgba(198,165,90,.3);background:transparent;cursor:pointer;transition:all .4s;padding:0}
.dcc-dot.active{background:var(--gold, #C6A55A);border-color:var(--gold, #C6A55A);box-shadow:0 0 12px rgba(198,165,90,.4);transform:scale(1.2)}

/* Side arrows */
.dcc-arrow{position:absolute;top:50%;transform:translateY(-50%);z-index:10;width:44px;height:44px;border-radius:50%;border:1px solid rgba(198,165,90,.15);background:rgba(8,10,6,.5);backdrop-filter:blur(8px);color:var(--gold, #C6A55A);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .3s;font-size:18px;padding:0}
.dcc-arrow:hover{background:rgba(198,165,90,.15);border-color:var(--gold, #C6A55A);box-shadow:0 0 20px rgba(198,165,90,.15)}
.dcc-arrow--prev{left:20px}
.dcc-arrow--next{right:20px}

/* Progress bar */
.dcc-progress{position:absolute;bottom:0;left:0;right:0;height:2px;z-index:10;background:rgba(255,255,255,.05)}
.dcc-progress__fill{height:100%;background:linear-gradient(90deg,var(--gold, #C6A55A),#e8d48b);width:0%;transition:width .1s linear}

@media(max-width:768px){
  .dcc-slide{min-height:80vh}
  .dcc-arrow{display:none}
  .dcc-nav{bottom:20px}
}
</style>

<section class="dcc" id="dccCarousel">
  <div class="dcc-track" id="dccTrack">

    {%- for block in section.blocks -%}
      <div class="dcc-slide dcc-slide--{{ block.settings.theme }}{% if forloop.first %} active{% endif %}" {{ block.shopify_attributes }}>
        <div class="dcc-slide__bg">
          {%- if block.settings.bg_image -%}
            <img src="{{ block.settings.bg_image | image_url: width: 1920 }}" alt="" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
          {%- else -%}
            <div style="width:100%;height:100%;background:var(--black-deep, #080a06)"></div>
          {%- endif -%}
        </div>
        <div class="dcc-particles" data-particles></div>
        <div class="dcc-slide__content">
          {%- if block.settings.eyebrow != blank -%}
            <div class="dcc-eyebrow">{{ block.settings.eyebrow }}</div>
          {%- endif -%}
          <h2 class="dcc-title">{{ block.settings.title }}</h2>
          {%- if block.settings.stat_number != blank -%}
            <div class="dcc-stat">
              <strong>{{ block.settings.stat_number }}</strong>
              <span>{{ block.settings.stat_label }}</span>
            </div>
          {%- endif -%}
          {%- if block.settings.body != blank -%}
            <p class="dcc-body">{{ block.settings.body }}</p>
          {%- endif -%}
          {%- if block.settings.cta_text != blank -%}
            <a href="{{ block.settings.cta_url }}" class="dcc-cta">{{ block.settings.cta_text }}</a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}

  </div>

  <button class="dcc-arrow dcc-arrow--prev" id="dccPrev"></button>
  <button class="dcc-arrow dcc-arrow--next" id="dccNext"></button>

  <div class="dcc-nav" id="dccNav">
    {%- for block in section.blocks -%}
      <button class="dcc-dot{% if forloop.first %} active{% endif %}" data-idx="{{ forloop.index0 }}"></button>
    {%- endfor -%}
  </div>

  <div class="dcc-progress"><div class="dcc-progress__fill" id="dccProgress"></div></div>
</section>

<script>
(function(){
  var track=document.getElementById('dccTrack');
  var slides=track.querySelectorAll('.dcc-slide');
  var dots=document.querySelectorAll('.dcc-dot');
  var progress=document.getElementById('dccProgress');
  var current=0;
  var total=slides.length;
  var interval=10000;
  var timer;
  var startTime;

  /* Particles */
  document.querySelectorAll('[data-particles]').forEach(function(container){
    for(var i=0;i<20;i++){
      var p=document.createElement('div');
      p.className='dcc-particle';
      p.style.left=Math.random()*100+'%';
      p.style.top=60+Math.random()*40+'%';
      p.style.animationDelay=(Math.random()*6).toFixed(1)+'s';
      p.style.animationDuration=(4+Math.random()*4).toFixed(1)+'s';
      container.appendChild(p);
    }
  });

  function goTo(idx){
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    current=((idx%total)+total)%total;
    slides[current].classList.add('active');
    dots[current].classList.add('active');
    track.scrollTo({left:track.offsetWidth*current,behavior:'smooth'});
    resetTimer();
  }

  function resetTimer(){
    clearInterval(timer);
    startTime=Date.now();
    if(progress)progress.style.width='0%';
    timer=setInterval(function(){
      var elapsed=Date.now()-startTime;
      var pct=Math.min((elapsed/interval)*100,100);
      if(progress)progress.style.width=pct+'%';
      if(elapsed>=interval){goTo(current+1)}
    },50);
  }

  document.getElementById('dccPrev').addEventListener('click',function(){goTo(current-1)});
  document.getElementById('dccNext').addEventListener('click',function(){goTo(current+1)});
  dots.forEach(function(dot){
    dot.addEventListener('click',function(){goTo(parseInt(this.getAttribute('data-idx')))});
  });

  /* Touch swipe */
  var startX=0;
  track.addEventListener('touchstart',function(e){startX=e.touches[0].clientX},{passive:true});
  track.addEventListener('touchend',function(e){
    var diff=startX-e.changedTouches[0].clientX;
    if(Math.abs(diff)>50){diff>0?goTo(current+1):goTo(current-1)}
  },{passive:true});

  /* Pause on hover */
  track.addEventListener('mouseenter',function(){clearInterval(timer)});
  track.addEventListener('mouseleave',function(){resetTimer()});

  resetTimer();
})();
</script>

{% schema %}
{
  "name": "Duendes Cine Slider",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {"type": "image_picker", "id": "bg_image", "label": "Imagen de fondo"},
        {"type": "select", "id": "theme", "label": "Tema", "default": "dark", "options": [
          {"value": "dark", "label": "Oscuro"},
          {"value": "gold", "label": "Dorado"},
          {"value": "forest", "label": "Bosque"}
        ]},
        {"type": "text", "id": "eyebrow", "label": "Etiqueta"},
        {"type": "textarea", "id": "title", "label": "Título (usa <em> para itálica dorada)"},
        {"type": "text", "id": "stat_number", "label": "Número estadística"},
        {"type": "text", "id": "stat_label", "label": "Label estadística"},
        {"type": "textarea", "id": "body", "label": "Cuerpo"},
        {"type": "text", "id": "cta_text", "label": "Texto botón"},
        {"type": "url", "id": "cta_url", "label": "Link botón"}
      ]
    }
  ],
  "presets": [{"name": "Duendes Cine Slider"}]
}
{% endschema %}

