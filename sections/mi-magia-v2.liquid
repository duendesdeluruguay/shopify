// INIT
// MAGIC LINK — auto-login para receptores de regalo sin cuenta Shopify
async function mmTryMagicLink() {
  try {
    const params = new URLSearchParams(window.location.search);
    const token = params.get('t');
    if (!token) return false;
    const resp = await fetch(GAS_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'text/plain;charset=utf-8' },
      body: JSON.stringify({ action: 'magic_lookup', token: token })
    });
    const data = await resp.json();
    if (!data || !data.success) return false;
    mmCustomer = { email: data.email, name: '', magic: true };
    try { localStorage.setItem('mm-session', JSON.stringify(mmCustomer)); } catch(e) {}
    document.getElementById('mm-gate').classList.remove('active');
    document.getElementById('mm-header').style.display = 'flex';
    mmNav('canalizaciones');
    if (data.channeling) {
      mmChannelings = [data.channeling];
      mmRenderGuardians([data.channeling]);
      mmRenderChannelings([data.channeling]);
    } else {
      mmLoadData();
    }
    mmSetDailyMessage();
    mmSetGuardianOfWeek();
    mmStartAutoRefresh();
    return true;
  } catch(e) { return false; }
}

// ==== AUTO-REFRESH SYSTEM ====
// Refreshes data every 5 minutes to catch Shopify changes in real-time
var mmRefreshInterval = null;
var MM_REFRESH_MS = 5 * 60 * 1000; // 5 minutes

function mmStartAutoRefresh() {
  mmStopAutoRefresh(); // clear any existing
  mmRefreshInterval = setInterval(function() {
    mmRefreshData(true); // silent = true
  }, MM_REFRESH_MS);
}

function mmStopAutoRefresh() {
  if (mmRefreshInterval) {
    clearInterval(mmRefreshInterval);
    mmRefreshInterval = null;
  }
}

/**
 * mmRefreshData(silent)
 * Re-fetches all data from GAS backend (which queries Shopify in real-time)
 * Clears old notifications and re-evaluates based on current state
 * silent=true: no visual feedback. silent=false: shows subtle refresh indicator
 */
async function mmRefreshData(silent) {
  if (!mmCustomer || !mmCustomer.email) return;

  // Show subtle refresh indicator (only if manual)
  var refreshBtn = document.getElementById('mm-refresh-btn');
  if (!silent && refreshBtn) {
    refreshBtn.classList.add('refreshing');
    refreshBtn.querySelector('.mm-refresh-icon').style.animation = 'spin 0.8s linear infinite';
  }

  try {
    const url = GAS_URL + '?action=get_customer_data&email=' + encodeURIComponent(mmCustomer.email);
    const response = await fetch(url, { redirect: 'follow' });
    const text = await response.text();
    let data;
    try { data = JSON.parse(text); } catch(e) { return; }

    // Check if session is still valid
    if (data && data.authorized === false) {
      // Access revoked — logout gracefully
      mmLogout();
      return;
    }

    // Update customer name if available
    if (data.bienvenida && data.bienvenida.name) {
      mmCustomer.name = data.bienvenida.name;
    }
    if ((!mmCustomer.name || mmCustomer.name === 'Vos') && data.customer && data.customer.first_name) {
      mmCustomer.name = data.customer.first_name;
    }
    if ((!mmCustomer.name || mmCustomer.name === 'Vos') && data.customer && data.customer.email) {
      var p2 = data.customer.email.split('@')[0];
      mmCustomer.name = p2.charAt(0).toUpperCase() + p2.slice(1);
    }
    if (true) {
      try { localStorage.setItem('mm-session', JSON.stringify(mmCustomer)); } catch(e) {}
    }
    document.getElementById('mm-welcome').textContent = '✦ ' + mmCustomer.name + ' ✦';

    // Update soul name
    if (data.channelings && data.channelings.length > 0) {
      for (var si = 0; si < data.channelings.length; si++) {
        var sn = data.channelings[si].soulName || '';
        if (sn && sn.trim().charAt(0) !== '{') {
          var soulEl = document.getElementById('mm-welcome-soul');
          if (soulEl) { soulEl.textContent = mmFixEncoding(sn); soulEl.style.display = 'block'; }
          break;
        }
      }
    }

    // Update guardians & channelings
    if (data.success && data.channelings && data.channelings.length > 0) {
      mmChannelings = data.channelings;
      mmRenderGuardians(data.channelings);
      mmRenderChannelings(data.channelings);
      mmRenderIdentityCards(data.channelings);
    }

    // CLEAR old notifications before re-evaluating
    mmClearNotifications();

    // Re-check for pending forms (real-time from Shopify)
    if (data.formStatus && data.formStatus.pendingOrders && data.formStatus.pendingOrders.length > 0) {
      window.mmPendingOrders = data.formStatus.pendingOrders; // Store globally for mmGoToRito()
      var count = data.formStatus.pendingOrders.length;
      var toastText = count === 1
        ? 'Tu guardián está esperando conocerte. Abrí el rito de la Orden ' + data.formStatus.pendingOrders[0].orderName + '.'
        : 'Hay ' + count + ' guardianes esperando conocerte. Abrí sus ritos.';
      // Only show toast on first load or manual refresh (not silent auto-refresh)
      if (!silent) {
        mmShowToast('El portal está abierto', toastText, function() { mmGoToRito(); }, 'Abrir el rito');
      }
      mmAddNotification('El guardián espera', toastText, function() { mmGoToRito(); });
    }

    // NEW v2: Rito completado → "Canalizando" badge (reemplaza el error de pendiente)
    if (data.formStatus && data.formStatus.ritoV2Status) {
      var ritoStatus2 = data.formStatus.ritoV2Status;
      var canalizandoCount2 = 0;
      for (var ordId2 in ritoStatus2) {
        if (ritoStatus2[ordId2] === 'review') canalizandoCount2++;
      }
      if (canalizandoCount2 > 0) {
        var canalText2 = canalizandoCount2 === 1
          ? 'Tu rito llegó. Durante los 7 días tu guardián y vos se están reconociendo.'
          : 'Tus ' + canalizandoCount2 + ' ritos están en canalización activa.';
        mmAddNotification('Canalizando ✦', canalText2, null);
      }
    }

    // Check for new channelings ready (published since last check)
    if (data.channelings) {
      for (var ci = 0; ci < data.channelings.length; ci++) {
        var ch = data.channelings[ci];
        if (ch.status === 'published' && ch.publishedDate) {
          // If published in last 24h, add notification
          var pubDate = new Date(ch.publishedDate);
          var now = new Date();
          if ((now - pubDate) < 24 * 60 * 60 * 1000) {
            mmAddNotification(
              'Canalización lista',
              (ch.guardianName || 'Tu guardián') + ' ya tiene su carta de canalización disponible.',
              function() { mmNav('canalizaciones'); }
            );
          }
        }
      }
    }

    // Update last refresh timestamp
    var lastRefreshEl = document.getElementById('mm-last-refresh');
    if (lastRefreshEl) {
      var now = new Date();
      lastRefreshEl.textContent = 'Actualizado: ' + now.getHours().toString().padStart(2,'0') + ':' + now.getMinutes().toString().padStart(2,'0');
    }

  } catch(err) {
    // Silent fail on refresh — don't disrupt UX
  } finally {
    if (!silent && refreshBtn) {
      refreshBtn.classList.remove('refreshing');
      var icon = refreshBtn.querySelector('.mm-refresh-icon');
      if (icon) icon.style.animation = '';
    }
  }
}

/**
 * mmClearNotifications()
 * Clears all notifications from the panel and hides bell dot
 * Called before re-evaluating notifications on refresh
 */
function mmClearNotifications() {
  var list = document.getElementById('mm-notif-list');
  if (list) list.innerHTML = '';
  var emptyEl = document.getElementById('mm-notif-empty');
  if (emptyEl) emptyEl.style.display = 'block';
  var dot = document.getElementById('mm-bell-dot');
  if (dot) dot.classList.remove('active');
}

