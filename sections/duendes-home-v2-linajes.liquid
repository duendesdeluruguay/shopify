{{ 'duendes-base.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign dh2_lin_tag = section.settings.tag | strip
  if dh2_lin_tag == blank
    assign dh2_lin_tag = 'duendes.home_v2.linajes.eyebrow' | t
    if dh2_lin_tag contains 'translation missing'
      assign dh2_lin_tag = 'duendes.home_v2.linajes.tag' | t
    endif
  endif
  assign dh2_lin_title = section.settings.title | strip
  if dh2_lin_title == blank
    assign dh2_lin_title = 'duendes.home_v2.linajes.title' | t
  endif
  assign dh2_lin_sub = 'duendes.home_v2.linajes.sub' | t
  if dh2_lin_sub contains 'translation missing'
    assign dh2_lin_sub = ''
  endif
-%}
<style>
  .dh2-lin {
    background: #faf9f6;
    padding: 14px 0 18px;
    color: #15110d;
  }
  .dh2-lin__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .dh2-lin__tag {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(21, 17, 13, 0.45);
    text-align: center;
    margin-bottom: 8px;
  }
  .dh2-lin__title {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-weight: 400;
    font-size: clamp(26px, 3.4vw, 40px);
    text-align: center;
    margin: 0 0 8px;
  }
  .dh2-lin__sub {
    font-family: var(--font-body--family, 'Cormorant Garamond', Georgia, serif);
    font-size: clamp(15px, 1.9vw, 18px);
    text-align: center;
    margin: 0 auto 14px;
    max-width: 520px;
    line-height: 1.45;
    color: rgba(21, 17, 13, 0.58);
    font-style: italic;
  }
  .dh2-lin__frame {
    margin-top: 6px;
    padding: 16px 12px 18px;
    border: 1px solid rgba(201, 169, 97, 0.38);
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.72) 0%, rgba(250, 249, 246, 0.95) 100%);
    box-shadow: 0 4px 28px rgba(21, 17, 13, 0.06);
  }
  .dh2-lin__frame-head {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 14px;
  }
  .dh2-lin__frame-line {
    flex: 1;
    height: 1px;
    max-width: 100px;
    background: linear-gradient(90deg, transparent, rgba(168, 139, 66, 0.55), transparent);
  }
  .dh2-lin__frame-kicker {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #a88b42;
    margin: 0;
    text-align: center;
    white-space: nowrap;
  }
  .dh2-lin__rail {
    display: flex;
    gap: clamp(10px, 1.8vw, 14px);
    overflow-x: auto;
    overflow-y: hidden;
    padding: 4px 4px 12px;
    margin: 0 -8px;
    scroll-snap-type: x proximity;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    touch-action: pan-x pinch-zoom;
    overscroll-behavior-x: contain;
  }
  .dh2-lin__rail::-webkit-scrollbar {
    height: 6px;
  }
  .dh2-lin__rail::-webkit-scrollbar-thumb {
    background: rgba(21, 17, 13, 0.18);
    border-radius: 99px;
  }
  .dh2-lin__card {
    position: relative;
    flex: 0 0 clamp(156px, 13.2vw, 188px);
    width: clamp(156px, 13.2vw, 188px);
    aspect-ratio: 2 / 3;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: #f4f1ec;
    scroll-snap-align: start;
    border: 1px solid rgba(201, 169, 97, 0.45);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.12);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .dh2-lin__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.18);
  }
  .dh2-lin__bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #3a2e1a, #15110d);
  }
  .dh2-lin__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.92;
  }
  .dh2-lin__shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 20%, rgba(5, 4, 2, 0.88));
    z-index: 1;
    pointer-events: none;
  }
  .dh2-lin__body {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: 12px 10px 14px;
    text-align: center;
  }
  .dh2-lin__name {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 6px;
    line-height: 1.25;
    color: #fff;
  }
  .dh2-lin__count {
    font-family: var(--font-body--family, 'Cormorant Garamond', Georgia, serif);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: rgba(244, 241, 236, 0.82);
  }
  @media (max-width: 768px) {
    .dh2-lin {
      padding: 2px 0 8px !important;
      margin-top: -6px;
    }
    .dh2-lin__inner {
      padding-left: max(20px, env(safe-area-inset-left, 0px));
      padding-right: max(20px, env(safe-area-inset-right, 0px));
    }
    .dh2-lin__sub {
      margin-bottom: 6px !important;
    }
    .dh2-lin__title {
      margin-bottom: 4px !important;
    }
    /* El marco dorado encogía el carril y rompía el swipe; en móvil el frame no genera caja
       (los hijos pasan al inner) y el rail hace bleed como recién llegados. */
    .dh2-lin__frame {
      display: contents;
    }
    .dh2-lin__frame-head {
      margin-bottom: 6px;
      gap: 8px;
    }
    .dh2-lin__frame-line {
      max-width: 72px;
    }
    .dh2-lin__frame-kicker {
      font-size: 10px;
      letter-spacing: 0.2em;
      white-space: normal;
      text-align: center;
      line-height: 1.3;
      max-width: min(300px, 85vw);
    }
    .dh2-lin__rail {
      display: flex;
      flex-wrap: nowrap;
      padding: 4px 0 10px;
      margin-top: 0;
      margin-left: calc(-1 * max(20px, env(safe-area-inset-left, 0px)));
      margin-right: calc(-1 * max(20px, env(safe-area-inset-right, 0px)));
      padding-left: max(16px, env(safe-area-inset-left, 0px));
      padding-right: max(16px, env(safe-area-inset-right, 0px));
      width: calc(100% + max(20px, env(safe-area-inset-left, 0px)) + max(20px, env(safe-area-inset-right, 0px)));
      max-width: none;
      box-sizing: border-box;
      scroll-padding-inline: 12px;
      overflow-x: scroll;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      touch-action: pan-x pinch-zoom;
      overscroll-behavior-x: contain;
      scroll-snap-type: none;
    }
    .dh2-lin__card {
      flex: 0 0 clamp(158px, 46vw, 204px);
      width: clamp(158px, 46vw, 204px);
      flex-shrink: 0;
    }
    .dh2-lin__body {
      padding: 14px 10px 16px;
    }
    .dh2-lin__name {
      font-size: 15px !important;
      letter-spacing: 0.08em !important;
    }
    .dh2-lin__count {
      font-size: 12px !important;
      letter-spacing: 0.06em !important;
    }
    h2.dh2-lin__title,
    .dh2-lin__title {
      font-size: 26px !important;
      line-height: 1.15 !important;
      max-width: 100% !important;
      margin-bottom: 8px !important;
    }
    .dh2-lin__tag {
      font-size: 9px !important;
      margin-bottom: 8px !important;
    }
  }
  @media (max-width: 768px) {
    .dh2-cb, .dh2-hero, .dh2-be, .dh2-sp, .dh2-ed, .dh2-rito, .dh2-lt, .dh2-tribu {
      padding: 6px 0 6px !important;
    }
    section.dh2-lin.section {
      padding: 0 0 6px !important;
    }
  }
</style>

<section class="dh2-lin section">
  <div class="dh2-lin__inner">
    <p class="dh2-lin__tag">{{ dh2_lin_tag }}</p>
    <h2 class="dh2-lin__title">{{ dh2_lin_title }}</h2>
    {% if dh2_lin_sub != blank %}
      <p class="dh2-lin__sub">{{ dh2_lin_sub }}</p>
    {% endif %}
    <div class="dh2-lin__frame">
      <div class="dh2-lin__frame-head">
        <span class="dh2-lin__frame-line" aria-hidden="true"></span>
        <p class="dh2-lin__frame-kicker">{{ 'duendes.home_v2.linajes.tipos_title' | t }}</p>
        <span class="dh2-lin__frame-line" aria-hidden="true"></span>
      </div>
      <div class="dh2-lin__rail" role="list">
      {% for block in section.blocks %}
        {% if block.type == 'linaje' %}
          {% liquid
            assign _lin_url = block.settings.url | default: '' | strip
            assign _lin_handle = ''
            if _lin_url contains 'shopify://collections/'
              assign _lin_handle = _lin_url | remove: 'shopify://collections/' | split: '/' | first | split: '?' | first
            elsif _lin_url contains '/collections/'
              assign _lin_tail = _lin_url | split: '/collections/' | last
              assign _lin_handle = _lin_tail | split: '/' | first | split: '?' | first
            endif
            assign _lin_col = blank
            if _lin_handle != blank
              assign _lin_col = collections[_lin_handle]
            endif
            assign _lin_photo = block.settings.image
            if _lin_photo == blank and _lin_col != blank and _lin_col.featured_image != blank
              assign _lin_photo = _lin_col.featured_image
            endif
            if _lin_photo == blank and _lin_col != blank
              for _lin_p in _lin_col.products limit: 20
                if _lin_p.featured_image != blank
                  assign _lin_photo = _lin_p.featured_image
                  break
                elsif _lin_p.featured_media != blank
                  assign _lin_photo = _lin_p.featured_media.preview_image
                  break
                elsif _lin_p.images.size > 0
                  assign _lin_photo = _lin_p.images[0]
                  break
                endif
              endfor
            endif
            assign _lin_title = block.settings.title | strip
            assign _hkw = _lin_handle | downcase | strip
            if _hkw == 'elves' or _hkw == 'elfos'
              assign _tx = 'duendes.home_v2.linajes.collections.elves' | t
              unless _tx contains 'translation missing'
                assign _lin_title = _tx
              endunless
            elsif _hkw == 'mediums' or _hkw == 'medianos'
              assign _tx = 'duendes.home_v2.linajes.collections.duendes' | t
              unless _tx contains 'translation missing'
                assign _lin_title = _tx
              endunless
            elsif _hkw == 'hadas'
              assign _tx = 'duendes.home_v2.linajes.collections.hadas' | t
              unless _tx contains 'translation missing'
                assign _lin_title = _tx
              endunless
            elsif _hkw == 'pixies'
              assign _tx = 'duendes.home_v2.linajes.collections.pixies' | t
              unless _tx contains 'translation missing'
                assign _lin_title = _tx
              endunless
            elsif _hkw == 'maestros'
              assign _tx = 'duendes.home_v2.linajes.collections.maestros' | t
              unless _tx contains 'translation missing'
                assign _lin_title = _tx
              endunless
            elsif _hkw == 'deluxe'
              assign _tx = 'duendes.home_v2.linajes.collections.deluxe' | t
              unless _tx contains 'translation missing'
                assign _lin_title = _tx
              endunless
            elsif _hkw == 'brujas'
              assign _tx = 'duendes.home_v2.linajes.collections.brujas' | t
              unless _tx contains 'translation missing'
                assign _lin_title = _tx
              endunless
            elsif _hkw == 'grandes'
              assign _tx = 'duendes.home_v2.linajes.collections.grandes' | t
              unless _tx contains 'translation missing'
                assign _lin_title = _tx
              endunless
            elsif _hkw == 'gigantes'
              assign _tx = 'duendes.home_v2.linajes.collections.gigantes' | t
              unless _tx contains 'translation missing'
                assign _lin_title = _tx
              endunless
            elsif _hkw == 'historicos'
              assign _tx = 'duendes.home_v2.linajes.collections.historicos' | t
              unless _tx contains 'translation missing'
                assign _lin_title = _tx
              endunless
            endif
            assign _lin_count = block.settings.count_label | strip
            assign _cl = _lin_count | downcase
            if _lin_count == blank or _cl == 'view collection'
              assign _lin_count = 'duendes.home_v2.linajes.view_collection' | t
            endif
          %}
          <a class="dh2-lin__card" href="{{ block.settings.url }}" role="listitem" {{ block.shopify_attributes }}>
            <div class="dh2-lin__bg" aria-hidden="true">
              {% if _lin_photo != blank %}
                {{ _lin_photo | image_url: width: 600 | image_tag: loading: 'lazy', alt: '', widths: '200,400,600' }}
              {% else %}
                <span style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:32px;color:rgba(201,169,97,0.55);">{{ block.settings.glyph | default: '✦' }}</span>
              {% endif %}
            </div>
            <div class="dh2-lin__shade" aria-hidden="true"></div>
            <div class="dh2-lin__body">
              <h3 class="dh2-lin__name">{{ _lin_title }}</h3>
              <span class="dh2-lin__count">{{ _lin_count }}</span>
            </div>
          </a>
        {% endif %}
      {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DDU v2 · Linajes",
  "tag": "section",
  "class": "duendes-home-v2-linajes-section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Etiqueta",
      "default": "POR LINAJE"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Cada Guardián viene de un linaje."
    }
  ],
  "blocks": [
    {
      "type": "linaje",
      "name": "Linaje",
      "settings": [
        { "type": "text", "id": "title", "label": "Nombre", "default": "Hadas" },
        { "type": "image_picker", "id": "image", "label": "Foto del linaje", "info": "Opcional: si está vacío, se usa la imagen destacada de la colección; si tampoco hay, la primera foto de un producto disponible en esa colección." },
        { "type": "text", "id": "count_label", "label": "Guardianes / contador (texto)", "default": "Ver colección" },
        { "type": "url", "id": "url", "label": "Enlace a colección" },
        { "type": "text", "id": "glyph", "label": "Marcador si no hay foto", "default": "✦", "info": "Solo se muestra si no cargás imagen." }
      ]
    }
  ],
  "presets": [
    {
      "name": "DDU v2 · Linajes",
      "blocks": [
        { "type": "linaje", "settings": { "title": "Hadas", "url": "shopify://collections/hadas" } },
        { "type": "linaje", "settings": { "title": "Pixies", "url": "shopify://collections/pixies" } },
        { "type": "linaje", "settings": { "title": "Elfos", "url": "shopify://collections/elfos" } },
        { "type": "linaje", "settings": { "title": "Medianos", "url": "shopify://collections/medianos" } },
        { "type": "linaje", "settings": { "title": "Maestros", "url": "shopify://collections/maestros" } },
        { "type": "linaje", "settings": { "title": "Deluxe", "url": "shopify://collections/deluxe" } },
        { "type": "linaje", "settings": { "title": "Brujas", "url": "shopify://collections/brujas" } },
        { "type": "linaje", "settings": { "title": "Grandes", "url": "shopify://collections/grandes" } },
        { "type": "linaje", "settings": { "title": "Gigantes", "url": "shopify://collections/gigantes" } },
        { "type": "linaje", "settings": { "title": "Históricos", "url": "shopify://collections/historicos" } }
      ]
    }
  ]
}
{% endschema %}
