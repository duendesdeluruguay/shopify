<div class="dt-orb dt-orb--2"></div>
<div class="dt-orb dt-orb--3"></div>

<div id="dtFireflies" style="position:fixed;inset:0;pointer-events:none;z-index:1;overflow:hidden"></div>

<div class="dt-share-toast" id="dtShareToast" translate="no" data-no-translate></div>

{%- liquid
  assign dt_lang_check = localization.language.iso_code | default: request.locale.iso_code | downcase
  assign dt_locale_js = 'en'
  if dt_lang_check contains 'es'
    assign dt_locale_js = 'es'
  endif
-%}

<div class="dt-wrap" id="dtWrap" translate="no" data-no-translate>

  <section class="dt-intro" id="dtIntro">
    <div class="dt-intro-sigil"></div>
    <p class="dt-intro-line" data-delay="200">{{ 'duendes.test.intro_line_1' | t }}</p>
    <p class="dt-intro-line" data-delay="1300">{{ 'duendes.test.intro_line_2' | t }}</p>
    <p class="dt-intro-line" data-delay="2400">{{ 'duendes.test.intro_line_3' | t }}</p>
    <div class="dt-magic-line" data-delay="3300"></div>
    <h1 class="dt-intro-title" data-delay="3700">{{ 'duendes.test.intro_title' | t }}</h1>
    <p class="dt-intro-sub" data-delay="4500">{{ 'duendes.test.intro_sub_1' | t }}</p>
    <p class="dt-intro-sub" data-delay="5300">{{ 'duendes.test.intro_sub_2' | t }}</p>

    <div class="dt-music-choice" data-delay="6100">
      <button class="dt-music-btn" data-action="start-with-music">{{ 'duendes.test.intro_music_yes' | t }}</button>
      <button class="dt-music-btn" data-action="start-no-music">{{ 'duendes.test.intro_music_no' | t }}</button>
    </div>
  </section>

  <!-- AUDIO + MUSIC TOGGLE -->
  <audio id="dtAudio" loop preload="none">
    <source src="{{ 'Raices-y-Agua-Interior.mp3' | asset_url }}" type="audio/mpeg">
  </audio>
  <button class="dt-music-toggle" id="dtMusicToggle" aria-label="{{ 'duendes.test.music_aria' | t | escape }}" type="button">
    <svg viewBox="0 0 24 24" id="dtMusicIcon"><path d="M9 18V6l12-3v12"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="15" r="3"/></svg>
  </button>

  <section class="dt-phase" id="dtPhaseForm">
    <div class="dt-progress" aria-label="{{ 'duendes.test.progress_aria' | t | escape }}">
      <span class="dt-progress-dot active"></span>
      <span class="dt-progress-line"></span>
      <span class="dt-progress-dot"></span>
      <span class="dt-progress-line"></span>
      <span class="dt-progress-dot"></span>
    </div>
    <h2 class="dt-phase-title">{{ 'duendes.test.form_title' | t }}</h2>
    <p class="dt-phase-sub">{{ 'duendes.test.form_sub' | t }}</p>

    <form class="dt-form" id="dtForm" novalidate>
      <div class="dt-field">
        <label for="dtName"><span>{{ 'duendes.test.form_name_label' | t }}</span><span class="req">*</span></label>
        <input type="text" id="dtName" name="name" autocomplete="name" placeholder="{{ 'duendes.test.form_name_placeholder' | t | escape }}" required>
        <div class="dt-field-error">{{ 'duendes.test.form_name_error' | t }}</div>
      </div>
      <div class="dt-field">
        <label for="dtEmail"><span>{{ 'duendes.test.form_email_label' | t }}</span><span class="req">*</span></label>
        <input type="email" id="dtEmail" name="email" autocomplete="email" inputmode="email" placeholder="{{ 'duendes.test.form_email_placeholder' | t | escape }}" required>
        <div class="dt-field-error">{{ 'duendes.test.form_email_error' | t }}</div>
      </div>
      <div class="dt-field">
        <label><span>{{ 'duendes.test.form_phone_label' | t }}</span><span class="req">*</span></label>
        <div class="dt-field-row">
          <select id="dtPhoneCountry" name="phoneCountry" aria-label="{{ 'duendes.test.phone_country_aria' | t | escape }}"></select>
          <input type="tel" id="dtPhoneNumber" name="phoneNumber" autocomplete="tel-national" inputmode="tel" placeholder="{{ 'duendes.test.form_phone_placeholder' | t | escape }}" required>
        </div>
        <div class="dt-field-error">{{ 'duendes.test.form_phone_error' | t }}</div>
        <div class="dt-field-hint">{{ 'duendes.test.form_phone_hint' | t }}</div>
      </div>
      <div class="dt-field">
        <label for="dtDob"><span>{{ 'duendes.test.form_dob_label' | t }}</span></label>
        <input type="date" id="dtDob" name="dob" autocomplete="bday">
        <div class="dt-field-error">{{ 'duendes.test.form_dob_error' | t }}</div>
        <div class="dt-field-hint">{{ 'duendes.test.form_dob_hint' | t }}</div>
      </div>
      <div class="dt-field">
        <label for="dtCountry"><span>{{ 'duendes.test.form_country_label' | t }}</span><span class="req">*</span></label>
        <select id="dtCountry" name="country" autocomplete="country" required></select>
        <div class="dt-field-error">{{ 'duendes.test.form_country_error' | t }}</div>
      </div>
      <div class="dt-consent">
        <p>{{ 'duendes.test.form_consent' | t }}</p>
      </div>
      <div class="dt-actions">
        <button type="button" class="dt-btn-back" data-action="back-to-intro">{{ 'duendes.test.form_back' | t }}</button>
        <button type="submit" class="dt-btn-next">{{ 'duendes.test.form_next' | t }}</button>
      </div>
    </form>
  </section>

  <section class="dt-phase" id="dtPhaseQuestion">
    <div class="dt-progress" aria-label="{{ 'duendes.test.progress_aria' | t | escape }}">
      <span class="dt-progress-dot done"></span>
      <span class="dt-progress-line done"></span>
      <span class="dt-progress-dot active"></span>
      <span class="dt-progress-line"></span>
      <span class="dt-progress-dot"></span>
    </div>
    <h2 class="dt-phase-title">{{ 'duendes.test.q_title' | t }}</h2>
    <p class="dt-phase-sub">{{ 'duendes.test.q_sub' | t }}</p>

    <form class="dt-form" id="dtQuestionForm" novalidate>
      <div class="dt-field">
        <div class="dt-textarea-wrap">
          <textarea class="dt-textarea" id="dtOpenQuestion" name="openQuestion" placeholder="{{ 'duendes.test.q_placeholder' | t | escape }}" required minlength="200" maxlength="3000" spellcheck="true"></textarea>
          <span class="dt-textarea-counter" id="dtTextCounter">{{ 'duendes.test.counter_initial' | t }}</span>
        </div>
        <div class="dt-field-error">{{ 'duendes.test.q_error' | t }}</div>
      </div>
      <div class="dt-actions">
        <button type="button" class="dt-btn-back" data-action="back-to-form">{{ 'duendes.test.q_back' | t }}</button>
        <button type="submit" class="dt-btn-next" id="dtQuestionSubmit" disabled>{{ 'duendes.test.q_next' | t }}</button>
      </div>
    </form>
  </section>

  <section class="dt-phase dt-loading" id="dtPhaseLoading">
    <div class="dt-loading-orb"></div>
    <h2 class="dt-loading-text">{{ 'duendes.test.loading_title' | t }}</h2>
    <p class="dt-loading-stages" id="dtLoadingStage">{{ 'duendes.test.loading_stage_1' | t }}</p>
  </section>

  <section class="dt-phase dt-result" id="dtPhaseResult"></section>

  <section class="dt-phase" id="dtPhaseError">
    <div class="dt-error">
      <h3>{{ 'duendes.test.error_title' | t }}</h3>
      <p>{{ 'duendes.test.error_text' | t }}</p>
      <button type="button" data-action="retry">{{ 'duendes.test.error_retry' | t }}</button>
    </div>
  </section>

</div>

<script translate="no" data-no-translate>
(function(){
  setTimeout(function(){
    document.querySelectorAll('.dt-intro [data-delay]').forEach(function(el){ el.classList.add('show'); });
  }, 400);

  var API_BASE = {% render 'duendes-api-worker-url', format: 'json' %};

  var LOCALE = {{ dt_locale_js | json }};
  var I18N = {
    loading_stage_1: {{ 'duendes.test.loading_stage_1' | t | json }},
    loading_stage_2: {{ 'duendes.test.loading_stage_2' | t | json }},
    loading_stage_3: {{ 'duendes.test.loading_stage_3' | t | json }},
    loading_stage_4: {{ 'duendes.test.loading_stage_4' | t | json }},
    result_greeting: {{ 'duendes.test.result_greeting' | t | json }},
    result_reveal: {{ 'duendes.test.result_reveal' | t | json }},
    result_personal_label: {{ 'duendes.test.result_personal_label' | t | json }},
    result_why_label: {{ 'duendes.test.result_why_label' | t | json }},
    result_compat_title: {{ 'duendes.test.result_compat_title' | t | json }},
    result_compat_sub: {{ 'duendes.test.result_compat_sub' | t | json }},
    result_cta: {{ 'duendes.test.result_cta' | t | json }},
    receive_title: {{ 'duendes.test.receive_title' | t | json }},
    receive_sub: {{ 'duendes.test.receive_sub' | t | json }},
    receive_email: {{ 'duendes.test.receive_email' | t | json }},
    receive_share_wa: {{ 'duendes.test.receive_share_wa' | t | json }},
    receive_copy: {{ 'duendes.test.receive_copy' | t | json }},
    receive_email_sent: {{ 'duendes.test.receive_email_sent' | t | json }},
    receive_email_sending: {{ 'duendes.test.receive_email_sending' | t | json }},
    receive_email_failed: {{ 'duendes.test.receive_email_failed' | t | json }},
    share_copied: {{ 'duendes.test.share_copied' | t | json }},
    share_wa_message: {{ 'duendes.test.share_wa_message' | t | json }},
    counter_suffix: {{ 'duendes.test.counter_suffix' | t | json }},
    counter_too_long: {{ 'duendes.test.counter_too_long' | t | json }}
  };
  function tr(key, vars){
    var s = I18N[key] || '';
    if (vars) { Object.keys(vars).forEach(function(k){ s = s.split('{'+k+'}').join(vars[k]); }); }
    return s;
  }

  var introEl = document.getElementById('dtIntro');
  var phaseForm = document.getElementById('dtPhaseForm');
  var phaseQ = document.getElementById('dtPhaseQuestion');
  var phaseLoading = document.getElementById('dtPhaseLoading');
  var phaseResult = document.getElementById('dtPhaseResult');
  var phaseError = document.getElementById('dtPhaseError');
  var formEl = document.getElementById('dtForm');
  var qFormEl = document.getElementById('dtQuestionForm');
  var textareaEl = document.getElementById('dtOpenQuestion');
  var counterEl = document.getElementById('dtTextCounter');
  var qSubmitBtn = document.getElementById('dtQuestionSubmit');
  var loadingStageEl = document.getElementById('dtLoadingStage');

  document.querySelectorAll('.dt-intro [data-delay]').forEach(function(el){
    var d = parseInt(el.getAttribute('data-delay')) || 0;
    setTimeout(function(){ el.classList.add('show'); }, d);
  });

  var fireflyContainer = document.getElementById('dtFireflies');
  var fireflyColors = ['dt-firefly--gold','dt-firefly--green','dt-firefly--white'];
  function spawnFirefly(){
    if (!fireflyContainer || fireflyContainer.children.length >= 12) return;
    var el = document.createElement('div');
    el.className = 'dt-firefly ' + fireflyColors[Math.floor(Math.random()*fireflyColors.length)];
    var size = 4 + Math.random()*12;
    el.style.width = size+'px'; el.style.height = size+'px';
    el.style.left = (Math.random()*100)+'%'; el.style.top = (Math.random()*100)+'%';
    var dur = 3 + Math.random()*5;
    el.style.transition = 'opacity '+dur+'s ease, transform '+dur+'s ease';
    fireflyContainer.appendChild(el);
    requestAnimationFrame(function(){
      el.style.opacity = (0.15 + Math.random()*0.45).toString();
      var dx = -40 + Math.random()*80, dy = -60 + Math.random()*40;
      el.style.transform = 'translate('+dx+'px,'+dy+'px) scale('+(0.5+Math.random()*0.8)+')';
    });
    setTimeout(function(){
      el.style.opacity = '0';
      setTimeout(function(){ if(el.parentNode) el.parentNode.removeChild(el); }, dur*1000);
    }, dur*1000);
  }
  function fireflyLoop(){ spawnFirefly(); setTimeout(fireflyLoop, 700 + Math.random()*1800); }
  fireflyLoop();

  function showPhase(name){
    introEl.style.display = (name === 'intro') ? 'flex' : 'none';
    [phaseForm, phaseQ, phaseLoading, phaseResult, phaseError].forEach(function(p){ p.classList.remove('active'); });
    if (name === 'form') phaseForm.classList.add('active');
    else if (name === 'question') phaseQ.classList.add('active');
    else if (name === 'loading') phaseLoading.classList.add('active');
    else if (name === 'result') phaseResult.classList.add('active');
    else if (name === 'error') phaseError.classList.add('active');
    window.scrollTo({top:0, behavior:'smooth'});
  }

  var COUNTRIES = [
    ["UY","+598","Uruguay","Uruguay"],
    ["AR","+54","Argentina","Argentina"],
    ["ES","+34","España","Spain"],
    ["MX","+52","México","Mexico"],
    ["CL","+56","Chile","Chile"],
    ["CO","+57","Colombia","Colombia"],
    ["PE","+51","Perú","Peru"],
    ["US","+1","Estados Unidos","United States"],
    ["BR","+55","Brasil","Brazil"],
    ["VE","+58","Venezuela","Venezuela"],
    ["EC","+593","Ecuador","Ecuador"],
    ["BO","+591","Bolivia","Bolivia"],
    ["PY","+595","Paraguay","Paraguay"],
    ["CR","+506","Costa Rica","Costa Rica"],
    ["PA","+507","Panamá","Panama"],
    ["DO","+1","República Dominicana","Dominican Republic"],
    ["GT","+502","Guatemala","Guatemala"],
    ["HN","+504","Honduras","Honduras"],
    ["SV","+503","El Salvador","El Salvador"],
    ["NI","+505","Nicaragua","Nicaragua"],
    ["CU","+53","Cuba","Cuba"],
    ["PR","+1","Puerto Rico","Puerto Rico"],
    ["CA","+1","Canadá","Canada"],
    ["GB","+44","Reino Unido","United Kingdom"],
    ["FR","+33","Francia","France"],
    ["DE","+49","Alemania","Germany"],
    ["IT","+39","Italia","Italy"],
    ["PT","+351","Portugal","Portugal"],
    ["NL","+31","Países Bajos","Netherlands"],
    ["BE","+32","Bélgica","Belgium"],
    ["CH","+41","Suiza","Switzerland"],
    ["AU","+61","Australia","Australia"],
    ["NZ","+64","Nueva Zelanda","New Zealand"],
    ["JP","+81","Japón","Japan"],
    ["IL","+972","Israel","Israel"]
  ];

  var phoneCountrySel = document.getElementById('dtPhoneCountry');
  var countrySel = document.getElementById('dtCountry');

  COUNTRIES.forEach(function(c){
    var label = (LOCALE === 'en') ? c[3] : c[2];
    var optP = document.createElement('option');
    optP.value = c[1]; optP.textContent = c[1] + ' ' + label;
    optP.dataset.code = c[0];
    phoneCountrySel.appendChild(optP);
    var optC = document.createElement('option');
    optC.value = c[0]; optC.textContent = label;
    countrySel.appendChild(optC);
  });

  function syncPhoneCountry() {
    var cc = countrySel.value;
    var match = COUNTRIES.find(function (c) { return c[0] === cc; });
    if (match) phoneCountrySel.value = match[1];
  }

  function setCountryIfValid(cc) {
    if (!cc) return false;
    cc = String(cc).toUpperCase();
    if (Array.from(countrySel.options).some(function (o) { return o.value === cc; })) {
      countrySel.value = cc;
      syncPhoneCountry();
      return true;
    }
    return false;
  }

  var dtShopCC = {{ localization.country.iso_code | default: '' | json }};
  if (dtShopCC) setCountryIfValid(dtShopCC);

  var navLang = (navigator.language || 'es-AR').split('-');
  var guessCC = (navLang[1] || '').toUpperCase();
  if (guessCC && guessCC.length === 2) setCountryIfValid(guessCC);
  if (!countrySel.value) {
    setCountryIfValid(LOCALE === 'en' ? 'US' : 'UY');
  }

  fetch('https://ipwho.is/', { mode: 'cors', credentials: 'omit' })
    .then(function (r) { return r.json(); })
    .then(function (d) {
      if (!d || d.success === false || !d.country_code) return;
      setCountryIfValid(d.country_code);
    })
    .catch(function () {});

  countrySel.addEventListener('change', syncPhoneCountry);
  syncPhoneCountry();

  // ── AUDIO ──
  var audioEl = document.getElementById('dtAudio');
  var musicToggle = document.getElementById('dtMusicToggle');
  var musicPlaying = false;
  function startMusic(){
    if (!audioEl) return;
    audioEl.volume = 0.28;
    var p = audioEl.play();
    if (p && p.then) p.catch(function(){});
    musicPlaying = true;
    musicToggle.classList.add('visible');
    musicToggle.classList.remove('muted');
  }
  function stopMusic(){
    if (!audioEl) return;
    try { audioEl.pause(); } catch(e){}
    musicPlaying = false;
    musicToggle.classList.add('muted');
  }
  if (musicToggle) {
    musicToggle.addEventListener('click', function(){
      if (musicPlaying) stopMusic();
      else { var p = audioEl.play(); if (p && p.then) p.catch(function(){}); musicPlaying = true; musicToggle.classList.remove('muted'); }
    });
  }

  document.body.addEventListener('click', function(e){
    var btn = e.target.closest('[data-action]');
    if (!btn) return;
    var action = btn.getAttribute('data-action');
    if (action === 'start' || action === 'start-with-music') {
      if (action === 'start-with-music') startMusic();
      showPhase('form');
    }
    else if (action === 'start-no-music') { stopMusic(); musicToggle.classList.add('visible'); showPhase('form'); }
    else if (action === 'back-to-intro') showPhase('intro');
    else if (action === 'back-to-form') showPhase('form');
    else if (action === 'retry') { showPhase('form'); }
  });

  function updateCounter(){
    var v = textareaEl.value;
    var len = v.length;
    var min = 200, max = 3000;
    if (len < min) {
      counterEl.textContent = len + ' / ' + min + ' ' + tr('counter_suffix');
      counterEl.classList.remove('ok','warn');
      qSubmitBtn.disabled = true;
    } else if (len > max - 200 && len <= max) {
      counterEl.textContent = len + ' / ' + max;
      counterEl.classList.add('warn');
      counterEl.classList.remove('ok');
      qSubmitBtn.disabled = false;
    } else if (len > max) {
      counterEl.textContent = len + ' / ' + max + ' (' + tr('counter_too_long') + ')';
      counterEl.classList.add('warn');
      counterEl.classList.remove('ok');
      qSubmitBtn.disabled = true;
    } else {
      counterEl.textContent = len + ' / ' + max;
      counterEl.classList.add('ok');
      counterEl.classList.remove('warn');
      qSubmitBtn.disabled = false;
    }
  }
  textareaEl.addEventListener('input', updateCounter);

  function validateField(field, valid){
    var wrap = field.closest('.dt-field');
    if (!wrap) return;
    if (valid) { wrap.classList.remove('has-error'); field.classList.remove('invalid'); }
    else { wrap.classList.add('has-error'); field.classList.add('invalid'); }
  }
  function validEmail(s){ return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(s); }
  function validPhone(s){
    var digits = (s || '').replace(/\D/g,'');
    return digits.length >= 6 && digits.length <= 15;
  }
  function validateForm(){
    var ok = true;
    var name = document.getElementById('dtName');
    var email = document.getElementById('dtEmail');
    var phone = document.getElementById('dtPhoneNumber');
    var dob = document.getElementById('dtDob');
    var country = document.getElementById('dtCountry');
    if (!name.value.trim() || name.value.trim().length < 2) { validateField(name, false); ok = false; } else { validateField(name, true); }
    if (!validEmail(email.value.trim())) { validateField(email, false); ok = false; } else { validateField(email, true); }
    if (!validPhone(phone.value.trim())) { validateField(phone, false); ok = false; } else { validateField(phone, true); }
    if (dob.value && dob.value.length > 0) {
      var d = new Date(dob.value);
      if (isNaN(d.getTime())) { validateField(dob, false); ok = false; }
      else { validateField(dob, true); }
    } else {
      validateField(dob, true);
    }
    if (!country.value) { validateField(country, false); ok = false; } else { validateField(country, true); }
    return ok;
  }

  var state = { name:'', email:'', phoneCountry:'', phoneNumber:'', dob:'', country:'', openQuestion:'' };

  formEl.addEventListener('submit', function(e){
    e.preventDefault();
    if (!validateForm()) return;
    state.name = document.getElementById('dtName').value.trim();
    state.email = document.getElementById('dtEmail').value.trim().toLowerCase();
    state.phoneCountry = document.getElementById('dtPhoneCountry').value;
    state.phoneNumber = document.getElementById('dtPhoneNumber').value.trim();
    state.dob = document.getElementById('dtDob').value;
    state.country = document.getElementById('dtCountry').value;
    showPhase('question');
    setTimeout(function(){ textareaEl.focus(); }, 200);
  });

  qFormEl.addEventListener('submit', function(e){
    e.preventDefault();
    var v = textareaEl.value.trim();
    if (v.length < 200) {
      var wrap = textareaEl.closest('.dt-field');
      wrap.classList.add('has-error');
      return;
    }
    state.openQuestion = v;
    runChanneling();
  });

  function loopLoadingStages(){
    var stages = [tr('loading_stage_1'), tr('loading_stage_2'), tr('loading_stage_3')];
    var i = 0;
    loadingStageEl.textContent = stages[0];
    return setInterval(function(){
      i = (i + 1) % stages.length;
      loadingStageEl.style.opacity = '0';
      setTimeout(function(){
        loadingStageEl.textContent = stages[i];
        loadingStageEl.style.opacity = '1';
      }, 400);
    }, 2500);
  }

  function runChanneling(){
    showPhase('loading');
    var stagesTimer = loopLoadingStages();

    fetch(API_BASE + '?action=guardian-deep-analysis', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action: 'guardian-deep-analysis',
        locale: LOCALE,
        name: state.name,
        email: state.email,
        phone: (state.phoneCountry || '') + state.phoneNumber,
        phoneCountry: state.phoneCountry,
        phoneNumber: state.phoneNumber,
        dob: state.dob,
        country: state.country,
        openQuestion: state.openQuestion
      })
    })
    .then(function(r){
      if (!r.ok) throw new Error('http_' + r.status);
      return r.json();
    })
    .then(function(data){
      clearInterval(stagesTimer);
      if (!data || !data.success || !data.guardian) { throw new Error('bad_response'); }
      loadingStageEl.style.opacity = '0';
      setTimeout(function(){
        loadingStageEl.textContent = tr('loading_stage_4');
        loadingStageEl.style.opacity = '1';
      }, 400);
      setTimeout(function(){ renderResult(data); }, 1400);
    })
    .catch(function(err){
      clearInterval(stagesTimer);
      console.error('[guardian-test]', err);
      showPhase('error');
    });
  }

  function renderResult(data){
    var g = data.guardian;
    var personal = data.personalMessage || '';
    var reason = data.reason || '';
    var compat = Array.isArray(data.compatibles) ? data.compatibles : [];
    var firstName = state.name.split(' ')[0];

    var compatHtml = '';
    if (compat.length) {
      compatHtml = '<div class="dt-compat">' +
        '<h3 class="dt-compat-title">' + tr('result_compat_title') + '</h3>' +
        '<p class="dt-compat-sub">' + tr('result_compat_sub') + '</p>' +
        '<div class="dt-compat-grid">' +
        compat.map(function(c){
          return '<a class="dt-compat-card" href="'+ (c.url || '#') +'">' +
            '<img src="'+ (c.img || '') +'" alt="'+ esc(c.name || '') +'" loading="lazy">' +
            '<div class="dt-compat-card-info">' +
              '<h4>'+ esc(c.name || '') +'</h4>' +
              '<p>'+ esc(c.type || '') +'</p>' +
              (c.reason ? '<p class="dt-compat-reason">'+ esc(c.reason) +'</p>' : '') +
            '</div>' +
          '</a>';
        }).join('') +
        '</div></div>';
    }

    phaseResult.innerHTML =
      '<p class="dt-result-greeting">' + esc(firstName) + ', ' + tr('result_greeting') + '</p>' +
      '<p class="dt-result-reveal">' + tr('result_reveal') + '</p>' +
      '<div class="dt-guardian-card">' +
        '<div class="dt-guardian-img-wrap">' +
          '<img class="dt-guardian-img" src="'+ (g.img || '') +'" alt="'+ esc(g.name || '') +'">' +
          '<div class="dt-guardian-img-overlay"></div>' +
        '</div>' +
        '<div class="dt-guardian-info">' +
          '<h2 class="dt-guardian-name">'+ esc(g.name || '') +'</h2>' +
          '<p class="dt-guardian-type">'+ esc(g.type || '') +'</p>' +
          (g.price ? '<p class="dt-guardian-price">' + esc(g.price) + '</p>' : '') +
          '<a href="'+ (g.url || '#') +'" class="dt-guardian-cta">' + tr('result_cta') + '</a>' +
        '</div>' +
      '</div>' +
      (personal ? '<div class="dt-personal-msg">' +
          '<p class="dt-personal-msg-label">' + tr('result_personal_label') + '</p>' +
          '<p>' + esc(personal) + '</p>' +
      '</div>' : '') +
      (reason ? '<div class="dt-why">' +
          '<p class="dt-why-label">' + tr('result_why_label') + '</p>' +
          '<p class="dt-why-text">' + esc(reason) + '</p>' +
      '</div>' : '') +
      compatHtml +
      '<div class="dt-share-wrap">' +
        '<p class="dt-share-title">' + tr('receive_title') + '</p>' +
        '<p class="dt-receive-sub">' + tr('receive_sub') + '</p>' +
        '<div class="dt-share-buttons">' +
          '<button class="dt-share-btn dt-receive-email" id="dtReceiveEmail">' +
            '<svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>' +
            '<span>' + tr('receive_email') + '</span>' +
          '</button>' +
          '<a class="dt-share-btn dt-receive-wa" id="dtShareWA" target="_blank" rel="noopener">' +
            '<svg viewBox="0 0 24 24"><path d="M22 12a10 10 0 11-3.5-7.6L22 3l-1.5 4.4A10 10 0 0122 12z"/></svg>' +
            '<span>' + tr('receive_share_wa') + '</span>' +
          '</a>' +
          '<button class="dt-share-btn" id="dtReceiveCopy">' +
            '<svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15V5a2 2 0 012-2h10"/></svg>' +
            '<span>' + tr('receive_copy') + '</span>' +
          '</button>' +
        '</div>' +
      '</div>';

    showPhase('result');

    var shareUrl = (window.location.origin || 'https://duendesdeluruguay.com') + '/pages/test-del-guardian';

    // ── BOTÓN EMAIL ──
    document.getElementById('dtReceiveEmail').addEventListener('click', function(){
      var btn = this;
      if (btn.disabled) return;
      var origText = btn.querySelector('span').textContent;
      btn.disabled = true;
      btn.querySelector('span').textContent = tr('receive_email_sending');
      fetch(API_BASE + '?action=guardian-send-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'guardian-send-email',
          locale: LOCALE,
          email: state.email,
          name: state.name,
          phone: (state.phoneCountry || '') + state.phoneNumber,
          guardian: g,
          personalMessage: personal,
          reason: reason,
          compatibles: compat,
          themes: data.themes || []
        })
      })
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (d && d.success) {
          toast(tr('receive_email_sent'));
          btn.querySelector('span').textContent = '✓';
          setTimeout(function(){ btn.querySelector('span').textContent = origText; btn.disabled = false; }, 5000);
        } else {
          throw new Error('failed');
        }
      })
      .catch(function(){
        toast(tr('receive_email_failed'));
        btn.querySelector('span').textContent = origText;
        btn.disabled = false;
      });
    });

    // ── BOTÓN COMPARTIR (WHATSAPP SIN DESTINATARIO — el usuario elige a quién) ──
    var shareWaText = tr('share_wa_message', { guardian: g.name || '' });
    var shareWaLink = 'https://wa.me/?text=' + encodeURIComponent(shareWaText + shareUrl);
    document.getElementById('dtShareWA').setAttribute('href', shareWaLink);

    // ── BOTÓN COPIAR ──
    document.getElementById('dtReceiveCopy').addEventListener('click', function(){
      var url = shareUrl;
      if (navigator.clipboard) {
        navigator.clipboard.writeText(url).then(function(){ toast(tr('share_copied')); });
      } else {
        var ta = document.createElement('textarea'); ta.value = url; document.body.appendChild(ta); ta.select();
        try { document.execCommand('copy'); toast(tr('share_copied')); } catch(e){}
        document.body.removeChild(ta);
      }
    });

    if (typeof gtag === 'function') {
      gtag('event', 'guardian_revealed', {
        guardian_name: g.name || '',
        guardian_type: g.type || '',
        locale: LOCALE
      });
    }
  }

  function toast(text){
    var t = document.getElementById('dtShareToast');
    t.textContent = text;
    t.classList.add('show');
    setTimeout(function(){ t.classList.remove('show'); }, 2400);
  }

  function esc(s){ return String(s == null ? '' : s).replace(/[&<>"']/g, function(c){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); }
})();
</script>
