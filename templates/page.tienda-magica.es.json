    "curiosidades": {
      "type": "duendes-catalog-curiosidades",
      "settings": {
        "theme": "light",
        "title": "Curiosidades de nuestras creaciones"
      },
      "blocks": {
        "c1": {
          "type": "curiosidad",
          "settings": {
            "label": "Alquimia",
            "text": "Cada Guardián se canaliza a mano en Piriápolis — cada uno es único en el mundo. No hay moldes. No hay fábricas. Solo manos, silencio y alquimia. Mi Magia comparte las mismas guías y utilidades para toda la comunidad adoptante."
          }
        },
        "c2": {
          "type": "curiosidad",
          "settings": {
            "label": "Elementales",
            "text": "Los Guardianes son a quienes la Pachamama puso a cargo del elemento tierra. Protegen la naturaleza, los hogares y a quienes eligen acompañar."
          }
        },
        "c3": {
          "type": "curiosidad",
          "settings": {
            "label": "Sincronicidad",
            "text": "Miles de adoptantes nos escriben lo mismo: llegó justo cuando lo necesitaba. No es casualidad. Los Guardianes encuentran a su persona."
          }
        },
        "c4": {
          "type": "curiosidad",
          "settings": {
            "label": "Channeling",
            "text": "Nosotros no elegimos qué crear. Cada Guardián nace con nombre, historia y propósito. La carta canalizada que acompaña a los medianos lo confirma."
          }
        },
        "c5": {
          "type": "curiosidad",
          "settings": {
            "label": "15.000 hogares",
            "text": "Más de quince mil Guardianes encontraron hogar en 45 países. Todo sigue hecho a mano. Todo sigue saliendo del mismo taller en Uruguay."
          }
        },
        "c6": {
          "type": "curiosidad",
          "settings": {
            "label": "Irrepetibles",
            "text": "Los medianos, grandes y gigantes existen una sola vez. Cuando uno se adopta, desaparece para siempre. No se repite, no se recrea, no se hace por encargo."
          }
        },
        "c7": {
          "type": "curiosidad",
          "settings": {
            "label": "Cristales",
            "text": "Cada Guardián lleva un cristal según su energía: amatista para protección, citrino para abundancia, cuarzo rosa para el amor."
          }
        },
        "c8": {
          "type": "curiosidad",
          "settings": {
            "label": "El test",
            "text": "¿No sabés cuál es el tuyo? El Test del Guardián te conecta con el ser elemental que vibra con tu momento."
          }
        }
      },
