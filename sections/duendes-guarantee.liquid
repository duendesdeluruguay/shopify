{{ 'duendes-base.css' | asset_url | stylesheet_tag }}
<style>
  .dg2 { position: relative; overflow: hidden; padding: clamp(60px, 8vw, 100px) 0; background: var(--black-deep, #080a06); color: var(--white, #FAFAF7); }
  .dg2__bg { position: absolute; inset: 0; z-index: 0; }
  .dg2__bg img { width: 100%; height: 100%; object-fit: cover; opacity: .1; filter: saturate(.3) brightness(.5); }
  .dg2__bg-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(8,10,6,.9) 0%, rgba(8,10,6,.78) 50%, rgba(8,10,6,.9) 100%); z-index: 1; }
  .dg2::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 50%, rgba(198,165,90,.04), transparent 60%); pointer-events: none; z-index: 2; }
  .dg2::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(198,165,90,.25), transparent); z-index: 3; }
  .dg2__container { max-width: 1100px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 3; }
  .dg2__header { text-align: center; margin-bottom: clamp(40px, 5vw, 56px); }
  .dg2__shield-icon { width: 72px; height: 72px; margin: 0 auto 24px; display: flex; align-items: center; justify-content: center; border-radius: 50%; border: 2px solid rgba(198,165,90,.3); background: rgba(198,165,90,.06); animation: dgPulse2 4s ease-in-out infinite; }
  @keyframes dgPulse2 { 0%, 100% { box-shadow: 0 0 0 0 rgba(198,165,90,.12); } 50% { box-shadow: 0 0 0 20px rgba(198,165,90,0); } }
  .dg2__shield-icon svg { width: 32px; height: 32px; stroke: var(--gold, #C6A55A); fill: none; stroke-width: 1.5; }
  .dg2__header h3 { font-family: var(--font-heading-family, 'Cinzel', serif); font-size: clamp(22px, 2.8vw, 32px); font-weight: 400; color: var(--white, #FAFAF7); letter-spacing: 1px; margin-bottom: 12px; }
  .dg2__header p { font-family: var(--font-body-family, 'Cormorant Garamond', serif); font-size: 17px; font-style: italic; color: #FAFAF7; max-width: 560px; margin: 0 auto; line-height: 1.6; }
  .dg2__diamond { display: flex; align-items: center; justify-content: center; gap: 16px; margin-top: 24px; }
  .dg2__diamond::before, .dg2__diamond::after { content: ''; width: 50px; height: 1px; background: linear-gradient(90deg, transparent, rgba(198,165,90,.3), transparent); }
  .dg2__diamond-icon { width: 6px; height: 6px; background: var(--gold, #C6A55A); transform: rotate(45deg); flex-shrink: 0; }
  .dg2__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; }
  .dg2__item { text-align: center; padding: 32px 20px; position: relative; transition: all .4s cubic-bezier(.25,.8,.25,1); opacity: 0; transform: translateY(20px); }
  .dg2__item.dg-visible { opacity: 1; transform: translateY(0); }
  .dg2__item:hover { background: rgba(198,165,90,.04); }
  .dg2__item:not(:last-child)::after { content: ''; position: absolute; top: 20%; right: 0; height: 60%; width: 1px; background: linear-gradient(180deg, transparent, rgba(198,165,90,.15), transparent); }
  .dg2__item-icon { font-size: 28px; margin-bottom: 16px; display: block; color: var(--gold, #C6A55A); transition: transform .3s; }
  .dg2__item:hover .dg2__item-icon { transform: scale(1.15); }
  .dg2__item h4 { font-family: var(--font-heading-family, 'Cinzel', serif); font-size: 14px; font-weight: 600; color: var(--gold, #C6A55A); letter-spacing: 1px; margin-bottom: 8px; text-transform: uppercase; }
  .dg2__item p { font-family: var(--font-body-family, 'Cormorant Garamond', serif); font-size: 15px; font-style: italic; color: rgba(255,255,255,.85); line-height: 1.5; margin: 0; }
  .dg2__bottom-line { margin-top: 24px; height: 1px; background: linear-gradient(90deg, transparent, rgba(198,165,90,.15), transparent); }
  @media (max-width: 1024px) { .dg2__grid { grid-template-columns: repeat(2, 1fr); } .dg2__item:nth-child(2)::after { display: none; } .dg2__item:nth-child(1), .dg2__item:nth-child(2) { border-bottom: 1px solid rgba(198,165,90,.08); } }
  @media (max-width: 480px) { .dg2__grid { grid-template-columns: 1fr; } .dg2__item::after { display: none; } .dg2__item { border-bottom: 1px solid rgba(198,165,90,.08); } .dg2__item:last-child { border-bottom: none; } }
  @media (prefers-reduced-motion: reduce) { .dg2__item { opacity: 1; transform: none; } }
</style>

<section class="dg2" id="duendes-garantia">
  {% if section.settings.background_image != blank %}
    <div class="dg2__bg">
      <img src="{{ section.settings.background_image | image_url: width: 1920 }}" alt="" loading="lazy" fetchpriority="low">
      <div class="dg2__bg-overlay"></div>
    </div>
  {% endif %}

  <div class="dg2__container">
    <div class="dg2__header duendes-reveal">
      <div class="dg2__shield-icon">
        <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <h3>{{ section.settings.title }}</h3>
      <p>{{ section.settings.subtitle }}</p>
      <div class="dg2__diamond"><span class="dg2__diamond-icon"></span></div>
    </div>

    <div class="dg2__grid">
      {%- for block in section.blocks -%}
        <div class="dg2__item duendes-reveal delay-{{ forloop.index }}" {{ block.shopify_attributes }} style="transition-delay:{{ forloop.index0 | times: 150 }}ms">
          <span class="dg2__item-icon">{{ block.settings.icon }}</span>
          <h4>{{ block.settings.text }}</h4>
          {% if block.settings.description != blank %}
            <p>{{ block.settings.description }}</p>
          {% endif %}
        </div>
      {%- endfor -%}
    </div>
    <div class="dg2__bottom-line"></div>
  </div>
</section>

<script>
(function(){
  var items = document.querySelectorAll('#duendes-garantia .dg2__item');
  if(!items.length || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  var obs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){ e.target.classList.add('dg-visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
  items.forEach(function(i){ obs.observe(i); });
})();
</script>

{% schema %}
{
  "name": "Duendes Garantia",
  "settings": [
    {"type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1"},
    {"type": "text", "id": "title", "label": "Titulo", "default": "Tu guardian llega perfecto o lo reemplazamos"},
    {"type": "textarea", "id": "subtitle", "label": "Subtitulo", "default": "Cada pieza viaja protegida con embalaje premium. Si algo sale mal, respondemos sin preguntas."},
    {"type": "image_picker", "id": "background_image", "label": "Imagen de fondo", "info": "Imagen sutil del taller o manos artesanas. Se muestra con overlay oscuro."}
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {"type": "text", "id": "icon", "label": "Icono", "default": "\u2713"},
        {"type": "text", "id": "text", "label": "Texto"},
        {"type": "text", "id": "description", "label": "Descripcion", "info": "Texto corto debajo del titulo (opcional)"}
      ]
    }
  ],
  "presets": [{"name": "Duendes Garantia"}]
}
{% endschema %}
