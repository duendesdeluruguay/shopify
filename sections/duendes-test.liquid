<style>
/* ═══════════════════════════════════════
   DUENDES TEST DEL GUARDIÁN v3
   ═══════════════════════════════════════ */

.dt-wrap{position:relative;min-height:100vh;background:#080a06;color:#fff;overflow-x:hidden;font-family:'Cormorant Garamond',Georgia,serif}
.dt-wrap *{box-sizing:border-box}
.dt-wrap input,.dt-wrap textarea,.dt-wrap select,.dt-wrap button{font-family:inherit}

.dt-orb{position:fixed;border-radius:50%;filter:blur(80px);opacity:.06;pointer-events:none;z-index:0}
.dt-orb--1{width:400px;height:400px;background:#C6A55A;top:-10%;left:-10%;animation:dtOrbFloat 20s ease-in-out infinite alternate}
.dt-orb--2{width:300px;height:300px;background:#4A5D3A;bottom:10%;right:-5%;animation:dtOrbFloat 25s ease-in-out infinite alternate-reverse}
.dt-orb--3{width:250px;height:250px;background:#C6A55A;top:50%;left:50%;animation:dtOrbFloat 18s ease-in-out infinite alternate}
@keyframes dtOrbFloat{0%{transform:translate(0,0) scale(1)}50%{transform:translate(40px,-30px) scale(1.15)}100%{transform:translate(-20px,20px) scale(.9)}}

.dt-firefly{position:fixed;border-radius:50%;pointer-events:none;z-index:1;opacity:0;will-change:transform,opacity}
.dt-firefly--gold{background:radial-gradient(circle,rgba(198,165,90,.6),rgba(198,165,90,0) 70%)}
.dt-firefly--green{background:radial-gradient(circle,rgba(74,93,58,.5),rgba(74,93,58,0) 70%)}
.dt-firefly--white{background:radial-gradient(circle,rgba(255,255,255,.4),rgba(255,255,255,0) 70%)}

@keyframes dtGoldBreath{0%,100%{text-shadow:0 0 8px rgba(198,165,90,.15),0 0 20px rgba(198,165,90,.05)}50%{text-shadow:0 0 16px rgba(198,165,90,.5),0 0 40px rgba(198,165,90,.2),0 0 60px rgba(198,165,90,.08)}}
@keyframes dtPulse{0%,100%{opacity:.4}50%{opacity:.85}}
@keyframes dtShine{0%{transform:translateX(-100%)}40%,100%{transform:translateX(100%)}}
@keyframes dtSigilSpin{from{transform:translate(-50%,-55%) rotate(0deg)}to{transform:translate(-50%,-55%) rotate(360deg)}}

.dt-intro{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;min-height:100dvh;text-align:center;padding:60px 24px}
.dt-intro-sigil{position:absolute;top:50%;left:50%;width:340px;height:340px;transform:translate(-50%,-55%);border:1px solid rgba(198,165,90,.1);border-radius:50%;pointer-events:none;animation:dtSigilSpin 60s linear infinite}
.dt-intro-sigil::before{content:'';position:absolute;inset:-30px;border:1px solid rgba(198,165,90,.05);border-radius:50%}
.dt-intro-sigil::after{content:'';position:absolute;inset:30px;border:1px solid rgba(198,165,90,.07);border-radius:50%}

.dt-intro-line{opacity:0;transform:translateY(30px);transition:opacity 1s cubic-bezier(.25,.46,.45,.94),transform 1s cubic-bezier(.25,.46,.45,.94);font-size:clamp(17px,4vw,21px);color:rgba(255,255,255,.7);line-height:1.7;max-width:640px;margin:0 auto;letter-spacing:.2px;position:relative;z-index:2}
.dt-intro-line.show{opacity:1;transform:translateY(0)}
.dt-intro-title{opacity:0;transform:scale(.85);transition:opacity 1s .15s,transform 1s .15s;font-family:'Cinzel','Cinzel Decorative',Georgia,serif;font-size:clamp(40px,9vw,68px);font-weight:300;letter-spacing:6px;color:#C6A55A;text-shadow:0 0 50px rgba(198,165,90,.55),0 0 100px rgba(198,165,90,.25);margin:36px 0 20px;position:relative;z-index:3}
.dt-intro-title.show{opacity:1;transform:scale(1);animation:dtGoldBreath 3s ease-in-out infinite 1.5s}
.dt-intro-sub{opacity:0;transition:opacity 1s;font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(15px,2.8vw,18px);font-style:italic;color:rgba(255,255,255,.55);max-width:540px;margin:0 auto 36px;line-height:1.7;letter-spacing:.2px;position:relative;z-index:2}
.dt-intro-sub.show{opacity:1}
.dt-magic-line{width:0;height:1px;background:linear-gradient(90deg,transparent,rgba(198,165,90,.5),#C6A55A,rgba(198,165,90,.5),transparent);margin:20px auto;transition:width 2s cubic-bezier(.25,.46,.45,.94);filter:drop-shadow(0 0 6px rgba(198,165,90,.3))}
.dt-magic-line.show{width:240px}

.dt-cta-primary{display:inline-block;margin-top:32px;padding:16px 44px;background:linear-gradient(135deg,#C6A55A 0%,#A38640 100%);color:#080a06;font-family:'Cinzel',Georgia,serif;font-size:13px;font-weight:600;letter-spacing:3px;text-transform:uppercase;border:none;border-radius:4px;cursor:pointer;transition:all .35s cubic-bezier(.25,.46,.45,.94);position:relative;overflow:hidden;opacity:0;transform:translateY(20px)}
.dt-cta-primary.show{opacity:1;transform:translateY(0)}
.dt-cta-primary:hover{box-shadow:0 8px 30px rgba(198,165,90,.45);transform:translateY(-2px)}
.dt-cta-primary::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.3),transparent);transform:translateX(-100%);animation:dtShine 4s ease-in-out infinite}

.dt-phase{display:none;position:relative;z-index:2;min-height:100vh;padding:60px 24px}
.dt-phase.active{display:flex;flex-direction:column;align-items:center;justify-content:flex-start}

.dt-progress{display:flex;gap:14px;margin-bottom:48px;align-items:center;justify-content:center}
.dt-progress-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.15);transition:all .5s}
.dt-progress-dot.done{background:#C6A55A;box-shadow:0 0 10px rgba(198,165,90,.5)}
.dt-progress-dot.active{background:#C6A55A;box-shadow:0 0 16px rgba(198,165,90,.7);transform:scale(1.4)}
.dt-progress-line{width:40px;height:1px;background:linear-gradient(90deg,rgba(198,165,90,.2),rgba(198,165,90,.05))}
.dt-progress-line.done{background:linear-gradient(90deg,#C6A55A,rgba(198,165,90,.4))}

.dt-phase-title{font-family:'Cinzel',Georgia,serif;font-size:clamp(26px,5vw,40px);font-weight:300;color:#C6A55A;letter-spacing:3px;text-align:center;margin:0 0 14px;text-shadow:0 0 30px rgba(198,165,90,.3)}
.dt-phase-sub{font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(15px,2.5vw,18px);font-style:italic;color:rgba(255,255,255,.55);text-align:center;margin:0 auto 40px;max-width:580px;line-height:1.7}

.dt-form{width:100%;max-width:520px;margin:0 auto}
.dt-field{margin-bottom:22px;position:relative}
.dt-field label{display:block;font-family:'Lato',sans-serif;font-size:11px;color:rgba(198,165,90,.85);text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;font-weight:400}
.dt-field label .req{color:#C6A55A;margin-left:4px}
.dt-field input,.dt-field select,.dt-field textarea{width:100%;padding:14px 18px;background:rgba(255,255,255,.04);border:1px solid rgba(198,165,90,.18);border-radius:6px;color:#fff;font-family:'Cormorant Garamond',Georgia,serif;font-size:17px;outline:none;transition:all .3s;-webkit-appearance:none}
.dt-field input:focus,.dt-field select:focus,.dt-field textarea:focus{border-color:#C6A55A;background:rgba(255,255,255,.07);box-shadow:0 0 0 3px rgba(198,165,90,.12)}
.dt-field input.invalid,.dt-field select.invalid,.dt-field textarea.invalid{border-color:rgba(220,80,80,.6);background:rgba(220,80,80,.05)}
.dt-field-error{display:none;color:#e88;font-size:12px;margin-top:6px;font-family:'Lato',sans-serif;letter-spacing:.3px}
.dt-field.has-error .dt-field-error{display:block}
.dt-field input::placeholder,.dt-field textarea::placeholder{color:rgba(255,255,255,.25)}
.dt-field select{background:rgba(255,255,255,.04) url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'%3E%3Cpath fill='%23C6A55A' d='M5 6L0 0h10z'/%3E%3C/svg%3E") no-repeat right 16px center;padding-right:40px}

.dt-field-row{display:grid;grid-template-columns:130px 1fr;gap:12px}
@media(max-width:520px){.dt-field-row{grid-template-columns:115px 1fr}}

.dt-field-hint{font-family:'Cormorant Garamond',Georgia,serif;font-size:13px;font-style:italic;color:rgba(255,255,255,.4);margin-top:6px;line-height:1.5}

.dt-textarea-wrap{position:relative}
.dt-textarea{min-height:240px;resize:vertical;line-height:1.7;font-size:18px}
.dt-textarea-counter{position:absolute;bottom:10px;right:14px;font-family:'Lato',sans-serif;font-size:11px;color:rgba(255,255,255,.35);letter-spacing:.5px;pointer-events:none}
.dt-textarea-counter.warn{color:rgba(255,165,80,.8)}
.dt-textarea-counter.ok{color:#C6A55A}

.dt-actions{display:flex;justify-content:space-between;align-items:center;margin-top:36px;gap:16px}
.dt-btn-back{background:transparent;border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.6);padding:12px 24px;border-radius:4px;font-family:'Cinzel',Georgia,serif;font-size:11px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all .3s}
.dt-btn-back:hover{border-color:rgba(198,165,90,.4);color:#C6A55A}
.dt-btn-next{flex:1;padding:14px 32px;background:linear-gradient(135deg,#C6A55A 0%,#A38640 100%);color:#080a06;font-family:'Cinzel',Georgia,serif;font-size:12px;font-weight:600;letter-spacing:3px;text-transform:uppercase;border:none;border-radius:4px;cursor:pointer;transition:all .35s;position:relative;overflow:hidden}
.dt-btn-next:hover:not(:disabled){box-shadow:0 8px 30px rgba(198,165,90,.45);transform:translateY(-2px)}
.dt-btn-next:disabled{opacity:.5;cursor:not-allowed}
.dt-btn-next::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.25),transparent);transform:translateX(-100%);animation:dtShine 5s ease-in-out infinite}

.dt-consent{margin-top:28px;padding:18px 22px;background:rgba(198,165,90,.04);border-left:2px solid rgba(198,165,90,.4);border-radius:0 8px 8px 0}
.dt-consent p{margin:0;font-family:'Cormorant Garamond',Georgia,serif;font-size:13px;font-style:italic;color:rgba(255,255,255,.5);line-height:1.65}

.dt-loading{align-items:center;justify-content:center;text-align:center}
.dt-loading-orb{width:120px;height:120px;border-radius:50%;background:radial-gradient(circle at 30% 30%,#C6A55A,#4A5D3A 70%);filter:blur(2px);box-shadow:0 0 80px rgba(198,165,90,.4),inset 0 0 40px rgba(255,255,255,.1);margin-bottom:48px;animation:dtPulse 2s ease-in-out infinite}
.dt-loading-text{font-family:'Cinzel',Georgia,serif;font-size:clamp(20px,3.5vw,28px);color:#C6A55A;letter-spacing:4px;text-transform:uppercase;animation:dtGoldBreath 3s ease-in-out infinite;margin:0 0 14px}
.dt-loading-stages{font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(14px,2.3vw,17px);font-style:italic;color:rgba(255,255,255,.5);min-height:26px;transition:opacity .6s}

.dt-result{padding:80px 24px 100px}
.dt-result-greeting{font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(15px,2.3vw,19px);font-style:italic;color:rgba(255,255,255,.55);text-align:center;margin-bottom:6px}
.dt-result-reveal{font-family:'Lato',sans-serif;font-size:clamp(11px,1.6vw,13px);color:#C6A55A;letter-spacing:4px;text-transform:uppercase;text-align:center;margin-bottom:48px;animation:dtGoldBreath 3s ease-in-out infinite}

.dt-guardian-card{max-width:480px;margin:0 auto 40px;background:linear-gradient(180deg,rgba(255,255,255,.04) 0%,rgba(255,255,255,.01) 100%);border:1px solid rgba(198,165,90,.18);border-radius:14px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.4),0 0 0 1px rgba(198,165,90,.08)}
.dt-guardian-img-wrap{position:relative;aspect-ratio:1/1;overflow:hidden;background:#0c0e08}
.dt-guardian-img{width:100%;height:100%;object-fit:cover;transition:transform 8s ease}
.dt-guardian-card:hover .dt-guardian-img{transform:scale(1.04)}
.dt-guardian-img-overlay{position:absolute;inset:0;background:linear-gradient(180deg,transparent 60%,rgba(8,10,6,.9) 100%);pointer-events:none}
.dt-guardian-info{padding:30px 28px 28px;text-align:center;position:relative}
.dt-guardian-name{font-family:'Cinzel',Georgia,serif;font-size:clamp(28px,4.2vw,42px);font-weight:300;color:#C6A55A;letter-spacing:3px;margin:0 0 8px;animation:dtGoldBreath 3s ease-in-out infinite}
.dt-guardian-type{font-family:'Lato',sans-serif;font-size:11px;color:rgba(255,255,255,.55);letter-spacing:3px;text-transform:uppercase;margin:0 0 18px}
.dt-guardian-price{font-family:'Lato',sans-serif;font-size:18px;font-weight:600;color:#A38640;margin:0 0 24px}
.dt-guardian-cta{display:inline-block;padding:14px 40px;background:linear-gradient(135deg,#C6A55A 0%,#A38640 100%);color:#080a06;font-family:'Cinzel',Georgia,serif;font-size:11px;font-weight:600;letter-spacing:3px;text-transform:uppercase;text-decoration:none;border-radius:4px;transition:all .3s;position:relative;overflow:hidden}
.dt-guardian-cta:hover{box-shadow:0 8px 30px rgba(198,165,90,.45);transform:translateY(-2px)}
.dt-guardian-cta::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.25),transparent);transform:translateX(-100%);animation:dtShine 5s ease-in-out infinite}

.dt-personal-msg{max-width:560px;margin:0 auto 40px;padding:32px 36px;background:rgba(198,165,90,.04);border-left:3px solid #C6A55A;border-radius:0 14px 14px 0}
.dt-personal-msg-label{font-family:'Lato',sans-serif;font-size:10px;color:#C6A55A;letter-spacing:3px;text-transform:uppercase;margin:0 0 14px;font-weight:400}
.dt-personal-msg p{font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(16px,2.4vw,19px);font-style:italic;color:rgba(255,255,255,.85);line-height:1.85;margin:0}

.dt-why{max-width:560px;margin:0 auto 48px;padding:24px 32px;border:1px solid rgba(198,165,90,.12);border-radius:14px;background:rgba(198,165,90,.02)}
.dt-why-label{font-family:'Lato',sans-serif;font-size:10px;color:#C6A55A;letter-spacing:3px;text-transform:uppercase;margin:0 0 12px;text-align:center}
.dt-why-text{font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(14px,2.1vw,16px);color:rgba(255,255,255,.7);line-height:1.75;margin:0;text-align:center}

.dt-compat{max-width:780px;margin:0 auto 48px}
.dt-compat-title{font-family:'Cinzel',Georgia,serif;font-size:clamp(18px,2.7vw,24px);font-weight:300;color:#C6A55A;letter-spacing:2px;text-align:center;margin:0 0 6px}
.dt-compat-sub{font-family:'Cormorant Garamond',Georgia,serif;font-size:14px;font-style:italic;color:rgba(255,255,255,.4);text-align:center;margin:0 0 32px}
.dt-compat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px}
.dt-compat-card{background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.06);border-radius:12px;overflow:hidden;text-decoration:none;color:#fff;transition:all .35s;display:block}
.dt-compat-card:hover{border-color:rgba(198,165,90,.4);transform:translateY(-4px);box-shadow:0 12px 30px rgba(0,0,0,.35)}
.dt-compat-card img{width:100%;aspect-ratio:1/1;object-fit:cover;background:#0c0e08}
.dt-compat-card-info{padding:14px 14px 16px}
.dt-compat-card-info h4{font-family:'Cinzel',Georgia,serif;font-size:15px;font-weight:300;letter-spacing:1px;margin:0 0 4px;color:#C6A55A}
.dt-compat-card-info p{font-family:'Lato',sans-serif;font-size:11px;color:rgba(255,255,255,.55);margin:0;letter-spacing:1px;text-transform:uppercase}
.dt-compat-reason{font-family:'Cormorant Garamond',Georgia,serif;font-size:12px;font-style:italic;color:rgba(255,255,255,.4);margin:6px 0 0;line-height:1.5}

.dt-share-wrap{max-width:560px;margin:0 auto;padding:32px 24px;text-align:center;border-top:1px solid rgba(198,165,90,.12);border-bottom:1px solid rgba(198,165,90,.12)}
.dt-share-title{font-family:'Cormorant Garamond',Georgia,serif;font-size:17px;font-style:italic;color:rgba(255,255,255,.6);margin:0 0 18px}
.dt-share-buttons{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.dt-share-btn{padding:10px 22px;background:transparent;border:1px solid rgba(198,165,90,.3);color:#C6A55A;font-family:'Cinzel',Georgia,serif;font-size:11px;letter-spacing:2px;text-transform:uppercase;border-radius:4px;cursor:pointer;transition:all .3s;text-decoration:none;display:inline-flex;align-items:center;gap:8px}
.dt-share-btn:hover{background:rgba(198,165,90,.08);border-color:#C6A55A}
.dt-share-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:1.6}
.dt-share-toast{position:fixed;bottom:32px;left:50%;transform:translateX(-50%) translateY(20px);background:rgba(8,10,6,.95);border:1px solid rgba(198,165,90,.4);color:#C6A55A;padding:12px 24px;border-radius:6px;font-family:'Lato',sans-serif;font-size:13px;letter-spacing:.5px;opacity:0;pointer-events:none;transition:all .4s;z-index:200;backdrop-filter:blur(10px)}
.dt-share-toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
.dt-receive-sub{font-family:'Cormorant Garamond',Georgia,serif;font-size:14px;font-style:italic;color:rgba(255,255,255,.45);margin:-10px 0 18px;text-align:center}
.dt-receive-email{background:rgba(198,165,90,.12);border-color:rgba(198,165,90,.5)}
.dt-receive-email:hover{background:rgba(198,165,90,.2)}
.dt-receive-wa{background:rgba(37,211,102,.12);border-color:rgba(37,211,102,.4);color:#25d366}
.dt-receive-wa:hover{background:rgba(37,211,102,.2);border-color:#25d366;color:#25d366}
.dt-share-btn:disabled{opacity:.5;cursor:not-allowed}
.dt-share-btn span{display:inline-block}

/* ── MUSIC CHOICE (intro) ── */
.dt-music-choice{opacity:0;transform:translateY(15px);transition:all .8s;display:flex;gap:14px;margin-top:18px;flex-wrap:wrap;justify-content:center}
.dt-music-choice.show{opacity:1;transform:translateY(0)}
.dt-music-btn{padding:12px 24px;border:1px solid rgba(198,165,90,.3);background:transparent;color:#C6A55A;font-family:'Cinzel',Georgia,serif;font-size:11px;letter-spacing:2px;text-transform:uppercase;border-radius:4px;cursor:pointer;transition:all .3s}
.dt-music-btn:hover{background:rgba(198,165,90,.1);border-color:#C6A55A}

/* ── MUSIC TOGGLE (persistente flotante) ── */
.dt-music-toggle{position:fixed;bottom:24px;right:24px;z-index:100;width:46px;height:46px;border-radius:50%;background:rgba(198,165,90,.15);border:1px solid rgba(198,165,90,.35);color:#C6A55A;font-size:18px;cursor:pointer;display:none;align-items:center;justify-content:center;transition:all .3s;backdrop-filter:blur(8px)}
.dt-music-toggle.visible{display:flex}
.dt-music-toggle:hover{background:rgba(198,165,90,.25);transform:scale(1.05)}
.dt-music-toggle svg{width:18px;height:18px;fill:currentColor}
.dt-music-toggle.muted{opacity:.6}

/* ── CINEMATIC TYPING REVEAL (result personal message) ── */
.dt-personal-msg p{position:relative}
.dt-result.active .dt-personal-msg{animation:dtFadeUp 1.2s .3s both}
.dt-result.active .dt-guardian-card{animation:dtFadeUp 1s both}
.dt-result.active .dt-why{animation:dtFadeUp 1.2s .6s both}
.dt-result.active .dt-compat{animation:dtFadeUp 1.2s .9s both}
.dt-result.active .dt-share-wrap{animation:dtFadeUp 1.2s 1.2s both}
@keyframes dtFadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}

.dt-error{max-width:480px;margin:80px auto;padding:32px;text-align:center;border:1px solid rgba(220,80,80,.3);border-radius:12px;background:rgba(220,80,80,.04)}
.dt-error h3{font-family:'Cinzel',Georgia,serif;color:#e88;margin:0 0 12px;font-size:20px;letter-spacing:2px}
.dt-error p{font-family:'Cormorant Garamond',Georgia,serif;color:rgba(255,255,255,.7);margin:0 0 20px;font-style:italic}
.dt-error button{padding:12px 28px;background:transparent;border:1px solid rgba(198,165,90,.4);color:#C6A55A;font-family:'Cinzel',Georgia,serif;font-size:11px;letter-spacing:2px;text-transform:uppercase;border-radius:4px;cursor:pointer}

@media(max-width:600px){
  .dt-actions{flex-direction:column-reverse}
  .dt-btn-back,.dt-btn-next{width:100%}
  .dt-compat-grid{grid-template-columns:repeat(2,1fr)}
  .dt-personal-msg{padding:24px 22px}
}
</style>

