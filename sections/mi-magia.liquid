{% style %}
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --primary-dark: #080a06;
    --gold: #C6A55A;
    --gold-light: #E8D4A8;
    --green-accent: #2D5F3F;
    --text-light: #F5F1E8;
    --text-muted: #B8B5AA;
    --border-gold: rgba(198, 165, 90, 0.3);
    --border-gold-solid: rgba(198, 165, 90, 0.6);
  }

  body {
    font-family: 'Lato', sans-serif;
    background-color: var(--primary-dark);
    color: var(--text-light);
    overflow-x: hidden;
  }

  #mi-magia-portal {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  /* FIREFLIES BACKGROUND ANIMATION */
  .fireflies-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .firefly {
    position: absolute;
    width: 4px;
    height: 4px;
    background: radial-gradient(circle, var(--gold) 0%, rgba(198, 165, 90, 0.5) 70%);
    border-radius: 50%;
    box-shadow: 0 0 6px var(--gold), 0 0 12px rgba(198, 165, 90, 0.5);
    animation: float var(--duration) infinite ease-in-out;
  }

  .firefly.green {
    background: radial-gradient(circle, var(--green-accent) 0%, rgba(45, 95, 63, 0.5) 70%);
    box-shadow: 0 0 6px var(--green-accent), 0 0 12px rgba(45, 95, 63, 0.5);
  }

  .firefly.white {
    background: radial-gradient(circle, #FFFFFF 0%, rgba(255, 255, 255, 0.5) 70%);
    box-shadow: 0 0 6px #FFFFFF, 0 0 12px rgba(255, 255, 255, 0.5);
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.5; }
    50% { transform: translate(var(--tx), var(--ty)) scale(1.2); opacity: 1; }
  }

  /* HEADER NAV */
  .mi-magia-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 80px;
    background: rgba(8, 10, 6, 0.95);
    border-bottom: 1px solid var(--border-gold);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    z-index: 1000;
    backdrop-filter: blur(10px);
  }

  .mi-magia-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 2px;
    cursor: pointer;
  }

  .mi-magia-nav {
    display: flex;
    gap: 40px;
    align-items: center;
  }

  .nav-link {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-light);
    cursor: pointer;
    transition: color 0.3s ease;
    border-bottom: 2px solid transparent;
    padding-bottom: 4px;
  }

  .nav-link:hover, .nav-link.active {
    color: var(--gold);
    border-bottom-color: var(--gold);
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
  }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    right: 0;
    background: rgba(8, 10, 6, 0.98);
    border: 1px solid var(--border-gold-solid);
    border-radius: 4px;
    min-width: 200px;
    margin-top: 8px;
    display: none;
    flex-direction: column;
    z-index: 1001;
  }

  .dropdown-menu.active {
    display: flex;
  }

  .dropdown-item {
    padding: 12px 20px;
    font-size: 13px;
    color: var(--text-light);
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s;
    border-bottom: 1px solid rgba(198, 165, 90, 0.1);
  }

  .dropdown-item:last-child {
    border-bottom: none;
  }

  .dropdown-item:hover {
    background-color: rgba(198, 165, 90, 0.1);
    color: var(--gold);
  }

  .nav-right {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .lang-toggle {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    color: var(--text-muted);
  }

  .lang-toggle.active {
    color: var(--gold);
  }

  .nav-button {
    padding: 8px 16px;
    border: 1px solid var(--gold);
    background: transparent;
    color: var(--gold);
    cursor: pointer;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    border-radius: 3px;
  }

  .nav-button:hover {
    background: var(--gold);
    color: var(--primary-dark);
    box-shadow: 0 0 20px rgba(198, 165, 90, 0.4);
  }

  /* CONTENT AREA */
  .mi-magia-content {
    flex: 1;
    margin-top: 80px;
    padding: 60px 40px;
    position: relative;
    z-index: 1;
  }

  .section {
    display: none;
    animation: fadeIn 0.6s ease-out;
  }

  .section.active {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* GATE / LOGIN SECTION */
  .gate-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: -80px;
    padding: 0 20px;
  }

  .gate-card {
    background: rgba(8, 10, 6, 0.8);
    border: 1px solid var(--border-gold-solid);
    border-radius: 8px;
    padding: 60px 40px;
    max-width: 400px;
    width: 100%;
    backdrop-filter: blur(20px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
  }

  .gate-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 32px;
    font-weight: 600;
    color: var(--gold);
    text-align: center;
    margin-bottom: 10px;
    letter-spacing: 2px;
  }

  .gate-subtitle {
    font-size: 13px;
    color: var(--text-muted);
    text-align: center;
    margin-bottom: 40px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .form-group {
    margin-bottom: 24px;
  }

  .form-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    margin-bottom: 8px;
    display: block;
  }

  .form-input {
    width: 100%;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-gold);
    border-radius: 4px;
    color: var(--text-light);
    font-family: inherit;
    font-size: 14px;
    transition: all 0.3s ease;
  }

  .form-input:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--gold);
    box-shadow: 0 0 12px rgba(198, 165, 90, 0.3);
  }

  .form-input::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .form-submit {
    width: 100%;
    padding: 14px 20px;
    background: var(--gold);
    color: var(--primary-dark);
    border: none;
    border-radius: 4px;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 0 20px rgba(198, 165, 90, 0.4);
  }

  .form-submit:hover {
    background: var(--gold-light);
    box-shadow: 0 0 30px rgba(198, 165, 90, 0.6);
    transform: translateY(-2px);
  }

  /* DASHBOARD SECTION */
  .dashboard-hero {
    font-family: 'Cormorant Garamond', serif;
    font-size: 48px;
    font-weight: 600;
    color: var(--gold);
    margin-bottom: 12px;
    letter-spacing: 2px;
    text-shadow: 0 0 20px rgba(198, 165, 90, 0.3);
  }

  .dashboard-subtitle {
    font-size: 14px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 60px;
  }

  .guardian-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
    margin-bottom: 60px;
  }

  .guardian-card {
    background: rgba(198, 165, 90, 0.05);
    border: 1px solid var(--border-gold);
    border-radius: 8px;
    padding: 30px;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .guardian-card:hover {
    background: rgba(198, 165, 90, 0.1);
    border-color: var(--gold);
    box-shadow: 0 8px 32px rgba(198, 165, 90, 0.2);
    transform: translateY(-4px);
  }

  .guardian-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    color: var(--gold);
    margin-bottom: 8px;
  }

  .guardian-type {
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 16px;
  }

  .guardian-meta {
    font-size: 13px;
    color: var(--text-light);
    line-height: 1.6;
  }

  .empty-state {
    text-align: center;
    padding: 60px 20px;
    color: var(--text-muted);
  }

  .empty-state-icon {
    font-size: 48px;
    margin-bottom: 20px;
  }

  /* FORMULARIO SECTION */
  .form-mode-selector {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }

  .mode-button {
    padding: 20px;
    background: rgba(198, 165, 90, 0.05);
    border: 2px solid var(--border-gold);
    border-radius: 8px;
    color: var(--text-light);
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    font-size: 14px;
    font-weight: 500;
  }

  .mode-button:hover, .mode-button.active {
    background: rgba(198, 165, 90, 0.15);
    border-color: var(--gold);
    color: var(--gold);
  }

  .form-section {
    background: rgba(198, 165, 90, 0.05);
    border: 1px solid var(--border-gold);
    border-radius: 8px;
    padding: 30px;
    margin-bottom: 30px;
  }

  .form-section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    color: var(--gold);
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-bottom: 20px;
  }

  .form-row.full {
    grid-template-columns: 1fr;
  }

  .gender-selector {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
  }

  .gender-button {
    flex: 1;
    padding: 10px;
    background: rgba(198, 165, 90, 0.05);
    border: 1px solid var(--border-gold);
    border-radius: 4px;
    color: var(--text-light);
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .gender-button:hover, .gender-button.active {
    background: var(--gold);
    color: var(--primary-dark);
    border-color: var(--gold);
  }

  .frequency-toggle {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 20px 0;
    padding: 16px;
    background: rgba(198, 165, 90, 0.05);
    border: 1px solid var(--border-gold);
    border-radius: 4px;
  }

  .toggle-switch {
    width: 40px;
    height: 24px;
    background: rgba(198, 165, 90, 0.3);
    border-radius: 12px;
    position: relative;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .toggle-switch.active {
    background: var(--gold);
  }

  .toggle-thumb {
    position: absolute;
    width: 20px;
    height: 20px;
    background: white;
    border-radius: 50%;
    top: 2px;
    left: 2px;
    transition: left 0.3s ease;
  }

  .toggle-switch.active .toggle-thumb {
    left: 18px;
  }

  .frequency-label {
    font-size: 13px;
    color: var(--text-light);
  }

  /* CANALIZACION SECTION */
  .canalizacion-hero {
    background: linear-gradient(135deg, rgba(198, 165, 90, 0.1) 0%, rgba(45, 95, 63, 0.05) 100%);
    border: 1px solid var(--border-gold);
    border-radius: 8px;
    padding: 60px 40px;
    text-align: center;
    margin-bottom: 40px;
  }

  .canalizacion-subtitle {
    font-size: 13px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
  }

  .guardian-name-large {
    font-family: 'Cormorant Garamond', serif;
    font-size: 48px;
    font-weight: 600;
    color: var(--gold);
    margin-bottom: 20px;
    letter-spacing: 2px;
    text-shadow: 0 0 20px rgba(198, 165, 90, 0.3);
  }

  .guardian-label {
    font-size: 13px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 30px;
  }

  .channeling-content {
    background: rgba(198, 165, 90, 0.05);
    border: 1px solid var(--border-gold);
    border-radius: 8px;
    padding: 40px;
    margin-bottom: 30px;
    line-height: 1.8;
    font-size: 15px;
  }

  .channeling-content p {
    margin-bottom: 16px;
  }

  .channeling-locked {
    text-align: center;
    padding: 60px 20px;
    color: var(--text-muted);
  }

  .channeling-locked-icon {
    font-size: 48px;
    margin-bottom: 20px;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  .care-guides {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
  }

  .care-card {
    background: rgba(198, 165, 90, 0.05);
    border: 1px solid var(--border-gold);
    border-radius: 8px;
    padding: 24px;
  }

  .care-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .care-content {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-light);
  }

  /* RITUAL SECTION */
  .ritual-hero {
    text-align: center;
    margin-bottom: 40px;
  }

  .ritual-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 40px;
    color: var(--gold);
    margin-bottom: 8px;
    letter-spacing: 2px;
  }

  .progress-bar-container {
    margin: 40px 0;
  }

  .progress-label {
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }

  .progress-bar {
    width: 100%;
    height: 6px;
    background: rgba(198, 165, 90, 0.2);
    border-radius: 3px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold) 0%, var(--green-accent) 100%);
    transition: width 0.3s ease;
    box-shadow: 0 0 10px rgba(198, 165, 90, 0.5);
  }

  .ritual-days {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
  }

  .ritual-day {
    background: rgba(198, 165, 90, 0.05);
    border: 1px solid var(--border-gold);
    border-radius: 8px;
    padding: 24px;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ritual-day:hover {
    background: rgba(198, 165, 90, 0.1);
    border-color: var(--gold);
  }

  .ritual-day.completed {
    background: rgba(45, 95, 63, 0.1);
    border-color: var(--green-accent);
  }

  .day-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 8px;
  }

  .day-name {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-light);
    margin-bottom: 12px;
  }

  .day-description {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 16px;
  }

  .day-checkbox {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
  }

  .checkbox {
    width: 20px;
    height: 20px;
    border: 2px solid var(--gold);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .checkbox.checked {
    background: var(--gold);
  }

  .checkbox.checked::after {
    content: '✓';
    color: var(--primary-dark);
    font-size: 12px;
    font-weight: bold;
  }

  .checkbox-label {
    font-size: 13px;
    color: var(--text-light);
  }

  /* INICIACION SECTION */
  .soul-name-display {
    text-align: center;
    padding: 60px 20px;
  }

  .soul-name-label {
    font-size: 13px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
  }

  .soul-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 56px;
    font-weight: 600;
    color: var(--gold);
    margin-bottom: 20px;
    letter-spacing: 2px;
    text-shadow: 0 0 20px rgba(198, 165, 90, 0.4);
  }

  .soul-name-meaning {
    font-size: 14px;
    color: var(--text-light);
    max-width: 500px;
    margin: 0 auto 40px;
    line-height: 1.6;
  }

  .elemental-chosen {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 20px;
  }

  /* BIENVENIDA SECTION */
  .bienvenida-hero {
    text-align: center;
    margin-bottom: 40px;
  }

  .bienvenida-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 40px;
    color: var(--gold);
    margin-bottom: 12px;
    letter-spacing: 2px;
  }

  .bienvenida-form {
    max-width: 400px;
    margin: 0 auto;
    background: rgba(198, 165, 90, 0.05);
    border: 1px solid var(--border-gold);
    border-radius: 8px;
    padding: 30px;
  }

  /* ELEGIDOS / CUIDADOS SECTIONS */
  .content-page {
    max-width: 800px;
    margin: 0 auto;
  }

  .page-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 40px;
    color: var(--gold);
    margin-bottom: 20px;
    letter-spacing: 2px;
    text-align: center;
  }

  .page-subtitle {
    font-size: 14px;
    color: var(--text-muted);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 40px;
  }

  .page-content {
    line-height: 1.8;
    font-size: 15px;
    color: var(--text-light);
  }

  .page-content h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    color: var(--gold);
    margin-top: 30px;
    margin-bottom: 15px;
  }

  .page-content p {
    margin-bottom: 16px;
  }

  /* MOBILE RESPONSIVE */
  @media (max-width: 768px) {
    .mi-magia-header {
      padding: 0 20px;
      height: 60px;
    }

    .mi-magia-nav {
      gap: 20px;
    }

    .nav-link {
      font-size: 12px;
      gap: 4px;
    }

    .mi-magia-content {
      padding: 40px 20px;
      margin-top: 60px;
    }

    .dashboard-hero {
      font-size: 32px;
    }

    .guardian-grid {
      grid-template-columns: 1fr;
    }

    .guardian-name-large {
      font-size: 32px;
    }

    .canalizacion-hero {
      padding: 40px 20px;
    }

    .ritual-days {
      grid-template-columns: 1fr;
    }

    .form-mode-selector {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .mi-magia-header {
      flex-direction: column;
      gap: 10px;
      height: auto;
      padding: 12px 16px;
    }

    .mi-magia-nav {
      width: 100%;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .nav-link {
      font-size: 11px;
    }

    .nav-right {
      width: 100%;
      justify-content: center;
      gap: 10px;
    }

    .mi-magia-content {
      padding: 20px;
      margin-top: auto;
    }

    .dashboard-hero {
      font-size: 24px;
    }

    .form-section {
      padding: 20px;
    }

    .gate-card {
      padding: 30px 20px;
    }
  }

  /* ANIMATIONS */
  .shimmer {
    animation: shimmer 3s infinite;
  }

  @keyframes shimmer {
    0%, 100% { text-shadow: 0 0 20px rgba(198, 165, 90, 0.3); }
    50% { text-shadow: 0 0 30px rgba(198, 165, 90, 0.6); }
  }

  .sigil {
    font-size: 24px;
    animation: sigil-pulse 2s infinite;
  }

  @keyframes sigil-pulse {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 1; }
  }
{% endstyle %}

<div id="mi-magia-portal">
  <!-- FIREFLIES BACKGROUND -->
  <div class="fireflies-container" id="fireflies-container"></div>

  <!-- HEADER NAV -->
  <header class="mi-magia-header">
    <div class="mi-magia-logo" onclick="switchSection('#dashboard')">✦ DUENDES</div>

    <nav class="mi-magia-nav">
