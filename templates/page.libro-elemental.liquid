{% comment %}
  La Guía de los Duendes del Uruguay · v4.0 BIBLIA
  · Tipografía: Cinzel (títulos) + Great Vibes (display) + Agency FB / Saira Condensed (body)
  · Todo el texto centrado
  · 50 páginas · tipos de seres + cuidados puntuales + sentires + preparar casa
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Great+Vibes&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Saira+Condensed:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  .libro-wrap {
    --black-deep: #0a0a0a; --cream: #F5F0E1; --cream-light: #FAF6EE;
    --gold: #C9A961; --gold-bright: #D8B872; --gold-dark: #8b7137;
    --brown-deep: #2A2620; --brown-soft: #5A5048;
    --line-gold: rgba(201,169,97,0.25);
    --wood-base: #2d1d11; --wood-mid: #3a2618; --wood-light: #4a3022; --wood-dark: #1a0f08;
    --font-info: 'Agency FB', 'Saira Condensed', 'Trebuchet MS', sans-serif;

    color: var(--cream); font-family: 'Cormorant Garamond', Georgia, serif;
    min-height: 100vh; padding: 28px 16px 60px; text-align: center;
    background-color: #0a0806;
    background-image:
      radial-gradient(ellipse at 50% 30%, rgba(80,55,30,0.35) 0%, rgba(0,0,0,0.92) 70%),
      radial-gradient(circle at 12% 88%, rgba(201,169,97,0.12) 0%, transparent 40%),
      radial-gradient(circle at 88% 12%, rgba(201,169,97,0.10) 0%, transparent 40%),
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='600' height='600' viewBox='0 0 600 600'><g fill='none' stroke='%23C9A961' stroke-width='1.5' opacity='0.06'><text x='300' y='180' text-anchor='middle' font-family='serif' font-style='italic' font-size='44' fill='%23C9A961' opacity='0.9'>Duendes del Uruguay</text><text x='300' y='220' text-anchor='middle' font-family='serif' font-size='14' letter-spacing='8' fill='%23C9A961' opacity='0.85'>%E2%9C%A6  %E2%9C%A6  %E2%9C%A6</text><text x='300' y='460' text-anchor='middle' font-family='serif' font-style='italic' font-size='44' fill='%23C9A961' opacity='0.9'>Duendes del Uruguay</text><text x='300' y='500' text-anchor='middle' font-family='serif' font-size='14' letter-spacing='8' fill='%23C9A961' opacity='0.85'>%E2%9C%A6  %E2%9C%A6  %E2%9C%A6</text></g></svg>"),
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='400' height='400' viewBox='0 0 400 400'><defs><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3'/><feColorMatrix values='0 0 0 0 0.79 0 0 0 0 0.66 0 0 0 0 0.38 0 0 0 0.04 0'/></filter></defs><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
    background-size: cover, cover, cover, 600px 600px, 400px 400px;
    background-repeat: no-repeat, no-repeat, no-repeat, repeat, repeat;
    background-attachment: fixed; position: relative; min-height: 100vh; overflow-x: hidden;
  }

  /* GLOW dorado sutil en esquinas */
  .libro-wrap::before {
    content:''; position: fixed; top: -100px; right: -100px; width: 500px; height: 500px; pointer-events: none; z-index: 0;
    background: radial-gradient(circle at center, rgba(201,169,97,0.18) 0%, rgba(201,169,97,0.05) 40%, transparent 70%);
    animation: glowPulse 9s ease-in-out infinite;
  }
  @keyframes glowPulse {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 1; }
  }
  .libro-wrap::after {
    content:''; position: fixed; bottom: -80px; left: -80px; width: 400px; height: 400px; pointer-events: none; z-index: 0;
    background: radial-gradient(circle at center, rgba(201,169,97,0.12) 0%, rgba(201,169,97,0.04) 50%, transparent 75%);
    animation: glowPulse 11s ease-in-out infinite reverse;
  }
    100% { background-position: -50% 8%, 200% 26%; }
  }

  .libro-wrap > * { position: relative; z-index: 1; }
  .libro-wrap * { box-sizing: border-box; }

  .libro-header { max-width: 760px; margin: 0 auto 24px; text-align: center; }
  .libro-header .eyebrow { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.5em; color: var(--gold); text-transform: uppercase; margin-bottom: 12px; text-shadow: 0 2px 8px rgba(0,0,0,0.7); }
  .libro-header h1 { font-family: 'Great Vibes', cursive; font-size: clamp(44px, 6.5vw, 72px); margin: 0 0 8px; line-height: 1; font-weight: 400; color: var(--cream); text-shadow: 0 4px 18px rgba(0,0,0,0.8); }
  .libro-header .sub { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.5em; color: var(--gold-bright); text-transform: uppercase; text-shadow: 0 2px 8px rgba(0,0,0,0.7); }

  .lang-overlay { position: fixed; inset: 0; background: rgba(10,8,6,0.97); z-index: 9999; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(8px); }
  .lang-overlay.hide { display: none; }
  .lang-box { max-width: 480px; text-align: center; padding: 40px 32px; border: 1px solid var(--gold); background: linear-gradient(160deg, #16110d 0%, #0a0806 100%); position: relative; }
  .lang-box::before { content:''; position: absolute; inset: 8px; border: 1px solid rgba(201,169,97,0.3); pointer-events:none; }
  .lang-box .ornament { color: var(--gold); font-family: 'Cinzel', serif; font-size: 14px; letter-spacing: 0.7em; margin-bottom: 18px; }
  .lang-box h2 { font-family: 'Great Vibes', cursive; font-weight: 400; font-size: 56px; color: var(--cream); margin: 0 0 8px; line-height: 1; }
  .lang-box .pretitle { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.4em; color: var(--gold); text-transform: uppercase; margin-bottom: 18px; }
  .lang-box p { font-family: var(--font-info); font-size: 16px; color: rgba(245,240,225,0.85); margin: 14px 0 28px; }
  .lang-buttons { display: flex; gap: 14px; justify-content: center; }
  .lang-buttons button { background: transparent; color: var(--cream); border: 1px solid var(--gold); padding: 14px 32px; font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.4em; text-transform: uppercase; cursor: pointer; transition: all 0.3s; }
  .lang-buttons button:hover { background: var(--gold); color: var(--black-deep); }
  .lang-buttons .recommended { background: var(--gold); color: var(--black-deep); }

  .flipbook-container { display: flex; justify-content: center; align-items: center; margin: 0 auto; max-width: 1120px; min-height: 600px; padding: 16px; }
  #book {
    box-shadow: 0 32px 100px rgba(0,0,0,0.85), 0 0 0 8px rgba(20,12,6,0.7), 0 0 0 9px var(--gold-dark);
    border-radius: 4px;
  }
  .page { background: var(--cream); color: var(--brown-deep); overflow: hidden; }
  .page-inner { padding: 32px 30px 28px; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; text-align: center; gap: 6px; }
  .page.dark { background: var(--black-deep); color: var(--cream); }
  .page.dark .page-inner::before { content: ''; position: absolute; inset: 14px; border: 1px solid rgba(201,169,97,0.22); pointer-events: none; }

  .page .eyebrow { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; letter-spacing: 0.5em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 14px; text-align: center; width: 100%; }
  .page.dark .eyebrow { color: var(--gold); }
  .page h2 { font-family: 'Great Vibes', cursive; font-size: 48px; margin: 0 auto 14px; line-height: 1; font-weight: 400; color: var(--brown-deep); text-align: center; width: 100%; }
  .page.dark h2 { color: var(--cream); }
  .page h3 { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10.5px; letter-spacing: 0.3em; color: var(--gold-dark); text-transform: uppercase; margin: 12px 0 8px; text-align: center; width: 100%; }
  .page.dark h3 { color: var(--gold); }

  /* TEXTO DE INFO · Agency / Saira Condensed */
  .page p { font-family: var(--font-info); font-weight: 400; font-size: 14px; line-height: 1.55; margin: 0 auto 10px; color: var(--brown-deep); text-align: center; max-width: 380px; letter-spacing: 0.01em; }
  .page.dark p { color: var(--cream); }
  .page p.lead { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; color: var(--brown-soft); font-size: 14.5px; }
  .page.dark p.lead { color: rgba(245,240,225,0.85); }
  .page strong { color: var(--brown-deep); font-weight: 600; }
  .page.dark strong { color: var(--cream); }
  .page em { font-style: italic; }

  .page .center-content { flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; width: 100%; text-align: center; }
  .page .symbol-row { color: var(--gold); letter-spacing: 0.7em; font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; text-align: center; }

  .page .page-number { position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%); font-family: 'Cinzel', serif; font-weight: 400; font-size: 9px; letter-spacing: 0.35em; color: var(--gold-dark); }
  .page.dark .page-number { color: var(--gold); opacity: 0.55; }

  /* TAPA */
  .page.cover {
    background: radial-gradient(ellipse at 30% 30%, rgba(50,40,30,0.4), transparent 60%), radial-gradient(ellipse at 70% 70%, rgba(40,30,20,0.5), transparent 60%), linear-gradient(135deg, #161210 0%, #0a0806 50%, #1a1410 100%);
    color: var(--cream); position: relative; box-shadow: inset 0 0 70px rgba(0,0,0,0.8);
  }
  .page.cover::before { content:''; position: absolute; inset: 22px; border: 1px solid rgba(201,169,97,0.45); }
  .page.cover::after { content:''; position: absolute; inset: 32px; border: 1px solid rgba(201,169,97,0.18); }
  .page.cover .page-inner { z-index: 2; align-items: center; justify-content: space-between; padding: 60px 30px; gap: 12px; text-align: center; }
  .page.cover .ornament-celtic-top { width: 80px; height: 80px; flex-shrink: 0; color: var(--gold); opacity: 0.95; }
  .page.cover .titulo-grande { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.5em; color: var(--gold); text-transform: uppercase; line-height: 1.4; text-align: center; }
  .page.cover h1 { font-family: 'Great Vibes', cursive; font-weight: 400; font-size: 58px; margin: 6px 0 8px; line-height: 1; color: var(--cream); text-shadow: 0 0 28px rgba(201,169,97,0.35); text-align: center; }
  .page.cover .marca-fina { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.6em; color: var(--gold-bright); text-transform: uppercase; text-align: center; }
  .page.cover .pie { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; font-size: 11px; color: rgba(245,240,225,0.55); margin: 0; text-align: center; }

  svg.ornament { display: block; margin: 14px auto; color: var(--gold-dark); }
  svg.ornament.dark { color: var(--gold); }
  svg.ornament.tiny { width: 32px; height: 32px; }
  svg.ornament.small { width: 60px; height: 60px; }
  svg.ornament.med { width: 90px; height: 90px; }

  .indice { font-family: var(--font-info); font-size: 12px; letter-spacing: 0.05em; color: var(--brown-deep); text-align: left; max-width: 380px; margin: 0 auto; }
  .indice-item { display: flex; justify-content: space-between; align-items: baseline; margin: 6px 0; }
  .indice-item .num { color: var(--gold-dark); margin-right: 8px; font-size: 11px; font-family: 'Cinzel', serif; letter-spacing: 0.15em; }
  .indice-item .name { flex: 1; }
  .indice-item .dots { flex: 1; border-bottom: 1px dotted var(--gold-dark); margin: 0 8px; align-self: end; height: 1px; }
  .indice-item .pg { color: var(--gold-dark); font-family: 'Cinzel', serif; }
  .indice-section { font-family: 'Cinzel', serif; font-weight: 500; font-size: 10px; letter-spacing: 0.35em; color: var(--gold); text-transform: uppercase; margin: 12px 0 4px; padding-bottom: 4px; border-bottom: 1px solid var(--gold-dark); text-align: center; }

  .page .cita { font-family: 'Great Vibes', cursive; font-size: 40px; line-height: 1.2; color: var(--gold-dark); text-align: center; padding: 16px 14px; font-weight: 400; }
  .page.dark .cita { color: var(--cream); font-size: 48px; }

  .foto-circle { width: 130px; height: 130px; border-radius: 50%; margin: 14px auto; overflow: hidden; border: 2px solid var(--gold); box-shadow: 0 8px 26px rgba(0,0,0,0.35); display: block; }
  .foto-circle img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .foto-rounded { width: 200px; height: 130px; border-radius: 16px; margin: 14px auto; overflow: hidden; border: 1px solid var(--gold); box-shadow: 0 6px 22px rgba(0,0,0,0.3); display: block; }
  .foto-rounded img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .foto-arch { width: 130px; height: 170px; border-radius: 65px 65px 6px 6px; margin: 14px auto; overflow: hidden; border: 1px solid var(--gold); box-shadow: 0 8px 26px rgba(0,0,0,0.35); display: block; }
  .foto-arch img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .foto-caption { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9px; letter-spacing: 0.35em; color: var(--gold-dark); text-transform: uppercase; margin-top: 8px; text-align: center; }

  .consejo-card { background: var(--cream-light); border: 1px solid var(--gold); border-radius: 6px; padding: 12px 14px; margin: 8px auto; text-align: center; max-width: 360px; }
  .consejo-card .titulo { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.3em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 5px; text-align: center; }
  .consejo-card p { font-family: var(--font-info); font-size: 13.5px; margin: 0 auto; line-height: 1.5; max-width: none; text-align: center; }
  .consejo-card.warning { border-color: #c47844; background: #fef0e0; }
  .consejo-card.warning .titulo { color: #a85e2c; }
  .consejo-card.elemento { background: linear-gradient(180deg, var(--cream-light) 0%, #f0e7d3 100%); border-width: 1.5px; }

  .elementos-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid var(--gold-dark); margin: 10px auto; max-width: 380px; }
  .elemento-cell { padding: 12px 10px; border-right: 1px solid var(--gold-dark); border-bottom: 1px solid var(--gold-dark); text-align: center; }
  .elemento-cell:nth-child(2n) { border-right: none; }
  .elemento-cell:nth-last-child(-n+2) { border-bottom: none; }
  .elemento-cell .titulo { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.3em; color: var(--gold-dark); margin-bottom: 5px; text-align: center; }
  .elemento-cell .quien { font-family: var(--font-info); font-size: 12px; color: var(--brown-deep); margin-bottom: 4px; font-weight: 500; text-align: center; }
  .elemento-cell .funcion { font-family: var(--font-info); font-size: 11.5px; color: var(--brown-soft); line-height: 1.45; text-align: center; }

  .dia-item { padding: 6px 8px; border-bottom: 1px solid var(--line-gold); text-align: center; max-width: 360px; margin: 0 auto; }
  .dia-item:last-child { border-bottom: none; }
  .dia-item .num { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; letter-spacing: 0.3em; color: var(--gold-dark); }
  .dia-item .titulo { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; letter-spacing: 0.2em; color: var(--brown-deep); }
  .dia-item .desc { font-family: var(--font-info); font-size: 12.5px; color: var(--brown-soft); line-height: 1.5; margin-top: 2px; text-align: center; }

  .compendio-tabla { font-size: 11px; max-width: 380px; margin: 0 auto; }
  .compendio-row { display: flex; padding: 7px 0; border-bottom: 1px solid var(--line-gold); align-items: baseline; text-align: left; }
  .compendio-row:last-child { border-bottom: none; }
  .compendio-row .nombre { flex: 0 0 110px; color: var(--brown-deep); letter-spacing: 0.18em; text-transform: uppercase; font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; }
  .compendio-row .uso { flex: 1; color: var(--brown-soft); font-family: var(--font-info); font-size: 12.5px; }

  .faq { margin: 8px auto; padding-bottom: 8px; border-bottom: 1px dotted var(--line-gold); text-align: center; max-width: 380px; }
  .faq:last-child { border-bottom: none; }
  .faq .pregunta { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.2em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 5px; text-align: center; }
  .faq .respuesta { font-family: var(--font-info); font-size: 12.5px; color: var(--brown-soft); line-height: 1.55; margin: 0 auto; text-align: center; }

  /* TIPO DE SER · card destacada */
  .ser-card { background: linear-gradient(160deg, var(--cream-light) 0%, #ede2c8 100%); border: 1.5px solid var(--gold); border-radius: 8px; padding: 14px 16px; margin: 8px auto; max-width: 380px; box-shadow: 0 4px 14px rgba(0,0,0,0.12); }
  .ser-card .ser-nombre { font-family: 'Great Vibes', cursive; font-size: 32px; color: var(--brown-deep); margin: 0 0 4px; line-height: 1; }
  .ser-card .ser-energia { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.4em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 8px; }
  .ser-card .ser-detalle { font-family: var(--font-info); font-size: 12.5px; color: var(--brown-soft); line-height: 1.5; margin: 0 auto 8px; text-align: center; }
  .ser-card .ser-meta { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-top: 8px; }
  .ser-card .ser-meta span { font-family: 'Cinzel', serif; font-size: 8.5px; letter-spacing: 0.2em; color: var(--gold-dark); text-transform: uppercase; padding: 3px 8px; border: 1px solid var(--gold-dark); border-radius: 100px; }

  .neuro-tag { display: inline-block; margin-top: 6px; padding: 4px 10px; background: var(--brown-deep); color: var(--gold); font-family: 'Cinzel', serif; font-size: 8.5px; letter-spacing: 0.3em; text-transform: uppercase; border-radius: 4px; }

  .cta-final { display: flex; flex-direction: column; gap: 10px; margin: 12px auto; max-width: 380px; }
  .cta-final-btn { display: block; padding: 14px 16px; background: var(--cream-light); border: 1px solid var(--gold); border-radius: 4px; text-decoration: none; color: var(--brown-deep); transition: all 0.3s; text-align: center; }
  .cta-final-btn:hover { background: var(--gold); color: var(--black-deep); }
  .cta-final-btn .cta-titulo { font-family: 'Cinzel', serif; font-weight: 500; font-size: 10px; letter-spacing: 0.3em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 4px; text-align: center; }
  .cta-final-btn:hover .cta-titulo { color: var(--black-deep); }
  .cta-final-btn .cta-text { font-family: var(--font-info); font-size: 13px; text-align: center; }

  .libro-controls { margin: 28px auto 0; display: flex; justify-content: center; align-items: center; gap: 18px; flex-wrap: wrap; }
  .libro-controls button { background: rgba(0,0,0,0.6); color: var(--gold); border: 1px solid var(--gold); padding: 12px 26px; font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.35em; text-transform: uppercase; cursor: pointer; transition: all 0.3s; backdrop-filter: blur(4px); }
  .libro-controls button:hover { background: var(--gold); color: var(--black-deep); }
  .libro-controls button:disabled { opacity: 0.4; cursor: not-allowed; }
  .libro-controls .page-indicator { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.35em; color: var(--gold); text-shadow: 0 2px 8px rgba(0,0,0,0.7); }
  .sound-toggle { background: rgba(0,0,0,0.6); color: var(--gold); border: 1px solid var(--gold); padding: 8px 14px; font-family: 'Cinzel', serif; font-weight: 400; font-size: 9px; letter-spacing: 0.3em; cursor: pointer; border-radius: 100px; }
  .sound-toggle.muted { opacity: 0.4; }

  .libro-footer { margin-top: 36px; text-align: center; font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.4em; color: rgba(201,169,97,0.7); text-transform: uppercase; text-shadow: 0 2px 8px rgba(0,0,0,0.7); }
  .libro-footer a { color: var(--gold); text-decoration: none; margin: 0 12px; }

  /* AURORAS · luces de otro mundo */
  .auroras {
    position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden;
    mix-blend-mode: screen;
  }
  .auroras .luz {
    position: absolute; width: 720px; height: 720px; border-radius: 50%;
    filter: blur(140px); opacity: 0; will-change: opacity, transform;
    animation: auroraRespirar 22s ease-in-out infinite;
  }
  .luz-magenta {
    background: radial-gradient(circle at 50% 50%, rgba(220,90,180,0.70) 0%, rgba(220,90,180,0.30) 35%, transparent 70%);
    top: -160px; left: -120px; animation-delay: 0s;
  }
  .luz-celeste {
    background: radial-gradient(circle at 50% 50%, rgba(110,200,240,0.65) 0%, rgba(110,200,240,0.25) 35%, transparent 70%);
    top: 8%; right: -180px; animation-delay: 5s; width: 680px; height: 680px;
  }
  .luz-dorada {
    background: radial-gradient(circle at 50% 50%, rgba(255,210,130,0.60) 0%, rgba(255,200,110,0.25) 35%, transparent 70%);
    bottom: -180px; right: 18%; animation-delay: 9s;
  }
  .luz-violeta {
    background: radial-gradient(circle at 50% 50%, rgba(160,100,230,0.55) 0%, rgba(160,100,230,0.22) 35%, transparent 70%);
    bottom: 5%; left: -160px; animation-delay: 13s; width: 760px; height: 760px;
  }
