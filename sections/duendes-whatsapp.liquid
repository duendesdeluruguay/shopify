{{ 'duendes-base.css' | asset_url | stylesheet_tag }}

<style>
  .duendes-whatsapp {
    background: var(--parchment);
    padding: 50px 0;
    text-align: center;
  }
  .duendes-whatsapp a {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--serif);
    font-size: 20px;
    color: var(--text);
    text-decoration: none;
    transition: color .3s;
  }
  .duendes-whatsapp a:hover { color: #25d366; }
  .duendes-whatsapp a svg { width: 32px; height: 32px; }
  .duendes-whatsapp__sub {
    font-size: 13px;
    color: var(--text-light);
    margin-top: 6px;
  }
</style>

<section class="duendes-whatsapp">
  <a href="https://wa.me/{{ section.settings.phone }}" target="_blank" rel="noopener">
    <svg viewBox="0 0 32 32" fill="none"><path d="M16 3C9.4 3 4 8.4 4 15c0 2.2.6 4.3 1.7 6.1L4 29l8.2-1.6c1.7.9 3.6 1.4 5.8 1.4 6.6 0 12-5.4 12-12S22.6 3 16 3z" fill="#25D366"/><path d="M22.4 19.1c-.4-.2-2.2-1.1-2.5-1.2-.3-.1-.6-.2-.8.2-.2.4-.9 1.2-1.1 1.4-.2.2-.4.2-.8 0-.4-.2-1.6-.6-3-1.8-1.1-1-1.8-2.2-2-2.6-.2-.4 0-.6.2-.8.1-.1.4-.5.5-.7.1-.2.2-.4.3-.6 0-.2 0-.4 0-.6 0-.2-.8-2-1.1-2.7-.3-.7-.6-.6-.8-.6h-.7c-.2 0-.6.1-.9.4-.3.3-1.2 1.2-1.2 2.8 0 1.6 1.2 3.2 1.4 3.4.2.2 2.4 3.6 5.8 5 .8.3 1.5.5 2 .7.8.3 1.6.2 2.2.1.7-.1 2.2-.9 2.5-1.7.3-.9.3-1.6.2-1.7-.1-.2-.3-.3-.7-.5z" fill="white"/></svg>
    {{ section.settings.text }}
  </a>
  <div class="duendes-whatsapp__sub">{{ section.settings.subtext }}</div>
</section>

{% schema %}
{
  "name": "Duendes WhatsApp",
  "tag": "section",
  "class": "duendes-whatsapp-section",
  "settings": [
    {
      "type": "text",
      "id": "phone",
      "label": "Número de WhatsApp (sin +)",
      "default": "59898690629"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Texto del link",
      "default": "¿Tenés dudas? Escribinos"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtexto",
      "default": "Respondemos en minutos"
    }
  ],
  "presets": [
    {
      "name": "Duendes WhatsApp"
    }
  ]
}
{% endschema %}
