{{ 'duendes-base.css' | asset_url | stylesheet_tag }}

<style>
  .duendes-faq {
    --bg: #FAFAF7;
    --bg-dark: #0d0f09;
    --text: #1a1a14;
    --text-light: #FAFAF7;
    --border: #e0ddd4;
    --serif: 'Cormorant Garamond', serif;
    --spacing: clamp(48px, 6vw, 80px);
  }

  .duendes-faq * { box-sizing: border-box; }

  /* Hero */
  .faq-hero {
    background: var(--bg-dark);
    padding: var(--spacing) 2rem;
    text-align: center;
  }

  .faq-hero-content {
    max-width: 680px;
    margin: 0 auto;
  }

  .faq-eyebrow {
    font-family: var(--serif);
    font-size: 0.8rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(250, 250, 247, 0.5);
    margin: 0 0 1rem;
  }

  .faq-title {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    color: var(--text-light);
    margin: 0 0 1rem;
    line-height: 1.15;
    font-weight: 600;
  }

  .faq-subtitle {
    font-family: var(--serif);
    font-size: 1.1rem;
    color: rgba(250, 250, 247, 0.65);
    margin: 0;
    line-height: 1.6;
  }

  /* FAQ Body */
  .faq-body {
    background: var(--bg);
    padding: var(--spacing) 2rem;
  }

  .faq-body-inner {
    max-width: 780px;
    margin: 0 auto;
  }

  /* Category */
  .faq-category {
    margin-bottom: clamp(40px, 5vw, 64px);
  }

  .faq-category:last-child { margin-bottom: 0; }

  .faq-category-name {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    font-weight: 600;
    color: var(--text);
    margin: 0 0 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  /* Accordion Items */
  .faq-item {
    border-bottom: 1px solid var(--border);
  }

  .faq-question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.15rem 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.4;
  }

  .faq-question:hover { opacity: 0.7; }

  .faq-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    position: relative;
  }

  .faq-icon::before,
  .faq-icon::after {
    content: '';
    position: absolute;
    background: var(--text);
    border-radius: 1px;
    transition: transform 0.3s ease;
  }

  .faq-icon::before {
    top: 50%;
    left: 3px;
    right: 3px;
    height: 1.5px;
    transform: translateY(-50%);
  }

  .faq-icon::after {
    left: 50%;
    top: 3px;
    bottom: 3px;
    width: 1.5px;
    transform: translateX(-50%);
  }

  .faq-item.open .faq-icon::after {
    transform: translateX(-50%) rotate(90deg);
    opacity: 0;
  }

  .faq-answer-wrap {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }

  .faq-answer {
    font-family: var(--serif);
    font-size: 1rem;
    color: rgba(26, 26, 20, 0.75);
    line-height: 1.7;
    padding: 0 0 1.25rem;
  }

  .faq-answer p { margin: 0 0 0.75rem; }
  .faq-answer p:last-child { margin-bottom: 0; }

  /* CTA */
  .faq-cta {
    background: var(--bg-dark);
    padding: var(--spacing) 2rem;
    text-align: center;
  }

  .faq-cta-inner {
    max-width: 580px;
    margin: 0 auto;
  }

  .faq-cta-title {
    font-family: var(--serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--text-light);
    margin: 0 0 0.75rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .faq-cta-text {
    font-family: var(--serif);
    font-size: 1rem;
    color: rgba(250, 250, 247, 0.6);
    margin: 0 0 1.75rem;
    line-height: 1.6;
  }

  .faq-cta-btn {
    display: inline-block;
    font-family: var(--serif);
    font-size: 0.95rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--bg-dark);
    background: var(--text-light);
    padding: 0.9rem 2.5rem;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .faq-cta-btn:hover { opacity: 0.85; }
</style>

{%- comment -%}
  FAQ Schema (2026-05-01) — JSON-LD FAQPage para que Google muestre las
  preguntas expandibles directo en el resultado de búsqueda. Acepta los
  blocks faq_item de la página, escapa HTML del answer dejando texto plano
  + voseo. Mejora CTR un 20-40% en queries informativos.
{%- endcomment -%}
{%- liquid
  assign faq_schema_items = ''
  for block in section.blocks
    if block.type == 'faq_item' and block.settings.question != blank and block.settings.answer != blank
      assign clean_answer = block.settings.answer | strip_html | strip_newlines | replace: '"', '\"' | strip
      assign clean_question = block.settings.question | strip_html | strip | replace: '"', '\"'
      capture item
        echo '{ "@type": "Question", "name": "'
        echo clean_question
        echo '", "acceptedAnswer": { "@type": "Answer", "text": "'
        echo clean_answer
        echo '" } }'
      endcapture
      if faq_schema_items != ''
        assign faq_schema_items = faq_schema_items | append: ','
      endif
      assign faq_schema_items = faq_schema_items | append: item
    endif
  endfor
-%}
{%- if faq_schema_items != '' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{{ faq_schema_items }}]
}
</script>
{%- endif -%}

<div class="duendes-faq">
  {%- comment -%} HERO {%- endcomment -%}
  <div class="faq-hero">
    <div class="faq-hero-content">
      <p class="faq-eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="faq-title">{{ section.settings.title }}</h1>
      {%- if section.settings.subtitle != blank -%}
        <p class="faq-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} FAQ BODY {%- endcomment -%}
  <div class="faq-body">
    <div class="faq-body-inner">
      {%- assign in_category = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'category_header' -%}
          {%- if in_category -%}
            </div>{%- comment -%} close previous .faq-category {%- endcomment -%}
          {%- endif -%}
          <div class="faq-category" {{ block.shopify_attributes }}>
            <h2 class="faq-category-name">{{ block.settings.title }}</h2>
          {%- assign in_category = true -%}

        {%- elsif block.type == 'faq_item' -%}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <button class="faq-question" aria-expanded="false">
              <span>{{ block.settings.question }}</span>
              <span class="faq-icon"></span>
            </button>
            <div class="faq-answer-wrap">
              <div class="faq-answer">{{ block.settings.answer }}</div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
      {%- if in_category -%}
        </div>{%- comment -%} close last .faq-category {%- endcomment -%}
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} CTA {%- endcomment -%}
  <div class="faq-cta">
    <div class="faq-cta-inner">
      <h2 class="faq-cta-title">{{ section.settings.cta_title }}</h2>
      {%- if section.settings.cta_text != blank -%}
        <p class="faq-cta-text">{{ section.settings.cta_text }}</p>
      {%- endif -%}
      {%- if section.settings.cta_url != blank -%}
        <a href="{{ section.settings.cta_url }}" class="faq-cta-btn">{{ section.settings.cta_button }}</a>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.duendes-faq .faq-question').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item = this.closest('.faq-item');
        var category = item.closest('.faq-category');
        var isOpen = item.classList.contains('open');

        // Close siblings in same category
        category.querySelectorAll('.faq-item.open').forEach(function (other) {
          if (other !== item) {
            other.classList.remove('open');
            other.querySelector('.faq-question').setAttribute('aria-expanded', 'false');
            other.querySelector('.faq-answer-wrap').style.maxHeight = '0';
          }
        });

        // Toggle current
        if (isOpen) {
          item.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
          item.querySelector('.faq-answer-wrap').style.maxHeight = '0';
        } else {
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
          var wrap = item.querySelector('.faq-answer-wrap');
          wrap.style.maxHeight = wrap.scrollHeight + 'px';
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Duendes FAQ",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "PREGUNTAS FRECUENTES"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Todo lo que necesitás saber"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Resolveremos todas tus dudas sobre nuestros guardianes canalizados, cómo comprar, envíos y más."
    },
    {
      "type": "text",
      "id": "cta_title",
      "label": "CTA Title",
      "default": "¿Todavía tenés dudas?"
    },
    {
      "type": "textarea",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Escribinos y te respondemos personalmente."
    },
    {
      "type": "text",
      "id": "cta_button",
      "label": "CTA Button Text",
      "default": "Contactar"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button URL"
    }
  ],
  "blocks": [
    {
      "type": "category_header",
      "name": "Categoría",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Name",
          "default": "General"
        }
      ]
    },
    {
      "type": "faq_item",
      "name": "Pregunta",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Pregunta",
          "default": "¿Pregunta?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Respuesta",
          "default": "<p>Respuesta aquí.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Duendes FAQ",
      "blocks": [
        { "type": "category_header", "settings": { "title": "La Magia" } },
        { "type": "faq_item", "settings": { "question": "¿Qué son exactamente los duendes canalizados?", "answer": "<p>No son figuras decorativas. Son seres canalizados en estado de meditación profunda — cada uno con nombre, historia y propósito propio.</p>" } },
        { "type": "faq_item", "settings": { "question": "¿Cómo sé cuál duende es para mí?", "answer": "<p>No lo elegís vos — él te elige a vos. Mirá los guardianes disponibles y prestá atención a cuál te detiene.</p>" } },
        { "type": "category_header", "settings": { "title": "Envíos y Pagos" } },
        { "type": "faq_item", "settings": { "question": "¿Hacen envíos internacionales?", "answer": "<p>Sí. Enviamos a todo el mundo desde Piriápolis, Uruguay.</p>" } }
      ]
    }
  ]
}
{% endschema %}

