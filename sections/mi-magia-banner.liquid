{% comment %}
  MI MAGIA BANNER REUSABLE - lineas doradas en movimiento arriba y abajo
{% endcomment %}
{%- liquid
  assign mm_lang = request.locale.iso_code | default: '' | slice: 0, 2 | downcase
  assign mm_loc = localization.language.iso_code | default: '' | slice: 0, 2 | downcase
  assign mm_en = false
  if mm_lang == 'en' or mm_loc == 'en'
    assign mm_en = true
  endif
  assign mm_title = section.settings.title
  assign mm_cta = section.settings.cta_text
  if mm_en
    assign _t = section.settings.title | strip | downcase
    if _t == 'mi magia' or _t contains 'mi magia'
      assign mm_title = 'MY MAGIC'
    endif
    assign _c = section.settings.cta_text | strip | downcase
    if _c contains 'mi magia' or _c contains 'entrar a mi magia' or _c contains 'enter mi magia'
      assign mm_cta = 'ENTER MY MAGIC'
    endif
  endif
-%}

<style>
.mm-strip-{{ section.id }}{ width:100%; background:#fff; padding:42px 32px; display:flex; align-items:center; justify-content:center; gap:48px; text-decoration:none; color:inherit; position:relative; transition:background 0.5s ease; margin:24px 0; }
.mm-strip-{{ section.id }}::before, .mm-strip-{{ section.id }}::after{ content:''; position:absolute; left:0; right:0; height:1px; background-image:linear-gradient(90deg, rgba(201,165,90,0.30) 0%, rgba(201,165,90,0.30) 30%, #f4d889 50%, rgba(201,165,90,0.30) 70%, rgba(201,165,90,0.30) 100%); background-size:300% 100%; background-position:0% 0; filter:drop-shadow(0 0 4px rgba(201,165,90,0.45)); animation:mmStripGoldFlow 6s linear infinite; pointer-events:none; }
.mm-strip-{{ section.id }}::before{ top:0; }
.mm-strip-{{ section.id }}::after{ bottom:0; animation-delay:-3s; }
@keyframes mmStripGoldFlow{ 0%{ background-position: 100% 0; } 100%{ background-position: -200% 0; } }
.mm-strip-{{ section.id }}:hover{ background:#fffbf2; }
.mm-strip-{{ section.id }} .mm-strip-text{ display:flex; flex-direction:column; align-items:flex-end; text-align:right; flex:1; max-width:480px; }
.mm-strip-{{ section.id }} .mm-strip-eyebrow{ font-family:'Cinzel', serif; font-size:10px; letter-spacing:4px; color:#6e4498; text-transform:uppercase; margin-bottom:6px; }
.mm-strip-{{ section.id }} .mm-strip-title{ font-family:'Cinzel', serif; font-size:clamp(20px, 2vw, 26px); font-weight:400; letter-spacing:3px; text-transform:uppercase; margin-bottom:6px; color:#1a1a1a; }
.mm-strip-{{ section.id }} .mm-strip-sub{ font-family:'Cormorant Garamond', serif; font-style:italic; font-size:15px; color:rgba(26,26,26,0.6); }
.mm-strip-{{ section.id }} .mm-strip-divider{ width:1px; height:64px; background:linear-gradient(180deg, transparent, rgba(110,68,152,0.45), transparent); }
.mm-strip-{{ section.id }} .mm-strip-cta{ display:inline-flex; align-items:center; gap:14px; font-family:'Cinzel', serif; font-size:12px; letter-spacing:3.5px; text-transform:uppercase; color:#6e4498; font-weight:500; position:relative; padding:12px 0; flex-shrink:0; text-decoration:none; }
.mm-strip-{{ section.id }} .mm-strip-cta::after{ content:''; position:absolute; bottom:0; left:0; right:0; height:1px; background:#6e4498; transform-origin:right; transform:scaleX(1); transition:transform 0.5s cubic-bezier(0.25,0.46,0.45,0.94); }
.mm-strip-{{ section.id }}:hover .mm-strip-cta::after{ transform:scaleX(0); transform-origin:left; }
.mm-strip-{{ section.id }} .mm-strip-cta-arrow{ font-size:14px; transition:transform 0.4s ease; }
.mm-strip-{{ section.id }}:hover .mm-strip-cta-arrow{ transform:translateX(6px); }
@media (max-width:820px){ .mm-strip-{{ section.id }}{ flex-direction:column; gap:20px; padding:32px 24px; } .mm-strip-{{ section.id }} .mm-strip-text{ align-items:center; text-align:center; } .mm-strip-{{ section.id }} .mm-strip-divider{ width:60px; height:1px; } }
</style>

<a href="{{ section.settings.cta_url | default: '/blogs/mi-magia' }}" class="mm-strip-{{ section.id }}">
  <div class="mm-strip-text">
    <div class="mm-strip-eyebrow">{{ section.settings.eyebrow }}</div>
    <div class="mm-strip-title">{{ mm_title }}</div>
    <div class="mm-strip-sub">{{ section.settings.subtitle }}</div>
  </div>
  <div class="mm-strip-divider"></div>
  <div class="mm-strip-cta">
    {{ mm_cta }}
    <span class="mm-strip-cta-arrow">{{ section.settings.cta_icon }}</span>
  </div>
</a>

{% schema %}
{
  "name": "Mi Magia Banner",
  "tag": "section",
  "class": "section-mi-magia-banner",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Tu portal personal"},
    {"type": "text", "id": "title", "label": "Titulo", "default": "Mi Magia"},
    {"type": "text", "id": "subtitle", "label": "Subtitulo", "default": "Si ya adoptaste a tu hada, pixie o duende, entra aca."},
    {"type": "text", "id": "cta_text", "label": "Texto del boton", "default": "Entrar a Mi Magia"},
    {"type": "text", "id": "cta_icon", "label": "Icono", "default": "✦"},
    {"type": "url", "id": "cta_url", "label": "Link"}
  ],
  "presets": [{"name": "Mi Magia Banner", "category": "Mi Magia"}]
}
{% endschema %}
