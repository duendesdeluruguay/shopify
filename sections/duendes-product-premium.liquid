<!-- ═══════════════════════════════════════
     JAVASCRIPT
═══════════════════════════════════════ -->
<script>
(function() {
  'use strict';

  /* ── Parallax Hero ── */
  var heroBg = document.getElementById('dpp-hero-bg');
  if (heroBg) {
    var heroEl = document.getElementById('dpp-hero');
    var heroH = heroEl ? heroEl.offsetHeight : 500;
    window.addEventListener('scroll', function() {
      var st = window.pageYOffset;
      if (st < heroH) {
        heroBg.style.transform = 'translateY(' + (st * 0.35) + 'px) scale(1.08)';
      }
    }, { passive: true });
  }

  /* ── Scroll Reveal ── */
  var reveals = document.querySelectorAll('.duendes-reveal');
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('dpp-visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });
    reveals.forEach(function(el) { obs.observe(el); });
  } else {
    reveals.forEach(function(el) { el.classList.add('dpp-visible'); });
  }

  /* ── Gallery ── */
  var mainImg = document.getElementById('dpp-main-img');
  var thumbs = document.querySelectorAll('.dpp-gallery__thumb');
  thumbs.forEach(function(th) {
    th.addEventListener('click', function() {
      if (!mainImg) return;
      mainImg.style.opacity = '0';
      setTimeout(function() {
        mainImg.src = th.getAttribute('data-src');
        mainImg.alt = th.getAttribute('data-alt') || '';
        mainImg.style.opacity = '1';
      }, 300);
      thumbs.forEach(function(t) { t.classList.remove('dpp-active'); });
      th.classList.add('dpp-active');
    });
  });

  /* ── Adopt Sound (Crystal Singing Bowl) ── */
  function playAdoptSound() {
    try {
      var ac = new (window.AudioContext || window.webkitAudioContext)();
      var t = ac.currentTime;
      [523.25, 659.25, 783.99, 1046.5].forEach(function(f, i) {
        var o = ac.createOscillator();
        var g = ac.createGain();
        o.type = 'sine';
        o.frequency.value = f;
        g.gain.setValueAtTime(0, t);
        g.gain.linearRampToValueAtTime(0.06 - i * 0.012, t + 0.15);
        g.gain.exponentialRampToValueAtTime(0.001, t + 2.5);
        o.connect(g);
        g.connect(ac.destination);
        o.start(t + i * 0.1);
        o.stop(t + 2.5);
      });
    } catch(e) {}
  }

  /* ── Golden Spores Explosion ── */
  function spawnGoldenSpores(btn) {
    var rect = btn.getBoundingClientRect();
    var cx = rect.left + rect.width / 2;
    var cy = rect.top + rect.height / 2;

    // Golden glow overlay
    var glow = document.createElement('div');
    glow.style.cssText = 'position:fixed;inset:0;background:radial-gradient(circle at ' + cx + 'px ' + cy + 'px, rgba(201,169,110,0.25) 0%, transparent 60%);z-index:9998;pointer-events:none;opacity:0;transition:opacity 0.3s;';
    document.body.appendChild(glow);
    requestAnimationFrame(function() { glow.style.opacity = '1'; });
    setTimeout(function() { glow.style.opacity = '0'; setTimeout(function() { glow.remove(); }, 500); }, 1200);

    // Spores
    for (var i = 0; i < 40; i++) {
      var spore = document.createElement('div');
      var angle = Math.random() * Math.PI * 2;
      var dist = 60 + Math.random() * 180;
      var dx = Math.cos(angle) * dist;
      var dy = Math.sin(angle) * dist - Math.random() * 100;
      var size = 3 + Math.random() * 5;
      var dur = 800 + Math.random() * 1000;
      spore.style.cssText = 'position:fixed;left:' + cx + 'px;top:' + cy + 'px;width:' + size + 'px;height:' + size + 'px;border-radius:50%;background:radial-gradient(circle,#e8d48b,#C9A96E);z-index:9999;pointer-events:none;opacity:1;box-shadow:0 0 ' + (size*2) + 'px rgba(201,169,110,0.6);transition:all ' + dur + 'ms cubic-bezier(0.25,0.8,0.25,1);';
      document.body.appendChild(spore);
      requestAnimationFrame(function() {
        spore.style.transform = 'translate(' + dx + 'px,' + dy + 'px) scale(0)';
        spore.style.opacity = '0';
      });
      setTimeout(function() { spore.remove(); }, dur + 100);
    }

    // Button glow
    btn.style.background = '#C9A96E';
    btn.style.boxShadow = '0 0 40px rgba(201,169,110,0.6), 0 0 80px rgba(201,169,110,0.3)';
    btn.style.color = '#0d0f09';
  }

  var atcBtn = document.getElementById('dpp-atc-btn');
  var atcForm = document.getElementById('dpp-atc-form');

  // Gift toggle (split multi-guardián #75): mostrar/ocultar inputs destinatario
  var giftRecipientPanel = document.getElementById('dpp-gift-recipient');
  var adoptionTypeHidden = document.getElementById('dpp-prop-adoption-type');
  var recipientNameInput = document.getElementById('dpp-prop-recipient-name');
  var recipientEmailInput = document.getElementById('dpp-prop-recipient-email');
  var giftRadios = document.querySelectorAll('input[name="dpp_adoption_choice"]');

  function syncGiftUI() {
    var selected = 'self';
    for (var ri = 0; ri < giftRadios.length; ri++) {
      if (giftRadios[ri].checked) { selected = giftRadios[ri].value; break; }
    }
    if (adoptionTypeHidden) adoptionTypeHidden.value = selected;
    if (giftRecipientPanel) {
      if (selected === 'gift_known') {
        giftRecipientPanel.removeAttribute('hidden');
        if (recipientNameInput) recipientNameInput.required = true;
        if (recipientEmailInput) recipientEmailInput.required = true;
      } else {
        giftRecipientPanel.setAttribute('hidden', '');
        // Limpiar values y required cuando no es gift_known así no se envían
        // properties vacías al carrito.
        if (recipientNameInput) { recipientNameInput.required = false; recipientNameInput.value = ''; }
        if (recipientEmailInput) { recipientEmailInput.required = false; recipientEmailInput.value = ''; }
      }
    }
  }
  for (var rj = 0; rj < giftRadios.length; rj++) {
    giftRadios[rj].addEventListener('change', syncGiftUI);
  }
  syncGiftUI();

  if (atcBtn && atcForm) {
    atcBtn.addEventListener('click', function(e) {
      e.preventDefault();
      // Si es gift_known, validar nombre y email antes de continuar
      var isGiftKnown = adoptionTypeHidden && adoptionTypeHidden.value === 'gift_known';
      if (isGiftKnown) {
        if (!recipientNameInput || !recipientNameInput.value.trim() || !recipientEmailInput || !recipientEmailInput.value.trim()) {
          var giftToggle = document.getElementById('dpp-gift-toggle');
          if (giftToggle) giftToggle.open = true;
          if (recipientNameInput) recipientNameInput.focus();
          atcBtn.classList.add('dpp-atc-btn--shake');
          setTimeout(function(){ atcBtn.classList.remove('dpp-atc-btn--shake'); }, 600);
          return;
        }
      }
      atcBtn.disabled = true;
      atcBtn.textContent = (window.__DPP_I18N && window.__DPP_I18N.connecting) || 'Connecting...';
      playAdoptSound();
      spawnGoldenSpores(atcBtn);
      setTimeout(function() {
        atcForm.submit();
      }, 1200);
    });
  }

  /* ── Fireflies ── */
  var firefliesContainer = document.getElementById('dpp-fireflies');
  if (firefliesContainer) {
    for (var fi = 0; fi < 18; fi++) {
      var ff = document.createElement('div');
      ff.className = 'dpp-hero__firefly';
      var size = 4 + Math.random() * 8;
      ff.style.width = size + 'px';
      ff.style.height = size + 'px';
      ff.style.left = (5 + Math.random() * 90) + '%';
      ff.style.top = (10 + Math.random() * 80) + '%';
      ff.style.setProperty('--dur', (6 + Math.random() * 8).toFixed(1) + 's');
      ff.style.setProperty('--delay', (Math.random() * 8).toFixed(1) + 's');
      ff.style.setProperty('--dx1', (Math.random() * 60 - 30) + 'px');
      ff.style.setProperty('--dy1', (Math.random() * 40 - 30) + 'px');
      ff.style.setProperty('--dx2', (Math.random() * 80 - 40) + 'px');
      ff.style.setProperty('--dy2', (Math.random() * 60 - 40) + 'px');
      ff.style.setProperty('--dx3', (Math.random() * 50 - 25) + 'px');
      ff.style.setProperty('--dy3', (Math.random() * 30 - 20) + 'px');
      firefliesContainer.appendChild(ff);
    }
  }

  /* ── Ficha golden orbs ── */
  var fichaOrbs = document.getElementById('dpp-ficha-orbs');
  if (fichaOrbs) {
    for (var ffi = 0; ffi < 10; ffi++) {
      var orb = document.createElement('div');
      orb.className = 'dpp-ficha__orb';
      var osize = 20 + Math.random() * 50;
      orb.style.width = osize + 'px';
      orb.style.height = osize + 'px';
      orb.style.left = (5 + Math.random() * 90) + '%';
      orb.style.top = (5 + Math.random() * 90) + '%';
      orb.style.setProperty('--dur', (8 + Math.random() * 12).toFixed(1) + 's');
      orb.style.setProperty('--delay', (Math.random() * 10).toFixed(1) + 's');
      orb.style.setProperty('--dx', (Math.random() * 60 - 30) + 'px');
      orb.style.setProperty('--dy', (Math.random() * 40 - 20) + 'px');
      fichaOrbs.appendChild(orb);
    }
  }

  /* ── Checklist animation ── */
  var checklist = document.getElementById('dpp-checklist');
  if (checklist) {
    var checkItems = checklist.querySelectorAll('.dpp-includes__item');
    var checkObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          for (var ci = 0; ci < checkItems.length; ci++) {
            (function(idx) {
              setTimeout(function() {
                checkItems[idx].classList.add('dpp-check-visible');
              }, idx * 300);
            })(ci);
          }
          checkObserver.unobserve(checklist);
        }
      });
    }, { threshold: 0.2 });
    checkObserver.observe(checklist);
  }

  /* ── Seal fireflies ── */
  var sealFireflies = document.getElementById('dpp-seal-fireflies');
  if (sealFireflies) {
    for (var sfi = 0; sfi < 12; sfi++) {
      var sff = document.createElement('div');
      sff.className = 'dpp-hero__firefly';
      var sfsize = 3 + Math.random() * 7;
      sff.style.width = sfsize + 'px';
      sff.style.height = sfsize + 'px';
      sff.style.left = (5 + Math.random() * 90) + '%';
      sff.style.top = (10 + Math.random() * 80) + '%';
      sff.style.setProperty('--dur', (8 + Math.random() * 10).toFixed(1) + 's');
      sff.style.setProperty('--delay', (Math.random() * 10).toFixed(1) + 's');
      sff.style.setProperty('--dx1', (Math.random() * 50 - 25) + 'px');
      sff.style.setProperty('--dy1', (Math.random() * 30 - 15) + 'px');
      sff.style.setProperty('--dx2', (Math.random() * 60 - 30) + 'px');
      sff.style.setProperty('--dy2', (Math.random() * 40 - 20) + 'px');
      sff.style.setProperty('--dx3', (Math.random() * 40 - 20) + 'px');
      sff.style.setProperty('--dy3', (Math.random() * 20 - 10) + 'px');
      sealFireflies.appendChild(sff);
    }
  }

  /* ── Signature writing animation on scroll ── */
  var sigWrap = document.getElementById('dpp-sig-wrap');
  if (sigWrap) {
    var sigObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var els = sigWrap.querySelectorAll('.dpp-seal__signature, .dpp-seal__sig-line, .dpp-seal__sig-glow');
          for (var si = 0; si < els.length; si++) {
            els[si].classList.add('dpp-sig-visible');
          }
          sigObserver.unobserve(sigWrap);
        }
      });
    }, { threshold: 0.5 });
    sigObserver.observe(sigWrap);
  }

  /* ── Ficha: Parse Description for Metadata ── */
  var storyBody = document.getElementById('dpp-story-body');
  if (storyBody) {
    var descText = storyBody.textContent || '';
    var descLower = descText.toLowerCase();

    /* Height */
    var heightMatch = descText.match(/(\d+)\s*(?:cent[ií]metros|centimetros|cm)/i);
    var fichaSize = document.getElementById('dpp-ficha-size');
    if (heightMatch && fichaSize) {
      var currentSize = fichaSize.textContent.trim();
      var tbr = (window.__DPP_I18N && window.__DPP_I18N.toBeRevealed) || 'To be revealed';
      if (currentSize && currentSize !== tbr && currentSize !== 'To be revealed' && currentSize !== 'Por revelar') {
        fichaSize.textContent = currentSize + ' · ' + heightMatch[1] + ' cm';
      } else {
        fichaSize.textContent = heightMatch[1] + ' cm';
      }
    }

    /* Crystal */
    var crystals = ['sodalita','citrino','cuarzo rosa','cuarzo','amatista','turmalina negra','turmalina','jade','obsidiana','ojo de tigre','lapislazuli','lapis lazuli','\u00e1gata','agata','aventurina','selenita','pirita','fluorita','labradorita','amazonita','rodonita','malaquita','howlita','onix','\u00f3nix','coral','granate','hematita'];
    var foundCrystal = '';
    crystals.forEach(function(c) {
      if (descLower.indexOf(c) > -1 && !foundCrystal) foundCrystal = c;
    });
    if (foundCrystal) {
      var fichaC = document.getElementById('dpp-ficha-crystal');
      if (fichaC) fichaC.textContent = foundCrystal.charAt(0).toUpperCase() + foundCrystal.slice(1);
    }

    /* Mission - extract a short compelling sentence about what the guardian does */
    var missionEl = document.getElementById('dpp-ficha-mission');
    if (missionEl) {
      var sentences = descText.replace(/\n/g, ' ').split(/(?<=[.!?])\s+/);
      var mission = '';
      var missionKeywords = ['proteg','ayud','acompa\u00f1','trabaj','lleg\u00f3 hasta','lleg\u00f3 porque','mi trabajo','mi misi\u00f3n','me especializo','experto en','nac\u00ed para','vine para','vine desde','mi prop\u00f3sito'];
      for (var si = 0; si < sentences.length; si++) {
        var sl = sentences[si].toLowerCase();
        for (var ki = 0; ki < missionKeywords.length; ki++) {
          if (sl.indexOf(missionKeywords[ki]) > -1 && sentences[si].length > 20 && sentences[si].length < 150) {
            mission = sentences[si].trim();
            break;
          }
        }
        if (mission) break;
      }
      if (mission) {
        missionEl.textContent = mission;
      }
    }
  }

  /* ── Recommendations ── */
  var recsContainer = document.getElementById('dpp-recs-scroll');
  if (recsContainer) {
    var productUrl = '/recommendations/products.json?product_id={{ product.id }}&limit=8';
    fetch(productUrl)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.products || !data.products.length) return;
        var html = '';
        data.products.forEach(function(p) {
          var img = p.featured_image || '';
          var price = (p.price / 100).toLocaleString('es-UY', { style: 'currency', currency: p.currency || 'USD' });
          html += '<a href="' + p.url + '" class="dpp-recs__card">';
          html += '<div class="dpp-recs__card-img"><img src="' + img + '" alt="' + (p.title || '') + '" loading="lazy"></div>';
          html += '<div class="dpp-recs__card-name dpp-cinzel">' + p.title + '</div>';
          html += '<div class="dpp-recs__card-price dpp-cinzel">' + price + '</div>';
          html += '</a>';
        });
        recsContainer.innerHTML = html;
      })
      .catch(function() {});
  }

})();
</script>

{%- comment -%}
  Sticky CTA producto mobile (2026-05-01) — aparece SOLO en mobile cuando
  el botón principal sale del viewport. Reduce abandono mobile dramáticamente.
{%- endcomment -%}
{%- if product != blank and current_variant.available -%}
  <div
    class="duendes-product-sticky"
    id="dppStickyBar"
    aria-hidden="true"
  >
    <div class="duendes-product-sticky__inner">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 96 }}"
          alt="{{ product.title | escape }}"
          class="duendes-product-sticky__img"
          loading="lazy"
          width="48"
          height="48"
        >
      {%- endif -%}
      <div class="duendes-product-sticky__info">
        <p class="duendes-product-sticky__name">{{ product.title }}</p>
        <p class="duendes-product-sticky__price">
          <span>{{ current_variant.price | money }}</span>
        </p>
      </div>
      <button
        type="button"
        class="duendes-product-sticky__btn"
        id="dppStickySubmit"
        aria-label="{{ 'duendes.product.sticky_aria' | t: title: product.title | escape }}"
      >
        {{ 'duendes.product.sticky_btn' | t }}
      </button>
    </div>
  </div>

  <script>
    (function(){
      var bar = document.getElementById('dppStickyBar');
      var mainBtn = document.getElementById('dpp-atc-btn');
      if (!bar || !mainBtn) return;

      // Mostrar el sticky cuando el botón principal sale del viewport
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if (e.isIntersecting) {
            bar.classList.remove('show');
            bar.setAttribute('aria-hidden', 'true');
          } else {
            bar.classList.add('show');
            bar.setAttribute('aria-hidden', 'false');
          }
        });
      }, { rootMargin: '0px 0px 80px 0px', threshold: 0 });
      io.observe(mainBtn);

      // Click en sticky → click en el botón principal (mantiene flow original)
      var stickyBtn = document.getElementById('dppStickySubmit');
      if (stickyBtn) {
        stickyBtn.addEventListener('click', function(){
          if (mainBtn && !mainBtn.disabled) {
            mainBtn.scrollIntoView({ behavior: 'smooth', block: 'center' });
            setTimeout(function(){ mainBtn.click(); }, 250);
          }
        });
      }
    })();
  </script>
{%- endif -%}

