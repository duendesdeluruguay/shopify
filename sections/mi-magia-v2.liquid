// NAVIGATION
function mmNav(section) {
  document.querySelectorAll('.mm-page').forEach(s => s.classList.remove('active'));
  const el = document.getElementById('mm-' + section);
  if (el) { el.classList.add('active'); window.scrollTo(0, 0); }
}

function mmNavMenu(section) {
  mmCloseMenu();
  mmNav(section);
}

/**
 * mmGoToRito() — Navigate to Rito de Reconocimiento page with context from pending orders
 * Builds query params from the first pending order if available
 */
function mmGoToRito() {
  var ritoUrl = '/pages/rito-reconocimiento';
  var params = [];
  // Try to get context from pending orders (loaded during data fetch)
  if (window.mmPendingOrders && window.mmPendingOrders.length > 0) {
    var po = window.mmPendingOrders[0];
    if (po.orderId) params.push('orderId=' + encodeURIComponent(po.orderId));
    if (po.store) params.push('store=' + encodeURIComponent(po.store));
  }
  if (mmCustomer && mmCustomer.email) {
    params.push('email=' + encodeURIComponent(mmCustomer.email));
  }
  if (params.length > 0) ritoUrl += '?' + params.join('&');
  window.location.href = ritoUrl;
}

/**
 * mmShowRitoFloating() — Muestra el recordatorio flotante del Rito si hay pendientes
 * y no fue descartado por el usuario en esta sesión
 */
function mmShowRitoFloating() {
  try {
    var dismissed = sessionStorage.getItem('mm_rito_floating_dismissed');
    if (dismissed === '1') return;
  } catch(e) {}
  var el = document.getElementById('mm-rito-floating');
  if (!el) return;
  // Pequeño delay para que aparezca después del hero (experiencia cinematográfica)
  setTimeout(function(){ el.classList.add('mm-show'); }, 1800);
  // Badge en la card del Rito
  var badge = document.getElementById('mm-card-rito-badge');
  if (badge) badge.style.display = 'inline-block';
}

/**
 * mmDismissRitoFloating() — El usuario cerró el recordatorio. Guardamos en sesión
 * para no molestar durante la misma visita.
 */
function mmDismissRitoFloating() {
  try { sessionStorage.setItem('mm_rito_floating_dismissed', '1'); } catch(e) {}
  var el = document.getElementById('mm-rito-floating');
  if (el) el.classList.remove('mm-show');
}

/**
 * mmTrackPortal(section) — Dispara evento de tracking hacia GAS (que lo reenvía
 * a Klaviyo como custom event para segmentar y automatizar flows).
 * NO bloquea la navegación — fire & forget.
 */
function mmTrackPortal(section) {
  try {
    if (!mmCustomer || !mmCustomer.email) return;
    var payload = {
      action: 'track_portal_event',
      email: mmCustomer.email,
      event: 'Portal Card Clicked',
      section: section,
      timestamp: new Date().toISOString()
    };
    // fire & forget — no esperamos respuesta
    fetch(GAS_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'text/plain;charset=utf-8' },
      body: JSON.stringify(payload),
      keepalive: true
    }).catch(function(){});
  } catch(e) {}
}

// MENU
function mmToggleMenu() {
  var panel = document.getElementById('mm-menu-panel');
  var overlay = document.getElementById('mm-menu-overlay');
  var hamburger = document.getElementById('mm-hamburger');
  var isOpen = panel.classList.contains('open');
  if (isOpen) {
    mmCloseMenu();
  } else {
    panel.classList.add('open');
    overlay.classList.add('open');
    hamburger.classList.add('open');
    // Close notifs if open
    document.getElementById('mm-notif-panel').classList.remove('open');
  }
}

function mmCloseMenu() {
  document.getElementById('mm-menu-panel').classList.remove('open');
  document.getElementById('mm-menu-overlay').classList.remove('open');
  document.getElementById('mm-hamburger').classList.remove('open');
}

// NOTIFICATIONS
function mmToggleNotifs() {
  var panel = document.getElementById('mm-notif-panel');
  var isOpen = panel.classList.contains('open');
  if (isOpen) {
    panel.classList.remove('open');
  } else {
    panel.classList.add('open');
    mmCloseMenu(); // Close menu if open
  }
}

function mmShowToast(title, text, action, actionText) {
  var toast = document.getElementById('mm-notif-toast');
  document.getElementById('mm-toast-title').textContent = title;
  document.getElementById('mm-toast-text').textContent = text;
  var btn = document.getElementById('mm-toast-action');
  btn.textContent = actionText || 'Ver';
  btn.onclick = function() { if (action) action(); mmDismissToast(); return false; };
  setTimeout(function() { toast.classList.add('visible'); }, 800);
}

function mmDismissToast() {
  document.getElementById('mm-notif-toast').classList.remove('visible');
}

function mmAddNotification(title, text, action) {
  var list = document.getElementById('mm-notif-list');
  // Hide empty state
  var emptyEl = document.getElementById('mm-notif-empty');
  if (emptyEl) emptyEl.style.display = 'none';
  // Add item
  var item = document.createElement('div');
  item.className = 'mm-notif-item';
  item.innerHTML = '<div class="mm-notif-item-title"><span class="mm-notif-item-dot"></span>' + title + '</div><div class="mm-notif-item-text">' + text + '</div><div class="mm-notif-item-time">Ahora</div>';
  if (action) item.onclick = function() { action(); document.getElementById('mm-notif-panel').classList.remove('open'); };
  list.prepend(item);
  // Show bell dot
  document.getElementById('mm-bell-dot').classList.add('active');
}

// Close notification panel when clicking outside
document.addEventListener('click', function(e) {
  var notifPanel = document.getElementById('mm-notif-panel');
  var bell = document.getElementById('mm-bell');
  if (notifPanel.classList.contains('open') && !notifPanel.contains(e.target) && !bell.contains(e.target)) {
    notifPanel.classList.remove('open');
  }
});

async function mmLogin() {
  const email = document.getElementById('mm-login-email').value.trim();
  const loginBtn = document.getElementById('mm-login-btn');
  const gate = document.getElementById('mm-gate');

  if (!email) {
    alert('Por favor ingresa tu email');
    return;
  }

  // Show loading state
  gate.classList.add('mm-gate-loading');
  loginBtn.disabled = true;
  const originalText = loginBtn.textContent;
  loginBtn.innerHTML = '<span class="mm-gate-spinner"></span>Verificando...';

  try {
    // Verify email against backend before showing dashboard
    const url = GAS_URL + '?action=get_customer_data&email=' + encodeURIComponent(email);
    const response = await fetch(url, { redirect: 'follow' });
    const text = await response.text();

    let data;
    try {
      data = JSON.parse(text);
    } catch(e) {
      // JSON parse failed — show error
      mmShowLoginError();
      gate.classList.remove('mm-gate-loading');
      loginBtn.disabled = false;
      loginBtn.textContent = originalText;
      return;
    }

    // Check if authorized — use backend's authorized field, fallback to channelings check
    const isAuthorized = data && (data.authorized === true || (data.success && data.channelings && data.channelings.length > 0));

    if (!isAuthorized) {
      // Email not found or no adoptions — show error
      mmShowLoginError();
      gate.classList.remove('mm-gate-loading');
      loginBtn.disabled = false;
      loginBtn.textContent = originalText;
      return;
    }

    // Authorization successful — proceed with login
    mmCustomer = { email: email, name: '', authorized: true };
    document.getElementById('mm-gate').classList.remove('active');
    document.getElementById('mm-header').style.display = 'flex';
    var ambientEl = document.getElementById('mm-ambient');
    if (ambientEl) ambientEl.style.display = 'block';
    mmNav('dashboard');
    mmLoadData();
    mmSetDailyMessage();
    mmSetGuardianOfWeek();
    mmLoadDiary();
    mmLoadOracleAnswers();
    try { localStorage.setItem('mm-session', JSON.stringify(mmCustomer)); } catch(e) {}

    // Start auto-refresh every 5 minutes
    mmStartAutoRefresh();

  } catch(err) {
    // Network or other error — show error state
    mmShowLoginError();
    gate.classList.remove('mm-gate-loading');
    loginBtn.disabled = false;
    loginBtn.textContent = originalText;
  }
}

function mmShowLoginError() {
  const formContainer = document.getElementById('mm-gate-form');
  const errorContainer = document.getElementById('mm-gate-error');

  if (formContainer) formContainer.style.display = 'none';
  if (errorContainer) errorContainer.classList.add('show');
}

function mmRetryLogin() {
  const formContainer = document.getElementById('mm-gate-form');
  const errorContainer = document.getElementById('mm-gate-error');
  const gate = document.getElementById('mm-gate');

  if (formContainer) formContainer.style.display = 'block';
  if (errorContainer) errorContainer.classList.remove('show');
  if (gate) gate.classList.remove('mm-gate-loading');

  document.getElementById('mm-login-email').value = '';
  document.getElementById('mm-login-email').focus();
}

function mmLogout() {
  mmCustomer = null;
  mmChannelings = [];
  document.getElementById('mm-header').style.display = 'none';
  document.querySelectorAll('.mm-page').forEach(s => s.classList.remove('active'));
  document.getElementById('mm-gate').classList.add('active');
  document.getElementById('mm-login-email').value = '';
  try { localStorage.removeItem('mm-session'); } catch(e) {}
  mmStopAutoRefresh();
}

// LOAD DATA
async function mmLoadData() {
  if (!mmCustomer || !mmCustomer.email) return;
  try {
    const url = GAS_URL + '?action=get_customer_data&email=' + encodeURIComponent(mmCustomer.email);
    const response = await fetch(url, { redirect: 'follow' });
    const text = await response.text();
    let data;
    try { data = JSON.parse(text); } catch(e) { return; }
    if (data.bienvenida && data.bienvenida.name) mmCustomer.name = data.bienvenida.name;
    if ((!mmCustomer.name || mmCustomer.name === 'Vos') && data.customer && data.customer.first_name) mmCustomer.name = data.customer.first_name;
    if ((!mmCustomer.name || mmCustomer.name === 'Vos') && data.customer && data.customer.email) {
      var p = data.customer.email.split('@')[0];
      mmCustomer.name = p.charAt(0).toUpperCase() + p.slice(1);
    }
    document.getElementById('mm-welcome').textContent = '✦ ' + mmCustomer.name + ' ✦';
    // Show first soul name in welcome
    if (data.channelings && data.channelings.length > 0) {
      for (var si = 0; si < data.channelings.length; si++) {
        var sn = data.channelings[si].soulName || '';
        if (sn && sn.trim().charAt(0) !== '{') {
          var soulEl = document.getElementById('mm-welcome-soul');
          if (soulEl) { soulEl.textContent = mmFixEncoding(sn); soulEl.style.display = 'block'; }
          break;
        }
      }
    }
    if (data.success && data.channelings && data.channelings.length > 0) {
      mmChannelings = data.channelings;
      mmRenderGuardians(data.channelings);
      mmRenderChannelings(data.channelings);
      mmRenderIdentityCards(data.channelings);
    } else { mmRenderGuardians([]); mmRenderChannelings([]); mmRenderIdentityCards([]); }

    // Check for pending forms → show as toast + notification
    if (data.formStatus && data.formStatus.pendingOrders && data.formStatus.pendingOrders.length > 0) {
      window.mmPendingOrders = data.formStatus.pendingOrders; // Store globally for mmGoToRito()
      var count = data.formStatus.pendingOrders.length;
      var toastText = count === 1
        ? 'Tu guardián está esperando conocerte. Abrí el rito de la Orden ' + data.formStatus.pendingOrders[0].orderName + '.'
        : 'Hay ' + count + ' guardianes esperando conocerte. Abrí sus ritos.';
      // Side toast — neuromarketing: no "tenés pendiente" (presión), sí "tu guardián espera" (invitación)
      mmShowToast('El portal está abierto', toastText, function() { mmGoToRito(); }, 'Abrir el rito');
      // Add to notifications panel
      mmAddNotification('El guardián espera', toastText, function() { mmGoToRito(); });
      // Recordatorio flotante cinematográfico + badge pulsante en la card del Rito
      mmShowRitoFloating();
    }

    // NEW v2: Rito completado pero canalización aún no publicada → mostrar estado positivo "canalizando"
    if (data.formStatus && data.formStatus.ritoV2Status) {
      var ritoStatus = data.formStatus.ritoV2Status;
      var canalizandoCount = 0;
      for (var ordId in ritoStatus) {
        if (ritoStatus[ordId] === 'review') canalizandoCount++;
      }
      if (canalizandoCount > 0) {
        var canalText = canalizandoCount === 1
          ? 'Tu rito llegó. Durante los 7 días tu guardián y vos se están reconociendo.'
          : 'Tus ' + canalizandoCount + ' ritos están en canalización activa.';
        mmAddNotification('Canalizando ✦', canalText, null);
      }
    }

    // Load ritual state for each channeling (detect if they completed the ritual)
    mmLoadRitualStates();

    mmLoadRecommendations();
  } catch(err) { mmRenderGuardians([]); mmRenderChannelings([]); }
}

