      form_email_label: "Email", form_email_placeholder: "you@email.com", form_email_error: "We need a valid email.",
      form_phone_label: "Phone", form_phone_placeholder: "number without country code", form_phone_error: "We need a valid phone.", form_phone_hint: "We only use it to send your reading by WhatsApp if you want.",
      form_dob_label: "Date of birth", form_dob_error: "We need your date of birth.", form_dob_hint: "Some channelings read this signal.",
