{%- assign adopted_count = 0 -%}
{%- for product in collection.products -%}
  {%- unless product.available -%}
    {%- assign adopted_count = adopted_count | plus: 1 -%}
  {%- endunless -%}
{%- endfor -%}

{%- if adopted_count > 0 -%}
<section class="adopted-carousel-section">
  <div class="adopted-carousel-header">
    <h2 class="adopted-carousel-title">{{ section.settings.title }}</h2>
    <p class="adopted-carousel-subtitle">{{ section.settings.subtitle }}</p>
  </div>
  <div class="adopted-carousel-track">
    {%- for product in collection.products -%}
      {%- unless product.available -%}
        <div class="adopted-carousel-item">
          <div class="adopted-carousel-circle">
            {%- if product.featured_image != blank -%}
              <img
                src="{{ product.featured_image | image_url: width: 200 }}"
                alt="{{ product.title | escape }}"
                width="200"
                height="200"
                loading="lazy"
              >
            {%- else -%}
              <div class="adopted-carousel-placeholder"></div>
            {%- endif -%}
          </div>
          <span class="adopted-carousel-name">{{ product.title }}</span>
        </div>
      {%- endunless -%}
    {%- endfor -%}
  </div>
</section>
{%- endif -%}

<style>
  .adopted-carousel-section {
    padding: 60px 20px 80px;
    background: #1a1a1a;
    text-align: center;
    overflow: hidden;
  }

  .adopted-carousel-header {
    margin-bottom: 36px;
  }

  .adopted-carousel-title {
    font-family: inherit;
    font-size: 1.4rem;
    font-weight: 300;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #c9a84c;
    margin: 0 0 8px;
  }

  .adopted-carousel-subtitle {
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 300;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #888;
    margin: 0;
  }

  .adopted-carousel-track {
    display: flex;
    gap: 28px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 10px 40px 20px;
    scrollbar-width: none;
  }

  .adopted-carousel-track::-webkit-scrollbar {
    display: none;
  }

  .adopted-carousel-item {
    flex: 0 0 auto;
    scroll-snap-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .adopted-carousel-circle {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    border: 2px solid #c9a84c;
    overflow: hidden;
    flex-shrink: 0;
  }

  .adopted-carousel-circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(70%) sepia(20%);
    transition: filter 0.3s ease;
  }

  .adopted-carousel-circle:hover img {
    filter: grayscale(30%) sepia(10%);
  }

  .adopted-carousel-placeholder {
    width: 100%;
    height: 100%;
    background: #2a2a2a;
  }

  .adopted-carousel-name {
    font-size: 0.7rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #999;
    max-width: 90px;
    text-align: center;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 749px) {
    .adopted-carousel-section {
      padding: 40px 10px 50px;
    }
    .adopted-carousel-track {
      gap: 20px;
      padding: 10px 20px 16px;
    }
    .adopted-carousel-circle {
      width: 72px;
      height: 72px;
    }
    .adopted-carousel-name {
      font-size: 0.65rem;
      max-width: 76px;
    }
  }
</style>

{% schema %}
{
  "name": "Guardianes Adoptados",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Guardianes que ya tienen hogar"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Fueron adoptados"
    }
  ],
  "presets": [
    {
      "name": "Guardianes Adoptados"
    }
  ]
}
{% endschema %}

