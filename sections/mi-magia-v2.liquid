// ═══════ RENDER IDENTITY CARDS ═══════
function mmRenderIdentityCards(channelings) {
  var container = document.getElementById('mm-identity-cards');
  var emptyEl = document.getElementById('mm-identity-empty');
  if (!container) return;

  var validCards = [];
  (channelings || []).forEach(function(ch) {
    var soulName = mmFixEncoding(ch.soulName || '');
    var soulMeaning = mmFixEncoding(ch.soulNameMeaning || '');
    var soulGuardian = mmFixEncoding(ch.soulNameGuardian || '');
    var soulGuardianMeaning = mmFixEncoding(ch.soulNameGuardianMeaning || '');
    // Skip JSON data in soul name fields
    if (soulName && soulName.trim().charAt(0) === '{') { try { JSON.parse(soulName); soulName = ''; } catch(e) {} }
    if (soulGuardian && soulGuardian.trim().charAt(0) === '{') { try { JSON.parse(soulGuardian); soulGuardian = ''; } catch(e) {} }
    if (soulGuardianMeaning && soulGuardianMeaning.trim().charAt(0) === '{') { try { JSON.parse(soulGuardianMeaning); soulGuardianMeaning = ''; } catch(e) {} }
    if (soulName || soulGuardian) {
      validCards.push({
        guardianName: mmFixEncoding(ch.guardianName || 'Guardi\u00e1n'),
        guardianType: mmFixEncoding(ch.guardianType || ''),
        soulName: soulName,
        soulMeaning: soulMeaning,
        soulGuardian: soulGuardian,
        soulGuardianMeaning: soulGuardianMeaning
      });
    }
  });

  if (validCards.length === 0) {
    container.innerHTML = '';
    if (emptyEl) emptyEl.style.display = 'block';
    return;
  }

  if (emptyEl) emptyEl.style.display = 'none';
  var html = '';
  validCards.forEach(function(card) {
    html += '<div class="mm-identity-section">';
    html += '<div class="mm-identity-overline">' + card.guardianName + (card.guardianType ? ' \u2014 ' + card.guardianType : '') + '</div>';

    html += '<div class="mm-identity-pair">';
    if (card.soulName) {
      html += '<div class="mm-identity-block">';
      html += '<div class="mm-identity-block-label">Tu nombre \u00e1lmico</div>';
      html += '<div class="mm-identity-block-name">' + card.soulName + '</div>';
      if (card.soulMeaning) html += '<div class="mm-identity-block-meaning">' + card.soulMeaning + '</div>';
      html += '</div>';
    }
    if (card.soulGuardian) {
      html += '<div class="mm-identity-block">';
      html += '<div class="mm-identity-block-label">Nombre \u00e1lmico del guardi\u00e1n</div>';
      html += '<div class="mm-identity-block-name">' + card.soulGuardian + '</div>';
      if (card.soulGuardianMeaning) html += '<div class="mm-identity-block-meaning">' + card.soulGuardianMeaning + '</div>';
      html += '</div>';
    }
    html += '</div>'; // pair

    html += '</div>'; // identity-section
  });
  container.innerHTML = html;
}

// ═══════ EL ORACULO — Submit question ═══════
function mmSubmitOracleQuestion() {
  var textarea = document.getElementById('mm-oraculo-question');
  var statusEl = document.getElementById('mm-oraculo-status');
  var successEl = document.getElementById('mm-oraculo-success');
  var question = (textarea ? textarea.value.trim() : '');

  if (!question) { statusEl.textContent = 'Escrib\u00ed tu pregunta antes de enviar.'; return; }
  if (question.length < 10) { statusEl.textContent = 'Tu pregunta es muy corta. Cont\u00e1nos m\u00e1s.'; return; }
  if (question.length > 500) { statusEl.textContent = 'M\u00e1ximo 500 caracteres por pregunta.'; return; }

  statusEl.textContent = 'Enviando al Or\u00e1culo...';

  var email = mmCustomer ? mmCustomer.email : 'anon';
  fetch(GAS_URL + '?action=submit_oracle_question', {
    method: 'POST',
    redirect: 'follow',
    headers: { 'Content-Type': 'text/plain' },
    body: JSON.stringify({ email: email, question: question })
  }).then(function(r) { return r.text(); })
    .then(function(t) {
      statusEl.textContent = '';
      textarea.value = '';
      successEl.style.display = 'block';
      setTimeout(function() { successEl.style.display = 'none'; }, 8000);
    })
    .catch(function(e) {
      statusEl.textContent = '';
      // Still show success — GAS might not have the handler yet but question will work once deployed
      textarea.value = '';
      successEl.style.display = 'block';
      setTimeout(function() { successEl.style.display = 'none'; }, 8000);
    });
}

// Load oracle answers
function mmLoadOracleAnswers() {
  var container = document.getElementById('mm-oraculo-answers');
  var emptyEl = document.getElementById('mm-oraculo-empty');
  if (!container) return;

  fetch(GAS_URL + '?action=get_oracle_answers', { redirect: 'follow' })
    .then(function(r) { return r.text(); })
    .then(function(t) {
      try {
        var data = JSON.parse(t);
        if (data.answers && data.answers.length > 0) {
          if (emptyEl) emptyEl.style.display = 'none';
          var html = '';
          data.answers.forEach(function(qa) {
            html += '<div class="mm-oraculo-qa">';
            html += '<div class="mm-oraculo-question">' + mmFixEncoding(qa.question) + '</div>';
