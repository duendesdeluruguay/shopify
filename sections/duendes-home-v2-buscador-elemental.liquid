  <div class="dh2-be__results" data-dh2-be-results hidden>
    <p class="dh2-be__results-lead" data-dh2-be-lead></p>
    <div class="dh2-be__deck" data-dh2-be-deck></div>
    <button type="button" class="dh2-be__again" data-dh2-be-reset>{{ 'duendes.home_v2.elemental_search.search_again' | t }}</button>
  </div>
  </div>

  <script type="application/json" data-dh2-be-data>
    {
      "products": [
        {%- assign first_json = true -%}
        {%- for product in search_collection.products limit: 50 -%}
          {%- if product.available -%}
            {%- unless first_json -%},{%- endunless -%}
            {%- assign first_json = false -%}
            {%- assign ess = product.metafields.custom.esencia.value | default: product.metafields.custom.esencia | default: '' -%}
            {%- assign tags_norm = product.tags | join: '|' | downcase -%}
            {
              "handle": {{ product.handle | json }},
              "title": {{ product.title | json }},
              "url": {{ product.url | json }},
              "price": {{ product.price | money | json }},
              "image": {% if product.featured_media %}{{ product.featured_media | image_url: width: 800 | json }}{% else %}""{% endif %},
              "essence": {{ ess | strip | json }},
              "tagsNorm": {{ tags_norm | json }}
            }
          {%- endif -%}
        {%- endfor -%}
      ],
      "gracePool": [
        {%- assign g_first = true -%}
        {%- for product in grace_coll.products limit: 50 -%}
          {%- if product.available -%}
            {%- unless g_first -%},{%- endunless -%}
            {%- assign g_first = false -%}
            {%- assign essg = product.metafields.custom.esencia.value | default: product.metafields.custom.esencia | default: '' -%}
            {%- assign tags_g = product.tags | join: '|' | downcase -%}
            {
              "handle": {{ product.handle | json }},
              "title": {{ product.title | json }},
              "url": {{ product.url | json }},
              "price": {{ product.price | money | json }},
              "image": {% if product.featured_media %}{{ product.featured_media | image_url: width: 800 | json }}{% else %}""{% endif %},
              "essence": {{ essg | strip | json }},
              "tagsNorm": {{ tags_g | json }}
            }
          {%- endif -%}
        {%- endfor -%}
      ],
      "fallback": [
        {%- assign fb_need_comma = false -%}
        {%- if section.settings.fallback_1 != blank and section.settings.fallback_1.available -%}
          {%- assign fp = section.settings.fallback_1 -%}
          {%- assign essf = fp.metafields.custom.esencia.value | default: fp.metafields.custom.esencia | default: '' -%}
          {%- assign tags_f = fp.tags | join: '|' | downcase -%}
          {
            "handle": {{ fp.handle | json }},
            "title": {{ fp.title | json }},
            "url": {{ fp.url | json }},
            "price": {{ fp.price | money | json }},
            "image": {% if fp.featured_media %}{{ fp.featured_media | image_url: width: 800 | json }}{% else %}""{% endif %},
            "essence": {{ essf | strip | json }},
            "tagsNorm": {{ tags_f | json }}
          }
          {%- assign fb_need_comma = true -%}
        {%- endif -%}
        {%- if section.settings.fallback_2 != blank and section.settings.fallback_2.available -%}
          {%- if fb_need_comma -%},{%- endif -%}
          {%- assign fp = section.settings.fallback_2 -%}
          {%- assign essf = fp.metafields.custom.esencia.value | default: fp.metafields.custom.esencia | default: '' -%}
          {%- assign tags_f = fp.tags | join: '|' | downcase -%}
          {
            "handle": {{ fp.handle | json }},
            "title": {{ fp.title | json }},
            "url": {{ fp.url | json }},
            "price": {{ fp.price | money | json }},
            "image": {% if fp.featured_media %}{{ fp.featured_media | image_url: width: 800 | json }}{% else %}""{% endif %},
            "essence": {{ essf | strip | json }},
            "tagsNorm": {{ tags_f | json }}
          }
          {%- assign fb_need_comma = true -%}
        {%- endif -%}
        {%- if section.settings.fallback_3 != blank and section.settings.fallback_3.available -%}
          {%- if fb_need_comma -%},{%- endif -%}
          {%- assign fp = section.settings.fallback_3 -%}
          {%- assign essf = fp.metafields.custom.esencia.value | default: fp.metafields.custom.esencia | default: '' -%}
          {%- assign tags_f = fp.tags | join: '|' | downcase -%}
          {
            "handle": {{ fp.handle | json }},
            "title": {{ fp.title | json }},
            "url": {{ fp.url | json }},
            "price": {{ fp.price | money | json }},
            "image": {% if fp.featured_media %}{{ fp.featured_media | image_url: width: 800 | json }}{% else %}""{% endif %},
            "essence": {{ essf | strip | json }},
            "tagsNorm": {{ tags_f | json }}
          }
        {%- endif -%}
      ]
    }
  </script>

  <script>
  (function () {
    var root = document.getElementById('dh2-be-{{ section.id }}');
    if (!root) return;

    var SINONIMOS = {
      miedo: ['proteccion'],
      ansiedad: ['calma'],
      tristeza: ['sanacion'],
      duelo: ['sanacion', 'transformacion'],
      dinero: ['abundancia'],
      pareja: ['amor'],
      casa: ['hogar'],
      hijos: ['proteccion', 'hogar'],
      trabajo: ['fuerza', 'abundancia'],
      salud: ['sanacion'],
      energia: ['fuerza'],
      suenos: ['magia'],
    };

    var I18N = {
      resultsBefore: {{ 'duendes.home_v2.elemental_search.results_before' | t | json }},
      resultsAfter: {{ 'duendes.home_v2.elemental_search.results_after' | t | json }},
    };

    function stripAccents(s) {
      try {
        return s.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
      } catch (e) {
        return s;
      }
    }

    function normalizeToken(s) {
      return stripAccents(String(s || '').trim().toLowerCase()).replace(/\s+/g, ' ');
    }

    function tagFromSlug(slug) {
      return 'esencia-' + slug;
    }

    function resolveTagsFromInput(token) {
      if (!token) return [];
      var base = token.split(/\s+/)[0];
      if (SINONIMOS.hasOwnProperty(base)) {
        return SINONIMOS[base].map(tagFromSlug);
      }
      return [tagFromSlug(base)];
    }

    function readData() {
      var el = root.querySelector('[data-dh2-be-data]');
      if (!el) return { products: [], gracePool: [], fallback: [] };
      try {
        var data = JSON.parse(el.textContent.trim());
        return {
          products: Array.isArray(data.products) ? data.products : [],
          gracePool: Array.isArray(data.gracePool) ? data.gracePool : [],
          fallback: Array.isArray(data.fallback) ? data.fallback : [],
        };
      } catch (e) {
        return { products: [], gracePool: [], fallback: [] };
      }
    }

    var DATA = readData();
    var PRODUCTS = DATA.products;
    var GRACE = (DATA.gracePool || []).filter(function (p) {
      return p && p.handle;
    });
    var FALLBACK = DATA.fallback.filter(function (p) {
      return p && p.handle;
    });

    function mergeUniqueToThree(target, pool) {
      var seen = {};
      target.forEach(function (p) {
        if (p && p.handle) seen[p.handle] = true;
      });
      for (var i = 0; i < pool.length && target.length < 3; i++) {
        var p = pool[i];
        if (p && p.handle && !seen[p.handle]) {
          target.push(p);
          seen[p.handle] = true;
        }
      }
    }

    function defaultTriple() {
      if (FALLBACK.length >= 3) return FALLBACK.slice(0, 3);
      if (FALLBACK.length > 0) {
        var out = FALLBACK.slice();
        mergeUniqueToThree(out, PRODUCTS);
        mergeUniqueToThree(out, GRACE);
        return out.slice(0, 3);
      }
      if (GRACE.length > 0) {
        var g = GRACE.slice(0, 3);
        mergeUniqueToThree(g, PRODUCTS);
        return g.slice(0, 3);
      }
      return PRODUCTS.slice(0, 3);
    }

    function productTagSet(p) {
      var raw = p.tagsNorm || '';
      if (!raw) return [];
      return raw.split('|').map(function (x) {
        return String(x).trim().toLowerCase();
      }).filter(Boolean);
    }

    function productHasAnyTag(p, tags) {
      if (!tags.length) return false;
      var set = productTagSet(p);
      for (var i = 0; i < tags.length; i++) {
        var want = tags[i].toLowerCase();
        if (set.indexOf(want) !== -1) return true;
      }
      return false;
    }

    function shuffle(arr) {
      var a = arr.slice();
      for (var i = a.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var t = a[i];
        a[i] = a[j];
        a[j] = t;
      }
      return a;
    }

    function escapeHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function renderCard(p) {
      var img = p.image
        ? '<div class="dh2-be__media"><img src="' +
          escapeHtml(p.image) +
          '" alt="' +
          escapeHtml(p.title) +
          '" loading="lazy" width="440" height="660"></div>'
        : '<div class="dh2-be__media"></div>';
      var ess = p.essence ? '<div class="dh2-be__essence">' + escapeHtml(p.essence) + '</div>' : '';
      return (
        '<a class="dh2-be__card" href="' +
        escapeHtml(p.url) +
        '">' +
        img +
        '<div class="dh2-be__shade"></div>' +
        '<div class="dh2-be__meta">' +
        '<div class="dh2-be__roman">✦</div>' +
        '<p class="dh2-be__name">' +
        escapeHtml(p.title) +
        '</p>' +
        ess +
        '<div class="dh2-be__price">' +
        escapeHtml(p.price) +
        '</div>' +
        '</div></a>'
      );
    }

    var panel = root.querySelector('[data-dh2-be-panel]');
    var form = root.querySelector('[data-dh2-be-form]');
    var input = root.querySelector('[data-dh2-be-input]');
    var results = root.querySelector('[data-dh2-be-results]');
    var lead = root.querySelector('[data-dh2-be-lead]');
    var deck = root.querySelector('[data-dh2-be-deck]');
    var resetBtn = root.querySelector('[data-dh2-be-reset]');
    var moreBtn = root.querySelector('[data-dh2-be-more]');
    var extra = root.querySelector('[data-dh2-be-extra]');

    if (moreBtn && extra) {
      moreBtn.addEventListener('click', function () {
        extra.classList.toggle('is-open');
      });
    }

    root.querySelectorAll('[data-dh2-be-chip]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var slug = btn.getAttribute('data-slug') || '';
        var label = btn.getAttribute('data-label') || btn.textContent.trim();
        runSearch(slug, label);
      });
    });

    function runSearch(slugOrRaw, displayLabel) {
      var token = normalizeToken(slugOrRaw);
      if (!token) return;
      var tags = resolveTagsFromInput(token);
      var matches = PRODUCTS.filter(function (p) {
        return productHasAnyTag(p, tags);
      });
      var triple = matches.length >= 3 ? pickThree(matches) : matches.length > 0 ? pickThree(matches) : [];
      if (triple.length < 3) {
        var def = defaultTriple();
        var seen = {};
        triple.forEach(function (p) {
          seen[p.handle] = true;
        });
        def.forEach(function (p) {
          if (triple.length >= 3) return;
          if (!seen[p.handle]) {
            triple.push(p);
            seen[p.handle] = true;
          }
        });
        triple = triple.slice(0, 3);
      } else {
        triple = triple.slice(0, 3);
      }

      var label =
        displayLabel ||
        (slugOrRaw && slugOrRaw.trim ? slugOrRaw.trim() : String(slugOrRaw || ''));

      if (panel) {
        panel.style.transition = 'opacity 0.3s ease';
        panel.style.opacity = '0';
      }

      window.setTimeout(function () {
        root.classList.add('dh2-be--has-results');
        if (lead) {
          lead.textContent =
            (I18N.resultsBefore || '').trim() +
            ' ' +
            label +
            (I18N.resultsAfter || '').trim();
        }
        if (deck) {
          deck.innerHTML = triple.map(renderCard).join('');
        }
        if (results) {
          results.hidden = false;
          results.style.opacity = '0';
          window.requestAnimationFrame(function () {
            results.classList.add('is-visible');
            results.style.opacity = '1';
          });
        }
      }, 300);
    }

    function showSearchAgain() {
      if (results) {
        results.classList.remove('is-visible');
        results.style.opacity = '0';
        window.setTimeout(function () {
          results.hidden = true;
          if (deck) deck.innerHTML = '';
          root.classList.remove('dh2-be--has-results');
          if (panel) panel.style.opacity = '1';
        }, 340);
      } else {
        root.classList.remove('dh2-be--has-results');
        if (panel) panel.style.opacity = '1';
      }
      if (input) input.value = '';
      if (extra) extra.classList.remove('is-open');
    }

    if (form && input) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var raw = input.value;
        var token = normalizeToken(raw);
        if (!token) return;
        runSearch(token, raw.trim());
      });
    }

    if (resetBtn) {
      resetBtn.addEventListener('click', showSearchAgain);
    }
  })();
</script>
</section>

