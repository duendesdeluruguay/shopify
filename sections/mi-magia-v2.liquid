            html += '</div>';
          });
          container.innerHTML = html;
        }
      } catch(e) { /* No answers yet — show empty state */ }
    })
    .catch(function(e) { /* Silent — empty state shows by default */ });
}

// DAILY MESSAGE
function mmSetDailyMessage() {
  const now = new Date();
  const dayOfYear = Math.floor((now - new Date(now.getFullYear(), 0, 0)) / 86400000);
  const index = dayOfYear % FRASES.length;
  document.getElementById('mm-daily-quote').textContent = FRASES[index];
}

// GUARDIAN OF THE WEEK
function mmSetGuardianOfWeek() {
  // Fetch available guardians from store
  fetch('/collections/todos-los-guardianes/products.json?limit=250')
    .then(r => r.json())
    .then(data => {
      const available = (data.products || []).filter(p => (p.variants && p.variants[0] && p.variants[0].available === true));
      if (available.length === 0) available = data.products || [];
      
      // Pick based on week
      const now = new Date();
      const weekNum = Math.floor((now - new Date(now.getFullYear(), 0, 1)) / (7 * 86400000));
      const index = weekNum % available.length;
      const p = available[index];
      
      const img = (p.featured_image && p.featured_image.src) || (p.images && p.images[0] && p.images[0].src) || (p.image && p.image.src) || '';
      const type = p.product_type || 'Ser Elemental';
      
      document.getElementById('mm-gotw-name').textContent = p.title || 'Guardián';
      document.getElementById('mm-gotw-type').textContent = type;
      document.getElementById('mm-gotw-quote').textContent = '"Cada semana elegimos un guardián especial para ti."';
      document.getElementById('mm-gotw-img').src = img;
    })
    .catch(e => {
      // Fallback a GOTW_DATA si falla la búsqueda
      const weekNum = Math.floor((new Date() - new Date(new Date().getFullYear(), 0, 1)) / (7 * 86400000));
      const index = weekNum % GOTW_DATA.length;
      const g = GOTW_DATA[index];
      document.getElementById('mm-gotw-name').textContent = g.name;
      document.getElementById('mm-gotw-type').textContent = g.type;
      document.getElementById('mm-gotw-quote').textContent = '"' + g.quote + '"';
      document.getElementById('mm-gotw-img').src = g.img;
    });
}

// RECOMMENDATIONS
async function mmLoadRecommendations() {
  const grid = document.getElementById('mm-reco-grid');
  try {
    const resp = await fetch('/collections/tienda-magica/products.json?limit=20');
    const data = await resp.json();
    if (!data.products || data.products.length === 0) { grid.innerHTML = '<p style="color:var(--text-light);">No hay recomendaciones disponibles.</p>'; return; }
    const shuffled = data.products.sort(() => 0.5 - Math.random()).slice(0, 3);
    let html = '';
    shuffled.forEach(p => {
      const img = p.images && p.images[0] ? p.images[0].src : '';
      const price = p.variants && p.variants[0] ? p.variants[0].price : '';
      html += '<div class="mm-reco-card" onclick="window.open(\'/products/' + p.handle + '\',\'_blank\')">';
      if (img) html += '<img src="' + img + '" alt="' + p.title + '">';
      html += '<h4>' + p.title + '</h4>';
      html += '<p class="type">' + (p.product_type || 'Guardian') + '</p>';
      if (price) html += '<p class="price">$' + price + '</p>';
      html += '</div>';
    });
    grid.innerHTML = html;
  } catch(e) { grid.innerHTML = '<p style="color:var(--text-light);">Explora la tienda para descubrir guardianes.</p>'; }
}

// DIARY
function mmLoadDiary() {
  const container = document.getElementById('mm-diary-entries');
  const empty = document.getElementById('mm-diary-empty');
  let entries = [];
  try { entries = JSON.parse(localStorage.getItem('mm-diary-' + (mmCustomer ? mmCustomer.email : '')) || '[]'); } catch(e) {}
  if (entries.length === 0) { container.innerHTML = ''; empty.style.display = 'block'; return; }
  empty.style.display = 'none';
  const categoryLabels = { senal: 'Senial / Sincronicidad', aroma: 'Aroma', mensaje: 'Mensaje', sueno: 'Suenio', emocion: 'Emocion', naturaleza: 'Naturaleza', otro: 'Otro' };
  let html = '';
  entries.sort((a, b) => new Date(b.date) - new Date(a.date)).forEach(entry => {
    html += '<div class="mm-diary-entry">';
    html += '<div class="date">' + new Date(entry.date).toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) + ' — ' + (categoryLabels[entry.category] || entry.category) + '</div>';
    html += '<div class="content">' + entry.text.replace(/\n/g, '<br>') + '</div>';
    html += '</div>';
  });
  container.innerHTML = html;
  document.getElementById('mm-diary-date').valueAsDate = new Date();
}

function mmSaveDiaryEntry() {
  const date = document.getElementById('mm-diary-date').value;
  const category = document.getElementById('mm-diary-category').value;
  const text = document.getElementById('mm-diary-text').value.trim();
  if (!date || !text) { alert('Completa la fecha y la descripcion'); return; }
  let entries = [];
  const key = 'mm-diary-' + (mmCustomer ? mmCustomer.email : '');
  try { entries = JSON.parse(localStorage.getItem(key) || '[]'); } catch(e) {}
  entries.push({ date, category, text, created: new Date().toISOString() });
  try { localStorage.setItem(key, JSON.stringify(entries)); } catch(e) {}
  document.getElementById('mm-diary-text').value = '';
  mmLoadDiary();
}

// ACCORDION
function mmToggleAccordion(header) {
  const body = header.nextElementSibling;
  const isOpen = body.classList.contains('open');
  document.querySelectorAll('.mm-accordion-body').forEach(b => b.classList.remove('open'));
  document.querySelectorAll('.mm-accordion-arrow').forEach(s => s.textContent = '+');
