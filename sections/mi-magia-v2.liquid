    </div>

    <div class="mm-content-wide">
      <div class="mm-tabs">
        <div class="mm-tab active" onclick="mmSwitchTab(this,'cuidados-basicos')">Cuidados B&aacute;sicos</div>
        <div class="mm-tab" onclick="mmSwitchTab(this,'rituales-activacion')">Rituales</div>
        <div class="mm-tab" onclick="mmSwitchTab(this,'lo-que-nunca')">Lo Que Nunca</div>
