{% comment %}
  La Guía de los Elfos · Duendes del Uruguay · v1.0
  · 46 páginas · flipbook PageFlip.js
  · Paleta tonal: azul profundo + plata + dorado · linaje vegetal/sabiduría
  · Sub-especies: Elfos del Bosque · de la Luna · del Camino · del Libro
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Great+Vibes&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Saira+Condensed:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  .libro-wrap {
    --indigo-deep: #1a2a4a;
    --indigo-medium: #4a5a7a;
    --indigo-light: #a8b8d4;
    --indigo-pastel: #dde3ee;
    --indigo-blush: #ecf0f6;
    --silver: #b8c4d0;
    --silver-light: #d8e0e8;
    --pearl: #f4ede0;

    --black-deep: #0a0e18;
    --cream: #F2EEE2;
    --cream-light: #F8F4E8;
    --gold: #C9A961;
    --gold-bright: #D8B872;
    --gold-dark: #8b7137;
    --brown-deep: #1a2030;
    --brown-soft: #3e4660;
    --line-gold: rgba(201,169,97,0.28);
    --line-indigo: rgba(74,90,122,0.32);

    --wood-base: #131a2a;
    --wood-mid: #1a2238;
    --wood-light: #232c44;
    --wood-dark: #08101c;
    --font-info: 'Agency FB', 'Saira Condensed', 'Trebuchet MS', sans-serif;

    color: var(--cream); font-family: 'Cormorant Garamond', Georgia, serif;
    min-height: 100vh; padding: 28px 16px 60px; text-align: center;
    background-color: var(--wood-dark);
    background-image:
      radial-gradient(ellipse at 50% 35%, rgba(74,90,122,0.22) 0%, rgba(0,0,0,0.95) 78%),
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='800' height='600' viewBox='0 0 800 600'><defs><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.035' numOctaves='3'/><feColorMatrix values='0 0 0 0 0.10 0 0 0 0 0.12 0 0 0 0 0.20 0 0 0 0.65 0'/></filter></defs><rect width='100%' height='100%' filter='url(%23n)'/></svg>"),
      repeating-linear-gradient(91deg, var(--wood-dark) 0px, var(--wood-base) 2px, var(--wood-mid) 5px, var(--wood-base) 9px, var(--wood-light) 14px, var(--wood-mid) 22px, var(--wood-base) 30px, var(--wood-dark) 40px);
    background-attachment: fixed; position: relative; min-height: 100vh;
  }
  .libro-wrap::before {
    content:''; position: fixed; inset: 0; pointer-events: none; z-index: 0; opacity: 0.10;
    background-image:
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180' viewBox='0 0 180 180'><g fill='none' stroke='%23C9A961' stroke-width='1.4' opacity='0.85'><circle cx='90' cy='90' r='42'/><path d='M90 48 L90 132 M48 90 L132 90' /><circle cx='90' cy='90' r='6' fill='%23C9A961'/></g></svg>"),
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='220' height='220' viewBox='0 0 220 220'><g fill='none' stroke='%23A8B8D4' stroke-width='1.2' opacity='0.7'><path d='M110 25 L110 195 M70 50 L110 25 L150 50 M70 170 L110 195 L150 170'/><circle cx='110' cy='110' r='4' fill='%23A8B8D4'/></g></svg>"),
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160' viewBox='0 0 160 160'><g fill='none' stroke='%23C9A961' stroke-width='1.2' opacity='0.85'><path d='M80 30 Q60 50, 60 80 Q60 110, 80 130 Q100 110, 100 80 Q100 50, 80 30 Z'/><line x1="80" y1="30" x2="80" y2="130"/></g></svg>"),
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200' viewBox='0 0 200 200'><g fill='none' stroke='%234A5A7A' stroke-width='1.2' opacity='0.7'><circle cx='100' cy='100' r='70'/><circle cx='100' cy='100' r='40'/><path d='M30 100 L170 100 M100 30 L100 170'/></g></svg>");
    background-position: 8% 12%, 78% 22%, 18% 72%, 88% 78%;
    background-repeat: no-repeat;
    background-size: 180px, 220px, 160px, 200px;
  }
  .libro-wrap::after {
    content:''; position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background:
      radial-gradient(ellipse at 22% 28%, rgba(168,184,212,0.10), transparent 38%),
      radial-gradient(ellipse at 78% 70%, rgba(184,196,208,0.08), transparent 45%),
      radial-gradient(ellipse at 50% 92%, rgba(201,169,97,0.06), transparent 50%);
  }

  .particula { position: fixed; pointer-events: none; z-index: 0; border-radius: 50%; opacity: 0; }
  .particula.gold { background: radial-gradient(circle, rgba(216,184,114,0.85) 0%, rgba(201,169,97,0) 70%); width: 5px; height: 5px; box-shadow: 0 0 8px rgba(216,184,114,0.6); }
  .particula.silver { background: radial-gradient(circle, rgba(216,224,232,0.75) 0%, rgba(184,196,208,0) 70%); width: 4px; height: 4px; box-shadow: 0 0 10px rgba(216,224,232,0.55); }
  .particula.indigo { background: radial-gradient(circle, rgba(168,184,212,0.7) 0%, rgba(74,90,122,0) 70%); width: 3px; height: 3px; box-shadow: 0 0 8px rgba(168,184,212,0.55); }

  .libro-wrap > * { position: relative; z-index: 1; }
  .libro-wrap * { box-sizing: border-box; }

  .libro-header { max-width: 760px; margin: 0 auto 24px; text-align: center; }
  .libro-header .eyebrow { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.5em; color: var(--gold); text-transform: uppercase; margin-bottom: 12px; text-shadow: 0 2px 8px rgba(0,0,0,0.7); }
  .libro-header h1 { font-family: 'Great Vibes', cursive; font-size: clamp(46px, 6.8vw, 78px); margin: 0 0 8px; line-height: 1; font-weight: 400; color: var(--cream); text-shadow: 0 4px 18px rgba(0,0,0,0.85), 0 0 30px rgba(168,184,212,0.18); }
  .libro-header .sub { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.5em; color: var(--gold-bright); text-transform: uppercase; text-shadow: 0 2px 8px rgba(0,0,0,0.7); }

  .lang-overlay { position: fixed; inset: 0; background: rgba(10,14,24,0.97); z-index: 9999; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(8px); }
  .lang-overlay.hide { display: none; }
  .lang-box { max-width: 480px; text-align: center; padding: 40px 32px; border: 1px solid var(--gold); background: linear-gradient(160deg, #131a2a 0%, #08101c 100%); position: relative; }
  .lang-box::before { content:''; position: absolute; inset: 8px; border: 1px solid rgba(168,184,212,0.32); pointer-events:none; }
  .lang-box .ornament { color: var(--gold); font-family: 'Cinzel', serif; font-size: 14px; letter-spacing: 0.7em; margin-bottom: 18px; }
  .lang-box h2 { font-family: 'Great Vibes', cursive; font-weight: 400; font-size: 56px; color: var(--cream); margin: 0 0 8px; line-height: 1; }
  .lang-box .pretitle { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.4em; color: var(--gold); text-transform: uppercase; margin-bottom: 18px; }
  .lang-box p { font-family: var(--font-info); font-size: 16px; color: rgba(242,238,226,0.85); margin: 14px 0 28px; }
  .lang-buttons { display: flex; gap: 14px; justify-content: center; }
  .lang-buttons button { background: transparent; color: var(--cream); border: 1px solid var(--gold); padding: 14px 32px; font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.4em; text-transform: uppercase; cursor: pointer; transition: all 0.3s; }
  .lang-buttons button:hover { background: var(--gold); color: var(--black-deep); }
  .lang-buttons .recommended { background: var(--gold); color: var(--black-deep); }

  .flipbook-container { display: flex; justify-content: center; align-items: center; margin: 0 auto; max-width: 1120px; min-height: 600px; padding: 16px; }
  #book {
    box-shadow: 0 32px 100px rgba(0,0,0,0.85), 0 0 0 8px rgba(20,28,46,0.7), 0 0 0 9px var(--gold-dark), 0 0 80px rgba(168,184,212,0.10);
    border-radius: 4px;
    touch-action: pan-y;
  }
  .page { background: var(--cream); color: var(--brown-deep); overflow: hidden; }
  .page-inner { padding: 36px 32px 26px; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; position: relative; text-align: center; }
  .page.dark { background: var(--black-deep); color: var(--cream); }
  .page.dark .page-inner::before { content: ''; position: absolute; inset: 14px; border: 1px solid rgba(168,184,212,0.25); pointer-events: none; }
  .page.indigo { background: linear-gradient(160deg, var(--indigo-pastel) 0%, var(--indigo-blush) 70%, var(--cream-light) 100%); color: var(--brown-deep); }
  .page.indigo .page-inner::before { content: ''; position: absolute; inset: 14px; border: 1px solid var(--line-indigo); pointer-events: none; }
  .page.deep-indigo { background: linear-gradient(160deg, #131a2a 0%, #060a14 100%); color: var(--cream); }
  .page.deep-indigo .page-inner::before { content: ''; position: absolute; inset: 14px; border: 1px solid rgba(168,184,212,0.32); pointer-events: none; }

  .page .eyebrow { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; letter-spacing: 0.5em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 14px; text-align: center; width: 100%; }
  .page.dark .eyebrow, .page.deep-indigo .eyebrow { color: var(--gold); }
  .page.indigo .eyebrow { color: var(--indigo-deep); letter-spacing: 0.5em; }
  .page h2 { font-family: 'Great Vibes', cursive; font-size: 48px; margin: 0 auto 14px; line-height: 1; font-weight: 400; color: var(--brown-deep); text-align: center; width: 100%; }
  .page.dark h2, .page.deep-indigo h2 { color: var(--cream); }
  .page.indigo h2 { color: var(--indigo-deep); }
  .page h3 { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10.5px; letter-spacing: 0.3em; color: var(--gold-dark); text-transform: uppercase; margin: 12px 0 8px; text-align: center; width: 100%; }

  .page p { font-family: var(--font-info); font-weight: 400; font-size: 14px; line-height: 1.55; margin: 0 auto 10px; color: var(--brown-deep); text-align: center; max-width: 380px; letter-spacing: 0.01em; }
  .page.dark p, .page.deep-indigo p { color: var(--cream); }
  .page p.lead { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; color: var(--brown-soft); font-size: 14.5px; }
  .page.dark p.lead, .page.deep-indigo p.lead { color: rgba(242,238,226,0.85); }
  .page.indigo p.lead { color: var(--indigo-deep); }
  .page strong { color: var(--brown-deep); font-weight: 600; }
  .page.dark strong, .page.deep-indigo strong { color: var(--cream); }
  .page em { font-style: italic; }

  .page .center-content { flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; width: 100%; text-align: center; }
  .page .page-number { position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%); font-family: 'Cinzel', serif; font-weight: 400; font-size: 9px; letter-spacing: 0.35em; color: var(--gold-dark); }
  .page.dark .page-number, .page.deep-indigo .page-number { color: var(--gold); opacity: 0.6; }

  .page.cover {
    background:
      radial-gradient(ellipse at 30% 30%, rgba(40,55,90,0.45), transparent 60%),
      radial-gradient(ellipse at 70% 70%, rgba(20,28,50,0.5), transparent 60%),
      linear-gradient(135deg, #131a2a 0%, #06090f 50%, #161e36 100%);
    color: var(--cream); position: relative; box-shadow: inset 0 0 70px rgba(0,0,0,0.85);
  }
  .page.cover::before { content:''; position: absolute; inset: 22px; border: 1px solid rgba(201,169,97,0.45); }
  .page.cover::after { content:''; position: absolute; inset: 32px; border: 1px solid rgba(168,184,212,0.22); }
  .page.cover .page-inner { z-index: 2; align-items: center; justify-content: space-between; padding: 60px 30px; gap: 12px; text-align: center; }
  .page.cover .ornament-celtic-top { width: 80px; height: 80px; flex-shrink: 0; color: var(--gold); opacity: 0.95; filter: drop-shadow(0 0 12px rgba(168,184,212,0.25)); }
  .page.cover .titulo-grande { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.5em; color: var(--gold); text-transform: uppercase; line-height: 1.4; text-align: center; }
  .page.cover h1 { font-family: 'Great Vibes', cursive; font-weight: 400; font-size: 60px; margin: 6px 0 8px; line-height: 1; color: var(--cream); text-shadow: 0 0 30px rgba(168,184,212,0.40); text-align: center; }
  .page.cover .marca-fina { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.6em; color: var(--gold-bright); text-transform: uppercase; text-align: center; }
  .page.cover .pie { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; font-size: 11px; color: rgba(242,238,226,0.6); margin: 0; text-align: center; }

  svg.ornament { display: block; margin: 14px auto; color: var(--gold-dark); }
  svg.ornament.dark { color: var(--gold); }
  svg.ornament.indigo-acc { color: var(--indigo-deep); }
  svg.ornament.tiny { width: 32px; height: 32px; }
  svg.ornament.small { width: 60px; height: 60px; }
  svg.ornament.med { width: 90px; height: 90px; }

  .indice { font-family: var(--font-info); font-size: 12px; letter-spacing: 0.05em; color: var(--brown-deep); text-align: left; max-width: 380px; margin: 0 auto; }
  .indice-item { display: flex; justify-content: space-between; align-items: baseline; margin: 6px 0; }
  .indice-item .num { color: var(--gold-dark); margin-right: 8px; font-size: 11px; font-family: 'Cinzel', serif; letter-spacing: 0.15em; }
  .indice-item .name { flex: 1; }
  .indice-item .dots { flex: 1; border-bottom: 1px dotted var(--gold-dark); margin: 0 8px; align-self: end; height: 1px; }
  .indice-item .pg { color: var(--gold-dark); font-family: 'Cinzel', serif; }
  .indice-section { font-family: 'Cinzel', serif; font-weight: 500; font-size: 10px; letter-spacing: 0.35em; color: var(--indigo-deep); text-transform: uppercase; margin: 12px 0 4px; padding-bottom: 4px; border-bottom: 1px solid var(--gold-dark); text-align: center; }

  .page .cita { font-family: 'Great Vibes', cursive; font-size: 40px; line-height: 1.2; color: var(--indigo-deep); text-align: center; padding: 16px 14px; font-weight: 400; }
  .page.dark .cita, .page.deep-indigo .cita { color: var(--cream); font-size: 48px; text-shadow: 0 0 28px rgba(168,184,212,0.20); }

  .foto-circle { width: 140px; height: 140px; border-radius: 50%; margin: 14px auto; overflow: hidden; border: 2px solid var(--gold); box-shadow: 0 8px 26px rgba(0,0,0,0.4), 0 0 22px rgba(168,184,212,0.18); display: block; }
  .foto-circle img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .foto-rounded { width: 220px; height: 140px; border-radius: 16px; margin: 14px auto; overflow: hidden; border: 1px solid var(--gold); box-shadow: 0 6px 22px rgba(0,0,0,0.32); display: block; }
  .foto-rounded img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .foto-arch { width: 140px; height: 180px; border-radius: 70px 70px 6px 6px; margin: 14px auto; overflow: hidden; border: 1px solid var(--gold); box-shadow: 0 8px 26px rgba(0,0,0,0.4), 0 0 24px rgba(168,184,212,0.18); display: block; }
  .foto-arch img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .foto-caption { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9px; letter-spacing: 0.35em; color: var(--gold-dark); text-transform: uppercase; margin-top: 8px; text-align: center; }

  .consejo-card { background: var(--cream-light); border: 1px solid var(--gold); border-radius: 6px; padding: 12px 14px; margin: 8px auto; text-align: center; max-width: 360px; }
  .consejo-card .titulo { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.3em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 5px; text-align: center; }
  .consejo-card p { font-family: var(--font-info); font-size: 13.5px; margin: 0 auto; line-height: 1.5; max-width: none; text-align: center; }
  .consejo-card.warning { border-color: #c47844; background: #fef0e0; }
  .consejo-card.warning .titulo { color: #a85e2c; }
  .consejo-card.indigo { border-color: var(--indigo-medium); background: linear-gradient(180deg, var(--indigo-blush) 0%, var(--cream-light) 100%); }
  .consejo-card.indigo .titulo { color: var(--indigo-deep); }
  .consejo-card.silver { border-color: var(--silver); background: linear-gradient(180deg, #eef2f5 0%, var(--cream-light) 100%); }
  .consejo-card.silver .titulo { color: #5a6878; }

  .elementos-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid var(--gold-dark); margin: 10px auto; max-width: 380px; background: var(--cream-light); }
  .elemento-cell { padding: 12px 10px; border-right: 1px solid var(--gold-dark); border-bottom: 1px solid var(--gold-dark); text-align: center; }
  .elemento-cell:nth-child(2n) { border-right: none; }
  .elemento-cell:nth-last-child(-n+2) { border-bottom: none; }
  .elemento-cell .titulo { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.3em; color: var(--indigo-deep); margin-bottom: 5px; text-align: center; }
  .elemento-cell .quien { font-family: var(--font-info); font-size: 12px; color: var(--brown-deep); margin-bottom: 4px; font-weight: 500; text-align: center; }
  .elemento-cell .funcion { font-family: var(--font-info); font-size: 11.5px; color: var(--brown-soft); line-height: 1.45; text-align: center; }

  .dia-item { padding: 6px 8px; border-bottom: 1px solid var(--line-gold); text-align: center; max-width: 360px; margin: 0 auto; }
  .dia-item:last-child { border-bottom: none; }
  .dia-item .num { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; letter-spacing: 0.3em; color: var(--gold-dark); }
  .dia-item .titulo { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; letter-spacing: 0.2em; color: var(--brown-deep); }
  .dia-item .desc { font-family: var(--font-info); font-size: 12.5px; color: var(--brown-soft); line-height: 1.5; margin-top: 2px; text-align: center; }

  .compendio-tabla { font-size: 11px; max-width: 380px; margin: 0 auto; }
  .compendio-row { display: flex; padding: 7px 0; border-bottom: 1px solid var(--line-gold); align-items: baseline; text-align: left; }
  .compendio-row:last-child { border-bottom: none; }
  .compendio-row .nombre { flex: 0 0 110px; color: var(--indigo-deep); letter-spacing: 0.18em; text-transform: uppercase; font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; }
  .compendio-row .uso { flex: 1; color: var(--brown-soft); font-family: var(--font-info); font-size: 12.5px; }

  .faq { margin: 8px auto; padding-bottom: 8px; border-bottom: 1px dotted var(--line-indigo); text-align: center; max-width: 380px; }
  .faq:last-child { border-bottom: none; }
  .faq .pregunta { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.2em; color: var(--indigo-deep); text-transform: uppercase; margin-bottom: 5px; text-align: center; }
  .faq .respuesta { font-family: var(--font-info); font-size: 12.5px; color: var(--brown-soft); line-height: 1.55; margin: 0 auto; text-align: center; }

  .ser-card { background: linear-gradient(160deg, var(--indigo-blush) 0%, var(--indigo-pastel) 100%); border: 1.5px solid var(--gold); border-radius: 10px; padding: 16px 18px; margin: 10px auto; max-width: 380px; box-shadow: 0 4px 14px rgba(26,42,74,0.15), 0 0 22px rgba(168,184,212,0.15); }
  .ser-card .ser-nombre { font-family: 'Great Vibes', cursive; font-size: 36px; color: var(--indigo-deep); margin: 0 0 4px; line-height: 1; }
  .ser-card .ser-energia { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.4em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 8px; }
  .ser-card .ser-detalle { font-family: var(--font-info); font-size: 12.5px; color: var(--brown-soft); line-height: 1.5; margin: 0 auto 8px; text-align: center; }
  .ser-card .ser-meta { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; margin-top: 8px; }
  .ser-card .ser-meta span { font-family: 'Cinzel', serif; font-size: 8.5px; letter-spacing: 0.2em; color: var(--gold-dark); text-transform: uppercase; padding: 3px 8px; border: 1px solid var(--gold-dark); border-radius: 100px; background: rgba(255,255,255,0.4); }

  .neuro-tag { display: inline-block; margin-top: 6px; padding: 4px 10px; background: var(--indigo-deep); color: var(--cream); font-family: 'Cinzel', serif; font-size: 8.5px; letter-spacing: 0.3em; text-transform: uppercase; border-radius: 4px; }
  .page.dark .neuro-tag, .page.deep-indigo .neuro-tag { background: var(--gold); color: var(--black-deep); }

