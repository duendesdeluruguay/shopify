{% comment %}
  La Guía de las Pixies · Duendes del Uruguay · v2.0 ESPEJO BIBLIA
  · Tipografía: Cinzel (títulos) + Great Vibes (display) + Cormorant Garamond (body)
  · Linaje vegetal/floral · Pixies del Bosque · del Jardín · de las Hierbas
  · 46 páginas · flipbook PageFlip v2.0.7 · buscador integrado · auroras pixies
  · Paleta menta/verde aire — NO usar paleta dorada de duendes
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Great+Vibes&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Saira+Condensed:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  .libro-wrap {
    --mint-deep: #2d5a3d;
    --mint-medium: #6b9b7c;
    --mint-light: #b6d4bf;
    --mint-pastel: #dcebd9;
    --mint-blush: #ecf3e7;
    --air-blue: #cfe1d7;
    --pearl: #f4ede0;
    --rose-pixie: #d99fb5;
    --jasmin: #f4ecd6;

    --black-deep: #0e160f;
    --cream: #F8F4E4;
    --cream-light: #FCF9EE;
    --gold: #C9A961;
    --gold-bright: #D8B872;
    --gold-dark: #8b7137;
    --brown-deep: #1c2c20;
    --brown-soft: #3e5246;
    --line-gold: rgba(201,169,97,0.28);
    --line-mint: rgba(107,155,124,0.32);

    --wood-base: #142519;
    --wood-mid: #1c2f24;
    --wood-light: #25402f;
    --wood-dark: #0a140d;
    --font-info: 'Cormorant Garamond', Georgia, serif;

    color: var(--cream); font-family: 'Cormorant Garamond', Georgia, serif;
    min-height: 100vh; padding: 28px 16px 60px; text-align: center;
    background-color: var(--wood-dark);
    background-image:
      radial-gradient(ellipse at 50% 35%, rgba(107,155,124,0.22) 0%, rgba(0,0,0,0.95) 78%),
      radial-gradient(circle at 12% 84%, rgba(182,212,191,0.10) 0%, transparent 42%),
      radial-gradient(circle at 86% 18%, rgba(201,169,97,0.10) 0%, transparent 42%),
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='600' height='600' viewBox='0 0 600 600'><g fill='none' stroke='%23B6D4BF' stroke-width='1.4' opacity='0.07'><text x='300' y='180' text-anchor='middle' font-family='serif' font-style='italic' font-size='42' fill='%23B6D4BF' opacity='0.9'>Pixies del Aire</text><text x='300' y='460' text-anchor='middle' font-family='serif' font-style='italic' font-size='42' fill='%23B6D4BF' opacity='0.9'>Pixies del Aire</text></g></svg>"),
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='400' height='400' viewBox='0 0 400 400'><defs><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3'/><feColorMatrix values='0 0 0 0 0.42 0 0 0 0 0.61 0 0 0 0 0.49 0 0 0 0.05 0'/></filter></defs><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
    background-size: cover, cover, cover, 600px 600px, 400px 400px;
    background-repeat: no-repeat, no-repeat, no-repeat, repeat, repeat;
    background-attachment: fixed; position: relative; min-height: 100vh; overflow-x: hidden;
  }

  /* GLOW menta sutil en esquinas */
  .libro-wrap::before {
    content:''; position: fixed; top: -100px; right: -100px; width: 500px; height: 500px; pointer-events: none; z-index: 0;
    background: radial-gradient(circle at center, rgba(182,212,191,0.20) 0%, rgba(182,212,191,0.06) 40%, transparent 70%);
    animation: glowPulse 9s ease-in-out infinite;
  }
  @keyframes glowPulse {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 1; }
  }
  .libro-wrap::after {
    content:''; position: fixed; bottom: -80px; left: -80px; width: 400px; height: 400px; pointer-events: none; z-index: 0;
    background: radial-gradient(circle at center, rgba(201,169,97,0.12) 0%, rgba(201,169,97,0.04) 50%, transparent 75%);
    animation: glowPulse 11s ease-in-out infinite reverse;
  }

  .libro-wrap > * { position: relative; z-index: 1; }
  .libro-wrap * { box-sizing: border-box; }

  .libro-header { max-width: 760px; margin: 0 auto 24px; text-align: center; }
  .libro-header .eyebrow { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.5em; color: var(--gold); text-transform: uppercase; margin-bottom: 12px; text-shadow: 0 2px 8px rgba(0,0,0,0.7); }
  .libro-header h1 { font-family: 'Great Vibes', cursive; font-size: clamp(46px, 6.8vw, 78px); margin: 0 0 8px; line-height: 1; font-weight: 400; color: var(--cream); text-shadow: 0 4px 18px rgba(0,0,0,0.85), 0 0 30px rgba(182,212,191,0.18); }
  .libro-header .sub { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.5em; color: var(--gold-bright); text-transform: uppercase; text-shadow: 0 2px 8px rgba(0,0,0,0.7); }

  .lang-overlay { position: fixed; inset: 0; background: rgba(14,22,15,0.97); z-index: 9999; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(8px); }
  .lang-overlay.hide { display: none; }
  .lang-box { max-width: 480px; text-align: center; padding: 40px 32px; border: 1px solid var(--gold); background: linear-gradient(160deg, #15211a 0%, #08110b 100%); position: relative; }
  .lang-box::before { content:''; position: absolute; inset: 8px; border: 1px solid rgba(182,212,191,0.32); pointer-events:none; }
  .lang-box .ornament { color: var(--gold); font-family: 'Cinzel', serif; font-size: 14px; letter-spacing: 0.7em; margin-bottom: 18px; }
  .lang-box h2 { font-family: 'Great Vibes', cursive; font-weight: 400; font-size: 56px; color: var(--cream); margin: 0 0 8px; line-height: 1; }
  .lang-box .pretitle { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.4em; color: var(--gold); text-transform: uppercase; margin-bottom: 18px; }
  .lang-box p { font-family: var(--font-info); font-size: 16px; color: rgba(248,244,228,0.85); margin: 14px 0 28px; }
  .lang-buttons { display: flex; gap: 14px; justify-content: center; }
  .lang-buttons button { background: transparent; color: var(--cream); border: 1px solid var(--gold); padding: 14px 32px; font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.4em; text-transform: uppercase; cursor: pointer; transition: all 0.3s; }
  .lang-buttons button:hover { background: var(--gold); color: var(--black-deep); }
  .lang-buttons .recommended { background: var(--gold); color: var(--black-deep); }

  .flipbook-container { display: flex; justify-content: center; align-items: center; margin: 0 auto; max-width: 1120px; min-height: 600px; padding: 16px; }
  #book {
    box-shadow: 0 32px 100px rgba(0,0,0,0.85), 0 0 0 8px rgba(20,32,22,0.7), 0 0 0 9px var(--gold-dark), 0 0 80px rgba(182,212,191,0.10);
    border-radius: 4px;
    touch-action: pan-y;
  }
  .page { background: var(--cream); color: var(--brown-deep); overflow: hidden; }
  .page-inner { padding: 32px 30px 28px; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; text-align: center; gap: 6px; }
  .page.dark { background: var(--black-deep); color: var(--cream); }
  .page.dark .page-inner::before { content: ''; position: absolute; inset: 14px; border: 1px solid rgba(182,212,191,0.25); pointer-events: none; }
  .page.mint { background: linear-gradient(160deg, var(--mint-pastel) 0%, var(--mint-blush) 70%, var(--cream-light) 100%); color: var(--brown-deep); }
  .page.mint .page-inner::before { content: ''; position: absolute; inset: 14px; border: 1px solid var(--line-mint); pointer-events: none; }
  .page.green-soft { background: linear-gradient(160deg, var(--mint-blush) 0%, #f3f7ee 100%); color: var(--brown-deep); }
  .page.green-soft .page-inner::before { content: ''; position: absolute; inset: 14px; border: 1px solid rgba(107,155,124,0.20); pointer-events: none; }
  .page.deep-mint { background: linear-gradient(160deg, #18301e 0%, #0c180f 100%); color: var(--cream); }
  .page.deep-mint .page-inner::before { content: ''; position: absolute; inset: 14px; border: 1px solid rgba(182,212,191,0.32); pointer-events: none; }

  .page .eyebrow { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; letter-spacing: 0.5em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 14px; text-align: center; width: 100%; }
  .page.dark .eyebrow, .page.deep-mint .eyebrow { color: var(--gold); }
  .page.mint .eyebrow, .page.green-soft .eyebrow { color: var(--mint-deep); letter-spacing: 0.5em; }
  .page h2 { font-family: 'Great Vibes', cursive; font-size: 48px; margin: 0 auto 14px; line-height: 1; font-weight: 400; color: var(--brown-deep); text-align: center; width: 100%; }
  .page.dark h2, .page.deep-mint h2 { color: var(--cream); }
  .page.mint h2, .page.green-soft h2 { color: var(--mint-deep); }
  .page h3 { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10.5px; letter-spacing: 0.3em; color: var(--gold-dark); text-transform: uppercase; margin: 12px 0 8px; text-align: center; width: 100%; }
  .page.dark h3, .page.deep-mint h3 { color: var(--gold); }
  .page.mint h3, .page.green-soft h3 { color: var(--mint-deep); }

  .page p { font-family: var(--font-info); font-weight: 400; font-size: 14px; line-height: 1.55; margin: 0 auto 10px; color: var(--brown-deep); text-align: center; max-width: 380px; letter-spacing: 0.01em; }
  .page.dark p, .page.deep-mint p { color: var(--cream); }
  .page p.lead { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; color: var(--brown-soft); font-size: 14.5px; }
  .page.dark p.lead, .page.deep-mint p.lead { color: rgba(248,244,228,0.85); }
  .page.mint p.lead, .page.green-soft p.lead { color: var(--mint-deep); }
  .page strong { color: var(--brown-deep); font-weight: 600; }
  .page.dark strong, .page.deep-mint strong { color: var(--cream); }
  .page em { font-style: italic; }

  .page .center-content { flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; width: 100%; text-align: center; }
  .page .symbol-row { color: var(--gold); letter-spacing: 0.7em; font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; text-align: center; }

  .page .page-number { position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%); font-family: 'Cinzel', serif; font-weight: 400; font-size: 9px; letter-spacing: 0.35em; color: var(--gold-dark); }
  .page.dark .page-number, .page.deep-mint .page-number { color: var(--gold); opacity: 0.6; }

  /* TAPA */
  .page.cover {
    background:
      radial-gradient(ellipse at 30% 30%, rgba(40,80,55,0.45), transparent 60%),
      radial-gradient(ellipse at 70% 70%, rgba(20,40,28,0.5), transparent 60%),
      linear-gradient(135deg, #14211a 0%, #08110b 50%, #16241c 100%);
    color: var(--cream); position: relative; box-shadow: inset 0 0 70px rgba(0,0,0,0.85);
  }
  .page.cover::before { content:''; position: absolute; inset: 22px; border: 1px solid rgba(201,169,97,0.45); }
  .page.cover::after { content:''; position: absolute; inset: 32px; border: 1px solid rgba(182,212,191,0.22); }
  .page.cover .page-inner { z-index: 2; align-items: center; justify-content: space-between; padding: 60px 30px; gap: 12px; text-align: center; }
  .page.cover .ornament-celtic-top { width: 80px; height: 80px; flex-shrink: 0; color: var(--gold); opacity: 0.95; filter: drop-shadow(0 0 12px rgba(182,212,191,0.25)); }
  .page.cover .titulo-grande { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.5em; color: var(--gold); text-transform: uppercase; line-height: 1.4; text-align: center; }
  .page.cover h1 { font-family: 'Great Vibes', cursive; font-weight: 400; font-size: 60px; margin: 6px 0 8px; line-height: 1; color: var(--cream); text-shadow: 0 0 30px rgba(182,212,191,0.40); text-align: center; }
  .page.cover .marca-fina { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.6em; color: var(--gold-bright); text-transform: uppercase; text-align: center; }
  .page.cover .pie { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; font-size: 11px; color: rgba(248,244,228,0.6); margin: 0; text-align: center; }

  svg.ornament { display: block; margin: 14px auto; color: var(--gold-dark); }
  svg.ornament.dark { color: var(--gold); }
  svg.ornament.mint-acc { color: var(--mint-deep); }
  svg.ornament.tiny { width: 32px; height: 32px; }
  svg.ornament.small { width: 60px; height: 60px; }
  svg.ornament.med { width: 90px; height: 90px; }
  svg.ornament.large { width: 130px; height: 130px; }

  .indice { font-family: var(--font-info); font-size: 12px; letter-spacing: 0.05em; color: var(--brown-deep); text-align: left; max-width: 380px; margin: 0 auto; }
  .indice-item { display: flex; justify-content: space-between; align-items: baseline; margin: 6px 0; }
  .indice-item .num { color: var(--gold-dark); margin-right: 8px; font-size: 11px; font-family: 'Cinzel', serif; letter-spacing: 0.15em; }
  .indice-item .name { flex: 1; }
  .indice-item .dots { flex: 1; border-bottom: 1px dotted var(--gold-dark); margin: 0 8px; align-self: end; height: 1px; }
  .indice-item .pg { color: var(--gold-dark); font-family: 'Cinzel', serif; }
  .indice-section { font-family: 'Cinzel', serif; font-weight: 500; font-size: 10px; letter-spacing: 0.35em; color: var(--mint-deep); text-transform: uppercase; margin: 12px 0 4px; padding-bottom: 4px; border-bottom: 1px solid var(--gold-dark); text-align: center; }

  .page .cita { font-family: 'Great Vibes', cursive; font-size: 40px; line-height: 1.2; color: var(--mint-deep); text-align: center; padding: 16px 14px; font-weight: 400; }
  .page.dark .cita, .page.deep-mint .cita { color: var(--cream); font-size: 48px; text-shadow: 0 0 28px rgba(182,212,191,0.20); }

  .foto-circle { width: 140px; height: 140px; border-radius: 50%; margin: 14px auto; overflow: hidden; border: 2px solid var(--gold); box-shadow: 0 8px 26px rgba(0,0,0,0.4), 0 0 22px rgba(182,212,191,0.18); display: block; }
  .foto-circle img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .foto-rounded { width: 220px; height: 140px; border-radius: 16px; margin: 14px auto; overflow: hidden; border: 1px solid var(--gold); box-shadow: 0 6px 22px rgba(0,0,0,0.32); display: block; }
  .foto-rounded img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .foto-arch { width: 140px; height: 180px; border-radius: 70px 70px 6px 6px; margin: 14px auto; overflow: hidden; border: 1px solid var(--gold); box-shadow: 0 8px 26px rgba(0,0,0,0.4), 0 0 24px rgba(182,212,191,0.18); display: block; }
  .foto-arch img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .foto-caption { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9px; letter-spacing: 0.35em; color: var(--gold-dark); text-transform: uppercase; margin-top: 8px; text-align: center; }

  .consejo-card { background: var(--cream-light); border: 1px solid var(--gold); border-radius: 6px; padding: 12px 14px; margin: 8px auto; text-align: center; max-width: 360px; }
  .consejo-card .titulo { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.3em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 5px; text-align: center; }
  .consejo-card p { font-family: var(--font-info); font-size: 13.5px; margin: 0 auto; line-height: 1.5; max-width: none; text-align: center; }
  .consejo-card.warning { border-color: #c47844; background: #fef0e0; }
  .consejo-card.warning .titulo { color: #a85e2c; }
  .consejo-card.mint { border-color: var(--mint-medium); background: linear-gradient(180deg, var(--mint-blush) 0%, var(--cream-light) 100%); }
  .consejo-card.mint .titulo { color: var(--mint-deep); }
  .consejo-card.air { border-color: #8aa9a0; background: linear-gradient(180deg, #eaf3ee 0%, var(--cream-light) 100%); }
  .consejo-card.air .titulo { color: #426055; }

  .elementos-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid var(--gold-dark); margin: 10px auto; max-width: 380px; background: var(--cream-light); }
  .elemento-cell { padding: 12px 10px; border-right: 1px solid var(--gold-dark); border-bottom: 1px solid var(--gold-dark); text-align: center; }
  .elemento-cell:nth-child(2n) { border-right: none; }
  .elemento-cell:nth-last-child(-n+2) { border-bottom: none; }
  .elemento-cell .titulo { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.3em; color: var(--mint-deep); margin-bottom: 5px; text-align: center; }
  .elemento-cell .quien { font-family: var(--font-info); font-size: 12px; color: var(--brown-deep); margin-bottom: 4px; font-weight: 500; text-align: center; }
  .elemento-cell .funcion { font-family: var(--font-info); font-size: 11.5px; color: var(--brown-soft); line-height: 1.45; text-align: center; }

  .dia-item { padding: 6px 8px; border-bottom: 1px solid var(--line-mint); text-align: center; max-width: 360px; margin: 0 auto; }
  .dia-item:last-child { border-bottom: none; }
  .dia-item .num { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; letter-spacing: 0.3em; color: var(--gold-dark); }
  .dia-item .titulo { font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; letter-spacing: 0.2em; color: var(--brown-deep); }
  .dia-item .desc { font-family: var(--font-info); font-size: 12.5px; color: var(--brown-soft); line-height: 1.5; margin-top: 2px; text-align: center; }

  .compendio-tabla { font-size: 11px; max-width: 380px; margin: 0 auto; }
  .compendio-row { display: flex; padding: 7px 0; border-bottom: 1px solid var(--line-mint); align-items: baseline; text-align: left; }
  .compendio-row:last-child { border-bottom: none; }
  .compendio-row .nombre { flex: 0 0 110px; color: var(--mint-deep); letter-spacing: 0.18em; text-transform: uppercase; font-family: 'Cinzel', serif; font-weight: 400; font-size: 9.5px; }
  .compendio-row .uso { flex: 1; color: var(--brown-soft); font-family: var(--font-info); font-size: 12.5px; }

  .faq { margin: 8px auto; padding-bottom: 8px; border-bottom: 1px dotted var(--line-mint); text-align: center; max-width: 380px; }
  .faq:last-child { border-bottom: none; }
  .faq .pregunta { font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.2em; color: var(--mint-deep); text-transform: uppercase; margin-bottom: 5px; text-align: center; }
  .faq .respuesta { font-family: var(--font-info); font-size: 12.5px; color: var(--brown-soft); line-height: 1.55; margin: 0 auto; text-align: center; }

  .ser-card { background: linear-gradient(160deg, var(--mint-blush) 0%, var(--mint-pastel) 100%); border: 1.5px solid var(--gold); border-radius: 10px; padding: 16px 18px; margin: 10px auto; max-width: 380px; box-shadow: 0 4px 14px rgba(45,90,61,0.15), 0 0 22px rgba(182,212,191,0.15); }
  .ser-card .ser-nombre { font-family: 'Great Vibes', cursive; font-size: 36px; color: var(--mint-deep); margin: 0 0 4px; line-height: 1; }
  .ser-card .ser-energia { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.4em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 8px; }
  .ser-card .ser-detalle { font-family: var(--font-info); font-size: 12.5px; color: var(--brown-soft); line-height: 1.5; margin: 0 auto 8px; text-align: center; }
  .ser-card .ser-meta { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; margin-top: 8px; }
  .ser-card .ser-meta span { font-family: 'Cinzel', serif; font-size: 8.5px; letter-spacing: 0.2em; color: var(--gold-dark); text-transform: uppercase; padding: 3px 8px; border: 1px solid var(--gold-dark); border-radius: 100px; background: rgba(255,255,255,0.4); }

  .neuro-tag { display: inline-block; margin-top: 6px; padding: 4px 10px; background: var(--mint-deep); color: var(--cream); font-family: 'Cinzel', serif; font-size: 8.5px; letter-spacing: 0.3em; text-transform: uppercase; border-radius: 4px; }
  .page.dark .neuro-tag, .page.deep-mint .neuro-tag { background: var(--gold); color: var(--black-deep); }

  .otra-especie-card {
    display: flex; flex-direction: column; align-items: center;
    background: linear-gradient(160deg, var(--cream-light) 0%, var(--mint-blush) 100%);
    border: 1px solid var(--gold);
    border-radius: 10px;
    padding: 14px 16px;
    max-width: 380px;
    margin: 0 auto;
    box-shadow: 0 4px 16px rgba(45,90,61,0.12);
  }
  .otra-especie-card .otra-foto {
    width: 120px; height: 120px; border-radius: 50%;
    overflow: hidden; border: 2px solid var(--gold);
    margin-bottom: 8px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.18);
  }
  .otra-especie-card .otra-foto img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .otra-especie-card .otra-foto.placeholder { background: linear-gradient(135deg, #18301e, #0c180f); display: flex; align-items: center; justify-content: center; color: var(--gold); }
  .otra-especie-card .otra-nombre { font-family: 'Great Vibes', cursive; font-size: 32px; color: var(--mint-deep); line-height: 1; margin: 4px 0 2px; }
  .otra-especie-card .otra-eyebrow { font-family: 'Cinzel', serif; font-size: 8.5px; letter-spacing: 0.4em; color: var(--gold-dark); text-transform: uppercase; margin-bottom: 6px; }
  .otra-especie-card .otra-deseo { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; font-size: 13px; color: var(--brown-deep); line-height: 1.5; margin: 4px auto 8px; max-width: 320px; }
  .otra-especie-card .otra-cta { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.35em; color: var(--mint-deep); text-transform: uppercase; padding: 7px 14px; border: 1px solid var(--mint-deep); border-radius: 100px; text-decoration: none; transition: all 0.3s; background: rgba(255,255,255,0.5); }
  .otra-especie-card .otra-cta:hover { background: var(--mint-deep); color: var(--cream); }

  .cta-final { display: flex; flex-direction: column; gap: 10px; margin: 12px auto; max-width: 380px; }
  .cta-final-btn { display: block; padding: 14px 16px; background: var(--cream-light); border: 1px solid var(--gold); border-radius: 4px; text-decoration: none; color: var(--brown-deep); transition: all 0.3s; text-align: center; }
  .cta-final-btn:hover { background: var(--gold); color: var(--black-deep); }
  .cta-final-btn .cta-titulo { font-family: 'Cinzel', serif; font-weight: 500; font-size: 10px; letter-spacing: 0.3em; color: var(--mint-deep); text-transform: uppercase; margin-bottom: 4px; text-align: center; }
  .cta-final-btn:hover .cta-titulo { color: var(--black-deep); }
  .cta-final-btn .cta-text { font-family: var(--font-info); font-size: 13px; text-align: center; }

  .libro-controls { margin: 28px auto 0; display: flex; justify-content: center; align-items: center; gap: 18px; flex-wrap: wrap; }
  .libro-controls button { background: rgba(0,0,0,0.6); color: var(--gold); border: 1px solid var(--gold); padding: 12px 26px; font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.35em; text-transform: uppercase; cursor: pointer; transition: all 0.3s; backdrop-filter: blur(4px); }
  .libro-controls button:hover { background: var(--gold); color: var(--black-deep); }
  .libro-controls button:disabled { opacity: 0.4; cursor: not-allowed; }
  .libro-controls .page-indicator { font-family: 'Cinzel', serif; font-weight: 400; font-size: 11px; letter-spacing: 0.35em; color: var(--gold); text-shadow: 0 2px 8px rgba(0,0,0,0.7); }
  .sound-toggle { background: rgba(0,0,0,0.6); color: var(--gold); border: 1px solid var(--gold); padding: 8px 14px; font-family: 'Cinzel', serif; font-weight: 400; font-size: 9px; letter-spacing: 0.3em; cursor: pointer; border-radius: 100px; }
  .sound-toggle.muted { opacity: 0.4; }

  .libro-footer { margin-top: 36px; text-align: center; font-family: 'Cinzel', serif; font-weight: 400; font-size: 10px; letter-spacing: 0.4em; color: rgba(201,169,97,0.7); text-transform: uppercase; text-shadow: 0 2px 8px rgba(0,0,0,0.7); }
  .libro-footer a { color: var(--gold); text-decoration: none; margin: 0 12px; }

  /* AURORAS PIXIE · luces florales / verde-rosa */
  .auroras {
    position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden;
    mix-blend-mode: screen;
  }
  .auroras .luz {
    position: absolute; width: 720px; height: 720px; border-radius: 50%;
    filter: blur(140px); opacity: 0; will-change: opacity, transform;
    animation: auroraRespirar 22s ease-in-out infinite;
  }
  .luz-menta {
    background: radial-gradient(circle at 50% 50%, rgba(150,210,170,0.70) 0%, rgba(110,180,140,0.30) 35%, transparent 70%);
    top: -160px; left: -120px; animation-delay: 0s;
  }
  .luz-rosa-pixie {
    background: radial-gradient(circle at 50% 50%, rgba(230,170,200,0.55) 0%, rgba(220,140,180,0.22) 35%, transparent 70%);
    top: 8%; right: -180px; animation-delay: 5s; width: 680px; height: 680px;
  }
  .luz-dorada {
    background: radial-gradient(circle at 50% 50%, rgba(255,210,130,0.55) 0%, rgba(255,200,110,0.22) 35%, transparent 70%);
    bottom: -180px; right: 18%; animation-delay: 9s;
  }
  .luz-lila {
    background: radial-gradient(circle at 50% 50%, rgba(190,160,220,0.55) 0%, rgba(160,130,210,0.22) 35%, transparent 70%);
    bottom: 5%; left: -160px; animation-delay: 13s; width: 760px; height: 760px;
  }
  .luz-jazmin {
    background: radial-gradient(circle at 50% 50%, rgba(250,240,210,0.55) 0%, rgba(230,210,160,0.22) 35%, transparent 70%);
    top: 45%; left: 30%; animation-delay: 7s; width: 600px; height: 600px;
  }
  .luz-aqua {
    background: radial-gradient(circle at 50% 50%, rgba(140,220,200,0.55) 0%, rgba(120,200,190,0.22) 35%, transparent 70%);
    top: 60%; right: 8%; animation-delay: 16s; width: 640px; height: 640px;
  }
  @keyframes auroraRespirar {
    0%   { opacity: 0;    transform: scale(0.85) translate(0, 0); }
    18%  { opacity: 0.55; transform: scale(1)    translate(40px, -30px); }
    50%  { opacity: 0.7;  transform: scale(1.12) translate(-50px, 60px); }
    82%  { opacity: 0.4;  transform: scale(1.18) translate(30px, -20px); }
    100% { opacity: 0;    transform: scale(1.25) translate(0, 0); }
  }

  /* Partículas (polen pixie) */
  .particulas { position: fixed; inset: 0; pointer-events: none; z-index: 0; }
  .particulas span {
    position: absolute; width: 5px; height: 5px; border-radius: 50%;
    background: radial-gradient(circle, rgba(220,235,210,0.9), rgba(182,212,191,0.3) 60%, transparent 100%);
    box-shadow: 0 0 8px rgba(220,235,210,0.7);
    animation: flotar 12s linear infinite;
    bottom: -20px;
  }
  .particulas span:nth-child(1) { left: 8%; animation-delay: 0s; animation-duration: 14s; }
  .particulas span:nth-child(2) { left: 18%; animation-delay: 1s; animation-duration: 11s; width: 4px; height: 4px; }
  .particulas span:nth-child(3) { left: 28%; animation-delay: 4s; animation-duration: 13s; width: 6px; height: 6px; }
  .particulas span:nth-child(4) { left: 38%; animation-delay: 2s; animation-duration: 12s; }
  .particulas span:nth-child(5) { left: 48%; animation-delay: 6s; animation-duration: 15s; width: 3px; height: 3px; }
  .particulas span:nth-child(6) { left: 58%; animation-delay: 3s; animation-duration: 10s; }
  .particulas span:nth-child(7) { left: 68%; animation-delay: 5s; animation-duration: 13s; width: 5px; height: 5px; }
  .particulas span:nth-child(8) { left: 78%; animation-delay: 7s; animation-duration: 14s; }
  .particulas span:nth-child(9) { left: 88%; animation-delay: 0.5s; animation-duration: 12s; width: 4px; height: 4px; }
  .particulas span:nth-child(10) { left: 92%; animation-delay: 8s; animation-duration: 16s; }
  .particulas span:nth-child(11) { left: 12%; animation-delay: 9s; animation-duration: 11s; width: 3px; height: 3px; }
  .particulas span:nth-child(12) { left: 32%; animation-delay: 10s; animation-duration: 13s; }
  .particulas span:nth-child(13) { left: 52%; animation-delay: 11s; animation-duration: 12s; width: 5px; height: 5px; }
  .particulas span:nth-child(14) { left: 72%; animation-delay: 4.5s; animation-duration: 14s; }
  .particulas span:nth-child(15) { left: 84%; animation-delay: 7.5s; animation-duration: 13s; width: 4px; height: 4px; }
  @keyframes flotar {
    0% { transform: translateY(0) translateX(0); opacity: 0; }
    8% { opacity: 1; }
    92% { opacity: 1; }
    100% { transform: translateY(-110vh) translateX(40px); opacity: 0; }
  }

  /* BUSCADOR · arriba del libro */
  .libro-wrap .libro-buscador { max-width: 480px; margin: 0 auto 16px; display: flex; align-items: center; gap: 8px; padding: 8px 14px; background: rgba(8,18,12,0.5); border: 0.5px solid rgba(201,169,97,0.4); border-radius: 999px; position: relative; }
  .libro-wrap .libro-buscador__icon { color: var(--gold); flex-shrink: 0; opacity: 0.85; }
  .libro-wrap .libro-buscador input { flex: 1; background: transparent; border: 0; outline: 0; color: var(--cream); font-family: 'Cormorant Garamond', Georgia, serif; font-size: 14px; font-style: italic; padding: 4px 0; min-width: 0; }
  .libro-wrap .libro-buscador input::placeholder { color: rgba(248,244,228,0.45); font-style: italic; }
  .libro-wrap .libro-buscador button { background: var(--mint-deep); color: var(--cream); border: 0; padding: 6px 16px; font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.35em; text-transform: uppercase; cursor: pointer; border-radius: 999px; transition: opacity 0.2s; }
  .libro-wrap .libro-buscador button:hover { opacity: 0.85; }
  .libro-wrap .libro-buscador ul#libro-search-results { position: absolute; top: 48px; left: 0; right: 0; background: #0c180f; border: 0.5px solid rgba(182,212,191,0.35); border-radius: 6px; padding: 6px 0; margin: 0; list-style: none; max-height: 280px; overflow-y: auto; z-index: 50; }
  .libro-wrap .libro-buscador ul li { padding: 8px 14px; font-family: 'Cormorant Garamond', serif; font-size: 13px; color: var(--cream); cursor: pointer; border-bottom: 0.5px solid rgba(182,212,191,0.15); transition: background 0.15s; }
  .libro-wrap .libro-buscador ul li:last-child { border-bottom: 0; }
  .libro-wrap .libro-buscador ul li:hover { background: rgba(182,212,191,0.12); }
  .libro-wrap .libro-buscador ul li .lbsr-page { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.3em; color: var(--mint-light); margin-right: 10px; }
  .libro-wrap .libro-buscador ul li .lbsr-snippet { color: rgba(248,244,228,0.7); font-size: 12px; display: block; margin-top: 2px; font-style: italic; }
  .libro-wrap .libro-buscador ul li mark { background: rgba(182,212,191,0.35); color: var(--cream); padding: 0 2px; border-radius: 2px; }
  @media (max-width: 768px) {
    .libro-wrap .libro-buscador { margin: 0 8px 12px; padding: 6px 12px; }
    .libro-wrap .libro-buscador input { font-size: 13px; }
    .libro-wrap .libro-buscador button { padding: 5px 12px; font-size: 8.5px; }
  }

  /* Divisor sutil */
  .page-divider { display: block; width: 28px; height: 0.5px; background: rgba(107,155,124,0.55); margin: 0 auto 14px !important; opacity: 0.8; }
  .page.dark .page-divider, .page.deep-mint .page-divider { background: rgba(182,212,191,0.4); }

  /* Frame TAROT premium para fichas pixie */
  .libro-wrap .foto-tarot {
    width: 200px; height: 280px;
    margin: 8px auto 6px; padding: 8px;
    position: relative; box-sizing: border-box;
    background: linear-gradient(160deg, #fcf9ee 0%, #e5efde 100%);
    box-shadow: 0 10px 30px rgba(45,90,61,0.30), inset 0 0 0 1px rgba(107,155,124,0.55);
    border: 1.5px solid var(--mint-medium);
    border-radius: 4px;
  }
  .libro-wrap .foto-tarot::before {
    content: ''; position: absolute; inset: 4px;
    border: 0.5px solid rgba(107,155,124,0.45); border-radius: 2px;
    pointer-events: none;
  }
  .libro-wrap .foto-tarot::after {
    content: '✿'; position: absolute; top: -8px; left: 50%; transform: translateX(-50%);
    color: var(--mint-deep); background: var(--cream-light); padding: 0 6px;
    font-size: 12px; line-height: 1;
  }
  .libro-wrap .foto-tarot img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    border-radius: 2px;
  }
  .libro-wrap .page.dark .foto-tarot,
  .libro-wrap .page.deep-mint .foto-tarot { background: linear-gradient(160deg, #18301e 0%, #0c180f 100%); border-color: var(--mint-light); box-shadow: 0 10px 30px rgba(0,0,0,0.6), inset 0 0 0 1px rgba(182,212,191,0.5); }
  .libro-wrap .page.dark .foto-tarot::before,
  .libro-wrap .page.deep-mint .foto-tarot::before { border-color: rgba(182,212,191,0.45); }
  .libro-wrap .page.dark .foto-tarot::after,
  .libro-wrap .page.deep-mint .foto-tarot::after { background: #0c180f; color: var(--mint-light); }
  .libro-wrap .foto-tarot-caption {
    font-family: 'Cinzel', serif; font-size: 8px; letter-spacing: 0.45em;
    color: var(--mint-deep); text-transform: uppercase;
    text-align: center; margin: 4px auto 0;
  }
  .libro-wrap .page.dark .foto-tarot-caption,
  .libro-wrap .page.deep-mint .foto-tarot-caption { color: var(--mint-light); }
  .libro-wrap .foto-tarot-ejemplo {
    font-family: 'Cinzel', serif; font-size: 7.5px; letter-spacing: 0.55em;
    color: rgba(107,155,124,0.75); text-transform: uppercase;
    text-align: center; margin: 4px auto 2px; padding: 2px 8px;
    display: inline-block; border-top: 0.5px solid rgba(107,155,124,0.4); border-bottom: 0.5px solid rgba(107,155,124,0.4);
  }
  .libro-wrap .page.dark .foto-tarot-ejemplo,
  .libro-wrap .page.deep-mint .foto-tarot-ejemplo { color: rgba(182,212,191,0.65); border-color: rgba(182,212,191,0.35); }
  @media (max-width: 768px) {
