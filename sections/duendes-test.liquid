      form_phone_label: "Teléfono", form_phone_placeholder: "número sin código de país", form_phone_error: "Necesitamos un teléfono válido.", form_phone_hint: "Lo usamos solo para enviarte el resultado por WhatsApp si lo pedís.",
      form_dob_label: "Fecha de nacimiento", form_dob_error: "Necesitamos tu fecha de nacimiento.", form_dob_hint: "Algunas canalizaciones leen esta señal.",
      form_country_label: "País donde vivís", form_country_error: "Elegí tu país.",
      form_consent: "Tu información queda en nuestra base privada. La usamos solo para enviarte tu canalización por email y, si nos lo pedís, por WhatsApp. Nunca la compartimos.",
      form_back: "Volver", form_next: "Continuar",
      q_title: "Vaciate.",
      q_sub: "El bosque te lee desde tus palabras. Contanos en tu propia voz qué sentís hoy, qué buscás, qué te molesta, qué te paraliza, qué necesitás cambiar. No hay respuesta correcta. Cuanto más honesta seas, más preciso es lo que te toca.",
