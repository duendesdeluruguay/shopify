{{ 'duendes-base.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign dh2_ed_quote = section.settings.quote | strip
  if dh2_ed_quote == blank
    assign dh2_ed_quote = 'duendes.home_v2.editorial.quote' | t
  endif
  assign dh2_ed_sig = section.settings.signature | strip
  if dh2_ed_sig == blank
    assign dh2_ed_sig = 'duendes.home_v2.editorial.signature' | t
  endif
  assign dh2_ed_link = section.settings.link_label | strip
  if dh2_ed_link == blank
    assign dh2_ed_link = 'duendes.home_v2.editorial.link_label' | t
  endif
-%}
<style>
  .dh2-ed {
    background: #faf9f6;
    padding: 56px 20px 64px;
    color: #15110d;
  }
  .dh2-ed__inner {
    max-width: 480px;
    margin: 0 auto;
    text-align: center;
  }
  .dh2-ed__quote {
    font-family: var(--font-body--family, 'Cormorant Garamond', Georgia, serif);
    font-size: clamp(18px, 2.4vw, 22px);
    line-height: 1.65;
    font-style: italic;
    margin: 0 0 22px;
    color: rgba(21, 17, 13, 0.88);
  }
  .dh2-ed__sig {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(21, 17, 13, 0.45);
    margin-bottom: 18px;
  }
  .dh2-ed__link {
    font-size: 13px;
    color: #a88b42;
    text-decoration: none;
    border-bottom: 1px solid rgba(168, 139, 66, 0.35);
    padding-bottom: 2px;
  }
  .dh2-ed__link:hover {
    color: #15110d;
    border-color: #15110d;
  }
  @media (max-width: 768px) {
    .dh2-ed.section {
      overflow-x: hidden;
      padding-left: max(20px, env(safe-area-inset-left, 0px));
      padding-right: max(24px, env(safe-area-inset-right, 0px));
    }
    .dh2-ed__quote {
      font-size: 16px !important;
      line-height: 1.55 !important;
    }
    .dh2-ed__sig {
      font-size: 9px !important;
    }
    .dh2-ed__link {
      font-size: 14px !important;
    }
  }
</style>
{{ 'duendes-home-v2-mobile-spacing.css' | asset_url | stylesheet_tag }}

<section class="dh2-ed section">
  <div class="dh2-ed__inner">
    <blockquote class="dh2-ed__quote">{{ dh2_ed_quote }}</blockquote>
    <p class="dh2-ed__sig">{{ dh2_ed_sig }}</p>
    {% if section.settings.link_url != blank %}
      <a class="dh2-ed__link" href="{{ section.settings.link_url }}">{{ dh2_ed_link }}</a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "DDU v2 · Editorial",
  "tag": "section",
  "class": "duendes-home-v2-editorial-section",
  "settings": [
    {
      "type": "textarea",
      "id": "quote",
      "label": "Cita",
      "default": "Los celtas los ponían en sus casas para proteger a la familia. En Escandinavia, si no le dejabas ofrenda al duende del hogar, la suerte se iba con él. No los inventamos nosotros — los canalizamos."
    },
    {
      "type": "text",
      "id": "signature",
      "label": "Firma",
      "default": "— DEL COMPENDIO ELEMENTAL"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Texto del enlace",
      "default": "Leer en Tribu Elemental"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Enlace"
    }
  ],
  "presets": [{ "name": "DDU v2 · Editorial" }]
}
{% endschema %}
