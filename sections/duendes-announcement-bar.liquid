{{ 'duendes-base.css' | asset_url | stylesheet_tag }}

<style>
  .duendes-announce {
    width: 100%;
    height: 32px;
    background: #1a1a14;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .duendes-announce__track {
    display: flex;
    white-space: nowrap;
    animation: duendesAnnounceScroll 40s linear infinite;
  }
  .duendes-announce__track span {
    font-family: var(--serif);
    font-size: 13px;
    color: #fff;
    padding: 0 18px;
    letter-spacing: .3px;
    font-weight: 400;
  }
  .duendes-announce__diamond {
    color: var(--gold-lt) !important;
    padding: 0 6px !important;
    font-size: 11px !important;
  }
  @keyframes duendesAnnounceScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<div class="duendes-announce">
  <div class="duendes-announce__track">
    {% for i in (1..2) %}
      {% for block in section.blocks %}
        <span>
          {%- assign _du_an = block.settings.text | strip -%}
          {%- if _du_an contains '[ddu:announcement_intl]' -%}
            {{- 'duendes.global.announcement_bar' | t -}}
          {%- else -%}
            {{- block.settings.text -}}
          {%- endif -%}
        </span>
        <span class="duendes-announce__diamond">&#10022;</span>
      {% endfor %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Duendes Barra Anuncio",
  "tag": "div",
  "class": "duendes-announce-section",
  "settings": [],
  "blocks": [
    {
      "type": "message",
      "name": "Mensaje",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto del mensaje",
          "default": "Envío internacional con tracking · 5 a 10 días hábiles"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Duendes Barra Anuncio",
      "blocks": [
        { "type": "message", "settings": { "text": "[ddu:announcement_intl]" } },
        { "type": "message", "settings": { "text": "Envíos a Uruguay por DAC · 5 a 7 días" } },
        { "type": "message", "settings": { "text": "Pago 100% seguro · Certificado SSL" } },
        { "type": "message", "settings": { "text": "Cada guardián es único · Hecho a mano sin moldes" } },
        { "type": "message", "settings": { "text": "Más de 15.000 guardianes adoptados en 10 años" } }
      ]
    }
  ]
}
{% endschema %}
