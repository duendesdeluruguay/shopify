<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>
  :root{--gold:#C6A55A;--gold-lt:#D6BD7B;--gold-dk:#A38640;--moss:#4A5D3A;--bark:#3E2F1C;--bark-deep:#2A1F12;--cream:#FAF8F4;--misty:#F4F1EC;--serif:'Cormorant Garamond',Georgia,serif;--sans:'Lato',sans-serif}
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{height:100%;font-family:var(--sans);background:#0a0806;color:var(--cream)}
  @media(min-width:769px){html,body{overflow:hidden}}
  .landing{display:flex;height:100vh;width:100%;position:relative}
  .region{flex:1;position:relative;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding:0 3rem 5rem;cursor:pointer;overflow:hidden;transition:flex .7s cubic-bezier(.25,.46,.45,.94)}
  .region:hover{flex:1.2}
  .region-bg{position:absolute;inset:0;background-size:cover;background-position:center 20%;transition:transform 1.2s cubic-bezier(.25,.46,.45,.94),filter .8s ease,opacity 2.5s ease-in-out;z-index:0;filter:brightness(.35) saturate(.8)}
  .region:hover .region-bg{transform:scale(1.08);filter:brightness(.45) saturate(1)}
  .region-bg.slide-a,.region-bg.slide-b{position:absolute;inset:0;background-size:cover;background-position:center 20%;transition:opacity 2.5s ease-in-out}
  .region-bg.slide-b{opacity:0}.region-bg.slide-a.faded{opacity:0}.region-bg.slide-b.visible{opacity:1}
  .region-latam .region-bg{background-image:url('https://cdn.shopify.com/s/files/1/0627/7785/2001/files/00046DF7-25B9-46F9-A7E4-132B3CDC8CFD.png?v=1774486368');background-position:center 20%}
  .region-intl .region-bg{background-image:url('https://cdn.shopify.com/s/files/1/0627/7785/2001/files/A489F107-5795-432C-9040-78F0FC5FCBAC.png?v=1774486370');background-position:center 20%}
  .region::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 100%,transparent 10%,rgba(10,8,6,.55) 70%),linear-gradient(to top,rgba(10,8,6,.92) 0%,rgba(10,8,6,.6) 25%,rgba(10,8,6,.15) 50%,transparent 65%);z-index:1;pointer-events:none}
  .region::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent 10%,var(--gold) 50%,transparent 90%);z-index:3;opacity:0;transition:opacity .5s ease}
  .region:hover::after{opacity:1}
  .region-content{position:relative;z-index:2;text-align:center;max-width:420px;display:flex;flex-direction:column;align-items:center;gap:1.4rem;opacity:0;transform:translateY(20px);animation:fadeUp .8s ease-out forwards;margin-bottom:1rem}
  .region-latam .region-content{animation-delay:.3s}.region-intl .region-content{animation-delay:.5s}
  @keyframes fadeUp{to{opacity:1;transform:translateY(0)}}
  .region-label{font-family:var(--sans);font-size:.7rem;font-weight:700;letter-spacing:.25em;text-transform:uppercase;color:var(--gold-lt);background:rgba(0,0,0,.65);padding:.45rem 1.2rem;border:1px solid rgba(198,165,90,.25);position:relative;text-shadow:0 0 12px rgba(198,165,90,.5),0 0 30px rgba(198,165,90,.2);backdrop-filter:blur(8px)}
  .region-label::before,.region-label::after{content:'';position:absolute;width:3px;height:3px;background:var(--gold);border-radius:50%;box-shadow:0 0 6px var(--gold),0 0 12px rgba(198,165,90,.4);animation:sporeFloat 3s ease-in-out infinite}
  .region-label::before{top:-8px;left:20%;animation-delay:0s}.region-label::after{bottom:-8px;right:15%;animation-delay:1.5s}
  @keyframes sporeFloat{0%,100%{opacity:.3;transform:translateY(0) scale(.8)}50%{opacity:1;transform:translateY(-4px) scale(1.2)}}
  .label-spores{position:absolute;inset:-30px;pointer-events:none;z-index:3}
  .label-spores .spore{position:absolute;width:3px;height:3px;background:var(--gold);border-radius:50%;box-shadow:0 0 6px var(--gold),0 0 12px rgba(198,165,90,.3);animation:sporeDrift 5s ease-in-out infinite}
  @keyframes sporeDrift{0%,100%{opacity:0;transform:translate(0,0) scale(.6)}20%{opacity:.9}50%{opacity:1;transform:translate(10px,-16px) scale(1.5)}80%{opacity:.5}}
  .region-title{font-family:var(--serif);font-size:clamp(2rem,4.5vw,3.2rem);font-weight:300;color:var(--cream);letter-spacing:.04em;line-height:1.15}
  .region-title strong{font-weight:700}
  .region-desc{font-size:.95rem;color:rgba(250,248,244,.6);font-weight:300;line-height:1.7;max-width:320px}
  .region-btn{display:inline-flex;align-items:center;gap:.7rem;background:linear-gradient(135deg,rgba(198,165,90,.12) 0%,rgba(163,134,64,.05) 100%);color:var(--gold-lt);font-family:var(--sans);font-size:.8rem;font-weight:700;padding:.85rem 2.2rem;border-radius:0;text-decoration:none;letter-spacing:.18em;text-transform:uppercase;transition:all .4s ease;border:1px solid rgba(198,165,90,.45);cursor:pointer;margin-top:.8rem;position:relative;overflow:hidden;box-shadow:0 0 25px rgba(198,165,90,.12),inset 0 0 15px rgba(198,165,90,.04);text-shadow:0 0 10px rgba(198,165,90,.4)}
  .region-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,var(--gold) 0%,var(--gold-dk) 100%);opacity:0;transition:opacity .4s ease;z-index:-1}
  .region-btn::after{content:'';position:absolute;top:-2px;left:-100%;width:40%;height:calc(100% + 4px);background:linear-gradient(90deg,transparent,rgba(198,165,90,.15),transparent);animation:btnShimmer 4s ease-in-out infinite;z-index:0}
  @keyframes btnShimmer{0%,100%{left:-100%}50%{left:150%}}
  .region-btn:hover{color:var(--bark-deep);border-color:var(--gold);box-shadow:0 0 40px rgba(198,165,90,.3),0 0 80px rgba(198,165,90,.08);text-shadow:none}
  .region-btn:hover::before{opacity:1}
  .region-btn .arrow{display:inline-block;transition:transform .3s ease;font-size:1.1rem}
  .region-btn:hover .arrow{transform:translateX(5px)}
  .divider{position:absolute;left:50%;top:0;bottom:0;width:1px;background:linear-gradient(to bottom,transparent 0%,rgba(198,165,90,.15) 15%,rgba(198,165,90,.4) 50%,rgba(198,165,90,.15) 85%,transparent 100%);z-index:10;transform:translateX(-50%)}
  .center-brand{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);z-index:20;display:flex;flex-direction:column;align-items:center;gap:1.2rem;pointer-events:none}
  .brand-mark{width:72px;height:72px;border:1px solid rgba(198,165,90,.3);border-radius:50%;display:flex;align-items:center;justify-content:center;background:#0a0806;backdrop-filter:blur(12px);box-shadow:0 0 25px rgba(198,165,90,.4),0 0 60px rgba(198,165,90,.2),0 0 100px rgba(198,165,90,.1),0 0 150px rgba(198,165,90,.05);animation:breathe 4s ease-in-out infinite}
  @keyframes breathe{0%,100%{box-shadow:0 0 25px rgba(198,165,90,.4),0 0 60px rgba(198,165,90,.2),0 0 100px rgba(198,165,90,.1),0 0 150px rgba(198,165,90,.05)}50%{box-shadow:0 0 35px rgba(198,165,90,.55),0 0 80px rgba(198,165,90,.3),0 0 130px rgba(198,165,90,.15),0 0 180px rgba(198,165,90,.08)}}
  .brand-mark img{width:50px;height:50px;object-fit:contain;opacity:.9;border-radius:50%}
  .brand-name{font-family:var(--serif);font-size:.75rem;color:var(--gold);letter-spacing:.2em;text-transform:uppercase;opacity:0;animation:fadeIn 1s ease-out 1s forwards;text-shadow:0 2px 12px rgba(0,0,0,.8);white-space:nowrap}
  @keyframes fadeIn{to{opacity:.8}}
  .top-tag{position:absolute;top:2.5rem;left:50%;transform:translateX(-50%);z-index:20;text-align:center;pointer-events:none;opacity:0;animation:fadeIn 1s ease-out .8s forwards}
  .top-tag span{font-family:var(--serif);font-size:clamp(.85rem,1.5vw,1rem);font-weight:300;font-style:italic;color:rgba(250,248,244,.4);letter-spacing:.08em}
  .scroll-dot{display:none}
  .particle{position:fixed;width:2px;height:2px;background:rgba(198,165,90,.4);border-radius:50%;pointer-events:none;z-index:5;animation:drift linear infinite}
  @keyframes drift{0%{opacity:0;transform:translateY(0) translateX(0)}15%{opacity:1}85%{opacity:1}100%{opacity:0;transform:translateY(-120px) translateX(30px)}}
  .fog{position:fixed;inset:0;pointer-events:none;z-index:4;opacity:.3}
  .fog::before,.fog::after{content:'';position:absolute;width:200%;height:200%;top:-50%;left:-50%}
  .fog::before{background:radial-gradient(ellipse at 30% 80%,rgba(198,165,90,.04) 0%,transparent 50%);animation:fogDrift1 20s infinite ease-in-out}
  .fog::after{background:radial-gradient(ellipse at 70% 20%,rgba(74,93,58,.04) 0%,transparent 50%);animation:fogDrift2 25s infinite ease-in-out}
  @keyframes fogDrift1{0%,100%{transform:translateX(-5%) translateY(0)}50%{transform:translateX(5%) translateY(-3%)}}
  @keyframes fogDrift2{0%,100%{transform:translateX(0) translateY(5%)}50%{transform:translateX(3%) translateY(-5%)}}
  .return-banner{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);z-index:100;background:rgba(10,8,6,.92);border:1px solid rgba(198,165,90,.3);padding:1rem 2rem;display:flex;align-items:center;gap:1.2rem;backdrop-filter:blur(16px);box-shadow:0 12px 40px rgba(0,0,0,.5);opacity:0;animation:slideUp .6s ease-out .5s forwards;white-space:nowrap}
  @keyframes slideUp{from{transform:translate(-50%,40px);opacity:0}to{transform:translate(-50%,0);opacity:1}}
  .return-banner p{font-size:.85rem;color:rgba(250,248,244,.7);font-weight:300}
  .return-banner a{color:var(--gold-lt);text-decoration:none;font-weight:600;border-bottom:1px solid rgba(198,165,90,.3);transition:border-color .3s ease}
  .return-banner a:hover{border-color:var(--gold)}
  .return-banner button{background:none;border:1px solid rgba(198,165,90,.3);color:rgba(250,248,244,.5);padding:.4rem 1rem;cursor:pointer;font-size:.75rem;font-family:var(--sans);letter-spacing:.1em;text-transform:uppercase;transition:all .3s ease}
  .return-banner button:hover{color:var(--gold-lt);border-color:var(--gold)}
  @media(max-width:768px){.landing{flex-direction:row;height:100vh;height:100dvh}.region{flex:1;padding:0 .5rem 2rem}.region:hover{flex:1}.region:hover .region-bg{transform:none;filter:brightness(.35) saturate(.8)}.region::before{background:linear-gradient(to bottom,transparent 0%,transparent 38%,rgba(10,8,6,.25) 44%,rgba(10,8,6,.65) 52%,rgba(10,8,6,.9) 60%,rgba(10,8,6,.97) 72%,rgba(10,8,6,.99) 100%)}.center-brand{top:38%;gap:.5rem}.brand-mark{width:90px;height:90px;border:1px solid rgba(198,165,90,.12);box-shadow:0 0 30px rgba(198,165,90,.5),0 0 70px rgba(198,165,90,.25),0 0 120px rgba(198,165,90,.12),0 0 180px rgba(198,165,90,.06)}.brand-mark img{width:68px;height:68px}.brand-name{font-size:.9rem;letter-spacing:.18em;opacity:1!important;animation:none!important;text-shadow:0 0 20px rgba(198,165,90,.6),0 0 40px rgba(198,165,90,.3),0 2px 12px rgba(0,0,0,.9)}.region-content{height:42vh;gap:0;margin-bottom:0;justify-content:space-evenly}.region-label{font-size:.5rem;padding:.25rem .6rem;letter-spacing:.12em}.region-title{font-size:clamp(1.15rem,4.5vw,1.5rem)}.region-desc{display:block;font-size:.65rem;line-height:1.5;max-width:155px;color:rgba(250,248,244,.8)}.region-btn{padding:.55rem .8rem;font-size:.6rem;letter-spacing:.08em;width:100%;justify-content:center;margin-top:0}.label-spores,.top-tag,.scroll-dot{display:none}.region-label::before,.region-label::after{display:none}.divider{left:50%;top:0;bottom:0;width:1px;height:auto;transform:translateX(-50%)}.return-banner{left:.5rem;right:.5rem;transform:none;white-space:normal;font-size:.7rem;padding:.6rem 1rem}@keyframes slideUp{from{transform:translateY(40px);opacity:0}to{transform:translateY(0);opacity:1}}.fog{opacity:.1}}
  @media(max-width:380px){.region-title{font-size:clamp(.9rem,3.8vw,1.1rem)}.region-btn{padding:.45rem .6rem;font-size:.5rem}.region-desc{font-size:.48rem;max-width:130px}.brand-mark{width:75px;height:75px}.brand-mark img{width:55px;height:55px}.brand-name{font-size:.75rem}}
</style>
