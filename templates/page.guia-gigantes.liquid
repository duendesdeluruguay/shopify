<script src="https://cdn.jsdelivr.net/npm/page-flip@2.0.7/dist/js/page-flip.browser.js"></script>
<script>
(function() {
  let audioCtx = null;
  let soundEnabled = true;
  function ensureAudioCtx() {
    if (!audioCtx) {
      try { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); } catch (e) { return null; }
    }
    if (audioCtx.state === 'suspended') audioCtx.resume();
    return audioCtx;
  }
  function playPageTurn() {
    if (!soundEnabled) return;
    const ctx = ensureAudioCtx(); if (!ctx) return;
    const duration = 0.65;
    const bufferSize = ctx.sampleRate * duration;
    const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
    const data = buffer.getChannelData(0);
    for (let i = 0; i < bufferSize; i++) {
      const t = i / bufferSize;
      const env = t < 0.20 ? (t/0.20) : Math.pow(1 - (t - 0.20)/0.80, 1.6);
      data[i] = (Math.random() * 2 - 1) * env * 0.7;
    }
    const noise = ctx.createBufferSource(); noise.buffer = buffer;
    const filter = ctx.createBiquadFilter(); filter.type = 'lowpass'; filter.Q.value = 0.5;
    filter.frequency.setValueAtTime(450, ctx.currentTime);
    filter.frequency.linearRampToValueAtTime(800, ctx.currentTime + 0.30);
    filter.frequency.linearRampToValueAtTime(280, ctx.currentTime + duration);
    const gain = ctx.createGain();
    gain.gain.setValueAtTime(0.20, ctx.currentTime);
    gain.gain.linearRampToValueAtTime(0, ctx.currentTime + duration);
    noise.connect(filter); filter.connect(gain); gain.connect(ctx.destination);
    noise.start(); noise.stop(ctx.currentTime + duration);

    /* Tambor bajo · pulso solemne */
    const osc = ctx.createOscillator(); osc.type = 'sine';
    osc.frequency.setValueAtTime(55, ctx.currentTime);
    osc.frequency.exponentialRampToValueAtTime(38, ctx.currentTime + duration);
    const oscGain = ctx.createGain();
    oscGain.gain.setValueAtTime(0.10, ctx.currentTime);
    oscGain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + duration);
    osc.connect(oscGain); oscGain.connect(ctx.destination);
    osc.start(); osc.stop(ctx.currentTime + duration);
  }

  function spawnParticles() {
    const types = ['gold','gold','bordeaux'];
    const total = 18;
    for (let i = 0; i < total; i++) {
      const p = document.createElement('div');
      const type = types[Math.floor(Math.random()*types.length)];
      p.className = 'particula ' + type;
      const startX = Math.random() * 100;
      const drift = (Math.random() - 0.5) * 24;
      const duration = 18 + Math.random() * 10;
      const delay = Math.random() * 14;
      const startY = 100 + Math.random() * 20;
      p.style.left = startX + 'vw';
      p.style.top = startY + 'vh';
      p.style.animation = 'particula-rise ' + duration + 's linear ' + delay + 's infinite';
      p.style.setProperty('--drift', drift + 'vw');
      document.body.appendChild(p);
    }
  }
  const styleEl = document.createElement('style');
  styleEl.textContent = '@keyframes particula-rise { 0% { transform: translate(0, 0); opacity: 0; } 10% { opacity: 1; } 90% { opacity: 1; } 100% { transform: translate(var(--drift), -120vh); opacity: 0; } }';
  document.head.appendChild(styleEl);

  document.addEventListener('DOMContentLoaded', function() {
    const overlay = document.getElementById('lang-overlay');
    const btnES = document.getElementById('lang-es');
    const btnEN = document.getElementById('lang-en');

    function startBook() {
      overlay.classList.add('hide');
      ensureAudioCtx();
      initFlipbook();
      spawnParticles();
    }

    const currentPath = window.location.pathname;
    const alreadyInES = currentPath.startsWith('/es/');
    const alreadyInEN = !alreadyInES;

    btnES.addEventListener('click', function() {
      try { localStorage.setItem('guia_gigantes_lang', 'es'); } catch(e) {}
      if (!alreadyInES) {
        window.location.href = '/es/pages/guia-gigantes';
        return;
      }
      startBook();
    });
    btnEN.addEventListener('click', function() {
      try { localStorage.setItem('guia_gigantes_lang', 'en_pending'); } catch(e) {}
      if (alreadyInES) {
        window.location.href = '/pages/guia-gigantes';
        return;
      }
      alert('The Master Giants Guide content is currently in Spanish. English version coming soon. Continuing in Spanish.');
      startBook();
    });

    try {
      const saved = localStorage.getItem('guia_gigantes_lang');
      if (saved === 'es' && alreadyInES) { startBook(); }
      else if (saved === 'en_pending' && alreadyInEN) { startBook(); }
    } catch(e) {}
  });

  function initFlipbook() {
    const bookEl = document.getElementById('book');
    if (!bookEl || typeof St === 'undefined') return;

    const isMobile = window.innerWidth < 768;
    const pageFlip = new St.PageFlip(bookEl, {
      width: isMobile ? 320 : 480,
      height: isMobile ? 460 : 680,
      size: 'fixed',
      minWidth: 280, maxWidth: 600,
      minHeight: 400, maxHeight: 800,
      drawShadow: true,
      flippingTime: 1200,
      usePortrait: isMobile,
      startZIndex: 0,
      autoSize: false,
      maxShadowOpacity: 0.6,
      showCover: true,
      mobileScrollSupport: true,
      swipeDistance: 30,
      clickEventForward: true,
      useMouseEvents: true,
      showPageCorners: true,
      disableFlipByClick: false
    });

    pageFlip.loadFromHTML(document.querySelectorAll('#book .page'));

    // AUTO-NUMERAR páginas · evita repetidos cuando hay splits
    (function renumberPages(){
      var allPages = document.querySelectorAll('#book .page');
      var num = 0;
      allPages.forEach(function(p){
        if(p.classList.contains('cover')) return;
        num++;
        var pn = p.querySelector('.page-number');
        if(pn){ pn.textContent = String(num).padStart(2, '0'); }
      });
    })();

    // BUSCADOR · expone pageFlip y permite saltar a la página resultado
    window.__gigantesPageFlip = pageFlip;
    var searchInput = document.getElementById('libro-search-input');
    var searchBtn = document.getElementById('libro-search-btn');
    var searchResults = document.getElementById('libro-search-results');
    var allPagesForSearch = Array.from(document.querySelectorAll('#book .page'));

    function normalize(s){ return (s||'').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g,''); }

    function runSearch(){
      var q = normalize(searchInput.value.trim());
      searchResults.innerHTML = '';
      if(!q || q.length < 2){ searchResults.hidden = true; return; }
      var matches = [];
      allPagesForSearch.forEach(function(p, i){
        var text = normalize(p.textContent);
        var idx = text.indexOf(q);
        if(idx >= 0){
          var titleEl = p.querySelector('h2') || p.querySelector('h1') || p.querySelector('.eyebrow') || p.querySelector('p');
          var title = titleEl ? titleEl.textContent.trim().slice(0, 60) : 'Página ' + i;
          var rawText = p.textContent.replace(/\s+/g,' ').trim();
          var rawIdx = normalize(rawText).indexOf(q);
          var start = Math.max(0, rawIdx - 30);
          var snippet = (start > 0 ? '…' : '') + rawText.slice(start, rawIdx + q.length + 50) + '…';
          matches.push({i: i, title: title, snippet: snippet});
        }
      });
      if(!matches.length){
        searchResults.innerHTML = '<li style="opacity:0.6;font-style:italic;cursor:default;">Sin resultados para "' + searchInput.value.trim() + '"</li>';
        searchResults.hidden = false;
        return;
      }
      matches.slice(0, 12).forEach(function(m){
        var li = document.createElement('li');
        li.innerHTML = '<span class="lbsr-page">P ' + String(m.i + 1).padStart(2,'0') + '</span><strong>' + m.title + '</strong><span class="lbsr-snippet">' + m.snippet.replace(new RegExp('('+searchInput.value.trim().replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')','ig'),'<mark>$1</mark>') + '</span>';
        li.addEventListener('click', function(){
          searchResults.hidden = true;
          if(window.__gigantesPageFlip){
            try {
              window.__gigantesPageFlip.turnToPage(m.i);
            } catch(err){
              try { window.__gigantesPageFlip.flip(m.i, 'top'); } catch(e){}
            }
            var fc = document.querySelector('.flipbook-container');
            if(fc) window.scrollTo({top: fc.offsetTop - 20, behavior:'smooth'});
          }
        });
        searchResults.appendChild(li);
      });
      searchResults.hidden = false;
    }
    if(searchBtn && searchInput && searchResults){
      searchBtn.addEventListener('click', runSearch);
      searchInput.addEventListener('keydown', function(e){ if(e.key === 'Enter'){ e.preventDefault(); runSearch(); } });
      searchInput.addEventListener('input', function(){ if(!searchInput.value.trim()){ searchResults.hidden = true; } });
      document.addEventListener('click', function(e){
        if(!e.target.closest('.libro-buscador')) searchResults.hidden = true;
      });
    }

    // FIT-TO-PAGE · escala contenido que rebasa la altura
    function measureNaturalHeight(pageNode, targetWidth){
      var html = pageNode.innerHTML;
      var holder = document.createElement('div');
      holder.style.cssText='position:fixed;left:-9999px;top:0;width:'+targetWidth+'px;visibility:hidden;';
      holder.className='libro-wrap';
      var pageClasses = 'page'
        + (pageNode.classList.contains('dark') ? ' dark' : '')
        + (pageNode.classList.contains('bordeaux') ? ' bordeaux' : '')
        + (pageNode.classList.contains('deep-bordeaux') ? ' deep-bordeaux' : '')
        + (pageNode.classList.contains('cover') ? ' cover' : '');
      holder.innerHTML = '<div class="'+pageClasses+'" style="position:relative;width:'+targetWidth+'px;height:auto;">' + html + '</div>';
      document.body.appendChild(holder);
      var pageEl = holder.querySelector('.page');
      var inner = pageEl.querySelector('.page-inner');
      if(inner) inner.style.height='auto';
      var h = pageEl.scrollHeight;
      document.body.removeChild(holder);
      return h;
    }

    function fitAllPages(){
      var originals = document.querySelectorAll('#book .page');
      var stfItems = document.querySelectorAll('.stf__item');
      if(!stfItems.length) return;
      var sample = stfItems[0];
      var pageW = sample.clientWidth || (isMobile ? 320 : 480);
      var pageH = sample.clientHeight || (isMobile ? 460 : 680);
      originals.forEach(function(orig, i){
        var stf = stfItems[i];
        if(!stf) return;
        var inner = stf.querySelector('.page-inner');
        if(!inner) return;
        inner.style.transform=''; inner.style.transformOrigin='center center';
        var natH = measureNaturalHeight(orig, pageW);
        if(natH > pageH){
          var scale = (pageH / natH) * 0.97;
          inner.style.transform = 'scale(' + scale.toFixed(3) + ')';
          inner.style.transformOrigin = 'center center';
        }
      });
    }
    setTimeout(fitAllPages, 350);
    setTimeout(fitAllPages, 1200);
    window.addEventListener('resize', function(){ setTimeout(fitAllPages, 250); });

    const prevBtn = document.getElementById('prev-page');
    const nextBtn = document.getElementById('next-page');
    const indicator = document.getElementById('page-indicator');
    const soundBtn = document.getElementById('sound-toggle');
    const total = pageFlip.getPageCount();

    function updateIndicator() {
      const cur = pageFlip.getCurrentPageIndex() + 1;
      indicator.textContent = String(cur).padStart(2, '0') + ' · ' + String(total).padStart(2, '0');
      prevBtn.disabled = cur === 1;
      nextBtn.disabled = cur === total;
    }

    prevBtn.addEventListener('click', () => pageFlip.flipPrev());
    nextBtn.addEventListener('click', () => pageFlip.flipNext());
    pageFlip.on('flip', () => { playPageTurn(); updateIndicator(); });

    soundBtn.addEventListener('click', function() {
      soundEnabled = !soundEnabled;
      soundBtn.textContent = soundEnabled ? '🔊 Sonido' : '🔇 Silencio';
      soundBtn.classList.toggle('muted', !soundEnabled);
      if (soundEnabled) ensureAudioCtx();
    });

    updateIndicator();

    let lastIsMobile = isMobile;
    window.addEventListener('resize', () => {
      const newIsMobile = window.innerWidth < 768;
      if (newIsMobile !== lastIsMobile) location.reload();
    });
  }
})();
</script>
