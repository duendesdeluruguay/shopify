/* ═══════ FLOATING RITO NOTIFICATION ═══════ */
.mm-rito-floating {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 9000;
  width: 300px;
  background: linear-gradient(135deg, rgba(26,58,45,0.97) 0%, rgba(13,26,42,0.97) 100%);
  border: 1px solid rgba(212,175,55,0.35);
  border-radius: 14px;
  padding: 20px 22px;
  box-shadow:
    0 10px 40px rgba(0,0,0,0.35),
    0 0 30px rgba(212,175,55,0.15);
  cursor: pointer;
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
              box-shadow 0.4s ease;
  color: #f5f1eb;
  display: none;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.mm-rito-floating.mm-show {
  display: block;
  animation: mmSlideInRight 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

@keyframes mmSlideInRight {
  from { transform: translateX(130%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

.mm-rito-floating:hover {
  transform: translateX(-4px);
  box-shadow:
    0 12px 52px rgba(0,0,0,0.4),
    0 0 42px rgba(212,175,55,0.3);
}

.mm-rito-floating-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}

.mm-rito-floating-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #ffb07a;
  box-shadow: 0 0 10px rgba(255,176,122,0.7);
  animation: mmBadgePulse 2s ease-in-out infinite;
}

.mm-rito-floating-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 17px;
  font-weight: 500;
  color: #f0d88c;
  letter-spacing: 0.02em;
}

.mm-rito-floating-text {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 14.5px;
  line-height: 1.45;
  color: rgba(245,241,235,0.87);
  margin-bottom: 14px;
}

.mm-rito-floating-cta {
  font-family: 'Lato', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #f0d88c;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: gap 0.3s ease;
}

.mm-rito-floating:hover .mm-rito-floating-cta { gap: 12px; }

.mm-rito-floating-close {
  position: absolute;
  top: 8px;
  right: 10px;
  background: transparent;
  border: none;
  color: rgba(245,241,235,0.55);
  font-size: 22px;
  line-height: 1;
  cursor: pointer;
  padding: 4px 8px;
  transition: color 0.25s ease;
  font-family: sans-serif;
}

.mm-rito-floating-close:hover {
  color: #f0d88c;
}

/* Mobile tweaks */
@media (max-width: 640px) {
  .mm-hero-cinematic { height: 240px; }
  .mm-hero-greeting { font-size: 26px; }
  .mm-hero-soul { font-size: 52px; margin-bottom: 14px; }
  .mm-hero-subtitle { font-size: 14px; }
  .mm-hero-orb { width: 64px; height: 64px; top: 16px; right: 16px; }
  .mm-hero-label { font-size: 9px; letter-spacing: 4px; }
  .mm-cine-card { height: 200px; }
  .mm-cine-card-title { font-size: 24px; }
  .mm-cine-card-sub { font-size: 13px; }
  .mm-cine-card-orb { width: 44px; height: 44px; top: 14px; right: 16px; }
  .mm-cine-card-content { padding: 22px 20px 20px; }
  .mm-cards-section { padding: 40px 16px 60px; }
  .mm-cards-section-title { font-size: 28px; }
  .mm-rito-floating { width: calc(100% - 32px); right: 16px; bottom: 16px; }
}

