{%- liquid
  assign dh2_cb_card_count = 0
  for block in section.blocks
    if block.type == 'carta' and block.settings.product != blank
      assign dh2_cb_card_count = dh2_cb_card_count | plus: 1
    endif
  endfor
  assign dh2_cb_tag = section.settings.tag | strip
  if dh2_cb_tag == blank
    assign dh2_cb_tag = 'duendes.home_v2.cartas.eyebrow' | t
    if dh2_cb_tag contains 'translation missing'
      assign dh2_cb_tag = 'duendes.home_v2.cartas_bosque.tag' | t
    endif
  endif
  assign dh2_cb_title = section.settings.title | strip
  if dh2_cb_title == blank
    assign dh2_cb_title = 'duendes.home_v2.cartas.title' | t
    if dh2_cb_title contains 'translation missing'
      assign dh2_cb_title = 'duendes.home_v2.cartas_bosque.title' | t
    endif
  endif
  assign dh2_cb_sub = 'duendes.home_v2.cartas.sub' | t
  if dh2_cb_sub contains 'translation missing'
    assign dh2_cb_sub = ''
  endif
  assign dh2_cb_swipe_hint = 'duendes.home_v2.cartas.hint' | t
  if dh2_cb_swipe_hint contains 'translation missing'
    assign dh2_cb_swipe_hint = ''
  endif
  assign dh2_cb_badge = section.settings.badge_destacado | strip
  if dh2_cb_badge == blank
    assign dh2_cb_badge = 'duendes.home_v2.cartas.badge' | t
    if dh2_cb_badge contains 'translation missing'
      assign dh2_cb_badge = 'duendes.home_v2.cartas_bosque.badge_destacado' | t
    endif
  endif
  assign dh2_cb_foot = section.settings.hint | strip
  if dh2_cb_foot == blank
    assign dh2_cb_foot = 'duendes.home_v2.cartas.foot' | t
    if dh2_cb_foot contains 'translation missing'
      assign dh2_cb_foot = 'duendes.home_v2.cartas_bosque.hint' | t
    endif
  endif
  assign dh2_cb_cta = 'duendes.home_v2.cartas.cta' | t
  if dh2_cb_cta contains 'translation missing'
    assign dh2_cb_cta = ''
  endif
  assign dh2_cb_cta_url = section.settings.cta_url | default: routes.all_products_collection_url
  assign dh2_cb_modal_aria = section.settings.modal_aria | strip
  if dh2_cb_modal_aria == blank
    assign dh2_cb_modal_aria = 'duendes.home_v2.cartas_bosque.modal_aria' | t
  endif
  assign dh2_cb_close_aria = section.settings.close_aria | strip
  if dh2_cb_close_aria == blank
    assign dh2_cb_close_aria = 'duendes.home_v2.cartas_bosque.close_aria' | t
  endif
  assign dh2_cb_modal_cta = section.settings.modal_cta | strip
  if dh2_cb_modal_cta == blank
    assign dh2_cb_modal_cta = 'duendes.home_v2.cartas_bosque.modal_cta' | t
  endif
-%}
{% if dh2_cb_card_count > 0 %}
{{ 'duendes-base.css' | asset_url | stylesheet_tag }}
<style>
  .dh2-cb {
    --dh2-gold: #c9a961;
    --dh2-ink: #15110d;
    background: #faf9f7 !important;
    color: var(--dh2-ink);
    padding: 24px 0 28px;
    position: relative;
    overflow-x: visible;
    overflow-y: visible;
  }
  .dh2-cb__inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .dh2-cb__tag {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(21, 17, 13, 0.5);
    text-align: center;
    margin-bottom: 12px;
  }
  .dh2-cb__title {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-weight: 400;
    font-size: clamp(22px, 2.8vw, 34px);
    text-align: center;
    margin: 0 0 10px;
    color: var(--dh2-ink);
  }
  .dh2-cb__sub {
    font-family: var(--font-body--family, 'Cormorant Garamond', Georgia, serif);
    font-size: clamp(15px, 1.9vw, 18px);
    text-align: center;
    margin: 0 auto 8px;
    max-width: 520px;
    line-height: 1.45;
    color: rgba(21, 17, 13, 0.62);
    font-style: italic;
  }
  .dh2-cb__swipe-hint {
    display: none;
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 10px;
    letter-spacing: 0.3em;
    color: rgba(201, 169, 97, 0.6);
    text-align: center;
    margin: 16px 0 0;
    text-transform: uppercase;
  }
  .dh2-cb__deck {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: clamp(8px, 2vw, 28px);
    margin-top: 36px;
  }
  .dh2-cb__card {
    position: relative;
    flex: 0 0 clamp(150px, 22vw, 220px);
    aspect-ratio: 2 / 3;
    border-radius: 14px;
    outline: none;
    border: 1px solid #c9a961;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: block;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.35s ease, border-color 0.25s ease;
    -webkit-tap-highlight-color: transparent;
    background: #0a0805;
  }
  @media (min-width: 768px) {
    .dh2-cb__deck {
      flex-wrap: nowrap;
      overflow: visible;
    }
    .dh2-cb__card--left {
      transform: perspective(900px) rotateY(-9deg) scale(1);
      transform-origin: center bottom;
    }
    .dh2-cb__card--right {
      transform: perspective(900px) rotateY(9deg) scale(1);
      transform-origin: center bottom;
    }
    .dh2-cb__card--center {
      flex: 0 0 clamp(188px, 28vw, 280px);
      transform: scale(1.05);
      z-index: 2;
    }
  }
  @media (hover: hover) and (pointer: fine) and (min-width: 768px) {
    .dh2-cb__card--left:hover,
    .dh2-cb__card--left:focus-visible {
      transform: perspective(900px) rotateY(-9deg) scale(1.06);
      box-shadow: 0 22px 60px rgba(201, 169, 97, 0.28);
      border-color: #d4b87a;
    }
    .dh2-cb__card--right:hover,
    .dh2-cb__card--right:focus-visible {
      transform: perspective(900px) rotateY(9deg) scale(1.06);
      box-shadow: 0 22px 60px rgba(201, 169, 97, 0.28);
      border-color: #d4b87a;
    }
    .dh2-cb__card--center:hover,
    .dh2-cb__card--center:focus-visible {
      transform: scale(1.1);
      box-shadow: 0 22px 60px rgba(201, 169, 97, 0.28);
      border-color: #d4b87a;
    }
  }
  @media (min-width: 768px) {
    .dh2-cb__card--left:active {
      transform: perspective(900px) rotateY(-9deg) scale(0.97);
    }
    .dh2-cb__card--right:active {
      transform: perspective(900px) rotateY(9deg) scale(0.97);
    }
    .dh2-cb__card--center:active {
      transform: scale(0.97);
    }
  }
  .dh2-cb__media {
    position: absolute;
    inset: 0;
  }
  .dh2-cb__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 1;
  }
  .dh2-cb__shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(5, 4, 2, 0.38) 0%, rgba(5, 4, 2, 0.48) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .dh2-cb__top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 10px;
    pointer-events: none;
  }
  .dh2-cb__roman {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 16px;
    letter-spacing: 0.3em;
    color: #c9a961;
    margin: 0;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
  }
  .dh2-cb__badge {
    margin-top: 8px;
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    background: #15110d;
    color: #c9a961;
    padding: 5px 12px;
    border-radius: 2px;
    border: 1px solid rgba(201, 169, 97, 0.35);
    white-space: nowrap;
  }
  @media (min-width: 768px) {
    .dh2-cb__card:not(.dh2-cb__card--center) .dh2-cb__badge {
      display: none;
    }
  }
  .dh2-cb__meta {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 18px 12px 16px;
    z-index: 2;
    text-align: center;
  }
  .dh2-cb__name {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: clamp(17px, 2.1vw, 19px);
    font-weight: 400;
    font-style: normal;
    margin: 0 0 6px;
    line-height: 1.2;
    color: #fff;
  }
  .dh2-cb__essence {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #c9a961;
    margin: 0 0 8px;
  }
  .dh2-cb__price {
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: #c9a961;
    margin: 0;
  }
  .dh2-cb__cta-wrap {
    text-align: center;
    margin-top: 22px;
  }
  .dh2-cb__cta {
    display: inline-block;
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #a88b42;
    text-decoration: none;
    border-bottom: 1px solid rgba(168, 139, 66, 0.45);
    padding-bottom: 2px;
  }
  .dh2-cb__cta:hover {
    color: #15110d;
    border-color: rgba(21, 17, 13, 0.35);
  }
  .dh2-cb__hint {
    text-align: center;
    margin-top: 20px;
    font-size: 13px;
    font-style: italic;
    color: rgba(21, 17, 13, 0.48);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }
  .dh2-cb__modal[hidden] {
    display: none !important;
  }
  .dh2-cb__modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(8, 6, 4, 0.72);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .dh2-cb__modal-panel {
    background: #15110d;
    border: 1px solid rgba(201, 169, 97, 0.35);
    border-radius: 14px;
    max-width: 420px;
    width: 100%;
    max-height: 90vh;
    overflow: auto;
    padding: 16px;
    color: #f4f1ec;
  }
  .dh2-cb__modal-close {
    float: right;
    border: none;
    background: transparent;
    color: var(--dh2-gold);
    font-size: 22px;
    cursor: pointer;
    line-height: 1;
  }
  .dh2-cb__modal-main img {
    width: 100%;
    border-radius: 8px;
    display: block;
  }
  .dh2-cb__modal-thumbs {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 10px;
  }
  .dh2-cb__modal-thumbs button {
    border: 1px solid rgba(201, 169, 97, 0.3);
    padding: 0;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    background: #0d0b09;
    width: 56px;
    height: 56px;
  }
  .dh2-cb__modal-thumbs img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .dh2-cb__modal-link {
    display: inline-block;
    margin-top: 14px;
    font-family: var(--font-heading--family, 'Cinzel', serif);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dh2-gold);
  }
  @media (max-width: 767px) {
    .dh2-cb__inner {
      overflow-x: visible;
    }
    .dh2-cb__swipe-hint {
      display: block;
    }
    .dh2-cb__badge {
      display: none;
    }
    .dh2-cb__card--focal .dh2-cb__badge {
      display: block;
    }
    .dh2-cb__deck {
      flex-wrap: nowrap;
      justify-content: flex-start;
      align-items: center;
      gap: 16px;
      margin-top: 24px;
      padding: 12px 32px 16px;
      margin-left: -20px;
      margin-right: -20px;
      width: calc(100% + 40px);
      max-width: none;
      box-sizing: border-box;
      overflow-x: auto;
      overflow-y: visible;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scroll-padding-inline: 32px;
      scrollbar-width: none;
      touch-action: pan-x;
    }
    .dh2-cb__deck::-webkit-scrollbar {
      display: none;
    }
    .dh2-cb__card,
    .dh2-cb__card--center,
    .dh2-cb__card--left,
    .dh2-cb__card--right {
      flex: 0 0 calc(85vw - 64px);
      max-width: none;
      scroll-snap-align: center;
      order: 0;
      transform: scale(0.88);
      transform-origin: center center;
      opacity: 0.88;
      filter: brightness(0.96);
      transition: transform 0.28s ease, opacity 0.28s ease, filter 0.28s ease, box-shadow 0.28s ease;
    }
    .dh2-cb__card--focal {
      transform: scale(1.07);
      opacity: 1;
      filter: none;
      z-index: 3;
      box-shadow: 0 22px 56px rgba(0, 0, 0, 0.4);
    }
    .dh2-cb__card--focal:active {
      transform: scale(0.98) !important;
    }
    .dh2-cb__card:not(.dh2-cb__card--focal):active {
      transform: scale(0.82) !important;
    }
  }
  /* Theme wrapper overrides (OS 2.0): fondo crema */
  section.dh2-cb.section {
    background-color: #faf9f7 !important;
    background-image: none !important;
    color: #15110d !important;
  }
  .dh2-cb__title {
    color: #15110d !important;
  }
  .dh2-cb__tag {
    color: rgba(21, 17, 13, 0.55) !important;
  }
  .dh2-cb__hint {
    color: rgba(21, 17, 13, 0.55) !important;
  }
  @media (max-width: 768px) {
    section.dh2-cb.section {
      overflow-x: visible;
    }
    .dh2-cb__inner {
      padding-left: max(20px, env(safe-area-inset-left, 0px));
      padding-right: max(20px, env(safe-area-inset-right, 0px));
    }
    h2.dh2-cb__title,
    .dh2-cb__title {
      font-size: 26px !important;
      line-height: 1.15 !important;
      max-width: 100% !important;
    }
    .dh2-cb__tag {
      font-size: 9px !important;
      letter-spacing: 0.2em !important;
    }
    .dh2-cb__hint {
      font-size: 15px !important;
      line-height: 1.45 !important;
    }
  }
  @media (max-width: 768px) {
    .dh2-cb, .dh2-hero, .dh2-new, .dh2-lin, .dh2-be, .dh2-sp, .dh2-ed, .dh2-rito, .dh2-lt, .dh2-tribu {
      padding-block: 18px !important;
    }
  }
</style>

<section
  class="dh2-cb section"
  id="dh2-cb-{{ section.id }}"
  style="background-color:#faf9f7!important;color:#15110d;"
  {{ section.shopify_attributes }}
>
  <div class="dh2-cb__inner">
    <p class="dh2-cb__tag">{{ dh2_cb_tag }}</p>
    <h2 class="dh2-cb__title">{{ dh2_cb_title }}</h2>
    {% if dh2_cb_sub != blank %}
      <p class="dh2-cb__sub">{{ dh2_cb_sub }}</p>
    {% endif %}
    {% if dh2_cb_swipe_hint != blank %}
      <p class="dh2-cb__swipe-hint">{{ dh2_cb_swipe_hint }}</p>
    {% endif %}
    <div class="dh2-cb__deck">
      {%- assign dh2_cb_slot = 0 -%}
      {% for block in section.blocks %}
        {% if block.type == 'carta' and block.settings.product != blank %}
          {%- assign dh2_cb_slot = dh2_cb_slot | plus: 1 -%}
          {%- assign dh2_cb_pos = dh2_cb_slot | minus: 1 -%}
          {% assign product = block.settings.product %}
          {% assign dh2_cb_roman = block.settings.roman | strip %}
          {% if dh2_cb_roman == blank %}
            {% case dh2_cb_slot %}
              {% when 1 %}
                {% assign dh2_cb_roman = 'I' %}
              {% when 2 %}
                {% assign dh2_cb_roman = 'II' %}
              {% else %}
                {% assign dh2_cb_roman = 'III' %}
            {% endcase %}
          {% endif %}
          {% capture card_class %}dh2-cb__card{% if dh2_cb_pos == 1 %} dh2-cb__card--center{% elsif dh2_cb_pos == 2 %} dh2-cb__card--right{% else %} dh2-cb__card--left{% endif %}{% endcapture %}
          <a
            href="{{ product.url }}"
            class="{{ card_class | strip }}"
            data-dh2-gallery-id="{{ block.id }}"
            data-dh2-title="{{ block.settings.display_title | default: product.title | escape }}"
            data-dh2-url="{{ product.url }}"
            aria-label="{{ block.settings.display_title | default: product.title | escape }}"
            {{ block.shopify_attributes }}
          >
            <div class="dh2-cb__media">
              {% if product.featured_media %}
                {{ product.featured_media | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '30vw', widths: '400,600,800' }}
              {% endif %}
            </div>
            <div class="dh2-cb__shade" aria-hidden="true"></div>
            <div class="dh2-cb__top">
              <p class="dh2-cb__roman" aria-hidden="true">{{ dh2_cb_roman }}</p>
              <span class="dh2-cb__badge">{{ dh2_cb_badge }}</span>
            </div>
            <div class="dh2-cb__meta">
              <p class="dh2-cb__name">{{ block.settings.display_title | default: product.title }}</p>
              <p class="dh2-cb__essence">{{ block.settings.essence }}</p>
              <p class="dh2-cb__price">{{ product.price | money }}</p>
            </div>
          </a>
          <script type="application/json" data-dh2-cb-gallery="{{ block.id }}">
            [{% for image in product.images limit: 8 %}{{ image | image_url: width: 1000 | json }}{% unless forloop.last %},{% endunless %}{% endfor %}]
          </script>
        {% endif %}
      {% endfor %}
    </div>
    {% if dh2_cb_cta != blank and dh2_cb_cta_url != blank %}
      <div class="dh2-cb__cta-wrap">
        <a class="dh2-cb__cta" href="{{ dh2_cb_cta_url }}">{{ dh2_cb_cta }}</a>
      </div>
    {% endif %}
    <p class="dh2-cb__hint">{{ dh2_cb_foot }}</p>
  </div>

  <div class="dh2-cb__modal" id="dh2-cb-modal-{{ section.id }}" hidden role="dialog" aria-modal="true" aria-label="{{ dh2_cb_modal_aria | escape }}">
    <div class="dh2-cb__modal-panel">
      <button type="button" class="dh2-cb__modal-close" data-dh2-cb-close aria-label="{{ dh2_cb_close_aria | escape }}">&times;</button>
      <h3 class="dh2-cb__name" style="margin-top: 0" data-dh2-cb-modal-title></h3>
      <div class="dh2-cb__modal-main" data-dh2-cb-modal-main></div>
      <div class="dh2-cb__modal-thumbs" data-dh2-cb-modal-thumbs></div>
      <a class="dh2-cb__modal-link" data-dh2-cb-modal-link href="#">{{ dh2_cb_modal_cta }}</a>
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('dh2-cb-{{ section.id }}');
    if (!root) return;
    var modal = document.getElementById('dh2-cb-modal-{{ section.id }}');
    var main = modal && modal.querySelector('[data-dh2-cb-modal-main]');
    var thumbs = modal && modal.querySelector('[data-dh2-cb-modal-thumbs]');
    var titleEl = modal && modal.querySelector('[data-dh2-cb-modal-title]');
    var linkEl = modal && modal.querySelector('[data-dh2-cb-modal-link]');
    var closeBtn = modal && modal.querySelector('[data-dh2-cb-close]');
    if (!modal || !main || !thumbs || !titleEl || !linkEl || !closeBtn) return;

    function parseGallery(scriptEl) {
      try {
        return JSON.parse(scriptEl.textContent.trim());
      } catch (e) {
        return [];
      }
    }

    function openModal(gallery, title, url) {
      titleEl.textContent = title || '';
      linkEl.href = url || '#';
      main.innerHTML = '';
      thumbs.innerHTML = '';
      var first = gallery[0];
      if (first) {
        var img = document.createElement('img');
        img.src = first;
        img.alt = title || '';
        main.appendChild(img);
      }
      gallery.forEach(function (src) {
        var b = document.createElement('button');
        b.type = 'button';
        var im = document.createElement('img');
        im.src = src;
        im.alt = '';
        b.appendChild(im);
        b.addEventListener('click', function () {
          main.innerHTML = '';
          var big = document.createElement('img');
          big.src = src;
          big.alt = title || '';
          main.appendChild(big);
        });
        thumbs.appendChild(b);
      });
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.hidden = true;
      document.body.style.overflow = '';
    }

    var deck = root.querySelector('.dh2-cb__deck');
    var focalRaf = 0;
    function updateCardFocal() {
      if (!deck) return;
      var isMobile = window.matchMedia('(max-width: 767px)').matches;
      var cards = root.querySelectorAll('[data-dh2-gallery-id]');
      if (!isMobile) {
        cards.forEach(function (c) {
          c.classList.remove('dh2-cb__card--focal');
        });
        return;
      }
      if (!cards.length) return;
      var deckRect = deck.getBoundingClientRect();
      var mid = deckRect.left + deckRect.width * 0.5;
      var best = null;
      var bestDist = Infinity;
      cards.forEach(function (card) {
        var r = card.getBoundingClientRect();
        var cx = r.left + r.width * 0.5;
        var d = Math.abs(cx - mid);
        if (d < bestDist) {
          bestDist = d;
          best = card;
        }
      });
      cards.forEach(function (card) {
        card.classList.toggle('dh2-cb__card--focal', card === best);
      });
    }
    function scheduleFocal() {
      if (focalRaf) cancelAnimationFrame(focalRaf);
      focalRaf = requestAnimationFrame(function () {
        focalRaf = 0;
        updateCardFocal();
      });
    }
    if (deck) {
      deck.addEventListener('scroll', scheduleFocal, { passive: true });
    }
    window.addEventListener('resize', scheduleFocal);
    scheduleFocal();
    requestAnimationFrame(scheduleFocal);

    root.querySelectorAll('[data-dh2-gallery-id]').forEach(function (card) {
      card.addEventListener('click', function (e) {
        var useModal =
          window.matchMedia('(hover: none) and (pointer: coarse)').matches ||
          window.matchMedia('(max-width: 767px)').matches;
        if (!useModal) return;
        e.preventDefault();
        var gid = card.getAttribute('data-dh2-gallery-id');
        var script = gid ? root.querySelector('script[data-dh2-cb-gallery="' + gid + '"]') : null;
        var gallery = script ? parseGallery(script) : [];
        openModal(gallery, card.getAttribute('data-dh2-title'), card.getAttribute('data-dh2-url'));
      });
    });

    modal.addEventListener('click', function (e) {
      if (e.target === modal) closeModal();
    });
    closeBtn.addEventListener('click', closeModal);
  })();
</script>
