{{ 'duendes-base.css' | asset_url | stylesheet_tag }}
<style>
.dunb{position:relative;overflow:hidden;padding:0;background:var(--black-deep, #080a06)}
.dunb-split{display:grid;grid-template-columns:1fr 1fr;min-height:70vh}

/* Image/video side - horizontal scrolling gallery */
.dunb-media{position:relative;overflow:hidden}
.dunb-media-track{display:flex;height:100%;scroll-snap-type:x mandatory;overflow-x:auto;scrollbar-width:none}
.dunb-media-track::-webkit-scrollbar{display:none}
.dunb-media-slide{flex:0 0 100%;scroll-snap-align:start;position:relative;min-height:400px}
.dunb-media-slide img{width:100%;height:100%;object-fit:cover}
.dunb-media-slide .dunb-placeholder{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;background:linear-gradient(135deg,rgba(198,165,90,.06),rgba(74,93,58,.04))}
.dunb-media-slide .dunb-placeholder span{font-size:48px;opacity:.3}
.dunb-media-slide .dunb-placeholder small{font-family:var(--serif, Georgia);font-size:13px;font-style:italic;color:var(--gold, #C6A55A);opacity:.5}

.dunb-media-nav{position:absolute;bottom:16px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:2}
.dunb-media-dot{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.3);cursor:pointer;transition:all .3s;border:none;padding:0}
.dunb-media-dot.active{background:var(--gold, #C6A55A);transform:scale(1.3);box-shadow:0 0 8px rgba(198,165,90,.4)}

/* Content side */
.dunb-content{display:flex;flex-direction:column;justify-content:center;padding:clamp(40px,5vw,72px) clamp(28px,4vw,56px);position:relative}
.dunb-content::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(198,165,90,.04),transparent 55%);pointer-events:none}
.dunb-inner{position:relative;z-index:1}
.dunb-eyebrow{font-family:var(--serif, Georgia);font-size:11px;letter-spacing:4px;text-transform:uppercase;color:var(--gold, #C6A55A);margin-bottom:16px}
.dunb-title{font-family:var(--serif, Georgia);font-size:clamp(24px,3vw,36px);font-weight:300;font-style:italic;color:#fff;margin:0 0 20px;line-height:1.2}
.dunb-title em{color:var(--gold-lt, #D6BD7B)}

.dunb-steps{margin:0;padding:0;list-style:none}
.dunb-step{display:flex;gap:16px;align-items:flex-start;padding:14px 0;border-bottom:1px solid rgba(198,165,90,.06);position:relative}
.dunb-step:last-child{border-bottom:none}
.dunb-step-num{width:28px;height:28px;border-radius:50%;border:1px solid rgba(198,165,90,.2);display:flex;align-items:center;justify-content:center;font-family:var(--serif, Georgia);font-size:13px;color:var(--gold, #C6A55A);flex-shrink:0;font-style:italic}
.dunb-step-text{font-family:var(--serif, Georgia);font-size:15px;font-style:italic;color:#FAFAF7;line-height:1.6}
.dunb-step-text strong{color:#ffffff;font-weight:600}

.dunb-cta{margin-top:28px}
.dunb-cta a{display:inline-flex;align-items:center;gap:8px;padding:14px 32px;background:var(--gold, #C6A55A);color:#fff;font-family:var(--serif, Georgia);font-size:12px;font-weight:600;letter-spacing:2px;text-transform:uppercase;border-radius:6px;text-decoration:none;transition:all .4s;position:relative;overflow:hidden}
.dunb-cta a::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.12),transparent);transform:translateX(-100%);animation:dunbShine 3s ease-in-out infinite}
@keyframes dunbShine{0%{transform:translateX(-100%)}40%,100%{transform:translateX(100%)}}
.dunb-cta a:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(198,165,90,.35)}

@media(max-width:768px){
  .dunb-split{grid-template-columns:1fr}
  .dunb-media{min-height:50vh}
}
</style>

<section class="dunb">
  <div class="dunb-split">
    <div class="dunb-media">
      <div class="dunb-media-track" id="dunbTrack">
        {%- for block in section.blocks -%}
          {%- if block.type == 'media' -%}
            <div class="dunb-media-slide" {{ block.shopify_attributes }}>
              {%- if block.settings.image -%}
                <img src="{{ block.settings.image | image_url: width: 1000 }}" alt="{{ block.settings.alt }}" loading="lazy">
              {%- else -%}
                <div class="dunb-placeholder">
                  <span>{{ block.settings.icon }}</span>
                  <small>{{ block.settings.alt }}</small>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="dunb-media-nav" id="dunbNav"></div>
    </div>
    <div class="dunb-content">
      <div class="dunb-inner">
        <div class="dunb-eyebrow">{{ section.settings.eyebrow }}</div>
        <h2 class="dunb-title">{{ section.settings.title }}</h2>
        <ul class="dunb-steps">
          {%- assign step_num = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'step' -%}
              {%- assign step_num = step_num | plus: 1 -%}
              <li class="dunb-step" {{ block.shopify_attributes }}>
                <div class="dunb-step-num">{{ step_num }}</div>
                <div class="dunb-step-text">{{ block.settings.text }}</div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
        <div class="dunb-cta">
          <a href="{{ section.settings.cta_url }}">{{ section.settings.cta_text }}</a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
(function(){
  var track=document.getElementById('dunbTrack');
  var nav=document.getElementById('dunbNav');
  if(!track)return;
  var slides=track.querySelectorAll('.dunb-media-slide');
  var total=slides.length;

  /* Create dots */
  for(var i=0;i<total;i++){
    var dot=document.createElement('button');
    dot.className='dunb-media-dot'+(i===0?' active':'');
    dot.setAttribute('data-idx',i);
    dot.addEventListener('click',function(){
      var idx=parseInt(this.getAttribute('data-idx'));
      track.scrollTo({left:track.offsetWidth*idx,behavior:'smooth'});
    });
    nav.appendChild(dot);
  }

  /* Update dots on scroll */
  track.addEventListener('scroll',function(){
    var idx=Math.round(track.scrollLeft/track.offsetWidth);
    nav.querySelectorAll('.dunb-media-dot').forEach(function(d,i){
      d.classList.toggle('active',i===idx);
    });
  },{passive:true});

  /* Auto-advance every 5s */
  var current=0;
  setInterval(function(){
    current=(current+1)%total;
    track.scrollTo({left:track.offsetWidth*current,behavior:'smooth'});
  },5000);
})();
</script>

{% schema %}
{
  "name": "Duendes Unboxing",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Etiqueta", "default": "LA EXPERIENCIA"},
    {"type": "textarea", "id": "title", "label": "Título", "default": "Abrirlo es <em>el primer ritual</em>"},
    {"type": "text", "id": "cta_text", "label": "Texto botón", "default": "ELEGIR MI GUARDIÁN"},
    {"type": "url", "id": "cta_url", "label": "Link botón"}
  ],
  "blocks": [
    {
      "type": "media",
      "name": "Foto/Video",
      "settings": [
        {"type": "image_picker", "id": "image", "label": "Imagen"},
        {"type": "text", "id": "alt", "label": "Descripción", "default": "Foto del unboxing"},
        {"type": "text", "id": "icon", "label": "Emoji placeholder", "default": "📦"}
      ]
    },
    {
      "type": "step",
      "name": "Paso",
      "settings": [
        {"type": "textarea", "id": "text", "label": "Texto del paso"}
      ]
    }
  ],
  "presets": [{"name": "Duendes Unboxing"}]
}
{% endschema %}

