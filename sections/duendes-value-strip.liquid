{{ 'duendes-base.css' | asset_url | stylesheet_tag }}
<style>
  .dvs2 { position: relative; overflow: hidden; padding: clamp(48px, 6vw, 80px) 0; background: #FAFAF8; }
  .dvs2::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 30%, rgba(198,165,90,.08), transparent 55%); pointer-events: none; }
  .dvs2::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent 10%, rgba(198,165,90,.3) 50%, transparent 90%); }
  .dvs2__shimmer {
    position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
    background: linear-gradient(105deg, transparent 40%, rgba(198,165,90,.04) 45%, rgba(198,165,90,.08) 50%, rgba(198,165,90,.04) 55%, transparent 60%);
    animation: dvs2Shimmer 8s ease-in-out infinite;
    pointer-events: none; z-index: 1;
  }
  @keyframes dvs2Shimmer { 0%,100% { left: -100%; } 50% { left: 100%; } }
  .dvs2__glow-orb {
    position: absolute; border-radius: 50%; pointer-events: none;
    background: radial-gradient(circle, rgba(198,165,90,.06) 0%, transparent 70%);
    animation: dvs2OrbPulse var(--dur) ease-in-out infinite var(--delay);
  }
  @keyframes dvs2OrbPulse { 0%,100% { opacity: 0.3; transform: scale(0.8); } 50% { opacity: 0.7; transform: scale(1.1); } }
  .dvs2__container { max-width: 680px; margin: 0 auto; padding: 0 20px; position: relative; z-index: 2; }
  .dvs2__header { text-align: center; margin-bottom: clamp(28px, 4vw, 44px); }
  .dvs2__eyebrow { font-family: 'Cormorant Garamond', serif; font-size: 11px; font-weight: 500; letter-spacing: 3px; text-transform: uppercase; color: #C6A55A; margin-bottom: 14px; font-style: italic; }
  .dvs2__header h3 { font-family: 'Cinzel', serif; font-size: clamp(20px, 2.5vw, 30px); font-weight: 400; color: #1a1a14; margin: 0; line-height: 1.3; }
  .dvs2__header h3 em { font-style: italic; color: #C6A55A; }
  .dvs2__diamond { display: flex; align-items: center; justify-content: center; gap: 12px; margin-top: 16px; }
  .dvs2__diamond::before, .dvs2__diamond::after { content: ''; width: 40px; height: 1px; background: linear-gradient(90deg, transparent, #C6A55A, transparent); opacity: .3; }
  .dvs2__diamond-icon { width: 6px; height: 6px; background: #C6A55A; transform: rotate(45deg); }

  .dvs2__list { list-style: none; padding: 0; margin: 0; }
  .dvs2__item {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 14px 18px; margin-bottom: 8px;
    border-radius: 6px;
    opacity: 0; transform: translateX(-40px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .dvs2__item:nth-child(odd) { background: #0a0c07; box-shadow: 0 2px 12px rgba(0,0,0,0.15); }
  .dvs2__item:nth-child(even) { background: #FAFAF8; border: 1px solid rgba(26,26,20,0.08); box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
  .dvs2__item.dvs-checked:nth-child(odd) { box-shadow: 0 2px 16px rgba(198,165,90,0.12), 0 2px 12px rgba(0,0,0,0.15); }
  .dvs2__item.dvs-checked:nth-child(even) { box-shadow: 0 2px 16px rgba(198,165,90,0.08), 0 2px 12px rgba(0,0,0,0.06); }
  .dvs2__item:nth-child(odd) h4 { color: #fff; }
  .dvs2__item:nth-child(odd) p { color: rgba(250,250,247,0.75); }
  .dvs2__item:nth-child(even) h4 { color: #1a1a14; }
  .dvs2__item:nth-child(even) p { color: #4a4a44; }
  .dvs2__item:nth-child(even) { transform: translateX(40px); }
  .dvs2__item.dvs-checked { opacity: 1; transform: translateX(0); }

  .dvs2__check {
    flex-shrink: 0; width: 24px; height: 24px; border-radius: 50%;
    border: 2px solid rgba(198,165,90,0.3); display: flex;
    align-items: center; justify-content: center;
    transition: all 0.4s ease; margin-top: 1px;
  }
  .dvs-checked .dvs2__check {
    border-color: #C6A55A; background: #C6A55A;
    box-shadow: 0 0 10px rgba(198,165,90,0.25);
  }
  .dvs2__check-svg {
    width: 12px; height: 12px; stroke-width: 3; fill: none;
    stroke-dasharray: 20; stroke-dashoffset: 20;
    transition: stroke-dashoffset 0.3s 0.2s ease;
  }
  .dvs2__item:nth-child(odd) .dvs2__check-svg { stroke: #0a0c07; }
  .dvs2__item:nth-child(even) .dvs2__check-svg { stroke: #fff; }
  .dvs-checked .dvs2__check-svg { stroke-dashoffset: 0; }

  .dvs2__item-content { flex: 1; }
  .dvs2__item h4 {
    font-family: 'Cinzel', serif; font-size: 13px; font-weight: 600;
    margin: 0 0 3px; letter-spacing: .5px;
  }
  .dvs2__item p {
    font-family: 'Cormorant Garamond', serif; font-size: 14px;
    line-height: 1.5; margin: 0;
  }
  .dvs2__bottom { text-align: center; margin-top: clamp(24px, 3vw, 36px); }
  .dvs2__bottom p { font-family: 'Cormorant Garamond', serif; font-size: 15px; font-style: italic; color: #4a4a44; line-height: 1.6; }
  .dvs2__bottom p strong { color: #C6A55A; }
  @media (prefers-reduced-motion: reduce) { .dvs2__item { opacity: 1; transform: none; } }
</style>

<section class="dvs2" id="duendes-valor">
  <div class="dvs2__shimmer"></div>
  <div class="dvs2__glow-orb" style="width:200px;height:200px;top:10%;left:5%;--dur:6s;--delay:0s;"></div>
  <div class="dvs2__glow-orb" style="width:150px;height:150px;top:50%;right:8%;--dur:8s;--delay:2s;"></div>
  <div class="dvs2__glow-orb" style="width:120px;height:120px;bottom:15%;left:40%;--dur:7s;--delay:4s;"></div>
  <div class="dvs2__container">
    <div class="dvs2__header">
      {% if section.settings.eyebrow != blank %}
        <p class="dvs2__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h3>{{ section.settings.title }}</h3>
      <div class="dvs2__diamond"><span class="dvs2__diamond-icon"></span></div>
    </div>
    <ul class="dvs2__list" id="dvs2-checklist">
      {%- for block in section.blocks -%}
        <li class="dvs2__item" {{ block.shopify_attributes }}>
          <div class="dvs2__check">
            <svg class="dvs2__check-svg" viewBox="0 0 16 16"><polyline points="3 8 7 12 13 4"/></svg>
          </div>
          <div class="dvs2__item-content">
            <h4>{{ block.settings.title }}</h4>
            <p>{{ block.settings.description }}</p>
          </div>
        </li>
      {%- endfor -%}
    </ul>
    {%- if section.settings.bottom_text != blank -%}
      <div class="dvs2__bottom"><p>{{ section.settings.bottom_text }}</p></div>
    {%- endif -%}
  </div>
</section>
<div class="duendes-gold-line"></div>
<div class="duendes-divider"><span class="duendes-divider-diamond"></span></div>
<script>
(function(){
  var list = document.getElementById('dvs2-checklist');
  if (!list) return;
  var items = list.querySelectorAll('.dvs2__item');
  var obs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting) {
        for (var i = 0; i < items.length; i++) {
          (function(idx){ setTimeout(function(){ items[idx].classList.add('dvs-checked'); }, idx * 200); })(i);
        }
        obs.unobserve(list);
      }
    });
  }, { threshold: 0.1 });
  obs.observe(list);
})();
</script>
{% schema %}
{
  "name": "Duendes Valor",
  "settings": [
    {"type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1"},
    {"type": "text", "id": "eyebrow", "label": "Etiqueta superior", "default": "POR QUE SOMOS DIFERENTES"},
    {"type": "textarea", "id": "title", "label": "Titulo", "default": "No es un duende mas. <em>Y por eso no cuesta como uno.</em>"},
    {"type": "textarea", "id": "bottom_text", "label": "Texto inferior"},
    {"type": "image_picker", "id": "background_image", "label": "Imagen de fondo"}
  ],
  "blocks": [
    {
      "type": "value_card",
      "name": "Tarjeta de valor",
      "settings": [
        {"type": "text", "id": "icon", "label": "Emoji", "default": "✨"},
        {"type": "text", "id": "title", "label": "Titulo"},
        {"type": "textarea", "id": "description", "label": "Descripcion"},
        {"type": "text", "id": "compare_them", "label": "Ellos (comparacion)"},
        {"type": "text", "id": "compare_us", "label": "Nosotros"}
      ]
    }
  ],
  "presets": [{"name": "Duendes Valor"}]
}
{% endschema %}