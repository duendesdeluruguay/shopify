    "curiosidades": {
      "type": "duendes-catalog-curiosidades",
      "settings": {
        "theme": "light",
        "title": "Curiosidades de nuestras creaciones"
      },
      "blocks": {
        "c1": {
          "type": "curiosidad",
          "settings": {
            "label": "Alquimia",
            "text": "Every Guardian is hand-channeled in Piriápolis during a 7-day ritual. There are no molds. There are no factories. Only hands, silence, and alchemy."
          }
        },
        "c2": {
          "type": "curiosidad",
          "settings": {
            "label": "Elementals",
            "text": "The Guardians are the ones Mother Earth placed in charge of the earth element. They protect nature, homes, and those they choose to accompany."
          }
        },
        "c3": {
          "type": "curiosidad",
          "settings": {
            "label": "Sincronicidad",
            "text": "Thousands of adopters write us the same thing: It arrived just when I needed it. It's not coincidence. The Guardians find their person."
          }
        },
        "c4": {
          "type": "curiosidad",
          "settings": {
            "label": "Channeling",
            "text": "We don't choose what to create. Every Guardian is born with a name, story, and purpose. The channeled letter accompanying the mid-size ones confirms it."
          }
        },
        "c5": {
          "type": "curiosidad",
          "settings": {
            "label": "15.000 hogares",
            "text": "More than fifteen thousand Guardians have found a home in 45 countries. Everything is still made by hand. Everything still comes out of the same studio in Uruguay."
          }
        },
        "c6": {
          "type": "curiosidad",
          "settings": {
            "label": "Irrepetibles",
            "text": "Mid-Size, Large, and Giants exist only once. When one is adopted, it disappears forever. It's not repeated, not recreated, not made to order."
          }
        },
        "c7": {
          "type": "curiosidad",
          "settings": {
            "label": "Cristales",
            "text": "Every Guardian carries a crystal according to their energy: amethyst for protection, citrine for abundance, rose quartz for love."
          }
        },
        "c8": {
          "type": "curiosidad",
          "settings": {
            "label": "El test",
            "text": "Not sure which Guardian is yours? The Guardian Test connects you with the elemental being that resonates with your moment."
          }
        }
      },
      "block_order": [
        "c1",
